{% extends 'rssi/layout.html.twig' %}

{% block page_title %}Tableau de bord{% endblock %}

{% block content %}

{# Cartes stats #}
<div style="display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:24px;">

    <div class="r-card" style="padding:20px; display:flex; align-items:center; gap:16px;">
        <div style="width:52px;height:52px;border-radius:14px;background:#DBEAFE;color:#1D4ED8;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;">
            <i class="bi bi-people-fill"></i>
        </div>
        <div>
            <div style="font-size:12px;color:#64748B;font-weight:500;">Employés</div>
            <div style="font-size:28px;font-weight:800;color:#0F172A;line-height:1;">{{ totalEmployes }}</div>
            <div style="font-size:11px;color:#94A3B8;">{{ totalDepartements }} département(s)</div>
        </div>
    </div>

    <div class="r-card" style="padding:20px; display:flex; align-items:center; gap:16px;">
        <div style="width:52px;height:52px;border-radius:14px;background:#CFFAFE;color:#0891B2;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;">
            <i class="bi bi-shield-check-fill"></i>
        </div>
        <div>
            <div style="font-size:12px;color:#64748B;font-weight:500;">Score vigilance moyen</div>
            <div style="font-size:28px;font-weight:800;color:#0F172A;line-height:1;">{{ scoreMoyen }}%</div>
            <div style="font-size:11px;color:#94A3B8;">Sur l'ensemble des employés</div>
        </div>
    </div>

    <div class="r-card" style="padding:20px; display:flex; align-items:center; gap:16px;">
        <div style="width:52px;height:52px;border-radius:14px;background:#FFEDD5;color:#C2410C;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;">
            <i class="bi bi-fish-fill"></i>
        </div>
        <div>
            <div style="font-size:12px;color:#64748B;font-weight:500;">Campagnes phishing</div>
            <div style="font-size:28px;font-weight:800;color:#0F172A;line-height:1;">{{ campagnesPhishingActives }}</div>
            <div style="font-size:11px;color:#94A3B8;">En cours</div>
        </div>
    </div>

    <div class="r-card" style="padding:20px; display:flex; align-items:center; gap:16px;">
        <div style="width:52px;height:52px;border-radius:14px;background:#FEE2E2;color:#B91C1C;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;">
            <i class="bi bi-cursor-fill"></i>
        </div>
        <div>
            <div style="font-size:12px;color:#64748B;font-weight:500;">Taux de clic moyen</div>
            <div style="font-size:28px;font-weight:800;color:#0F172A;line-height:1;">{{ tauxClicMoyen }}%</div>
            <div style="font-size:11px;color:#94A3B8;">Sur les campagnes phishing</div>
        </div>
    </div>

</div>

{# Graphiques ligne 1 #}
<div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:24px;">

    <div class="r-card">
        <div class="r-card-header">
            <div class="r-card-title"><i class="bi bi-graph-up"></i> Évolution score vigilance</div>
        </div>
        <div class="r-card-body">
            <canvas id="chartVigilance" height="200"></canvas>
        </div>
    </div>

    <div class="r-card">
        <div class="r-card-header">
            <div class="r-card-title"><i class="bi bi-fish"></i> Dernière campagne phishing</div>
            {% if derniereCampagne %}
                <span class="r-badge r-badge-orange">{{ derniereCampagne.titre }}</span>
            {% endif %}
        </div>
        <div class="r-card-body">
            {% if derniereCampagne %}
                <canvas id="chartPhishing" height="200"></canvas>
            {% else %}
                <div class="r-empty">
                    <i class="bi bi-fish"></i>
                    <p>Aucune campagne phishing lancée</p>
                    <a href="#" class="r-btn r-btn-primary">Créer une campagne</a>
                </div>
            {% endif %}
        </div>
    </div>

</div>

{# Graphiques ligne 2 #}
<div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">

    {# Formations en cours #}
    <div class="r-card">
        <div class="r-card-header">
            <div class="r-card-title"><i class="bi bi-mortarboard-fill"></i> Formations en cours</div>
        </div>
        <div class="r-card-body">
            {% if campagnesFormation|length > 0 %}
                <div style="display:flex;flex-direction:column;gap:16px;">
                    {% for c in campagnesFormation %}
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
                        <div>
                            <div style="font-size:13px;font-weight:600;color:#1E293B;">{{ c.titre }}</div>
                            <div style="font-size:11px;color:#94A3B8;">T{{ c.trimestre }} {{ c.annee }} • {{ c.dateDebut|date('d/m') }} → {{ c.dateFin|date('d/m/Y') }}</div>
                        </div>
                        <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
                            <div style="width:100px;height:6px;background:#E2E8F0;border-radius:99px;overflow:hidden;">
                                {% set pct = c.totalParticipants > 0 ? ((c.nombreTermines / c.totalParticipants) * 100)|round : 0 %}
                                <div style="height:100%;width:{{ pct }}%;background:linear-gradient(90deg,#06B6D4,#0284C7);border-radius:99px;"></div>
                            </div>
                            <span style="font-size:12px;font-weight:700;color:#475569;min-width:32px;text-align:right;">{{ pct }}%</span>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="r-empty">
                    <i class="bi bi-mortarboard"></i>
                    <p>Aucune campagne de formation active</p>
                    <a href="#" class="r-btn r-btn-primary">Créer une campagne</a>
                </div>
            {% endif %}
        </div>
    </div>

    {# Employés vulnérables #}
    <div class="r-card">
        <div class="r-card-header">
            <div class="r-card-title">
                <i class="bi bi-exclamation-triangle-fill" style="color:#F59E0B;"></i>
                Employés les plus vulnérables
            </div>
        </div>
        {% if employesVulnerables|length > 0 %}
        <table class="r-table">
            <thead>
                <tr>
                    <th>Employé</th>
                    <th>Département</th>
                    <th>Score</th>
                    <th>Niveau</th>
                </tr>
            </thead>
            <tbody>
                {% for e in employesVulnerables %}
                <tr>
                    <td>
                        <div style="font-weight:600;color:#1E293B;">{{ e.prenom }} {{ e.nom }}</div>
                        <div style="font-size:11px;color:#94A3B8;">{{ e.email }}</div>
                    </td>
                    <td>{{ e.departement ? e.departement.nom : '—' }}</td>
                    <td>
                        <span class="r-badge {% if e.scoreVigilance < 30 %}r-badge-red{% elseif e.scoreVigilance < 60 %}r-badge-orange{% else %}r-badge-gray{% endif %}">
                            {{ e.scoreVigilance }}%
                        </span>
                    </td>
                    <td>
                        <span class="r-badge r-badge-red">{{ e.niveauVigilance }}</span>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
            <div class="r-card-body">
                <div class="r-empty">
                    <i class="bi bi-shield-check" style="color:#86EFAC;"></i>
                    <p style="color:#166534;">Tous les employés ont un bon score !</p>
                </div>
            </div>
        {% endif %}
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
const ctxV = document.getElementById('chartVigilance');
if (ctxV) {
    new Chart(ctxV, {
        type: 'line',
        data: {
            labels: {{ evolutionLabels|json_encode|raw }},
            datasets: [{
                label: 'Score vigilance (%)',
                data: {{ evolutionScores|json_encode|raw }},
                borderColor: '#06B6D4',
                backgroundColor: 'rgba(6,182,212,0.08)',
                borderWidth: 2.5, fill: true, tension: 0.4,
                pointBackgroundColor: '#06B6D4', pointRadius: 4,
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: { min: 0, max: 100, grid: { color: '#F1F5F9' }, ticks: { color: '#94A3B8', font: { size: 11 } } },
                x: { grid: { display: false }, ticks: { color: '#94A3B8', font: { size: 11 } } }
            }
        }
    });
}

const ctxP = document.getElementById('chartPhishing');
if (ctxP) {
    new Chart(ctxP, {
        type: 'doughnut',
        data: {
            labels: ["Ont cliqué","Ont soumis des données","Ont signalé","N'ont pas cliqué"],
            datasets: [{
                data: [
                    {{ derniereCampagne is defined and derniereCampagne ? derniereCampagne.liensCliques : 0 }},
                    {{ derniereCampagne is defined and derniereCampagne ? derniereCampagne.donneesSubmises : 0 }},
                    {{ derniereCampagne is defined and derniereCampagne ? derniereCampagne.emailsSignales : 0 }},
                    {{ derniereCampagne is defined and derniereCampagne ? (derniereCampagne.emailsEnvoyes - derniereCampagne.liensCliques) : 0 }},
                ],
                backgroundColor: ['#F87171','#FB923C','#34D399','#94A3B8'],
                borderWidth: 0, hoverOffset: 6,
            }]
        },
        options: {
            responsive: true, cutout: '68%',
            plugins: { legend: { position: 'bottom', labels: { font: { size: 12 }, padding: 16, color: '#475569' } } }
        }
    });
}
</script>
{% endblock %}
