{% extends 'rssi/layout.html.twig' %}
{% block page_title %}Tableau de bord{% endblock %}

{% block content %}
<div class="dash-page">

  {# ═══════════ LIGNE 1 — 4 KPIs ═══════════ #}
  <section class="kpi-grid">

    {# Employés #}
    <div class="card kpi tone-blue">
      <div class="kpi-head">
        <span class="kpi-icon"><i class="bi bi-people-fill"></i></span>
        <span class="kpi-label">Employés</span>
      </div>
      <div class="kpi-value">{{ totalEmployes }}</div>
      <div class="kpi-sub">{{ totalActifs }} actifs · {{ totalDepartements }} dép.</div>
    </div>

    {# Score vigilance — jauge circulaire #}
    <div class="card kpi tone-indigo">
      <div class="kpi-head">
        <span class="kpi-icon"><i class="bi bi-shield-fill-check"></i></span>
        <span class="kpi-label">Score vigilance moyen</span>
      </div>
      <div class="kpi-gauge-wrap">
        {% set gaugeColor = scoreMoyen >= 70 ? '#16A34A' : (scoreMoyen >= 50 ? '#F59E0B' : '#DC2626') %}
        {% set circ = 163 %}
        {% set offset = circ - (circ * scoreMoyen / 100) %}
        <svg class="gauge" viewBox="0 0 64 64">
          <circle cx="32" cy="32" r="26" fill="none" stroke="#EEF2F7" stroke-width="6"/>
          <circle cx="32" cy="32" r="26" fill="none" stroke="{{ gaugeColor }}" stroke-width="6"
                  stroke-linecap="round" stroke-dasharray="{{ circ }}"
                  stroke-dashoffset="{{ offset }}"
                  transform="rotate(-90 32 32)"/>
          <text x="32" y="36" text-anchor="middle" class="gauge-text">{{ scoreMoyen }}</text>
        </svg>
        <div class="kpi-gauge-meta">
          <span class="kpi-sub">Objectif annuel</span>
          <strong>80 / 100</strong>
        </div>
      </div>
    </div>

    {# Taux de clic #}
    <div class="card kpi tone-rose">
      <div class="kpi-head">
        <span class="kpi-icon"><i class="bi bi-mouse2-fill"></i></span>
        <span class="kpi-label">Taux de clic</span>
      </div>
      <div class="kpi-value">{{ clickRate }}<span class="unit">%</span></div>
      <div class="kpi-sub">Moyenne secteur : 22%</div>
    </div>

    {# Taux de signalement #}
    <div class="card kpi tone-green">
      <div class="kpi-head">
        <span class="kpi-icon"><i class="bi bi-flag-fill"></i></span>
        <span class="kpi-label">Taux de signalement</span>
      </div>
      <div class="kpi-value">{{ reportRate }}<span class="unit">%</span></div>
      <div class="kpi-sub">Emails reportés à temps</div>
    </div>
  </section>

  {# ═══════════ LIGNE 2 — Chart + Top vulnérables ═══════════ #}
  <section class="mid-grid">

    {# Graphique phishing #}
    <div class="card span-2 chart-card">
      <div class="card-head">
        <div>
          <h3><i class="bi bi-bar-chart-fill"></i> Performances campagnes phishing</h3>
          <p>Suivi du comportement des employés</p>
        </div>
        <a href="#" class="link">Toutes les campagnes <i class="bi bi-chevron-right"></i></a>
      </div>
      <div class="card-body">
        {% if campagnesPhishing|length == 0 %}
          <div class="empty">
            <i class="bi bi-inbox"></i>
            <p>Aucune campagne phishing enregistrée</p>
            <a href="#" class="btn-primary">Créer une campagne</a>
          </div>
        {% else %}
          <div class="legend">
            <span><i style="background:#DC2626"></i>Taux de clic</span>
            <span><i style="background:#EA580C"></i>Soumission</span>
            <span><i style="background:#16A34A"></i>Signalement</span>
          </div>
          <div class="chart-wrap"><canvas id="chartCampagnes"></canvas></div>
        {% endif %}
      </div>
    </div>

    {# Top employés vulnérables (anciennement "Top employés vulnérable") #}
    <div class="card panel">
      <div class="card-head compact">
        <h3><i class="bi bi-person-exclamation"></i> Top employés vulnérables</h3>
        <a href="#" class="link">Tous <i class="bi bi-chevron-right"></i></a>
      </div>
      <ul class="list">
        {% if topVulnerabilites|length == 0 %}
          <li class="empty-row">Aucun employé vulnérable 🎉</li>
        {% else %}
          {% for e in topVulnerabilites %}
            <li>
              <div class="avatar">{{ e.prenom|slice(0,1)|upper }}{{ e.nom|slice(0,1)|upper }}</div>
              <div class="list-body">
                <strong>{{ e.prenom }} {{ e.nom }}</strong>
                <span>{{ e.departement ? e.departement.nom : '—' }}</span>
              </div>
              <div class="score-pill">
                <span class="score-num">{{ e.scoreVigilance|round }}</span>
                <span class="muted">/100</span>
              </div>
            </li>
          {% endfor %}
        {% endif %}
      </ul>
    </div>
  </section>

  {# ═══════════ LIGNE 3 — Formations + Top employés + Départements vulnérables ═══════════ #}
  <section class="bot-grid">

    {# Formations #}
    <div class="card panel">
      <div class="card-head compact">
        <h3><i class="bi bi-mortarboard-fill"></i> Formations auto en cours</h3>
        <a href="#" class="link">Suivi <i class="bi bi-chevron-right"></i></a>
      </div>
      <ul class="list">
        {% if formationsIndiv|length == 0 %}
          <li class="empty-row">Aucune formation individuelle active</li>
        {% else %}
          {% for p in formationsIndiv %}
            <li>
              <div class="avatar">{{ p.employe.prenom|slice(0,1)|upper }}{{ p.employe.nom|slice(0,1)|upper }}</div>
              <div class="list-body">
                <strong>{{ p.employe.prenom }} {{ p.employe.nom }}</strong>
                <span>{{ p.module.titre|slice(0,30) }}{% if p.module.titre|length > 30 %}…{% endif %}</span>
                <div class="score-pill" style="margin-top:.3rem">
                  <div class="score-bar"><div style="width:{{ p.pourcentageProgression }}%;background:#2563EB"></div></div>
                  <span class="score-num">{{ p.pourcentageProgression }}%</span>
                </div>
              </div>
              {% if p.statut == 'EN_COURS' %}
                <span class="tag tag-ok">En cours</span>
              {% else %}
                <span class="tag tag-neutral">Attente</span>
              {% endif %}
            </li>
          {% endfor %}
        {% endif %}
      </ul>
    </div>

    {# Top employés (avec étoiles) #}
    <div class="card panel">
      <div class="card-head compact">
        <h3><i class="bi bi-trophy-fill"></i> Top employés</h3>
        <a href="#" class="link">Tous <i class="bi bi-chevron-right"></i></a>
      </div>
      <ul class="list">
        {% if topEmployes|length == 0 %}
          <li class="empty-row">Aucun employé</li>
        {% else %}
          {% for e in topEmployes %}
            <li>
              <span class="rank">{{ loop.index }}</span>
              <div class="avatar">{{ e.prenom|slice(0,1)|upper }}{{ e.nom|slice(0,1)|upper }}</div>
              <div class="list-body">
                <strong>{{ e.prenom }} {{ e.nom }}</strong>
                <span class="stars">
                  {% for i in 1..5 %}
                    <i class="bi bi-star-fill" style="color:{% if i <= e.nombreEtoiles %}#F59E0B{% else %}#E2E8F0{% endif %}; fill:{% if i <= e.nombreEtoiles %}#F59E0B{% else %}#E2E8F0{% endif %};"></i>
                  {% endfor %}
                </span>
              </div>
              <span class="score-num">{{ e.scoreVigilance|round }}</span>
            </li>
          {% endfor %}
        {% endif %}
      </ul>
    </div>

    {# Départements vulnérables (déplacé ici, à la place des alertes) #}
    <div class="card panel">
      <div class="card-head compact">
        <h3><i class="bi bi-building"></i> Départements vulnérables</h3>
        <a href="#" class="link">Voir <i class="bi bi-chevron-right"></i></a>
      </div>
      <ul class="list">
        {% if departements|length == 0 %}
          <li class="empty-row">Aucun département</li>
        {% else %}
          {% for d in departements %}
            <li>
              <div class="list-body">
                <strong>{{ d.dept.nom }}</strong>
                <span>{{ d.nb }} emp.</span>
              </div>
              <div class="score-pill">
                <div class="score-bar"><div style="width:{{ d.score }}%"></div></div>
                <span class="score-num">{{ d.score }}%</span>
              </div>
              {% if d.risque > 0 %}
                <span class="tag tag-danger">{{ d.risque }}</span>
              {% else %}
                <span class="tag tag-ok">OK</span>
              {% endif %}
            </li>
          {% endfor %}
        {% endif %}
      </ul>
    </div>
  </section>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.dash-page { font-family:"Inter",ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,sans-serif; color:#0D1829; display:flex; flex-direction:column; gap:.85rem; }
.dash-page * { box-sizing:border-box; }

/* CARD BASE */
.card { background:#fff; border:1px solid #E5E9F0; border-radius:8px; padding:1.1rem 1.25rem; }
.card-head { display:flex; justify-content:space-between; align-items:flex-start; gap:.75rem; margin-bottom:1rem; }
.card-head.compact { margin-bottom:.85rem; padding-bottom:.85rem; border-bottom:1px solid #EEF2F7; }
.card-head h3 { font-size:.9rem; font-weight:600; margin:0; color:#0D1829; display:inline-flex; align-items:center; gap:.45rem; }
.card-head h3 .count { background:#FEE2E2; color:#B91C1C; font-size:.65rem; padding:.1rem .45rem; border-radius:4px; font-weight:700; }
.card-head p { font-size:.75rem; color:#64748B; margin:.2rem 0 0; }
.card-head h3 i { color:#2563EB; }
.link { color:#2563EB; font-size:.75rem; font-weight:500; text-decoration:none; display:inline-flex; align-items:center; gap:.15rem; }
.link:hover { color:#1D4ED8; }

/* KPIs — 4 colonnes */
.kpi-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:.75rem; }
.kpi { padding:1rem 1.1rem; }
.kpi-head { display:flex; align-items:center; gap:.55rem; margin-bottom:.7rem; }
.kpi-icon { width:28px; height:28px; display:grid; place-items:center; border-radius:6px; background:#EFF6FF; color:#2563EB; font-size:.85rem; }
.tone-indigo .kpi-icon { background:#EEF2FF; color:#4F46E5; }
.tone-rose   .kpi-icon { background:#FEE2E2; color:#B91C1C; }
.tone-green  .kpi-icon { background:#DCFCE7; color:#15803D; }
.kpi-label { font-size:.75rem; color:#475569; font-weight:500; }
.kpi-value { font-size:1.7rem; font-weight:700; letter-spacing:-.03em; line-height:1; font-variant-numeric:tabular-nums; }
.kpi-value .unit { font-size:.95rem; color:#94A3B8; font-weight:500; margin-left:.15rem; }
.kpi-sub { font-size:.7rem; color:#64748B; margin-top:.5rem; display:block; }

/* GAUGE */
.kpi-gauge-wrap { display:flex; align-items:center; gap:.9rem; }
.gauge { width:64px; height:64px; flex-shrink:0; }
.gauge-text { font-size:18px; font-weight:700; fill:#0D1829; font-family:"Inter",sans-serif; }
.kpi-gauge-meta { display:flex; flex-direction:column; gap:.15rem; }
.kpi-gauge-meta strong { font-size:.85rem; font-weight:700; color:#0D1829; font-variant-numeric:tabular-nums; }
.kpi-gauge-meta .kpi-sub { margin:0; }

/* MID GRID (2 colonnes) */
.mid-grid { display:grid; grid-template-columns:2fr 1fr; gap:.85rem; }
.span-2 { grid-column:span 1; }
.chart-card { display:flex; flex-direction:column; }
.legend { display:flex; gap:.9rem; font-size:.72rem; color:#475569; margin-bottom:.6rem; }
.legend span { display:inline-flex; align-items:center; gap:.35rem; }
.legend i { width:8px; height:8px; border-radius:2px; display:inline-block; }
.chart-wrap { height:260px; position:relative; }
.empty { text-align:center; padding:2rem 1rem; color:#94A3B8; }
.empty i { font-size:1.8rem; display:block; margin-bottom:.5rem; }
.btn-primary { display:inline-block; margin-top:.6rem; background:#2563EB; color:#fff; padding:.45rem .9rem; border-radius:6px; font-size:.78rem; font-weight:600; text-decoration:none; }
.btn-primary:hover { background:#1D4ED8; }

/* PANELS / LISTS */
.panel { display:flex; flex-direction:column; }
.list, .alert-list { list-style:none; margin:0; padding:0; }
.list li { display:flex; align-items:center; gap:.65rem; padding:.55rem 0; border-bottom:1px solid #F1F5F9; }
.list li:last-child { border-bottom:none; }
.empty-row { color:#94A3B8; font-size:.78rem; padding:1rem 0; justify-content:center; }
.avatar { width:32px; height:32px; border-radius:6px; background:#EEF2F7; color:#475569; display:grid; place-items:center; font-size:.7rem; font-weight:700; flex-shrink:0; }
.rank { width:20px; font-size:.72rem; font-weight:700; color:#94A3B8; text-align:center; font-variant-numeric:tabular-nums; }
.list-body { flex:1; min-width:0; display:flex; flex-direction:column; }
.list-body strong { font-size:.8rem; font-weight:600; color:#0D1829; }
.list-body span { font-size:.7rem; color:#64748B; }
.stars { color:#F59E0B; font-size:.65rem; letter-spacing:1px; display:inline-flex; gap:2px; }
.stars i { font-size:.65rem; }
.muted { color:#94A3B8; font-size:.7rem; }

.score-pill { display:flex; align-items:center; gap:.5rem; flex-shrink:0; }
.score-bar { width:60px; height:4px; background:#F1F5F9; border-radius:2px; overflow:hidden; }
.score-bar div { height:100%; background:linear-gradient(90deg,#DC2626,#F59E0B); }
.score-num { font-size:.8rem; font-weight:700; color:#0D1829; font-variant-numeric:tabular-nums; min-width:28px; text-align:right; }

/* TAGS */
.tag { display:inline-flex; align-items:center; gap:.25rem; padding:.15rem .5rem; border-radius:4px; font-size:.68rem; font-weight:600; flex-shrink:0; }
.tag-ok { background:#DCFCE7; color:#15803D; }
.tag-danger { background:#FEE2E2; color:#B91C1C; }
.tag-neutral { background:#F1F5F9; color:#475569; }

/* BOT GRID (3 colonnes) */
.bot-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:.85rem; }

/* RESPONSIVE */
@media (max-width:1400px) {
  .kpi-grid { grid-template-columns:repeat(4,1fr); }
}
@media (max-width:1100px) {
  .mid-grid { grid-template-columns:1fr 1fr; }
  .bot-grid { grid-template-columns:repeat(2,1fr); }
}
@media (max-width:768px) {
  .kpi-grid { grid-template-columns:repeat(2,1fr); }
  .mid-grid, .bot-grid { grid-template-columns:1fr; }
  .card { padding:1rem; }
  .chart-wrap { height:200px; }
}
</style>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
{% if campagnesPhishing|length > 0 %}
(function() {
    const ctx = document.getElementById('chartCampagnes');
    if (!ctx) return;
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: {{ campagnesLabels|raw }},
            datasets: [
                { label:'Taux de clic (%)', data:{{ campagnesClics|raw }}, backgroundColor:'#DC2626', borderRadius:3, borderSkipped:false },
                { label:'Soumission (%)',   data:{{ campagnesSubmissions|raw }}, backgroundColor:'#EA580C', borderRadius:3, borderSkipped:false },
                { label:'Signalement (%)',  data:{{ campagnesSignalements|raw }}, backgroundColor:'#16A34A', borderRadius:3, borderSkipped:false }
            ]
        },
        options: {
            responsive:true, maintainAspectRatio:false,
            plugins: {
                legend:{ display:false },
                tooltip:{ backgroundColor:'#0D1829', titleColor:'#94A3B8', bodyColor:'#F1F5F9', padding:10, cornerRadius:6,
                    callbacks:{ label:c => '  '+c.dataset.label+' : '+c.parsed.y+'%' } }
            },
            scales: {
                x: { grid:{display:false}, border:{display:false}, ticks:{color:'#64748B', font:{size:11, family:'Inter'}} },
                y: { grid:{color:'#EEF2F7'}, border:{display:false}, ticks:{color:'#64748B', font:{size:11, family:'Inter'}, callback:v=>v+'%'}, min:0, max:100 }
            }
        }
    });
})();
{% endif %}
</script>
{% endblock %}