{% extends 'rssi/layout.html.twig' %}

{% block page_title %}Campagnes Phishing{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('rssi_phishing_nouvelle') }}" class="r-btn r-btn-primary">
        <i class="bi bi-plus-lg"></i> Nouvelle campagne
    </a>
{% endblock %}

{% block content %}

{# ── Stats globales ── #}
{% set nbPlanifiees = campagnes|filter(c => c.statut == 'PLANIFIEE')|length %}
{% set nbEnCours    = campagnes|filter(c => c.statut == 'EN_COURS')|length %}
{% set nbTerminees  = campagnes|filter(c => c.statut == 'TERMINEE')|length %}
{% set totalCibles  = 0 %}
{% set totalEnvoyes = 0 %}
{% set totalClics   = 0 %}
{% for c in campagnes %}
    {% set totalCibles  = totalCibles  + c.totalCibles %}
    {% set totalEnvoyes = totalEnvoyes + c.emailsEnvoyes %}
    {% set totalClics   = totalClics   + c.liensCliques %}
{% endfor %}

<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px;">

    <div class="r-card" style="padding:20px;display:flex;align-items:center;gap:14px;">
        <div style="width:48px;height:48px;border-radius:12px;background:#FEF3C7;color:#D97706;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">
            <i class="bi bi-fish"></i>
        </div>
        <div>
            <div style="font-size:26px;font-weight:800;color:#0F172A;line-height:1;">{{ campagnes|length }}</div>
            <div style="font-size:12px;color:#64748B;margin-top:2px;">Campagnes totales</div>
        </div>
    </div>

    <div class="r-card" style="padding:20px;display:flex;align-items:center;gap:14px;">
        <div style="width:48px;height:48px;border-radius:12px;background:#CFFAFE;color:#0891B2;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">
            <i class="bi bi-send-fill"></i>
        </div>
        <div>
            <div style="font-size:26px;font-weight:800;color:#0F172A;line-height:1;">{{ totalEnvoyes }}</div>
            <div style="font-size:12px;color:#64748B;margin-top:2px;">Emails envoyés</div>
        </div>
    </div>

    <div class="r-card" style="padding:20px;display:flex;align-items:center;gap:14px;">
        <div style="width:48px;height:48px;border-radius:12px;background:#FEE2E2;color:#DC2626;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">
            <i class="bi bi-cursor-fill"></i>
        </div>
        <div>
            <div style="font-size:26px;font-weight:800;color:#0F172A;line-height:1;">{{ totalClics }}</div>
            <div style="font-size:12px;color:#64748B;margin-top:2px;">Liens cliqués</div>
        </div>
    </div>

    <div class="r-card" style="padding:20px;display:flex;align-items:center;gap:14px;">
        <div style="width:48px;height:48px;border-radius:12px;background:#DCFCE7;color:#166534;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">
            <i class="bi bi-shield-check"></i>
        </div>
        <div>
            <div style="font-size:26px;font-weight:800;color:#0F172A;line-height:1;">
                {% if totalEnvoyes > 0 %}{{ ((totalClics / totalEnvoyes) * 100)|round(1) }}%{% else %}—{% endif %}
            </div>
            <div style="font-size:12px;color:#64748B;margin-top:2px;">Taux de clic global</div>
        </div>
    </div>

</div>

{% if gabarits|length == 0 %}
<div style="background:#FEF9C3;border:1px solid #FEF08A;border-radius:10px;padding:16px;margin-bottom:20px;font-size:13px;color:#854D0E;">
    <i class="bi bi-exclamation-triangle-fill"></i>
    Aucun gabarit phishing disponible. L'administrateur doit en créer avant que vous puissiez lancer une campagne.
</div>
{% endif %}

{% if campagnes|length == 0 %}
<div class="r-card">
    <div class="r-card-body">
        <div class="r-empty">
            <i class="bi bi-fish"></i>
            <p>Aucune campagne phishing créée. Lancez votre première simulation pour tester la vigilance de vos équipes.</p>
            <a href="{{ path('rssi_phishing_nouvelle') }}" class="r-btn r-btn-primary">
                <i class="bi bi-plus-lg"></i> Créer une campagne
            </a>
        </div>
    </div>
</div>
{% else %}

<div class="r-card">
    <table class="r-table">
        <thead>
            <tr>
                <th>Campagne</th>
                <th>Gabarit</th>
                <th>Cibles</th>
                <th>Envoyés</th>
                <th>Cliqués</th>
                <th>Signalés</th>
                <th>Statut</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for c in campagnes %}
        <tr>
            <td>
                <div style="font-weight:700;color:#1E293B;">{{ c.titre }}</div>
                {% if c.description %}
                    <div style="font-size:11px;color:#94A3B8;max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ c.description }}</div>
                {% endif %}
            </td>
            <td>
                <div style="font-size:13px;color:#475569;">{{ c.gabarit.titre }}</div>
                <div style="font-size:11px;color:#94A3B8;">{{ c.gabarit.categorie }}</div>
            </td>
            <td style="font-weight:700;color:#0F172A;text-align:center;">{{ c.totalCibles }}</td>
            <td style="text-align:center;">
                <span style="font-weight:700;color:#0891B2;">{{ c.emailsEnvoyes }}</span>
                {% if c.totalCibles > 0 %}
                    <div style="font-size:10px;color:#94A3B8;">{{ ((c.emailsEnvoyes/c.totalCibles)*100)|round }}%</div>
                {% endif %}
            </td>
            <td style="text-align:center;">
                {% if c.emailsEnvoyes > 0 %}
                    <span style="font-weight:700;color:{% if c.tauxClic > 30 %}#DC2626{% elseif c.tauxClic > 10 %}#D97706{% else %}#166534{% endif %};">
                        {{ c.liensCliques }}
                    </span>
                    <div style="font-size:10px;color:#94A3B8;">{{ c.tauxClic|round(1) }}%</div>
                {% else %}<span style="color:#CBD5E1;">—</span>{% endif %}
            </td>
            <td style="text-align:center;">
                <span style="font-weight:700;color:#166534;">{{ c.emailsSignales }}</span>
                {% if c.emailsEnvoyes > 0 %}
                    <div style="font-size:10px;color:#94A3B8;">{{ c.tauxSignalement|round(1) }}%</div>
                {% endif %}
            </td>
            <td>
                {% if c.statut == 'PLANIFIEE' %}
                    <span class="r-badge r-badge-blue"><i class="bi bi-clock"></i> Planifiée</span>
                {% elseif c.statut == 'EN_COURS' %}
                    <span class="r-badge r-badge-orange"><i class="bi bi-play-circle-fill"></i> En cours</span>
                {% elseif c.statut == 'TERMINEE' %}
                    <span class="r-badge r-badge-green"><i class="bi bi-check-circle-fill"></i> Terminée</span>
                {% elseif c.statut == 'ANNULEE' %}
                    <span class="r-badge r-badge-gray"><i class="bi bi-x-circle"></i> Annulée</span>
                {% endif %}
            </td>
            <td style="font-size:12px;color:#64748B;">{{ c.datePlanifiee|date('d/m/Y') }}</td>
            <td>
                <div style="display:flex;gap:5px;">
                    <a href="{{ path('rssi_phishing_detail', {id: c.id}) }}" class="r-btn r-btn-ghost" style="padding:6px 10px;" title="Voir">
                        <i class="bi bi-bar-chart-line"></i>
                    </a>
                    {% if c.statut == 'PLANIFIEE' %}
                    <form method="post" action="{{ path('rssi_phishing_lancer', {id: c.id}) }}"
                          onsubmit="return confirm('Lancer la campagne « {{ c.titre }} » maintenant ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('lancer_' ~ c.id) }}">
                        <button type="submit" class="r-btn r-btn-primary" style="padding:6px 10px;" title="Lancer">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </form>
                    {% endif %}
                </div>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

{% endif %}
{% endblock %}
