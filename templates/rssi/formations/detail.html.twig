{% extends 'rssi/layout.html.twig' %}

{% block page_title %}{{ campagne.titre }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('rssi_formations_liste') }}" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
    {% if campagne.statut == 'PLANIFIEE' %}
        <form method="post" action="{{ path('rssi_formations_statut', {id: campagne.id, statut: 'EN_COURS'}) }}" style="display:inline;">
            <input type="hidden" name="_token" value="{{ csrf_token('statut_' ~ campagne.id) }}">
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-play-fill"></i> Lancer</button>
        </form>
    {% elseif campagne.statut == 'EN_COURS' %}
        <form method="post" action="{{ path('rssi_formations_statut', {id: campagne.id, statut: 'TERMINEE'}) }}" id="form-term-camp-{{ campagne.id }}" style="display:inline;">
            <input type="hidden" name="_token" value="{{ csrf_token('statut_' ~ campagne.id) }}">
            <button type="submit" class="btn btn-ghoste btn-sm"
                    data-confirm="Marquer cette campagne comme terminée ?"
                    data-form="form-term-camp-{{ campagne.id }}">
                <i class="bi bi-stop-fill"></i> Terminer
            </button>
        </form>
    {% endif %}
{% endblock %}

{% block content %}
<div class="campaign-container">

    {# En-tête de la campagne #}
    {% set pct = campagne.totalParticipants > 0 ? ((campagne.nombreTermines / campagne.totalParticipants) * 100)|round : 0 %}
    <div class="campaign-header">
        <div class="campaign-icon" data-statut="{{ campagne.statut }}">
            <i class="bi bi-mortarboard-fill"></i>
        </div>
        <div class="campaign-info">
            <div class="campaign-title">
                <h1>{{ campagne.titre }}</h1>
                <span class="badge badge-{{ campagne.statut|lower|replace({'_': '-'}) }}">
                    {{ campagne.statut|replace({'_': ' '}) }}
                </span>
            </div>
            {% if campagne.description %}
                <p class="campaign-description">{{ campagne.description }}</p>
            {% endif %}
            <div class="campaign-meta">
                <span><i class="bi bi-calendar3"></i> T{{ campagne.trimestre }} {{ campagne.annee }}</span>
                <span><i class="bi bi-play"></i> {{ campagne.dateDebut|date('d/m/Y') }}</span>
                <span><i class="bi bi-stop"></i> {{ campagne.dateFin|date('d/m/Y') }}</span>
                <span><i class="bi bi-people"></i> {{ campagne.totalParticipants }} participant(s)</span>
                <span><i class="bi bi-exclamation-triangle"></i> -{{ campagne.pointsPenalite }} pts si non complété</span>
            </div>
        </div>
        <div class="campaign-progress-circle">
            <div class="progress-value">{{ pct }}%</div>
            <div class="progress-label">complété</div>
        </div>
    </div>

    {# Barre de progression globale #}
    <div class="global-progress">
        <div class="progress-bar-bg">
            <div class="progress-bar-fill" style="width: {{ pctGlobal ?? pct }}%;"></div>
        </div>
        <div class="progress-stats">
            <span><i class="bi bi-check-circle" style="color:#166534;"></i> {{ termines ?? campagne.nombreTermines }} terminé(s)</span>
            <span><i class="bi bi-play-circle" style="color:#3B82F6;"></i> {{ enCours ?? campagne.nombreEnCours }} en cours</span>
            <span><i class="bi bi-clock" style="color:#D97706;"></i> {{ enRetard ?? campagne.nombreEnRetard }} en retard</span>
        </div>
    </div>

    {# Stat-cards résumées #}



    {# ── Stat-cards globales ── #}
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;">
        <div class="r-card" style="padding:16px;text-align:center;">
            <div style="font-size:28px;font-weight:900;color:#1E293B;line-height:1;">{{ totalP ?? campagne.totalParticipants }}</div>
            <div style="font-size:12px;color:var(--gray-500);margin-top:4px;">Participants</div>
        </div>
        <div class="r-card" style="padding:16px;text-align:center;">
            <div style="font-size:28px;font-weight:900;color:#059669;line-height:1;">{{ nbTermines ?? campagne.nombreTermines }}</div>
            <div style="font-size:12px;color:var(--gray-500);margin-top:4px;">Terminés</div>
        </div>
        <div class="r-card" style="padding:16px;text-align:center;">
            <div style="font-size:28px;font-weight:900;color:#2563EB;line-height:1;">{{ nbEnCours ?? campagne.nombreEnCours }}</div>
            <div style="font-size:12px;color:var(--gray-500);margin-top:4px;">En cours</div>
        </div>
        <div class="r-card" style="padding:16px;text-align:center;">
            <div style="font-size:28px;font-weight:900;color:#D97706;line-height:1;">{{ nbEnRetard ?? campagne.nombreEnRetard }}</div>
            <div style="font-size:12px;color:var(--gray-500);margin-top:4px;">En retard</div>
        </div>
    </div>

    {# stat-card-count marker #}
    {# Deux colonnes : modules + participants #}
    <div class="campaign-grid">
        {# Colonne gauche : progression par module #}
        <div class="r-card">
            <div class="r-card-header">
                <div class="r-card-title">
                    <i class="bi bi-book-half" style="color:#3B82F6;"></i> Modules ({{ statsModules|length }})
                </div>
            </div>
            <div class="r-card-body modules-list">
                {% for s in statsModules %}
                <div class="module-item">
                    <div class="module-header">
                        <div>
                            <div class="module-title">{{ s.module.titre }}</div>
                            <div class="module-stats">{{ s.termines }}/{{ s.total }} terminés · {{ s.enCours }} en cours</div>
                        </div>
                        <span class="module-percent">{{ s.pct }}%</span>
                    </div>
                    <div class="progress-bar-bg small">
                        <div class="progress-bar-fill" style="width: {{ s.pct }}%;"></div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>

        {# Colonne droite : participants #}
        <div class="r-card">
            <div class="r-card-header">
                <div class="r-card-title">
                    <i class="bi bi-people" style="color:#3B82F6;"></i> Participants ({{ parEmploye|length }})
                </div>
            </div>
            <div class="table-responsive">
                <table class="r-table">
                    <thead>
                        <tr>
                            <th>Employé</th>
                            <th>Progression</th>
                            <th>Détail par module</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for data in parEmploye %}
                        {% set epct = data.pct_moyen ?? 0 %}
                        <tr>
                            <td class="employee-cell">
                                <div class="employee-avatar">
                                    {{ data.employe.prenom|slice(0,1)|upper }}{{ data.employe.nom|slice(0,1)|upper }}
                                </div>
                                <div>
                                    <div class="employee-name">{{ data.employe.prenom }} {{ data.employe.nom }}</div>
                                    <div class="employee-dept">{{ data.employe.departement ? data.employe.departement.nom : '—' }}</div>
                                </div>
                            </td>
                            <td>
                                <div class="progress-indicator">
                                    <div class="progress-bar-bg small">
                                        <div class="progress-bar-fill" style="width: {{ epct }}%;"></div>
                                    </div>
                                    <span class="progress-value">{{ epct }}%</span>
                                </div>
                            </td>
                            <td style="font-size:12px;min-width:160px;">
                                <div style="color:var(--gray-500);margin-bottom:4px;">{{ data.termines }}/{{ data.nb_modules }} module(s) terminé(s)</div>
                                {% for p in data.progressions %}
                                <div style="margin-bottom:5px;">
                                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2px;">
                                        <span style="font-size:11px;color:var(--gray-600);max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="{{ p.module.titre }}">{{ p.module.titre|slice(0,18) }}{% if p.module.titre|length > 18 %}…{% endif %}</span>
                                        <span style="font-size:11px;font-weight:700;color:{% if p.statut == 'TERMINE' %}#059669{% elseif p.pourcentageProgression > 0 %}#2563EB{% else %}#94A3B8{% endif %};">{{ p.pourcentageProgression }}%</span>
                                    </div>
                                    <div style="height:4px;background:#E2E8F0;border-radius:99px;overflow:hidden;">
                                        <div style="height:100%;width:{{ p.pourcentageProgression }}%;background:{% if p.statut == 'TERMINE' %}#10B981{% elseif p.pourcentageProgression > 0 %}#3B82F6{% else %}#CBD5E1{% endif %};border-radius:99px;transition:width .3s;"></div>
                                    </div>
                                </div>
                                {% endfor %}
                            </td>
                            <td>
                                {% if data.retard %}
                                    <span class="badge badge-red">Retard</span>
                                {% elseif epct == 100 %}
                                    <span class="badge badge-green">Terminé</span>
                                {% elseif epct > 0 %}
                                    <span class="badge badge-blue">En cours</span>
                                {% else %}
                                    <span class="badge badge-gray">Non commencé</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="empty-table">
                                <i class="bi bi-people"></i> Aucun participant assigné.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* Override couleur cyan -> bleu */
    :root {
        --r-accent: #3B82F6;
        --r-accent-dim: rgba(59,130,246,0.12);
    }
    .r-brand-icon, .r-user-avatar {
        background: linear-gradient(135deg, #3B82F6, #2563EB) !important;
        box-shadow: 0 2px 8px rgba(59,130,246,0.2) !important;
    }
    .r-brand-role, .r-nav-link.active {
        color: #3B82F6 !important;
    }
    .r-nav-link.active {
        background: rgba(59,130,246,0.12) !important;
    }
    .r-topbar-company {
        background: #EFF6FF !important;
        border-color: #BFDBFE !important;
        color: #1E40AF !important;
    }

    /* Container principal */
    .campaign-container {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* En-tête campagne */
    .campaign-header {
        background: white;
        border-radius: 1rem;
        border: 1px solid #E2E8F0;
        padding: 1.5rem;
        display: flex;
        gap: 1.25rem;
        flex-wrap: wrap;
        align-items: flex-start;
    }
    .campaign-icon {
        width: 60px;
        height: 60px;
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        flex-shrink: 0;
    }
    .campaign-icon[data-statut="EN_COURS"] { background: #CFFAFE; color: #0891B2; }
    .campaign-icon[data-statut="PLANIFIEE"] { background: #FEF9C3; color: #CA8A04; }
    .campaign-icon[data-statut="TERMINEE"] { background: #DCFCE7; color: #166534; }
    .campaign-icon[data-statut="ANNULEE"] { background: #F1F5F9; color: #94A3B8; }
    .campaign-info {
        flex: 1;
        min-width: 200px;
    }
    .campaign-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 0.5rem;
    }
    .campaign-title h1 {
        font-size: 1.25rem;
        font-weight: 800;
        color: #0F172A;
        margin: 0;
    }
    .campaign-description {
        font-size: 0.875rem;
        color: #475569;
        margin: 0 0 0.75rem 0;
    }
    .campaign-meta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        font-size: 0.75rem;
        color: #94A3B8;
    }
    .campaign-meta i {
        margin-right: 0.25rem;
    }
    .campaign-progress-circle {
        text-align: center;
        flex-shrink: 0;
    }
    .progress-value {
        font-size: 2rem;
        font-weight: 800;
        color: #0F172A;
        line-height: 1;
    }
    .progress-label {
        font-size: 0.7rem;
        color: #64748B;
    }
    html.dark .campaign-header {
        background: #1E293B;
        border-color: #334155;
    }
    html.dark .campaign-title h1 {
        color: #F1F5F9;
    }
    html.dark .campaign-description {
        color: #94A3B8;
    }
    html.dark .progress-value {
        color: #F1F5F9;
    }

    /* Barre globale */
    .global-progress {
        background: white;
        border-radius: 1rem;
        border: 1px solid #E2E8F0;
        padding: 1rem;
    }
    .progress-bar-bg {
        width: 100%;
        height: 0.5rem;
        background: #E2E8F0;
        border-radius: 999px;
        overflow: hidden;
    }
    .progress-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, #3B82F6, #2563EB);
        border-radius: 999px;
        transition: width 0.5s;
    }
    .progress-stats {
        display: flex;
        gap: 1.5rem;
        margin-top: 0.5rem;
        font-size: 0.75rem;
        color: #64748B;
        flex-wrap: wrap;
    }
    html.dark .global-progress {
        background: #1E293B;
        border-color: #334155;
    }
    html.dark .progress-bar-bg {
        background: #334155;
    }

    /* Grille responsive */
    .campaign-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }
    @media (max-width: 900px) {
        .campaign-grid {
            grid-template-columns: 1fr;
        }
    }

    /* Modules */
    .modules-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .module-item {
        width: 100%;
    }
    .module-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 0.5rem;
    }
    .module-title {
        font-size: 0.8125rem;
        font-weight: 600;
        color: #0F172A;
    }
    .module-stats {
        font-size: 0.6875rem;
        color: #94A3B8;
    }
    .module-percent {
        font-size: 0.875rem;
        font-weight: 700;
        color: #3B82F6;
    }
    html.dark .module-title {
        color: #F1F5F9;
    }
    .progress-bar-bg.small {
        height: 0.25rem;
    }

    /* Tableau participants */
    .employee-cell {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .employee-avatar {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: linear-gradient(135deg, #3B82F6, #2563EB);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 600;
        color: white;
        flex-shrink: 0;
    }
    .employee-name {
        font-weight: 600;
        color: #1E293B;
    }
    .employee-dept {
        font-size: 0.65rem;
        color: #94A3B8;
    }
    .progress-indicator {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .empty-table {
        text-align: center;
        padding: 2rem;
        color: #94A3B8;
    }
    .empty-table i {
        font-size: 1.5rem;
        display: block;
        margin-bottom: 0.5rem;
    }
    html.dark .employee-name {
        color: #F1F5F9;
    }

    /* Badges */
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.2rem 0.5rem;
        border-radius: 20px;
        font-size: 0.65rem;
        font-weight: 600;
        white-space: nowrap;
    }
    .badge-planifiee, .badge-orange { background: #FEF9C3; color: #CA8A04; }
    .badge-en-cours, .badge-cyan { background: #CFFAFE; color: #0891B2; }
    .badge-terminee, .badge-green { background: #DCFCE7; color: #166534; }
    .badge-annulee, .badge-gray { background: #F1F5F9; color: #475569; }
    .badge-red { background: #FEE2E2; color: #991B1B; }
    .badge-blue { background: #DBEAFE; color: #1E40AF; }
    html.dark .badge-planifiee { background: #422006; color: #FDE047; }
    html.dark .badge-en-cours { background: #164E63; color: #22D3EE; }
    html.dark .badge-terminee { background: #14532D; color: #4ADE80; }
    html.dark .badge-annulee { background: #1E293B; color: #94A3B8; }
    html.dark .badge-red { background: #7F1D1D; color: #FCA5A5; }
    html.dark .badge-blue { background: #1E3A8A; color: #60A5FA; }

    /* Boutons */
    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s ease;
        cursor: pointer;
        border: none;
        border-radius: 8px;
        font-size: 0.8125rem;
        line-height: 1.4;
        white-space: nowrap;
    }
    .btn-sm {
        padding: 0.25rem 0.75rem;
        font-size: 0.75rem;
    }
    .btn-primary {
        background: #3B82F6;
        color: white;
        padding: 0.375rem 1rem;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
    .btn-primary:hover {
        background: #2563EB;
    }
    .btn-danger {
        background: #EF4444;
        color: white;
        padding: 0.375rem 1rem;
    }
    .btn-danger:hover {
        background: #DC2626;
    }
    .btn-ghost {
        background: blue;
        border: 1px solid #E2E8F0;
        color: #475569;
        padding: 0.375rem 1rem;
    }
    .btn-ghost:hover {
        background: #F8FAFC;
        border-color: #CBD5E1;
        color: #1E293B;
    }
    html.dark .btn-ghost {
        border-color: #334155;
        color: #94A3B8;
    }
    html.dark .btn-ghost:hover {
        background: #1E293B;
        border-color: #475569;
        color: #F1F5F9;
    }

    /* Responsive fine */
    @media (max-width: 768px) {
        .campaign-header {
            flex-direction: column;
            align-items: stretch;
        }
        .campaign-progress-circle {
            text-align: left;
        }
        .progress-stats {
            flex-direction: column;
            gap: 0.25rem;
        }
        .employee-cell {
            flex-direction: column;
            align-items: flex-start;
        }
        .r-table th, .r-table td {
            padding: 0.5rem;
        }
    }
    @media (max-width: 480px) {
        .campaign-icon {
            width: 48px;
            height: 48px;
            font-size: 1.25rem;
        }
        .campaign-title h1 {
            font-size: 1rem;
        }
        .progress-value {
            font-size: 1.5rem;
        }
    }
</style>
{% endblock %}