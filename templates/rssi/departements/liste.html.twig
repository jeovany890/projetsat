{% extends 'rssi/layout.html.twig' %}

{% block page_title %}Départements{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('rssi_departements_nouveau') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nouveau département
    </a>
{% endblock %}

{% block content %}

{# ── Stats globales ── #}
{% set totalEmployes = 0 %}
{% set totalActifs = 0 %}
{% for d in departements %}
    {% set totalEmployes = totalEmployes + d.employes|length %}
    {% for e in d.employes %}
        {% if e.estActif %}{% set totalActifs = totalActifs + 1 %}{% endif %}
    {% endfor %}
{% endfor %}

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon blue"><i class="bi bi-diagram-3-fill"></i></div>
        <div class="stat-info">
            <div class="stat-value">{{ departements|length }}</div>
            <div class="stat-label">Départements</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon cyan"><i class="bi bi-people-fill"></i></div>
        <div class="stat-info">
            <div class="stat-value">{{ totalEmployes }}</div>
            <div class="stat-label">Employés au total</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="bi bi-person-check-fill"></i></div>
        <div class="stat-info">
            <div class="stat-value">{{ totalActifs }}</div>
            <div class="stat-label">Employés actifs</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon gray"><i class="bi bi-diagram-3"></i></div>
        <div class="stat-info">
            <div class="stat-value">{{ departements|filter(d => d.employes|length > 0)|length }}</div>
            <div class="stat-label">Dép. avec employés</div>
        </div>
    </div>
</div>

{% if departements|length == 0 %}
<div class="r-card">
    <div class="r-card-body">
        <div class="r-empty">
            <i class="bi bi-diagram-3"></i>
            <p>Aucun département créé. Commencez par structurer votre organisation.</p>
            <a href="{{ path('rssi_departements_nouveau') }}" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Créer le premier département
            </a>
        </div>
    </div>
</div>
{% else %}

<div class="r-card">
    <div class="r-card-header">
        <div class="r-card-title"><i class="bi bi-diagram-3-fill" style="color:#3B82F6;"></i> Vue d'ensemble</div>
    </div>

    <div class="table-responsive-wrapper">
        <table class="r-table dept-table">
            <thead>
                <tr>
                    <th>Département</th>
                    <th>Employés</th>
                    <th>Actifs</th>
                    <th>Score vig. moyen</th>
                    <th>Étoiles</th>
                    <th>Risque</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for dept in departements %}
                {% set nbActifs = 0 %}
                {% set totalScore = 0 %}
                {% set nbAvecScore = 0 %}
                {% set nbRisque = 0 %}
                {% set totalEtoiles = 0 %}

                {% for e in dept.employes %}
                    {% if e.estActif %}{% set nbActifs = nbActifs + 1 %}{% endif %}
                    {% if e.totalPoints > 0 %}
                        {% set totalScore = totalScore + e.scoreVigilance %}
                        {% set nbAvecScore = nbAvecScore + 1 %}
                    {% endif %}
                    {% set totalEtoiles = totalEtoiles + e.nombreEtoiles %}
                    {% if e.scoreVigilance < 40 and e.totalPoints > 0 %}
                        {% set nbRisque = nbRisque + 1 %}
                    {% endif %}
                {% endfor %}

                {% set scoreMoyen = nbAvecScore > 0 ? (totalScore / nbAvecScore)|round(1) : null %}
                {% set pctActifs = dept.employes|length > 0 ? ((nbActifs / dept.employes|length) * 100)|round : 0 %}

                <tr>
                    <td data-label="Département">
                        <div class="dept-cell">
                            <i class="bi bi-diagram-3-fill" style="color:#3B82F6; margin-right: 8px;"></i>
                            <div>
                                <strong>{{ dept.nom }}</strong>
                                {% if dept.description %}
                                    <div class="dept-desc">{{ dept.description|slice(0,60) }}{% if dept.description|length > 60 %}…{% endif %}</div>
                                {% endif %}
                            </div>
                        </div>
                    </td>
                    <td data-label="Employés">{{ dept.employes|length }}</td>
                    <td data-label="Actifs">{{ nbActifs }}</td>
                    <td data-label="Score vig. moyen">
                        {% if scoreMoyen is not null %}
                            {{ scoreMoyen }}%
                        {% else %}
                            <span class="text-muted">0</span>
                        {% endif %}
                    </td>
                    <td data-label="Étoiles">
                        <span class="stars">★</span> {{ totalEtoiles }}/5
                    </td>
                    <td data-label="Risque">
                        {% if nbRisque > 0 %}
                            <span class="badge badge-red"><i class="bi bi-exclamation-triangle-fill"></i> {{ nbRisque }} à risque</span>
                        {% elseif dept.employes|length == 0 %}
                            <span class="badge badge-gray">0</span>
                        {% else %}
                            <span class="badge badge-green"><i class="bi bi-check-circle-fill"></i> OK</span>
                        {% endif %}
                    </td>
                    <td data-label="Actions" class="actions-cell">
                        <div class="action-buttons-crud">
                            {# Voir les employés du département #}
                            <a href="{{ path('rssi_employes_liste') }}?dept={{ dept.id }}" class="btn-icon" title="Voir les employés">
                                <i class="bi bi-people-fill"></i>
                            </a>
                            {# Modifier le département #}
                            <a href="{{ path('rssi_departements_modifier', {id: dept.id}) }}" class="btn-icon btn-icon-edit" title="Modifier">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            {# Supprimer (uniquement si aucun employé) #}
                            {% if dept.employes|length == 0 %}
                                <form method="post" action="{{ path('rssi_departements_supprimer', {id: dept.id}) }}" style="display: inline-block;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('supprimer_dept_' ~ dept.id) }}">
                                    <button type="submit" class="btn-icon btn-icon-delete" onclick="return confirm('Supprimer « {{ dept.nom }} » ?')" title="Supprimer">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </form>
                            {% else %}
                                <span class="btn-icon btn-icon-delete disabled" title="Impossible : contient des employés">
                                    <i class="bi bi-trash3-fill"></i>
                                </span>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endif %}
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ===== DESIGN SYSTEM ÉPURÉ ===== */
    :root {
        --bg: #F8FAFC;
        --surface: #FFFFFF;
        --border: #E2E8F0;
        --text-primary: #0F172A;
        --text-secondary: #475569;
        --text-muted: #64748B;
        --accent: #3B82F6;
        --accent-light: #EFF6FF;
        --danger: #EF4444;
        --danger-light: #FEF2F2;
        --warning: #F59E0B;
        --warning-light: #FFFBEB;
        --success: #10B981;
        --success-light: #F0FDF4;
    }

    /* Grille statistiques */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin-bottom: 1.75rem;
    }
    @media (max-width: 1024px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px) { .stats-grid { grid-template-columns: 1fr; } }

    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 0.75rem;
        padding: 1rem;
        display: flex;
        align-items: center;
        gap: 0.875rem;
        transition: all 0.2s;
    }
    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }
    .stat-icon.blue { background: #DBEAFE; color: #1D4ED8; }
    .stat-icon.cyan { background: #CFFAFE; color: #0891B2; }
    .stat-icon.green { background: #DCFCE7; color: #166534; }
    .stat-icon.gray { background: #F1F5F9; color: #475569; }
    .stat-value { font-size: 1.625rem; font-weight: 800; color: var(--text-primary); line-height: 1.2; }
    .stat-label { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem; }
    html.dark .stat-card { background: #1E293B; border-color: #334155; }
    html.dark .stat-value { color: #F1F5F9; }

    /* Tableau responsive */
    .table-responsive-wrapper {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        margin-top: 1rem;
    }
    .r-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
        min-width: 780px;
        border: 1px solid var(--border);
        border-radius: 0.75rem;
    }
    .r-table th {
        text-align: left;
        padding: 0.875rem 1rem;
        background-color: #F8FAFC;
        color: var(--text-secondary);
        font-weight: 600;
        border-bottom: 1px solid var(--border);
    }
    .r-table td {
        padding: 0.875rem 1rem;
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
    }
    .r-table tr:last-child td { border-bottom: none; }
    html.dark .r-table th {
        background-color: #1E293B;
        color: #94A3B8;
        border-bottom-color: #334155;
    }
    html.dark .r-table td { border-bottom-color: #334155; }

    /* Cellule département */
    .dept-cell {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .dept-desc {
        font-size: 0.7rem;
        color: var(--text-muted);
        max-width: 220px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        margin-top: 2px;
    }
    .stars { color: #F59E0B; font-weight: 600; }

    /* Badges */
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.25rem 0.5rem;
        border-radius: 9999px;
        font-size: 0.7rem;
        font-weight: 600;
        white-space: nowrap;
    }
    .badge-red { background: var(--danger-light); color: #991B1B; }
    .badge-green { background: var(--success-light); color: #166534; }
    .badge-gray { background: #F1F5F9; color: #475569; }
    html.dark .badge-red { background: #7F1D1D; color: #FCA5A5; }
    html.dark .badge-green { background: #14532D; color: #4ADE80; }
    html.dark .badge-gray { background: #334155; color: #CBD5E1; }

    /* Actions : icônes uniquement */
    .action-buttons-crud {
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }
    .btn-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-muted);
        font-size: 1rem;
        transition: all 0.15s;
        cursor: pointer;
        text-decoration: none;
    }
    .btn-icon:hover {
        background: var(--bg);
        border-color: var(--text-muted);
        color: var(--text-primary);
    }
    .btn-icon-edit:hover {
        background: var(--warning-light);
        border-color: var(--warning);
        color: var(--warning);
    }
    .btn-icon-delete:hover {
        background: var(--danger-light);
        border-color: var(--danger);
        color: var(--danger);
    }
    .btn-icon.disabled {
        opacity: 0.5;
        cursor: not-allowed;
        pointer-events: none;
    }
    html.dark .btn-icon {
        border-color: #334155;
        color: #94A3B8;
    }
    html.dark .btn-icon:hover {
        background: #1E293B;
        border-color: #64748B;
        color: #F1F5F9;
    }
    html.dark .btn-icon-edit:hover {
        background: #713F12;
        border-color: #F59E0B;
        color: #FBBF24;
    }
    html.dark .btn-icon-delete:hover {
        background: #7F1D1D;
        border-color: #EF4444;
        color: #FCA5A5;
    }

    /* Bouton principal */
    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 1rem;
        border-radius: 40px;
        font-size: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        background-color: var(--accent);
        color: white;
        border: none;
        cursor: pointer;
        transition: all 0.15s;
    }
    .btn-primary:hover {
        background-color: #2563EB;
        transform: translateY(-1px);
    }

    /* Responsive */
    @media (max-width: 768px) {
        .r-table th, .r-table td { padding: 0.6rem 0.75rem; }
        .dept-desc { max-width: 140px; }
        .btn-icon { width: 28px; height: 28px; font-size: 0.875rem; }
        .action-buttons-crud { gap: 0.3rem; }
    }
    @media (max-width: 640px) {
        .action-buttons-crud { flex-wrap: wrap; }
    }
</style>
{% endblock %}