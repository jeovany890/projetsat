{% extends 'rssi/layout.html.twig' %}

{% block page_title %}Départements{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('rssi_departements_nouveau') }}" class="r-btn r-btn-primary">
        <i class="bi bi-plus-lg"></i> Nouveau département
    </a>
{% endblock %}

{% block content %}

{# ── Stats globales ── #}
{% set totalEmployes = 0 %}
{% set totalActifs = 0 %}
{% for d in departements %}
    {% set totalEmployes = totalEmployes + d.employes|length %}
    {% for e in d.employes %}
        {% if e.estActif %}{% set totalActifs = totalActifs + 1 %}{% endif %}
    {% endfor %}
{% endfor %}

<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px;">

    <div class="r-card" style="padding:20px;display:flex;align-items:center;gap:14px;">
        <div style="width:48px;height:48px;border-radius:12px;background:#DBEAFE;color:#1D4ED8;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">
            <i class="bi bi-diagram-3-fill"></i>
        </div>
        <div>
            <div style="font-size:26px;font-weight:800;color:#0F172A;line-height:1;">{{ departements|length }}</div>
            <div style="font-size:12px;color:#64748B;margin-top:2px;">Départements</div>
        </div>
    </div>

    <div class="r-card" style="padding:20px;display:flex;align-items:center;gap:14px;">
        <div style="width:48px;height:48px;border-radius:12px;background:#CFFAFE;color:#0891B2;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">
            <i class="bi bi-people-fill"></i>
        </div>
        <div>
            <div style="font-size:26px;font-weight:800;color:#0F172A;line-height:1;">{{ totalEmployes }}</div>
            <div style="font-size:12px;color:#64748B;margin-top:2px;">Employés au total</div>
        </div>
    </div>

    <div class="r-card" style="padding:20px;display:flex;align-items:center;gap:14px;">
        <div style="width:48px;height:48px;border-radius:12px;background:#DCFCE7;color:#166534;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">
            <i class="bi bi-person-check-fill"></i>
        </div>
        <div>
            <div style="font-size:26px;font-weight:800;color:#0F172A;line-height:1;">{{ totalActifs }}</div>
            <div style="font-size:12px;color:#64748B;margin-top:2px;">Employés actifs</div>
        </div>
    </div>

    <div class="r-card" style="padding:20px;display:flex;align-items:center;gap:14px;">
        <div style="width:48px;height:48px;border-radius:12px;background:#F1F5F9;color:#475569;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">
            <i class="bi bi-diagram-3"></i>
        </div>
        <div>
            <div style="font-size:26px;font-weight:800;color:#0F172A;line-height:1;">{{ departements|filter(d => d.employes|length > 0)|length }}</div>
            <div style="font-size:12px;color:#64748B;margin-top:2px;">Dép. avec employés</div>
        </div>
    </div>

</div>

{% if departements|length == 0 %}
<div class="r-card">
    <div class="r-card-body">
        <div class="r-empty">
            <i class="bi bi-diagram-3"></i>
            <p>Aucun département créé. Commencez par structurer votre organisation.</p>
            <a href="{{ path('rssi_departements_nouveau') }}" class="r-btn r-btn-primary">
                <i class="bi bi-plus-lg"></i> Créer le premier département
            </a>
        </div>
    </div>
</div>
{% else %}

{# ── Tableau des départements ── #}
<div class="r-card">
    <div class="r-card-header">
        <div class="r-card-title"><i class="bi bi-diagram-3-fill"></i> Vue d'ensemble</div>
        <span style="font-size:12px;color:#94A3B8;">{{ departements|length }} département(s)</span>
    </div>
    <table class="r-table">
        <thead>
            <tr>
                <th>Département</th>
                <th>Employés</th>
                <th>Actifs</th>
                <th>Score vigilance moyen</th>
                <th>Étoiles cumulées</th>
                <th>Risque</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for dept in departements %}
            {% set nbActifs = 0 %}
            {% set totalScore = 0 %}
            {% set nbAvecScore = 0 %}
            {% set totalEtoiles = 0 %}
            {% set nbRisque = 0 %}

            {% for e in dept.employes %}
                {% if e.estActif %}{% set nbActifs = nbActifs + 1 %}{% endif %}
                {% if e.totalPoints > 0 %}
                    {% set totalScore = totalScore + e.scoreVigilance %}
                    {% set nbAvecScore = nbAvecScore + 1 %}
                {% endif %}
                {% set totalEtoiles = totalEtoiles + e.totalEtoiles %}
                {% if e.scoreVigilance < 40 and e.totalPoints > 0 %}
                    {% set nbRisque = nbRisque + 1 %}
                {% endif %}
            {% endfor %}

            {% set scoreMoyen = nbAvecScore > 0 ? (totalScore / nbAvecScore)|round(1) : null %}
            {% set pct = nbActifs > 0 ? ((nbActifs / dept.employes|length) * 100)|round : 0 %}

            <tr>
                <td>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <div style="width:38px;height:38px;border-radius:10px;background:#CFFAFE;color:#0891B2;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;">
                            <i class="bi bi-diagram-3-fill"></i>
                        </div>
                        <div>
                            <div style="font-weight:700;color:#1E293B;">{{ dept.nom }}</div>
                            {% if dept.description %}
                                <div style="font-size:11px;color:#94A3B8;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ dept.description }}</div>
                            {% endif %}
                        </div>
                    </div>
                </td>
                <td>
                    <span style="font-weight:700;color:#0F172A;">{{ dept.employes|length }}</span>
                    <span style="font-size:11px;color:#94A3B8;margin-left:4px;">employé(s)</span>
                </td>
                <td>
                    {% if dept.employes|length > 0 %}
                    <div style="display:flex;align-items:center;gap:8px;">
                        <div style="width:60px;height:5px;background:#E2E8F0;border-radius:99px;overflow:hidden;">
                            <div style="height:100%;width:{{ pct }}%;background:#34D399;border-radius:99px;"></div>
                        </div>
                        <span style="font-size:12px;font-weight:600;color:#166534;">{{ nbActifs }}</span>
                    </div>
                    {% else %}
                        <span style="color:#CBD5E1;font-size:12px;">—</span>
                    {% endif %}
                </td>
                <td>
                    {% if scoreMoyen is not null %}
                        <div style="display:flex;align-items:center;gap:8px;">
                            <div style="width:60px;height:5px;background:#E2E8F0;border-radius:99px;overflow:hidden;">
                                <div style="height:100%;width:{{ scoreMoyen }}%;background:{% if scoreMoyen >= 60 %}#34D399{% elseif scoreMoyen >= 40 %}#FBBF24{% else %}#F87171{% endif %};border-radius:99px;"></div>
                            </div>
                            <span style="font-size:12px;font-weight:700;color:#475569;">{{ scoreMoyen }}%</span>
                        </div>
                    {% else %}
                        <span style="color:#CBD5E1;font-size:12px;font-style:italic;">Aucun quiz</span>
                    {% endif %}
                </td>
                <td>
                    <span style="color:#F59E0B;font-weight:700;">★ {{ totalEtoiles }}</span>
                </td>
                <td>
                    {% if nbRisque > 0 %}
                        <span class="r-badge r-badge-red">
                            <i class="bi bi-exclamation-triangle-fill"></i> {{ nbRisque }} à risque
                        </span>
                    {% elseif dept.employes|length == 0 %}
                        <span class="r-badge r-badge-gray">Vide</span>
                    {% else %}
                        <span class="r-badge r-badge-green"><i class="bi bi-check-circle-fill"></i> OK</span>
                    {% endif %}
                </td>
                <td>
                    <div style="display:flex;gap:6px;">
                        <a href="{{ path('rssi_employes_liste') }}?dept={{ dept.id }}" class="r-btn r-btn-ghost" style="padding:6px 10px;" title="Voir les employés">
                            <i class="bi bi-people"></i>
                        </a>
                        <a href="{{ path('rssi_departements_modifier', {id: dept.id}) }}" class="r-btn r-btn-ghost" style="padding:6px 10px;" title="Modifier">
                            <i class="bi bi-pencil"></i>
                        </a>
                        {% if dept.employes|length == 0 %}
                        <form method="post" action="{{ path('rssi_departements_supprimer', {id: dept.id}) }}"
                              onsubmit="return confirm('Supprimer « {{ dept.nom }} » ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('supprimer_dept_' ~ dept.id) }}">
                            <button type="submit" class="r-btn r-btn-danger" style="padding:6px 10px;" title="Supprimer">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                        {% else %}
                        <button class="r-btn r-btn-ghost" style="padding:6px 10px;opacity:0.3;cursor:not-allowed;" disabled title="Impossible : contient des employés">
                            <i class="bi bi-trash"></i>
                        </button>
                        {% endif %}
                    </div>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

{% endif %}
{% endblock %}
