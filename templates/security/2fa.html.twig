{% extends 'base.html.twig' %}

{% block title %}Vérification 2FA · SAT Platform{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Syne:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --font-display: 'Syne', sans-serif;
            --font-body: 'DM Sans', sans-serif;
            --green: #00E5A0;
            --red: #FF3B5C;
            --dark-bg: #060810;
            --dark-card: #0C0F1D;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: var(--font-body);
            background: var(--dark-bg);
            color: #e2e8f0;
            min-height: 100vh;
            transition: background 0.4s, color 0.4s;
        }
        h2 { font-family: var(--font-display); }

        /* ========== LIGHT MODE ========== */
        html.light body { background: #f8fafc; color: #1e293b; }
        html.light nav { background: rgba(255,255,255,0.7) !important; border-color: rgba(0,0,0,0.05) !important; }
        html.light .nav-white { color: #0f172a !important; }
        html.light .form-card { background: #fff !important; border-color: rgba(0,0,0,0.06) !important; box-shadow: 0 10px 40px rgba(0,0,0,0.04); }
        html.light .form-card h2 { color: #0f172a !important; }
        html.light .form-card p { color: #475569 !important; }
        html.light .alert-error { background: rgba(255,59,92,0.06); border-color: rgba(255,59,92,0.15); color: #dc2626; }
        html.light .alert-success { background: rgba(0,229,160,0.06); border-color: rgba(0,229,160,0.15); color: #166534; }

        /* ========== NAVBAR ========== */
        nav {
            position: fixed; top: 0; left: 0; width: 100%; z-index: 50;
            background: rgba(0,0,0,0.12); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255,255,255,0.05);
            transition: transform 0.4s, opacity 0.4s, background 0.3s;
        }
        .nav-hidden { transform: translateY(-100%); opacity: 0; pointer-events: none; }
        .nav-inner { max-width: 72rem; margin: 0 auto; padding: 0 1rem; height: 3.5rem; display: flex; align-items: center; justify-content: space-between; }
        .nav-logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
        .nav-logo-icon { width: 1.75rem; height: 1.75rem; border-radius: 0.5rem; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: center; color: var(--green); }
        .nav-logo-icon svg { width: 16px; height: 16px; }
        .nav-logo-text { line-height: 1; }
        .nav-logo-title { font-family: var(--font-display); font-weight: 600; font-size: 1rem; text-transform: uppercase; letter-spacing: -0.03em; }
        .nav-logo-sub { font-family: var(--font-display); font-weight: 500; font-size: 0.65rem; text-transform: uppercase; color: #64748b; }
        .nav-actions { display: flex; align-items: center; gap: 0.5rem; }
        .theme-btn { width: 2.25rem; height: 2.25rem; border-radius: 50%; border: 1px solid rgba(255,255,255,0.08); background: transparent; color: #94a3b8; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
        .theme-btn:hover { color: var(--green); border-color: rgba(0,229,160,0.3); }
        .theme-btn svg { width: 16px; height: 16px; }
        .btn-nav { background: rgba(0,229,160,0.1); color: var(--green); border: 1px solid rgba(0,229,160,0.2); padding: 0.35rem 0.75rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; text-decoration: none; transition: all 0.2s; }
        .btn-nav:hover { background: var(--green); color: #060810; }

        /* ========== MAIN ========== */
        .main-container {
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            padding: 5rem 1rem 2rem; position: relative; overflow: hidden;
        }
        .glow-left, .glow-right { position: absolute; pointer-events: none; border-radius: 50%; filter: blur(100px); opacity: 0.25; }
        .glow-left { width: 500px; height: 500px; background: rgba(0,229,160,0.08); top: -100px; left: -100px; }
        .glow-right { width: 400px; height: 400px; background: rgba(255,59,92,0.05); bottom: -100px; right: -100px; }

        /* ========== FORM CARD ========== */
        .form-card {
            max-width: 28rem; width: 100%; position: relative; z-index: 10;
            background: rgba(12,15,29,0.7); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            border-radius: 1.25rem; border: 1px solid rgba(255,255,255,0.04);
            padding: 2rem; animation: fadeUp 0.7s ease both;
        }
        @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
        @media (max-width: 480px) { .form-card { padding: 1.25rem; } }

        .form-icon { width: 3.5rem; height: 3.5rem; border-radius: 50%; background: rgba(0,229,160,0.06); border: 1px solid rgba(0,229,160,0.2); display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--green); }
        .form-icon svg { width: 24px; height: 24px; }
        .form-card h2 { font-size: 1.25rem; text-align: center; margin-bottom: 0.5rem; }
        .form-card .subtitle { font-size: 0.8125rem; color: #94a3b8; text-align: center; line-height: 1.5; margin-bottom: 0.25rem; }
        .form-card .email-highlight { font-weight: 600; color: var(--green); }
        .form-card .hint { font-size: 0.7rem; color: #64748b; text-align: center; margin-bottom: 1.25rem; }

        /* ========== ALERTS ========== */
        .alert { display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem; border-radius: 0.75rem; font-size: 0.75rem; font-weight: 500; margin-bottom: 1rem; }
        .alert svg { width: 18px; height: 18px; flex-shrink: 0; }
        .alert-error { background: rgba(255,59,92,0.06); border: 1px solid rgba(255,59,92,0.12); color: #f87171; }
        .alert-success { background: rgba(0,229,160,0.06); border: 1px solid rgba(0,229,160,0.12); color: var(--green); }

        /* ========== BUTTON ========== */
        .btn-submit {
            width: 100%; display: inline-flex; align-items: center; justify-content: center; gap: 0.4rem;
            padding: 0.7rem 1.25rem; border-radius: 999px; font-size: 0.8125rem; font-weight: 600;
            cursor: pointer; border: none; transition: all 0.2s; font-family: var(--font-body);
            background: var(--green); color: #060810; box-shadow: 0 4px 16px rgba(0,229,160,0.2);
        }
        .btn-submit:hover { background: #fff; transform: scale(1.02); }
        .btn-submit svg { width: 16px; height: 16px; }

        /* ========== FOOTER LINK ========== */
        .footer-link { display: block; text-align: center; margin-top: 1rem; font-size: 0.7rem; color: #64748b; text-decoration: none; transition: color 0.2s; }
        .footer-link:hover { color: var(--green); }

        /* ========== SVG ICONS ========== */
        .svg-icon { stroke: currentColor; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
    </style>
{% endblock %}

{% block body %}

<svg style="display:none;" xmlns="http://www.w3.org/2000/svg">
    <symbol id="svg-shield" viewBox="0 0 24 24" class="svg-icon"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></symbol>
    <symbol id="svg-mailbox" viewBox="0 0 24 24" class="svg-icon"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></symbol>
    <symbol id="svg-moon" viewBox="0 0 24 24" class="svg-icon"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></symbol>
    <symbol id="svg-sun" viewBox="0 0 24 24" class="svg-icon"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></symbol>
    <symbol id="svg-arrow-up-right" viewBox="0 0 24 24" class="svg-icon"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></symbol>
    <symbol id="svg-close-circle" viewBox="0 0 24 24" class="svg-icon"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></symbol>
    <symbol id="svg-check-circle" viewBox="0 0 24 24" class="svg-icon"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></symbol>
</svg>

<nav id="main-nav">
    <div class="nav-inner">
        <a href="{{ path('app_home') }}" class="nav-logo">
            <div class="nav-logo-icon"><svg><use href="#svg-shield"/></svg></div>
            <div class="nav-logo-text">
                <div class="nav-logo-title nav-white">SAT</div>
                <div class="nav-logo-sub">Platform</div>
            </div>
        </a>
        <div class="nav-actions">
            <button id="theme-toggle" class="theme-btn"><svg id="theme-icon"><use href="#svg-sun"/></svg></button>
            <span style="width:1px;height:1.25rem;background:rgba(255,255,255,0.08);"></span>
            <a href="{{ path('app_home') }}" class="btn-nav">Accueil</a>
        </div>
    </div>
</nav>

<main class="main-container">
    <div class="glow-left"></div>
    <div class="glow-right"></div>

    <div class="form-card">
        
        {% for msg in app.flashes('error') %}
            <div class="alert alert-error">
                <svg><use href="#svg-close-circle"/></svg>
                <span>{{ msg }}</span>
            </div>
        {% endfor %}
        {% for msg in app.flashes('success') %}
            <div class="alert alert-success">
                <svg><use href="#svg-check-circle"/></svg>
                <span>{{ msg }}</span>
            </div>
        {% endfor %}

        <div class="form-icon">
            <svg><use href="#svg-mailbox"/></svg>
        </div>
        <h2 class="nav-white">Vérification en deux étapes</h2>
        <p class="subtitle">
            Un lien de connexion a été envoyé à<br>
            <strong class="email-highlight">{{ email }}</strong>
        </p>
        <p class="hint">Vous n'avez pas reçu de lien ?</p>

        <form method="post" action="{{ path('app_2fa_renvoyer') }}">
            <button type="submit" class="btn-submit">
                <svg><use href="#svg-arrow-up-right"/></svg>
                Renvoyer le lien
            </button>
        </form>

        <a href="{{ path('app_logout') }}" class="footer-link">Se connecter</a>
    </div>
</main>

<script>
    let lastY = window.scrollY;
    const nav = document.getElementById('main-nav');
    window.addEventListener('scroll', () => {
        if (window.scrollY > lastY && window.scrollY > 80) nav.classList.add('nav-hidden');
        else nav.classList.remove('nav-hidden');
        lastY = window.scrollY;
    });

    const html = document.documentElement;
    const themeIcon = document.getElementById('theme-icon');
    function setTheme(t) {
        if (t === 'light') { html.classList.add('light'); themeIcon.innerHTML = '<use href="#svg-sun"/>'; }
        else { html.classList.remove('light'); themeIcon.innerHTML = '<use href="#svg-moon"/>'; }
    }
    setTheme(localStorage.getItem('sat-theme') || 'light');
    document.getElementById('theme-toggle').addEventListener('click', () => {
        const n = html.classList.contains('light') ? 'dark' : 'light';
        setTheme(n); localStorage.setItem('sat-theme', n);
    });
</script>
{% endblock %}