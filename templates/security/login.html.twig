{% extends 'base.html.twig' %}

{% block title %}Connexion · SAT Platform{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=Syne:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <style>
        :root { --font-display:'Syne',sans-serif; --font-body:'DM Sans',sans-serif; }
        
        /* GESTION DU THÈME & TRANSITIONS */
        body { font-family:var(--font-body); background-color:#060810; color:#e2e8f0; transition: all 0.4s ease-in-out; }
        
        /* Mode Clair Forcé */
        html.light body { background-color: #f8fafc; color: #1e293b; }
        html.light .bg-grid { background-image: linear-gradient(to right,rgba(0,0,0,.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(0,0,0,.05) 1px,transparent 1px); }
        
        /* Navbar Translucide & Smart Hide */
        nav { 
            background-color: rgba(0, 0, 0, 0.1) !important; 
            backdrop-blur: 24px !important; 
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease, background-color 0.3s ease !important; 
        }
        
        .nav-hidden { 
            transform: translateY(-100%); 
            opacity: 0; 
            pointer-events: none; 
        }

        html.light nav { background-color: rgba(255, 255, 255, 0.3) !important; border-color: rgba(0,0,0,0.05) !important; }
        html.light nav .text-white { color: #0f172a !important; }

        /* Synchronisation Carte GAUCHE */
        html.light .hero-card { background-color: rgba(255, 255, 255, 0.8) !important; border-color: rgba(0,0,0,0.05) !important; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.03); }
        html.light .hero-card h1 { color: #0f172a !important; }
        html.light .hero-card p, html.light .hero-card .stats-label { color: #64748b !important; }
        html.light .hero-card .stats-value { color: #0f172a !important; }
        html.light .hero-card .border-t { border-color: rgba(0,0,0,0.05) !important; }

        /* Synchronisation Carte DROITE */
        html.light .form-card { background-color: #ffffff !important; border-color: rgba(0,0,0,0.08) !important; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.06); }
        html.light .input-sat { background: #f1f5f9; border-color: #cbd5e1; color: #0f172a; }
        html.light .form-card h2 { color: #0f172a !important; }

        /* Styles de base */
        .bg-grid { background-size:40px 40px; background-image:linear-gradient(to right,rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,.03) 1px,transparent 1px); }
        .glow-emerald { background:radial-gradient(circle at center,rgba(0,229,160,.15) 0%,transparent 70%); }
        .glow-red { background:radial-gradient(circle at center,rgba(255,59,92,.1) 0%,transparent 70%); }
        .anim-fade-up { animation:fadeUp .7s cubic-bezier(.22,.68,0,1.2) both; }
        @keyframes fadeUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
        
        .input-sat { background: #0C0F1D; border: 1px solid rgba(255,255,255,0.07); color: #F9FAFB; border-radius: 1rem; padding: 0.75rem 1rem; width: 100%; transition: all 0.2s; }
        .input-sat:focus { border-color: #00E5A0; outline: none; box-shadow: 0 0 0 2px rgba(0,229,160,0.15); }
        
        .btn-primary-sat { background: #00E5A0; color: #060810; border-radius: 9999px; padding: 0.875rem 1.5rem; font-weight: 600; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; transition: all 0.2s; width: 100%; box-shadow: 0 8px 20px rgba(0,229,160,0.2); }
        .btn-primary-sat:hover { background: white; transform: scale(1.02); }

        .badge-register { background: rgba(0,229,160,0.1); color: #00E5A0; border: 1px solid rgba(0,229,160,0.2); padding: 0.5rem 1rem; border-radius: 9999px; font-size: 0.875rem; font-weight: 600; transition: all 0.3s; }
        .badge-register:hover { background: #00E5A0; color: #060810; }

        /* RÉINTÉGRATION DES STYLES D'ERREUR (Manquants dans le code 2) */
        .alert-sat { background: rgba(0,229,160,0.1); border: 1px solid rgba(0,229,160,0.2); border-radius: 1rem; padding: 1rem; display: flex; align-items: center; gap: 0.75rem; color: #e2e8f0; margin-bottom: 1.5rem; }
        .alert-sat-error { background: rgba(255,59,92,0.1); border-color: rgba(255,59,92,0.2); }
        html.light .alert-sat-error { background: rgba(255,59,92,0.1); color: #FF3B5C; }
        .alert-sat i { font-size: 1.25rem; color: #00E5A0; }
        .alert-sat-error i { color: #FF3B5C; }
    </style>
{% endblock %}

{% block body %}
<nav id="main-nav" class="fixed top-0 left-0 w-full z-50 border-b border-white/5">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <div class="flex items-center gap-6">
            <a href="{{ path('app_home') }}" class="flex items-center gap-2 group">
                <div class="w-8 h-8 rounded-lg bg-[#0C0F1D]/50 border border-white/10 flex items-center justify-center text-[#00E5A0] transition-all">
                    <iconify-icon icon="solar:shield-linear" width="20"></iconify-icon>
                </div>
                <div class="flex flex-col leading-none">
                    <span class="font-display font-semibold text-white tracking-tighter text-lg uppercase transition-colors">SAT</span>
                    <span class="font-display font-medium text-slate-500 tracking-tighter text-xs uppercase">Platform</span>
                </div>
            </a>
        </div>

        <div class="flex items-center gap-3">
            <button id="theme-toggle" class="w-10 h-10 rounded-full border border-white/10 text-slate-400 hover:text-[#00E5A0] hover:border-[#00E5A0]/50 transition-all flex items-center justify-center">
                <iconify-icon id="theme-icon" icon="solar:moon-stars-bold-duotone" width="20"></iconify-icon>
            </button>
            
            <span class="w-px h-6 bg-white/10"></span>

            <a href="{{ path('app_register') }}" class="badge-register">
                Créer un compte
            </a>
        </div>
    </div>
</nav>

<main class="min-h-screen flex items-center justify-center pt-28 pb-12 px-4 bg-grid relative overflow-hidden transition-colors duration-300">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] glow-emerald pointer-events-none opacity-40"></div>
    <div class="absolute bottom-0 right-0 w-[600px] h-[600px] glow-red pointer-events-none opacity-30"></div>

    <div class="max-w-6xl w-full relative z-10 flex flex-col lg:flex-row items-stretch gap-6 lg:gap-8">
        
        <div class="flex-1 flex flex-col justify-between p-8 lg:p-12 bg-[#0C0F1D]/60 backdrop-blur-md hero-card transition-all duration-300 rounded-3xl border border-white/5 shadow-xl">
            <div>
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 bg-[#060810]/80 mb-8 transition-all">
                    <span class="flex h-2 w-2 rounded-full bg-[#00E5A0]"></span>
                    <span class="text-[10px] font-bold text-slate-300 uppercase tracking-widest">Security Awareness Training</span>
                </div>
                <h1 class="font-display font-semibold text-4xl md:text-5xl text-white tracking-tight leading-tight mb-6 transition-colors">
                    Transformez vos employés en <span class="text-[#00E5A0]">bouclier humain</span>
                </h1>
                <p class="text-slate-400 text-lg max-w-md transition-colors">
                    Formations contextualisées et simulations de phishing pour les PME béninoises.
                </p>
            </div>

            <div class="grid grid-cols-3 gap-4 mt-12 pt-8 border-t border-white/5 transition-colors">
                <div>
                    <div class="font-display font-semibold text-2xl text-white stats-value">500+</div>
                    <div class="text-[10px] text-slate-500 uppercase font-bold tracking-wider stats-label">Employés</div>
                </div>
                <div>
                    <div class="font-display font-semibold text-2xl text-white stats-value">98%</div>
                    <div class="text-[10px] text-slate-500 uppercase font-bold tracking-wider stats-label">Réussite</div>
                </div>
                <div>
                    <div class="font-display font-semibold text-2xl text-white stats-value">24/7</div>
                    <div class="text-[10px] text-slate-500 uppercase font-bold tracking-wider stats-label">Support</div>
                </div>
            </div>
        </div>

        <div class="flex-1 flex flex-col justify-center p-8 lg:p-12 bg-[#0C0F1D] form-card transition-all duration-300 rounded-3xl border border-white/5 shadow-2xl">
            <div class="w-full max-w-sm mx-auto">
                
                {# Messages flash (succès/erreur depuis autres controllers) #}
                {% for msg in app.flashes('success') %}
                <div class="alert-sat" style="background:rgba(0,229,160,.12);border-color:rgba(0,229,160,.25);margin-bottom:1rem;">
                    <i class="bi bi-check-circle-fill" style="color:#00E5A0;font-size:1.1rem;"></i>
                    <span style="color:#00E5A0;">{{ msg }}</span>
                </div>
                {% endfor %}
                {% for msg in app.flashes('warning') %}
                <div class="alert-sat" style="background:rgba(245,158,11,.12);border-color:rgba(245,158,11,.25);margin-bottom:1rem;">
                    <i class="bi bi-exclamation-triangle-fill" style="color:#F59E0B;font-size:1.1rem;"></i>
                    <span style="color:#F59E0B;">{{ msg }}</span>
                </div>
                {% endfor %}
                {% for msg in app.flashes('error') %}
                <div class="alert-sat alert-sat-error" style="margin-bottom:1rem;">
                    <i class="bi bi-x-circle-fill" style="color:#FF3B5C;font-size:1.1rem;"></i>
                    <span>{{ msg }}</span>
                </div>
                {% endfor %}
                {# Erreur d'authentification Symfony #}
                {% if error %}
                    <div class="alert-sat alert-sat-error">
                        <iconify-icon icon="solar:close-circle-linear" width="20" class="text-[#FF3B5C]"></iconify-icon>
                        <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                    </div>
                {% endif %}

                <div class="text-center mb-10">
                    <h2 class="font-display font-semibold text-3xl text-white tracking-tight mb-2 transition-colors">Bon retour</h2>
                    <p class="text-slate-400 text-sm transition-colors">Accédez à votre tableau de bord</p>
                </div>

                <form method="post" class="space-y-5">
                    <div>
                        <label for="username" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 transition-colors">Adresse email</label>
                        <input type="email" id="username" name="_username" value="{{ last_username }}" required autofocus placeholder="nom@entreprise.bj" class="input-sat">
                    </div>

                    <div>
                        <div class="flex justify-between mb-2">
                            <label for="password" class="text-xs font-bold text-slate-400 uppercase tracking-wider transition-colors">Mot de passe</label>
                            <a href="{{ path('app_reset_password_request') }}" class="text-xs text-[#00E5A0] hover:underline">Oublié ?</a>
                        </div>
                        <div class="relative">
                            <input type="password" id="password" name="_password" required placeholder="••••••••" class="input-sat pr-12">
                            <button type="button" onclick="togglePasswordVisibility()" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 hover:text-[#00E5A0]">
                                <iconify-icon id="password-eye-icon" icon="solar:eye-linear" width="20"></iconify-icon>
                            </button>
                        </div>
                    </div>

                    {# RÉINTÉGRATION DU BOUTON SE SOUVENIR DE MOI #}
                    <div class="flex items-center text-sm mt-2">
                        <label class="flex items-center gap-2 cursor-pointer text-slate-400">
                            <input type="checkbox" name="_remember_me" class="w-4 h-4 rounded border-white/20 bg-[#060810] text-[#00E5A0] focus:ring-[#00E5A0]">
                            <span>Se souvenir de moi</span>
                        </label>
                    </div>

                    {# LE JETON CSRF MANQUANT EST ICI #}
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button type="submit" class="btn-primary-sat w-full mt-4">
                        Se connecter
                        <iconify-icon icon="solar:arrow-right-up-linear" width="18"></iconify-icon>
                    </button>

                    <div class="flex items-center gap-3 my-6">
                        <div class="flex-1 h-px bg-white/5 transition-colors"></div>
                        <span class="text-[10px] text-slate-600 uppercase font-bold">Nouveau ici ?</span>
                        <div class="flex-1 h-px bg-white/5 transition-colors"></div>
                    </div>

                    <a href="{{ path('app_register') }}" class="block text-center text-sm font-semibold text-slate-400 hover:text-[#00E5A0] transition-colors">
                        Inscrire mon entreprise
                    </a>
                </form>
            </div>
        </div>
    </div>
</main>

<script>
    // --- LOGIQUE DE LA NAVBAR (HIDE ON SCROLL) ---
    let lastScrollY = window.scrollY;
    const nav = document.getElementById('main-nav');

    window.addEventListener('scroll', () => {
        if (window.scrollY > lastScrollY && window.scrollY > 100) {
            nav.classList.add('nav-hidden');
        } else {
            nav.classList.remove('nav-hidden');
        }
        lastScrollY = window.scrollY;
    });

    // --- LOGIQUE DU THEME (CLAIR/SOMBRE) ---
    const themeBtn = document.getElementById('theme-toggle');
    const themeIcon = document.getElementById('theme-icon');
    const html = document.documentElement;

    function applyTheme(theme) {
        if (theme === 'light') {
            html.classList.add('light');
            themeIcon.setAttribute('icon', 'solar:sun-bold-duotone');
        } else {
            html.classList.remove('light');
            themeIcon.setAttribute('icon', 'solar:moon-stars-bold-duotone');
        }
    }

    const savedTheme = localStorage.getItem('sat-theme') || 'light';
    applyTheme(savedTheme);

    themeBtn.addEventListener('click', () => {
        const newTheme = html.classList.contains('light') ? 'dark' : 'light';
        applyTheme(newTheme);
        localStorage.setItem('sat-theme', newTheme);
    });

    // --- LOGIQUE DE L'OEIL MOT DE PASSE ---
    function togglePasswordVisibility() {
        const input = document.getElementById('password');
        const icon = document.getElementById('password-eye-icon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.setAttribute('icon', 'solar:eye-closed-linear');
        } else {
            input.type = 'password';
            icon.setAttribute('icon', 'solar:eye-linear');
        }
    }
</script>
{% endblock %}