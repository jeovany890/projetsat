{% extends 'base.html.twig' %}

{% block title %}Connexion - SAT Platform{% endblock %}

{% block body %}
<div style="min-height: 100vh; display: flex; background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%);">
    
    {# Partie gauche - Hero #}
    <div style="flex: 1; display: flex; align-items: center; justify-content: center; padding: var(--space-12);">
        <div style="max-width: 500px;">
            <div style="margin-bottom: var(--space-8);">
                <h1 style="font-size: var(--text-5xl); font-weight: var(--font-black); background: linear-gradient(135deg, var(--primary-600), var(--secondary-600)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: var(--space-4);">
                    SAT Platform
                </h1>
                <p style="font-size: var(--text-xl); color: var(--gray-600);">
                    Formation Cybersécurité & Audit de Conformité pour entreprises béninoises
                </p>
            </div>
            
            <div style="display: flex; gap: var(--space-6); margin-top: var(--space-8);">
                <div>
                    <div style="font-size: var(--text-3xl); font-weight: var(--font-bold); color: var(--primary-600);">500+</div>
                    <div style="color: var(--gray-600);">Employés formés</div>
                </div>
                <div>
                    <div style="font-size: var(--text-3xl); font-weight: var(--font-bold); color: var(--secondary-600);">98%</div>
                    <div style="color: var(--gray-600);">Taux de réussite</div>
                </div>
                <div>
                    <div style="font-size: var(--text-3xl); font-weight: var(--font-bold); color: var(--success);">24/7</div>
                    <div style="color: var(--gray-600);">Support disponible</div>
                </div>
            </div>
        </div>
    </div>

    {# Partie droite - Formulaire #}
    <div style="flex: 1; display: flex; align-items: center; justify-content: center; background: white; padding: var(--space-12); box-shadow: var(--shadow-2xl);">
        <div style="width: 100%; max-width: 450px;">
            
            {# Flashes #}
            {% for message in app.flashes('success') %}
                <div class="alert alert-success" style="margin-bottom: var(--space-6);">
                    <i class="bi bi-check-circle-fill alert-icon"></i>
                    <div class="alert-content">{{ message }}</div>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger" style="margin-bottom: var(--space-6);">
                    <i class="bi bi-x-circle-fill alert-icon"></i>
                    <div class="alert-content">{{ message }}</div>
                </div>
            {% endfor %}

            {% if error %}
                <div class="alert alert-danger" style="margin-bottom: var(--space-6);">
                    <i class="bi bi-x-circle-fill alert-icon"></i>
                    <div class="alert-content">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                </div>
            {% endif %}

            <div style="text-align: center; margin-bottom: var(--space-8);">
                <h2 style="font-size: var(--text-3xl); font-weight: var(--font-bold); color: var(--gray-900); margin-bottom: var(--space-2);">
                    Bon retour ! 👋
                </h2>
                <p style="color: var(--gray-600);">Connectez-vous pour accéder à votre espace</p>
            </div>

            <form method="post">
                <div class="form-group">
                    <label class="form-label" for="username">
                        <i class="bi bi-envelope"></i> Adresse email
                    </label>
                    <input 
                        type="email" 
                        class="form-control" 
                        id="username" 
                        name="_username" 
                        value="{{ last_username }}" 
                        required 
                        autofocus
                        placeholder="exemple@email.com"
                    >
                </div>

                <div class="form-group">
                    <label class="form-label" for="password">
                        <i class="bi bi-lock"></i> Mot de passe
                    </label>
                    <input 
                        type="password" 
                        class="form-control" 
                        id="password" 
                        name="_password" 
                        required
                        placeholder="••••••••"
                    >
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-6);">
                    <label style="display: flex; align-items: center; gap: var(--space-2); cursor: pointer;">
                        <input type="checkbox" name="_remember_me" style="width: 18px; height: 18px;">
                        <span style="font-size: var(--text-sm); color: var(--gray-600);">Se souvenir de moi</span>
                    </label>
                    <a href="{{ path('app_reset_password_request') }}" style="font-size: var(--text-sm); color: var(--primary-600); font-weight: var(--font-semibold);">
                        Mot de passe oublié ?
                    </a>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button type="submit" class="btn btn-primary btn-lg btn-block" style="margin-bottom: var(--space-4);">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Se connecter
                </button>

                <div style="text-align: center; color: var(--gray-600); font-size: var(--text-sm);">
                    Pas encore de compte ?
                    <a href="{{ path('app_register') }}" style="color: var(--primary-600); font-weight: var(--font-semibold);">
                        Inscrire votre entreprise
                    </a>
                </div>
            </form>

        </div>
    </div>

</div>
{% endblock %}