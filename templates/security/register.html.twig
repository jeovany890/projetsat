<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Inscription Entreprise · SAT Platform</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Syne:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <style>
        :root {
            --font-display: 'Syne', sans-serif;
            --font-body: 'DM Sans', sans-serif;
            --bg-dark: #060810;
            --bg-card: #0C0F1D;
            --text-white: #F9FAFB;
            --text-gray: #94a3b8;
            --text-slate: #64748b;
            --brand-green: #00E5A0;
            --border-light: rgba(255, 255, 255, 0.07);
            --border-medium: rgba(255, 255, 255, 0.1);
            --border-white-5: rgba(255, 255, 255, 0.05);
            --border-white-10: rgba(255, 255, 255, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--font-body);
            background-color: var(--bg-dark);
            color: #e2e8f0;
            transition: all 0.4s ease-in-out;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Mode Clair */
        html.light body {
            background-color: #f8fafc;
            color: #1e293b;
        }

        html.light .bg-grid {
            background-image: linear-gradient(to right, rgba(0,0,0,.05) 1px, transparent 1px),
                              linear-gradient(to bottom, rgba(0,0,0,.05) 1px, transparent 1px);
        }

        /* Navbar */
        nav {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 50;
            background-color: rgba(0, 0, 0, 0.1) !important;
            backdrop-filter: blur(24px) !important;
            -webkit-backdrop-filter: blur(24px) !important;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease, background-color 0.3s ease !important;
        }

        .nav-hidden {
            transform: translateY(-100%);
            opacity: 0;
            pointer-events: none;
        }

        html.light nav {
            background-color: rgba(255, 255, 255, 0.3) !important;
            border-color: rgba(0,0,0,0.05) !important;
        }

        .nav-container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 16px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        @media (min-width: 768px) {
            .nav-container {
                padding: 0 24px;
                height: 80px;
            }
        }

        .nav-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        @media (min-width: 768px) {
            .nav-left {
                gap: 24px;
            }
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .nav-logo-icon {
            width: 28px;
            height: 28px;
            border-radius: 8px;
            background: rgba(12, 15, 29, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--brand-green);
            transition: all 0.3s;
            flex-shrink: 0;
        }

        @media (min-width: 768px) {
            .nav-logo-icon {
                width: 32px;
                height: 32px;
            }
        }

        .nav-logo-text {
            display: flex;
            flex-direction: column;
            line-height: 1;
        }

        .nav-logo-title {
            font-family: var(--font-display);
            font-weight: 600;
            color: white;
            letter-spacing: -0.05em;
            font-size: 16px;
            text-transform: uppercase;
            transition: color 0.3s;
        }

        @media (min-width: 768px) {
            .nav-logo-title {
                font-size: 18px;
            }
        }

        .nav-logo-subtitle {
            font-family: var(--font-display);
            font-weight: 500;
            color: #64748b;
            letter-spacing: -0.05em;
            font-size: 10px;
            text-transform: uppercase;
        }

        @media (min-width: 768px) {
            .nav-logo-subtitle {
                font-size: 12px;
            }
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        @media (min-width: 768px) {
            .nav-right {
                gap: 12px;
            }
        }

        .theme-toggle {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 1px solid rgba(255, 255, 255, 0.1);
            background: transparent;
            color: #94a3b8;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            flex-shrink: 0;
        }

        @media (min-width: 768px) {
            .theme-toggle {
                width: 40px;
                height: 40px;
            }
        }

        .theme-toggle:hover {
            color: var(--brand-green);
            border-color: rgba(0, 229, 160, 0.5);
        }

        .nav-separator {
            width: 1px;
            height: 20px;
            background: rgba(255, 255, 255, 0.1);
        }

        @media (min-width: 768px) {
            .nav-separator {
                height: 24px;
            }
        }

        .nav-login-btn {
            background: rgba(0, 229, 160, 0.1);
            color: var(--brand-green);
            border: 1px solid rgba(0, 229, 160, 0.2);
            padding: 6px 12px;
            border-radius: 9999px;
            font-size: 12px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s;
            white-space: nowrap;
        }

        @media (min-width: 768px) {
            .nav-login-btn {
                padding: 8px 16px;
                font-size: 14px;
            }
        }

        .nav-login-btn:hover {
            background: var(--brand-green);
            color: #060810;
        }

        /* Main Content */
        main {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding-top: 80px;
            padding-bottom: 32px;
            padding-left: 12px;
            padding-right: 12px;
            position: relative;
            overflow: hidden;
            transition: color 0.3s;
        }

        @media (min-width: 768px) {
            main {
                padding-top: 112px;
                padding-bottom: 48px;
                padding-left: 16px;
                padding-right: 16px;
            }
        }

        .bg-grid {
            background-size: 40px 40px;
            background-image: linear-gradient(to right, rgba(255,255,255,.03) 1px, transparent 1px),
                              linear-gradient(to bottom, rgba(255,255,255,.03) 1px, transparent 1px);
            position: absolute;
            inset: 0;
            pointer-events: none;
        }

        .glow-emerald {
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 300px;
            height: 300px;
            background: radial-gradient(circle at center, rgba(0,229,160,.12) 0%, transparent 70%);
            pointer-events: none;
            opacity: 0.4;
        }

        @media (min-width: 768px) {
            .glow-emerald {
                width: 500px;
                height: 400px;
            }
        }

        @media (min-width: 1024px) {
            .glow-emerald {
                width: 800px;
                height: 600px;
            }
        }

        .glow-red {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle at center, rgba(255,59,92,.08) 0%, transparent 70%);
            pointer-events: none;
            opacity: 0.3;
        }

        @media (min-width: 768px) {
            .glow-red {
                width: 400px;
                height: 400px;
            }
        }

        @media (min-width: 1024px) {
            .glow-red {
                width: 600px;
                height: 600px;
            }
        }

        .content-wrapper {
            max-width: 1280px;
            width: 100%;
            position: relative;
            z-index: 10;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        @media (min-width: 1024px) {
            .content-wrapper {
                flex-direction: row;
                gap: 32px;
                align-items: stretch;
            }
        }

        /* Hero Card (Gauche) */
        .hero-card {
            padding: 24px;
            background: rgba(12, 15, 29, 0.6);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        @media (min-width: 768px) {
            .hero-card {
                padding: 32px;
                border-radius: 24px;
            }
        }

        @media (min-width: 1024px) {
            .hero-card {
                width: 41.666%;
                padding: 48px;
                justify-content: space-between;
            }
        }

        html.light .hero-card {
            background-color: rgba(255, 255, 255, 0.8) !important;
            border-color: rgba(0,0,0,0.05) !important;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.03);
        }

        html.light .hero-card h1 {
            color: #0f172a !important;
        }

        html.light .hero-card .hero-desc {
            color: #64748b !important;
        }

        html.light .hero-card .stats-label {
            color: #64748b !important;
        }

        html.light .hero-card .stats-value {
            color: #0f172a !important;
        }

        html.light .hero-card .stats-section {
            border-color: rgba(0,0,0,0.05) !important;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 12px;
            border-radius: 9999px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(6, 8, 16, 0.8);
            transition: all 0.3s;
            width: fit-content;
        }

        @media (min-width: 768px) {
            .hero-badge {
                padding: 8px 16px;
                margin-bottom: 32px;
            }
        }

        html.light .hero-badge {
            background-color: rgba(0,0,0,0.05) !important;
            border-color: rgba(0,0,0,0.1) !important;
            color: #475569 !important;
        }

        .hero-badge-dot {
            display: flex;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--brand-green);
        }

        @media (min-width: 768px) {
            .hero-badge-dot {
                width: 8px;
                height: 8px;
            }
        }

        .hero-badge-text {
            font-size: 10px;
            font-weight: 700;
            color: #cbd5e1;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        @media (min-width: 768px) {
            .hero-badge-text {
                font-size: 12px;
            }
        }

        .hero-title {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 24px;
            color: white;
            letter-spacing: -0.025em;
            line-height: 1.2;
            transition: color 0.3s;
        }

        @media (min-width: 768px) {
            .hero-title {
                font-size: 36px;
                margin-bottom: 24px;
            }
        }

        @media (min-width: 1024px) {
            .hero-title {
                font-size: 42px;
            }
        }

        .hero-title span {
            color: var(--brand-green);
        }

        .hero-desc {
            color: #94a3b8;
            font-size: 14px;
            transition: color 0.3s;
            margin-top: 12px;
        }

        @media (min-width: 768px) {
            .hero-desc {
                font-size: 16px;
            }
        }

        @media (min-width: 1024px) {
            .hero-desc {
                font-size: 18px;
            }
        }

        .stats-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            transition: border-color 0.3s;
        }

        @media (min-width: 768px) {
            .stats-section {
                gap: 16px;
                padding-top: 32px;
                margin-top: 48px;
            }
        }

        .stats-value {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 20px;
            color: white;
        }

        @media (min-width: 768px) {
            .stats-value {
                font-size: 24px;
            }
        }

        .stats-label {
            font-size: 10px;
            color: #64748b;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 0.1em;
        }

        @media (min-width: 768px) {
            .stats-label {
                font-size: 12px;
            }
        }

        /* Form Card (Droite) */
        .form-card {
            padding: 20px;
            background: #0C0F1D;
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
        }

        @media (min-width: 768px) {
            .form-card {
                padding: 32px;
                border-radius: 24px;
            }
        }

        @media (min-width: 1024px) {
            .form-card {
                width: 58.333%;
                padding: 48px;
            }
        }

        html.light .form-card {
            background-color: #ffffff !important;
            border-color: rgba(0,0,0,0.08) !important;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.06);
        }

        html.light .form-card h2 {
            color: #0f172a !important;
        }

        html.light .form-card .form-subtitle {
            color: #64748b !important;
        }

        html.light .form-card label {
            color: #64748b !important;
        }

        .form-header {
            text-align: center;
            margin-bottom: 24px;
        }

        @media (min-width: 768px) {
            .form-header {
                margin-bottom: 40px;
            }
        }

        .form-title {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 22px;
            color: white;
            letter-spacing: -0.025em;
            margin-bottom: 4px;
            transition: color 0.3s;
        }

        @media (min-width: 768px) {
            .form-title {
                font-size: 26px;
                margin-bottom: 8px;
            }
        }

        @media (min-width: 1024px) {
            .form-title {
                font-size: 30px;
            }
        }

        .form-subtitle {
            color: #94a3b8;
            font-size: 12px;
            transition: color 0.3s;
        }

        @media (min-width: 768px) {
            .form-subtitle {
                font-size: 14px;
            }
        }

        /* Alert */
        .alert-error {
            margin-bottom: 20px;
            padding: 12px;
            border-radius: 12px;
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            display: flex;
            align-items: flex-start;
            gap: 8px;
            color: #f87171;
            font-size: 12px;
            font-weight: 500;
        }

        @media (min-width: 768px) {
            .alert-error {
                margin-bottom: 32px;
                padding: 16px;
                border-radius: 16px;
                gap: 12px;
                font-size: 14px;
            }
        }

        .alert-error iconify-icon {
            font-size: 16px;
            margin-top: 2px;
            flex-shrink: 0;
        }

        @media (min-width: 768px) {
            .alert-error iconify-icon {
                font-size: 20px;
            }
        }

        /* Stepper */
        .stepper {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
            position: relative;
            max-width: 100%;
            width: 100%;
        }

        @media (min-width: 768px) {
            .stepper {
                max-width: 384px;
                margin-left: auto;
                margin-right: auto;
                margin-bottom: 40px;
            }
        }

        .stepper-line {
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 100%;
            height: 1px;
            background: rgba(255, 255, 255, 0.1);
            z-index: 0;
            transition: background-color 0.3s;
        }

        html.light .stepper-line {
            background-color: rgba(0,0,0,0.1) !important;
        }

        .stepper-step {
            position: relative;
            z-index: 10;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            padding: 0 8px;
            flex: 1;
        }

        @media (min-width: 768px) {
            .stepper-step {
                padding: 0 12px;
                gap: 8px;
            }
        }

        .stepper-bg {
            background-color: #0C0F1D;
            transition: background-color 0.4s ease;
        }

        html.light .stepper-bg {
            background-color: #ffffff !important;
        }

        .step-circle {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            transition: all 0.3s;
            flex-shrink: 0;
        }

        @media (min-width: 768px) {
            .step-circle {
                width: 32px;
                height: 32px;
                font-size: 12px;
            }
        }

        .step-active {
            background: var(--brand-green);
            color: #060810;
            box-shadow: 0 0 15px rgba(0, 229, 160, 0.3);
            border: none;
        }

        .step-inactive {
            background: #060810;
            color: #64748b;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        html.light .step-inactive {
            background: #f1f5f9 !important;
            border-color: #cbd5e1 !important;
            color: #94a3b8 !important;
        }

        .step-label {
            font-size: 9px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            transition: color 0.3s;
            text-align: center;
            white-space: nowrap;
        }

        @media (min-width: 768px) {
            .step-label {
                font-size: 12px;
                letter-spacing: 0.1em;
            }
        }

        .step-text-active {
            color: white;
        }

        .step-text-inactive {
            color: #64748b;
        }

        html.light .step-text-active {
            color: #0f172a !important;
        }

        html.light .step-text-inactive {
            color: #94a3b8 !important;
        }

        /* Wizard Steps */
        .wizard-step {
            display: none;
            flex: 1;
        }

        .wizard-step.active {
            display: flex;
            flex-direction: column;
        }

        .form-grid {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-bottom: 24px;
            flex: 1;
        }

        @media (min-width: 768px) {
            .form-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 20px;
                margin-bottom: 32px;
            }
            
            .form-grid .col-span-2 {
                grid-column: span 2;
            }
        }

        .form-group {
            display: flex;
            flex-direction: column;
            width: 100%;
        }

        .form-label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 6px;
            transition: color 0.3s;
        }

        @media (min-width: 768px) {
            .form-label {
                font-size: 12px;
                letter-spacing: 0.1em;
                margin-bottom: 8px;
            }
        }

        .form-label .required {
            color: var(--brand-green);
        }

        .input-sat {
            background: #060810;
            border: 1px solid rgba(255, 255, 255, 0.07);
            color: #F9FAFB;
            border-radius: 12px;
            padding: 10px 14px;
            width: 100%;
            transition: all 0.2s;
            font-size: 13px;
            font-family: var(--font-body);
            outline: none;
        }

        @media (min-width: 768px) {
            .input-sat {
                border-radius: 16px;
                padding: 12px 16px;
                font-size: 14px;
            }
        }

        .input-sat:focus {
            border-color: var(--brand-green);
            box-shadow: 0 0 0 2px rgba(0, 229, 160, 0.15);
        }

        html.light .input-sat {
            background: #f1f5f9;
            border-color: #cbd5e1;
            color: #0f172a;
        }

        select.input-sat {
            appearance: none;
            -webkit-appearance: none;
            padding-right: 36px;
            cursor: pointer;
        }

        @media (min-width: 768px) {
            select.input-sat {
                padding-right: 40px;
            }
        }

        .select-wrapper {
            position: relative;
        }

        .select-wrapper .select-icon {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            pointer-events: none;
            color: #94a3b8;
        }

        @media (min-width: 768px) {
            .select-wrapper .select-icon {
                right: 16px;
            }
        }

        /* Boutons */
        .btn-primary {
            background: var(--brand-green);
            color: #060810;
            border-radius: 9999px;
            padding: 12px 20px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            transition: all 0.2s;
            box-shadow: 0 8px 20px rgba(0, 229, 160, 0.2);
            border: none;
            cursor: pointer;
            font-size: 13px;
            font-family: var(--font-body);
            text-decoration: none;
            width: 100%;
        }

        @media (min-width: 768px) {
            .btn-primary {
                padding: 14px 24px;
                font-size: 14px;
                gap: 8px;
                width: auto;
            }
        }

        .btn-primary:hover {
            background: white;
            transform: scale(1.02);
        }

        .btn-secondary {
            background: transparent;
            color: #94a3b8;
            border-radius: 9999px;
            padding: 12px 20px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            transition: all 0.2s;
            border: 1px solid rgba(255, 255, 255, 0.1);
            cursor: pointer;
            font-size: 13px;
            font-family: var(--font-body);
            width: 100%;
        }

        @media (min-width: 768px) {
            .btn-secondary {
                padding: 14px 24px;
                font-size: 14px;
                gap: 8px;
                width: auto;
            }
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #F9FAFB;
        }

        html.light .btn-secondary {
            border-color: #cbd5e1;
            color: #64748b;
        }

        html.light .btn-secondary:hover {
            background: #f1f5f9;
            color: #0f172a;
        }

        .btn-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: auto;
        }

        @media (min-width: 768px) {
            .btn-group {
                flex-direction: row;
                justify-content: space-between;
                align-items: center;
                gap: 16px;
            }
        }

        .btn-group-right {
            align-items: flex-end;
        }

        @media (min-width: 768px) {
            .btn-group-right {
                justify-content: flex-end;
            }
        }

        /* Step 3 Validation */
        .validation-icon {
            width: 60px;
            height: 60px;
            background: rgba(0, 229, 160, 0.1);
            color: var(--brand-green);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            border: 1px solid rgba(0, 229, 160, 0.2);
        }

        @media (min-width: 768px) {
            .validation-icon {
                width: 80px;
                height: 80px;
                margin-bottom: 24px;
            }
        }

        .validation-icon iconify-icon {
            font-size: 30px;
        }

        @media (min-width: 768px) {
            .validation-icon iconify-icon {
                font-size: 40px;
            }
        }

        .validation-title {
            font-size: 18px;
            font-family: var(--font-display);
            font-weight: 600;
            color: white;
            margin-bottom: 8px;
            text-align: center;
            transition: color 0.3s;
        }

        @media (min-width: 768px) {
            .validation-title {
                font-size: 20px;
            }
        }

        .validation-desc {
            color: #94a3b8;
            font-size: 12px;
            max-width: 100%;
            margin: 0 auto;
            text-align: center;
            transition: color 0.3s;
        }

        @media (min-width: 768px) {
            .validation-desc {
                font-size: 14px;
                max-width: 384px;
            }
        }

        .validation-content {
            text-align: center;
            margin-bottom: 24px;
            flex: 1;
        }

        @media (min-width: 768px) {
            .validation-content {
                margin-bottom: 40px;
            }
        }

        /* Masquer les éléments sur mobile si nécessaire */
        @media (max-width: 767px) {
            .hide-mobile {
                display: none;
            }
        }
    </style>
</head>
<body>
    <nav id="main-nav">
        <div class="nav-container">
            <div class="nav-left">
                <a href="/" class="nav-logo">
                    <div class="nav-logo-icon">
                        <iconify-icon icon="solar:shield-linear" width="18" height="18"></iconify-icon>
                    </div>
                    <div class="nav-logo-text">
                        <span class="nav-logo-title">SAT</span>
                        <span class="nav-logo-subtitle">Platform</span>
                    </div>
                </a>
            </div>

            <div class="nav-right">
                <button id="theme-toggle" class="theme-toggle">
                    <iconify-icon id="theme-icon" icon="solar:moon-stars-bold-duotone" width="18" height="18"></iconify-icon>
                </button>
                
                <span class="nav-separator hide-mobile"></span>

                <a href="/login" class="nav-login-btn">
                    Se connecter
                </a>
            </div>
        </div>
    </nav>

    <main>
        <div class="bg-grid"></div>
        <div class="glow-emerald"></div>
        <div class="glow-red"></div>

        <div class="content-wrapper">
            <!-- Hero Card -->
            <div class="hero-card">
                <div>
                    <div class="hero-badge">
                        <span class="hero-badge-dot"></span>
                        <span class="hero-badge-text">Programme SAT</span>
                    </div>
                    <h1 class="hero-title">
                        Sécurisez l'avenir de votre <span>entreprise</span>
                    </h1>
                    <p class="hero-desc">
                        Rejoignez les entreprises béninoises qui transforment leurs employés en première ligne de défense contre les cyberattaques.
                    </p>
                </div>

                <div class="stats-section">
                    <div>
                        <div class="stats-value">3</div>
                        <div class="stats-label">Étapes simples</div>
                    </div>
                    <div>
                        <div class="stats-value">100%</div>
                        <div class="stats-label">Sécurisé</div>
                    </div>
                </div>
            </div>

            <!-- Form Card -->
            <div class="form-card">
                <div class="form-header">
                    <h2 class="form-title">Inscription</h2>
                    <p class="form-subtitle">Remplissez les informations de votre structure</p>
                </div>

                <div class="alert-error" style="display: none;" id="alert-error">
                    <iconify-icon icon="solar:danger-circle-linear" width="18" height="18"></iconify-icon>
                    <div id="alert-message"></div>
                </div>

                <div class="stepper">
                    <div class="stepper-line"></div>
                    
                    <div class="stepper-step stepper-bg" id="indicator-1">
                        <div class="step-circle step-active indicator-circle">1</div>
                        <span class="step-label step-text-active indicator-text">Entreprise</span>
                    </div>
                    
                    <div class="stepper-step stepper-bg" id="indicator-2">
                        <div class="step-circle step-inactive indicator-circle">2</div>
                        <span class="step-label step-text-inactive indicator-text">RSSI</span>
                    </div>
                    
                    <div class="stepper-step stepper-bg" id="indicator-3">
                        <div class="step-circle step-inactive indicator-circle">3</div>
                        <span class="step-label step-text-inactive indicator-text">Validation</span>
                    </div>
                </div>

                <form method="post" action="/register" id="wizard-form" novalidate style="flex: 1; display: flex; flex-direction: column;">
                    
                    <!-- Step 1 -->
                    <div id="step-1" class="wizard-step active">
                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label" for="entreprise_nom">
                                    Nom de l'entreprise <span class="required">*</span>
                                </label>
                                <input type="text" id="entreprise_nom" name="entreprise_nom" required placeholder="Ex: TechSolutions SARL" class="input-sat">
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="ifu">
                                    Numéro IFU <span class="required">*</span>
                                </label>
                                <input type="text" id="ifu" name="ifu" required placeholder="3202301234567" maxlength="13" class="input-sat">
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="rccm">
                                    Numéro RCCM <span class="required">*</span>
                                </label>
                                <input type="text" id="rccm" name="rccm" required placeholder="RB/COT/23/A/123" class="input-sat">
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="secteur">
                                    Secteur d'activité <span class="required">*</span>
                                </label>
                                <div class="select-wrapper">
                                    <select id="secteur" name="secteur" required class="input-sat">
                                        <option value="">Sélectionnez...</option>
                                        <option value="Technologie">Technologie</option>
                                        <option value="Finance">Finance</option>
                                        <option value="Commerce">Commerce</option>
                                        <option value="Industrie">Industrie</option>
                                        <option value="Services">Services</option>
                                        <option value="Santé">Santé</option>
                                        <option value="Éducation">Éducation</option>
                                        <option value="Autre">Autre</option>
                                    </select>
                                    <span class="select-icon">
                                        <iconify-icon icon="solar:alt-arrow-down-linear" width="14" height="14"></iconify-icon>
                                    </span>
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="nombre_employes">
                                    Nombre d'employés <span class="required">*</span>
                                </label>
                                <input type="number" id="nombre_employes" name="nombre_employes" required min="1" placeholder="Ex: 25" class="input-sat">
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="email_entreprise">
                                    Email entreprise <span class="required">*</span>
                                </label>
                                <input type="email" id="email_entreprise" name="email_entreprise" required placeholder="contact@entreprise.bj" class="input-sat">
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="telephone_entreprise">
                                    Téléphone
                                </label>
                                <input type="tel" id="telephone_entreprise" name="telephone_entreprise" required placeholder="+229 01 XX XX XX XX" class="input-sat">
                            </div>
                        </div>

                        <div class="btn-group btn-group-right">
                            <button type="button" onclick="nextStep(2)" class="btn-primary">
                                Étape suivante
                                <iconify-icon icon="solar:arrow-right-linear" width="16" height="16"></iconify-icon>
                            </button>
                        </div>
                    </div>

                    <!-- Step 2 -->
                    <div id="step-2" class="wizard-step">
                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label" for="prenom_rssi">
                                    Prénom du RSSI <span class="required">*</span>
                                </label>
                                <input type="text" id="prenom_rssi" name="prenom_rssi" required placeholder="Jean" class="input-sat">
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="nom_rssi">
                                    Nom du RSSI <span class="required">*</span>
                                </label>
                                <input type="text" id="nom_rssi" name="nom_rssi" required placeholder="KPOSSA" class="input-sat">
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="email_rssi">
                                    Email professionnel (RSSI) <span class="required">*</span>
                                </label>
                                <input type="email" id="email_rssi" name="email_rssi" required placeholder="jean.kpossa@entreprise.bj" class="input-sat">
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="telephone_rssi">
                                    Téléphone
                                </label>
                                <input type="tel" id="telephone_rssi" name="telephone_rssi" placeholder="+229 XX XX XX XX" class="input-sat">
                            </div>
                        </div>

                        <div class="btn-group">
                            <button type="button" onclick="prevStep(1)" class="btn-secondary">
                                <iconify-icon icon="solar:arrow-left-linear" width="16" height="16"></iconify-icon>
                                Retour
                            </button>
                            <button type="button" onclick="nextStep(3)" class="btn-primary">
                                Étape suivante
                                <iconify-icon icon="solar:arrow-right-linear" width="16" height="16"></iconify-icon>
                            </button>
                        </div>
                    </div>

                    <!-- Step 3 -->
                    <div id="step-3" class="wizard-step">
                        <div class="validation-content">
                            <div class="validation-icon">
                                <iconify-icon icon="solar:shield-check-linear" width="30" height="30"></iconify-icon>
                            </div>
                            <h3 class="validation-title">Prêt à soumettre ?</h3>
                            <p class="validation-desc">
                                Votre demande sera examinée par notre équipe technique. Un email de confirmation contenant les instructions d'accès sera envoyé au Responsable Sécurité sous 48h.
                            </p>
                        </div>

                        <div class="btn-group">
                            <button type="button" onclick="prevStep(2)" class="btn-secondary">
                                <iconify-icon icon="solar:arrow-left-linear" width="16" height="16"></iconify-icon>
                                Modifier
                            </button>
                            <button type="submit" class="btn-primary">
                                <iconify-icon icon="solar:check-read-linear" width="16" height="16"></iconify-icon>
                                Confirmer et soumettre
                            </button>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </main>

    <script>
        // --- LOGIQUE DE LA NAVBAR (HIDE ON SCROLL) ---
        let lastScrollY = window.scrollY;
        const nav = document.getElementById('main-nav');

        window.addEventListener('scroll', () => {
            if (window.scrollY > lastScrollY && window.scrollY > 100) {
                nav.classList.add('nav-hidden');
            } else {
                nav.classList.remove('nav-hidden');
            }
            lastScrollY = window.scrollY;
        });

        // --- GESTION DU THÈME ---
        const themeBtn = document.getElementById('theme-toggle');
        const themeIcon = document.getElementById('theme-icon');
        const html = document.documentElement;

        function applyTheme(theme) {
            if (theme === 'light') {
                html.classList.add('light');
                themeIcon.setAttribute('icon', 'solar:sun-bold-duotone');
            } else {
                html.classList.remove('light');
                themeIcon.setAttribute('icon', 'solar:moon-stars-bold-duotone');
            }
        }

        const savedTheme = localStorage.getItem('sat-theme') || 'dark';
        applyTheme(savedTheme);

        themeBtn.addEventListener('click', () => {
            const newTheme = html.classList.contains('light') ? 'dark' : 'light';
            applyTheme(newTheme);
            localStorage.setItem('sat-theme', newTheme);
        });

        // --- LOGIQUE DU WIZARD ---
        function nextStep(step) {
            const currentStepDiv = document.querySelector('.wizard-step.active');
            const inputs = currentStepDiv.querySelectorAll('input, select, textarea');
            let valid = true;
            
            inputs.forEach(input => {
                if(!input.checkValidity()) {
                    input.reportValidity();
                    valid = false;
                }
            });
            
            if(valid) showStep(step);
        }

        function prevStep(step) {
            showStep(step);
        }

        function showStep(step) {
            document.querySelectorAll('.wizard-step').forEach(el => {
                el.classList.remove('active');
            });
            
            const current = document.getElementById('step-' + step);
            current.classList.add('active');
            
            for(let i = 1; i <= 3; i++) {
                const indicator = document.getElementById('indicator-' + i);
                const circle = indicator.querySelector('.indicator-circle');
                const text = indicator.querySelector('.indicator-text');
                
                if (i < step) {
                    circle.className = 'step-circle step-active indicator-circle';
                    circle.innerHTML = '<iconify-icon icon="solar:check-read-linear" width="12" height="12"></iconify-icon>';
                    text.className = 'step-label step-text-active indicator-text';
                } else if (i === step) {
                    circle.className = 'step-circle step-active indicator-circle';
                    circle.innerHTML = i;
                    text.className = 'step-label step-text-active indicator-text';
                } else {
                    circle.className = 'step-circle step-inactive indicator-circle';
                    circle.innerHTML = i;
                    text.className = 'step-label step-text-inactive indicator-text';
                }
            }
        }

        function showError(message) {
            const alert = document.getElementById('alert-error');
            const alertMessage = document.getElementById('alert-message');
            alertMessage.textContent = message;
            alert.style.display = 'flex';
        }
    </script>
</body>
</html>