{% extends 'base.html.twig' %}

{% block title %}Inscription Entreprise · SAT Platform{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Syne:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <style>
        :root { --font-display:'Syne',sans-serif; --font-body:'DM Sans',sans-serif; }
        
        /* GESTION DU THÈME & TRANSITIONS */
        body { font-family:var(--font-body); background-color:#060810; color:#e2e8f0; transition: all 0.4s ease-in-out; }
        
        /* Mode Clair Forcé */
        html.light body { background-color: #f8fafc; color: #1e293b; }
        html.light .bg-grid { background-image: linear-gradient(to right,rgba(0,0,0,.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(0,0,0,.05) 1px,transparent 1px); }
        
        /* Navbar Translucide & Smart Hide */
        nav { 
            background-color: rgba(0, 0, 0, 0.1) !important; 
            backdrop-blur: 24px !important; 
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease, background-color 0.3s ease !important; 
        }
        .nav-hidden { transform: translateY(-100%); opacity: 0; pointer-events: none; }
        html.light nav { background-color: rgba(255, 255, 255, 0.3) !important; border-color: rgba(0,0,0,0.05) !important; }
        html.light nav .text-white { color: #0f172a !important; }

        /* Synchronisation Carte GAUCHE */
        html.light .hero-card { background-color: rgba(255, 255, 255, 0.8) !important; border-color: rgba(0,0,0,0.05) !important; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.03); }
        html.light .hero-card h1 { color: #0f172a !important; }
        html.light .hero-card p, html.light .hero-card .stats-label { color: #64748b !important; }
        html.light .hero-card .stats-value { color: #0f172a !important; }
        html.light .hero-card .border-t { border-color: rgba(0,0,0,0.05) !important; }
        html.light .hero-badge { background-color: rgba(0,0,0,0.05) !important; border-color: rgba(0,0,0,0.1) !important; color: #475569 !important; }

        /* Synchronisation Carte DROITE */
        html.light .form-card { background-color: #ffffff !important; border-color: rgba(0,0,0,0.08) !important; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.06); }
        html.light .input-sat { background: #f1f5f9; border-color: #cbd5e1; color: #0f172a; }
        html.light .form-card h2 { color: #0f172a !important; }
        html.light .form-card label { color: #64748b !important; }
        
        /* Stepper Sync */
        .stepper-bg { background-color: #0C0F1D; transition: background-color 0.4s ease; }
        html.light .stepper-bg { background-color: #ffffff !important; }
        html.light .stepper-line { background-color: rgba(0,0,0,0.1) !important; }
        html.light .step-inactive { background: #f1f5f9 !important; border-color: #cbd5e1 !important; color: #94a3b8 !important; }
        html.light .step-text-inactive { color: #94a3b8 !important; }
        html.light .step-text-active { color: #0f172a !important; }

        /* Styles de base */
        .bg-grid { background-size:40px 40px; background-image:linear-gradient(to right,rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,.03) 1px,transparent 1px); }
        .glow-emerald { background:radial-gradient(circle at center,rgba(0,229,160,.12) 0%,transparent 70%); }
        .glow-red { background:radial-gradient(circle at center,rgba(255,59,92,.08) 0%,transparent 70%); }
        
        .input-sat { background: #060810; border: 1px solid rgba(255,255,255,0.07); color: #F9FAFB; border-radius: 1rem; padding: 0.75rem 1rem; width: 100%; transition: all 0.2s; font-size: 0.875rem; }
        .input-sat:focus { border-color: #00E5A0; outline: none; box-shadow: 0 0 0 2px rgba(0,229,160,0.15); }
        select.input-sat { appearance: none; padding-right: 2.5rem; }
        
        .btn-primary-sat { background: #00E5A0; color: #060810; border-radius: 9999px; padding: 0.875rem 1.5rem; font-weight: 600; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; transition: all 0.2s; box-shadow: 0 8px 20px rgba(0,229,160,0.2); }
        .btn-primary-sat:hover { background: white; transform: scale(1.02); }

        .btn-secondary-sat { background: transparent; color: #94a3b8; border-radius: 9999px; padding: 0.875rem 1.5rem; font-weight: 600; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; transition: all 0.2s; border: 1px solid rgba(255,255,255,0.1); }
        .btn-secondary-sat:hover { background: rgba(255,255,255,0.05); color: #F9FAFB; }
        html.light .btn-secondary-sat { border-color: #cbd5e1; color: #64748b; }
        html.light .btn-secondary-sat:hover { background: #f1f5f9; color: #0f172a; }

        .badge-register { background: rgba(0,229,160,0.1); color: #00E5A0; border: 1px solid rgba(0,229,160,0.2); padding: 0.5rem 1rem; border-radius: 9999px; font-size: 0.875rem; font-weight: 600; transition: all 0.3s; }
        .badge-register:hover { background: #00E5A0; color: #060810; }
        
        /* Utilities */
        .step-active { background: #00E5A0; color: #060810; box-shadow: 0 0 15px rgba(0,229,160,0.3); border-color: #00E5A0; }
        .step-inactive { background: #060810; color: #64748b; border: 1px solid rgba(255,255,255,0.1); }
    </style>
{% endblock %}

{% block body %}
<nav id="main-nav" class="fixed top-0 left-0 w-full z-50 border-b border-white/5">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <div class="flex items-center gap-6">
            <a href="{{ path('app_home') }}" class="flex items-center gap-2 group">
                <div class="w-8 h-8 rounded-lg bg-[#0C0F1D]/50 border border-white/10 flex items-center justify-center text-[#00E5A0] transition-all">
                    <iconify-icon icon="solar:shield-linear" stroke-width="1.5" class="text-xl"></iconify-icon>
                </div>
                <div class="flex flex-col leading-none">
                    <span class="font-display font-semibold text-white tracking-tighter text-lg uppercase transition-colors">SAT</span>
                    <span class="font-display font-medium text-slate-500 tracking-tighter text-xs uppercase">Platform</span>
                </div>
            </a>
        </div>

        <div class="flex items-center gap-3">
            <button id="theme-toggle" class="w-10 h-10 rounded-full border border-white/10 text-slate-400 hover:text-[#00E5A0] hover:border-[#00E5A0]/50 transition-all flex items-center justify-center">
                <iconify-icon id="theme-icon" icon="solar:moon-stars-bold-duotone" class="text-xl"></iconify-icon>
            </button>
            
            <span class="w-px h-6 bg-white/10"></span>

            <a href="{{ path('app_login') }}" class="badge-register">
                Se connecter
            </a>
        </div>
    </div>
</nav>

<main class="min-h-screen flex items-center justify-center pt-28 pb-12 px-4 bg-grid relative overflow-hidden transition-colors duration-300">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] glow-emerald pointer-events-none opacity-40"></div>
    <div class="absolute bottom-0 right-0 w-[600px] h-[600px] glow-red pointer-events-none opacity-30"></div>

    <div class="max-w-7xl w-full relative z-10 flex flex-col lg:flex-row items-stretch gap-6 lg:gap-8">
        
        <div class="lg:w-5/12 flex flex-col justify-between p-8 lg:p-12 bg-[#0C0F1D]/60 backdrop-blur-md hero-card transition-all duration-300 rounded-3xl border border-white/5 shadow-xl">
            <div>
                <div class="hero-badge inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 bg-[#060810]/80 mb-8 transition-all">
                    <span class="flex h-2 w-2 rounded-full bg-[#00E5A0]"></span>
                    <span class="text-xs font-bold text-slate-300 uppercase tracking-wider">Programme SAT</span>
                </div>
                <h1 class="font-display font-semibold text-4xl md:text-5xl text-white tracking-tight leading-tight mb-6 transition-colors">
                    Sécurisez l'avenir de votre <span class="text-[#00E5A0]">entreprise</span>
                </h1>
                <p class="text-slate-400 text-lg transition-colors">
                    Rejoignez les entreprises béninoises qui transforment leurs employés en première ligne de défense contre les cyberattaques.
                </p>
            </div>

            <div class="grid grid-cols-2 gap-4 mt-12 pt-8 border-t border-white/5 transition-colors">
                <div>
                    <div class="font-display font-semibold text-2xl text-white stats-value">3</div>
                    <div class="text-xs text-slate-500 uppercase font-bold tracking-wider stats-label">Étapes simples</div>
                </div>
                <div>
                    <div class="font-display font-semibold text-2xl text-white stats-value">100%</div>
                    <div class="text-xs text-slate-500 uppercase font-bold tracking-wider stats-label">Sécurisé</div>
                </div>
            </div>
        </div>

        <div class="lg:w-7/12 flex flex-col p-8 lg:p-12 bg-[#0C0F1D] form-card transition-all duration-300 rounded-3xl border border-white/5 shadow-2xl">
            
            <div class="text-center mb-10">
                <h2 class="font-display font-semibold text-3xl text-white tracking-tight mb-2 transition-colors">Inscription</h2>
                <p class="text-slate-400 text-sm transition-colors">Remplissez les informations de votre structure</p>
            </div>

            {% for message in app.flashes('error') %}
                <div class="mb-8 p-4 rounded-2xl bg-red-500/10 border border-red-500/20 flex items-start gap-3 text-red-400 text-sm font-medium">
                    <iconify-icon icon="solar:danger-circle-linear" stroke-width="1.5" class="text-xl mt-0.5 shrink-0"></iconify-icon>
                    <div>{{ message }}</div>
                </div>
            {% endfor %}

            <div class="flex items-center justify-between mb-10 relative max-w-sm mx-auto w-full">
                <div class="absolute left-0 top-1/2 -translate-y-1/2 w-full h-px bg-white/10 z-0 stepper-line transition-colors"></div>
                
                <div class="relative z-10 flex flex-col items-center gap-2 px-3 stepper-bg indicator-wrapper" id="indicator-1">
                    <div class="indicator-circle w-8 h-8 rounded-full step-active flex items-center justify-center text-xs font-bold transition-all">1</div>
                    <span class="indicator-text text-xs font-bold uppercase tracking-wider text-white transition-colors step-text-active">Entreprise</span>
                </div>
                
                <div class="relative z-10 flex flex-col items-center gap-2 px-3 stepper-bg indicator-wrapper" id="indicator-2">
                    <div class="indicator-circle w-8 h-8 rounded-full step-inactive flex items-center justify-center text-xs font-bold transition-all">2</div>
                    <span class="indicator-text text-xs font-bold uppercase tracking-wider text-slate-500 transition-colors step-text-inactive">RSSI</span>
                </div>
                
                <div class="relative z-10 flex flex-col items-center gap-2 px-3 stepper-bg indicator-wrapper" id="indicator-3">
                    <div class="indicator-circle w-8 h-8 rounded-full step-inactive flex items-center justify-center text-xs font-bold transition-all">3</div>
                    <span class="indicator-text text-xs font-bold uppercase tracking-wider text-slate-500 transition-colors step-text-inactive">Validation</span>
                </div>
            </div>

            <form method="post" action="{{ path('app_register') }}" id="wizard-form" novalidate class="flex-1 flex flex-col">
                
                <div id="step-1" class="wizard-step block flex-1">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-8">
                        <div class="md:col-span-2">
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 transition-colors" for="entreprise_nom">
                                Nom de l'entreprise <span class="text-[#00E5A0]">*</span>
                            </label>
                            <input type="text" id="entreprise_nom" name="entreprise_nom" required placeholder="Ex: TechSolutions SARL" class="input-sat">
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 transition-colors" for="ifu">
                                Numéro IFU <span class="text-[#00E5A0]">*</span>
                            </label>
                            <input type="text" id="ifu" name="ifu" required placeholder="3202301234567" maxlength="13" class="input-sat">
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 transition-colors" for="rccm">
                                Numéro RCCM <span class="text-[#00E5A0]">*</span>
                            </label>
                            <input type="text" id="rccm" name="rccm" required placeholder="RB/COT/23/A/123" class="input-sat">
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 transition-colors" for="secteur">
                                Secteur d'activité <span class="text-[#00E5A0]">*</span>
                            </label>
                            <div class="relative">
                                <select id="secteur" name="secteur" required class="input-sat cursor-pointer">
                                    <option value="" class="bg-[#0C0F1D] text-white">Sélectionnez...</option>
                                    <option value="Technologie" class="bg-[#0C0F1D] text-white">Technologie</option>
                                    <option value="Finance" class="bg-[#0C0F1D] text-white">Finance</option>
                                    <option value="Commerce" class="bg-[#0C0F1D] text-white">Commerce</option>
                                    <option value="Industrie" class="bg-[#0C0F1D] text-white">Industrie</option>
                                    <option value="Services" class="bg-[#0C0F1D] text-white">Services</option>
                                    <option value="Santé" class="bg-[#0C0F1D] text-white">Santé</option>
                                    <option value="Éducation" class="bg-[#0C0F1D] text-white">Éducation</option>
                                    <option value="Autre" class="bg-[#0C0F1D] text-white">Autre</option>
                                </select>
                                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-slate-400">
                                    <iconify-icon icon="solar:alt-arrow-down-linear" stroke-width="1.5"></iconify-icon>
                                </div>
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 transition-colors" for="nombre_employes">
                                Nombre d'employés <span class="text-[#00E5A0]">*</span>
                            </label>
                            <input type="number" id="nombre_employes" name="nombre_employes" required min="1" placeholder="Ex: 25" class="input-sat">
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 transition-colors" for="email_entreprise">
                                Email entreprise <span class="text-[#00E5A0]">*</span>
                            </label>
                            <input type="email" id="email_entreprise" name="email_entreprise" required placeholder="contact@entreprise.bj" class="input-sat">
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 transition-colors" for="telephone_entreprise">
                                Téléphone <span class="text-[#00E5A0]"></span>
                            </label>
                            <input type="tel" id="telephone_entreprise" name="telephone_entreprise" required placeholder="+229 01 XX XX XX XX" class="input-sat">
                        </div>
                    </div>

                    <div class="mt-auto flex justify-end">
                        <button type="button" onclick="nextStep(2)" class="btn-primary-sat w-full md:w-auto">
                            Étape suivante
                            <iconify-icon icon="solar:arrow-right-linear" stroke-width="1.5" class="text-lg"></iconify-icon>
                        </button>
                    </div>
                </div>

                <div id="step-2" class="wizard-step hidden flex-1">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-8">
                        <div>
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 transition-colors" for="prenom_rssi">
                                Prénom du RSSI <span class="text-[#00E5A0]">*</span>
                            </label>
                            <input type="text" id="prenom_rssi" name="prenom_rssi" required placeholder="Jean" class="input-sat">
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 transition-colors" for="nom_rssi">
                                Nom du RSSI <span class="text-[#00E5A0]">*</span>
                            </label>
                            <input type="text" id="nom_rssi" name="nom_rssi" required placeholder="KPOSSA" class="input-sat">
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 transition-colors" for="email_rssi">
                                Email professionnel (RSSI) <span class="text-[#00E5A0]">*</span>
                            </label>
                            <input type="email" id="email_rssi" name="email_rssi" required placeholder="jean.kpossa@entreprise.bj" class="input-sat">
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 transition-colors" for="telephone_rssi">
                                Téléphone 
                            </label>
                            <input type="tel" id="telephone_rssi" name="telephone_rssi" placeholder="+229 XX XX XX XX" class="input-sat">
                        </div>
                    </div>

                    <div class="mt-auto flex flex-col-reverse md:flex-row justify-between items-center gap-4">
                        <button type="button" onclick="prevStep(1)" class="btn-secondary-sat w-full md:w-auto">
                            <iconify-icon icon="solar:arrow-left-linear" stroke-width="1.5" class="text-lg"></iconify-icon>
                            Retour
                        </button>
                        <button type="button" onclick="nextStep(3)" class="btn-primary-sat w-full md:w-auto">
                            Étape suivante
                            <iconify-icon icon="solar:arrow-right-linear" stroke-width="1.5" class="text-lg"></iconify-icon>
                        </button>
                    </div>
                </div>

                <div id="step-3" class="wizard-step hidden flex-1">
                    <div class="mb-10 text-center">
                        <div class="w-20 h-20 bg-[#00E5A0]/10 text-[#00E5A0] rounded-full flex items-center justify-center mx-auto mb-6 border border-[#00E5A0]/20">
                            <iconify-icon icon="solar:shield-check-linear" stroke-width="1.5" class="text-4xl"></iconify-icon>
                        </div>
                        <h3 class="text-xl font-display font-semibold text-white mb-2 transition-colors">Prêt à soumettre ?</h3>
                        <p class="text-slate-400 text-sm max-w-sm mx-auto transition-colors">
                            Votre demande sera examinée par notre équipe technique. Un email de confirmation contenant les instructions d'accès sera envoyé au Responsable Sécurité sous 48h.
                        </p>
                    </div>

                    <div class="mt-auto flex flex-col-reverse md:flex-row justify-between items-center gap-4">
                        <button type="button" onclick="prevStep(2)" class="btn-secondary-sat w-full md:w-auto">
                            <iconify-icon icon="solar:arrow-left-linear" stroke-width="1.5" class="text-lg"></iconify-icon>
                            Modifier
                        </button>
                        <button type="submit" class="btn-primary-sat w-full md:w-auto">
                            <iconify-icon icon="solar:check-read-linear" stroke-width="1.5" class="text-lg"></iconify-icon>
                            Confirmer et soumettre
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</main>

<script>
    // --- LOGIQUE DE LA NAVBAR (HIDE ON SCROLL) ---
    let lastScrollY = window.scrollY;
    const nav = document.getElementById('main-nav');

    window.addEventListener('scroll', () => {
        if (window.scrollY > lastScrollY && window.scrollY > 100) {
            nav.classList.add('nav-hidden');
        } else {
            nav.classList.remove('nav-hidden');
        }
        lastScrollY = window.scrollY;
    });

    // --- GESTION DU THÈME ---
    const themeBtn = document.getElementById('theme-toggle');
    const themeIcon = document.getElementById('theme-icon');
    const html = document.documentElement;

    function applyTheme(theme) {
        if (theme === 'light') {
            html.classList.add('light');
            themeIcon.setAttribute('icon', 'solar:sun-bold-duotone');
        } else {
            html.classList.remove('light');
            themeIcon.setAttribute('icon', 'solar:moon-stars-bold-duotone');
        }
    }

    const savedTheme = localStorage.getItem('sat-theme') || 'dark';
    applyTheme(savedTheme);

    themeBtn.addEventListener('click', () => {
        const newTheme = html.classList.contains('light') ? 'dark' : 'light';
        applyTheme(newTheme);
        localStorage.setItem('sat-theme', newTheme);
    });

    // --- LOGIQUE DU WIZARD ---
    function nextStep(step) {
        const currentStepDiv = document.querySelector('.wizard-step.block');
        const inputs = currentStepDiv.querySelectorAll('input, select, textarea');
        let valid = true;
        
        inputs.forEach(input => {
            if(!input.checkValidity()) {
                input.reportValidity();
                valid = false;
            }
        });
        
        if(valid) showStep(step);
    }

    function prevStep(step) {
        showStep(step);
    }

    function showStep(step) {
        // Cacher toutes les étapes
        document.querySelectorAll('.wizard-step').forEach(el => {
            el.classList.remove('block');
            el.classList.add('hidden');
        });
        
        // Afficher l'étape cible
        const current = document.getElementById('step-' + step);
        current.classList.remove('hidden');
        current.classList.add('block');
        current.classList.add('flex-1');
        
        // Mettre à jour le Stepper
        for(let i = 1; i <= 3; i++) {
            const indicator = document.getElementById('indicator-' + i);
            const circle = indicator.querySelector('.indicator-circle');
            const text = indicator.querySelector('.indicator-text');
            
            if (i < step) {
                // Complété
                circle.className = "indicator-circle w-8 h-8 rounded-full step-active flex items-center justify-center text-xs font-bold transition-all";
                circle.innerHTML = '<iconify-icon icon="solar:check-read-linear" stroke-width="1.5" class="text-sm"></iconify-icon>';
                text.className = "indicator-text text-xs font-bold uppercase tracking-wider text-white transition-colors step-text-active";
            } else if (i === step) {
                // Actuel
                circle.className = "indicator-circle w-8 h-8 rounded-full step-active flex items-center justify-center text-xs font-bold transition-all";
                circle.innerHTML = i;
                text.className = "indicator-text text-xs font-bold uppercase tracking-wider text-white transition-colors step-text-active";
            } else {
                // À venir
                circle.className = "indicator-circle w-8 h-8 rounded-full step-inactive flex items-center justify-center text-xs font-bold transition-all";
                circle.innerHTML = i;
                text.className = "indicator-text text-xs font-bold uppercase tracking-wider text-slate-500 transition-colors step-text-inactive";
            }
        }
    }
</script>
{% endblock %}