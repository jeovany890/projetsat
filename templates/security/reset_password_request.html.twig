{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - SAT Platform{% endblock %}

{% block body %}
<div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%); padding: var(--space-6);">
    
    <div class="card" style="width: 100%; max-width: 500px;">
        <div class="card-body" style="padding: var(--space-10);">
            
            <div style="text-align: center; margin-bottom: var(--space-8);">
                <div style="display: inline-flex; align-items: center; justify-content: center; width: 80px; height: 80px; background: var(--warning-light); border-radius: var(--radius-full); margin-bottom: var(--space-4);">
                    <i class="bi bi-key" style="font-size: var(--text-4xl); color: var(--warning);"></i>
                </div>
                <h2 style="font-size: var(--text-3xl); font-weight: var(--font-bold); color: var(--gray-900); margin-bottom: var(--space-2);">
                    Mot de passe oublié ?
                </h2>
                <p style="color: var(--gray-600);">
                    Entrez votre adresse email pour recevoir un lien de réinitialisation
                </p>
            </div>

            {# Flashes #}
            {% for message in app.flashes('success') %}
                <div class="alert alert-success" style="margin-bottom: var(--space-6);">
                    <i class="bi bi-check-circle-fill alert-icon"></i>
                    <div class="alert-content">{{ message }}</div>
                </div>
            {% endfor %}

            <form method="post">
                
                <div class="form-group">
                    <label class="form-label" for="email">
                        <i class="bi bi-envelope"></i> Adresse email
                    </label>
                    <input 
                        type="email" 
                        class="form-control" 
                        id="email" 
                        name="email" 
                        required
                        placeholder="exemple@email.com"
                        autofocus
                    >
                </div>

                <button type="submit" class="btn btn-primary btn-lg btn-block">
                    <i class="bi bi-send"></i>
                    Envoyer le lien de réinitialisation
                </button>

                <div style="text-align: center; margin-top: var(--space-6);">
                    <a href="{{ path('app_login') }}" style="color: var(--gray-600); font-size: var(--text-sm); display: inline-flex; align-items: center; gap: var(--space-2);">
                        <i class="bi bi-arrow-left"></i>
                        Retour à la connexion
                    </a>
                </div>

            </form>

        </div>
    </div>

</div>
{% endblock %}