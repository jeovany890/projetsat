{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - SAT Platform{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Syne:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <style>
        :root {
            --sat-green: #00f09a; /* Ton vert spécifique */
            --sat-bg-input: #eef4ff; /* Ton bleu très pâle */
            --sat-text-gray: #64748b;
            --sat-dark: #1e293b;
        }

        .page-bg {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background-color: #f8fafc;
            background-image: 
                linear-gradient(to right, #e2e8f0 1px, transparent 1px),
                linear-gradient(to bottom, #e2e8f0 1px, transparent 1px);
            background-size: 50px 50px;
        }

        /* NAVBAR SUBTILE AVEC BLUR ET FOND BLANC LÉGER */
        .sat-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 4rem;
            background-color: rgba(255, 255, 255, 0.5) !important; /* Blanc subtil */
            backdrop-filter: blur(20px) !important; /* Effet de flou pro */
            border-bottom: 1px solid rgba(0,0,0,0.05);
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .btn-outline {
            border: 1px solid #e2e8f0;
            padding: 10px 24px;
            border-radius: 14px;
            text-decoration: none;
            color: var(--sat-green);
            background: white;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.3s;
        }
        .btn-outline:hover {
            border-color: var(--sat-green);
            box-shadow: 0 4px 12px rgba(0,240,154,0.1);
        }

        .form-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .auth-card {
            background: white;
            width: 100%;
            max-width: 520px;
            padding: 4rem;
            border-radius: 40px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.05);
        }

        /* ICÔNE "PRO" : BOÎTE VITRÉE AVEC ICÔNE LINEAR */
        .icon-box {
            background-color: rgba(0, 240, 154, 0.08); /* Fond vert très léger */
            width: 72px;
            height: 72px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem;
            border: 1px solid rgba(0, 240, 154, 0.2);
            backdrop-filter: blur(10px);
        }

        .form-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .form-header h1 {
            font-size: 2.25rem;
            font-weight: 700;
            color: var(--sat-dark);
            margin-bottom: 0.75rem;
            letter-spacing: -1px;
        }

        .form-header p {
            color: var(--sat-text-gray);
            font-size: 16px;
            line-height: 1.6;
        }

        .input-wrapper {
            margin-bottom: 2rem;
        }

        .input-label {
            font-size: 12px;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            margin-bottom: 10px;
            display: block;
            letter-spacing: 0.8px;
        }

        .form-input {
            width: 100%;
            padding: 1.15rem 1.75rem;
            background-color: var(--sat-bg-input);
            border: 2px solid transparent;
            border-radius: 18px;
            font-size: 16px;
            color: var(--sat-dark);
            transition: all 0.3s ease;
        }

        .form-input:focus {
            background-color: white;
            border-color: var(--sat-green);
            outline: none;
            box-shadow: 0 0 0 5px rgba(0, 240, 154, 0.1);
            transform: translateY(-2px);
        }

        .btn-submit {
            width: 100%;
            padding: 1.15rem;
            background-color: var(--sat-green);
            color: #000;
            border: none;
            border-radius: 100px;
            font-weight: 700;
            font-size: 17px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            transition: all 0.3s;
        }

        .btn-submit:hover {
            transform: scale(1.02);
            box-shadow: 0 10px 20px rgba(0,240,154,0.2);
        }

        .footer-links {
            text-align: center;
            margin-top: 2.5rem;
        }

        .link-back {
            color: var(--sat-green);
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
        }
        .link-back:hover {
            gap: 12px; /* Effet pro au survol */
        }
    </style>

<div class="page-bg">
    <nav class="sat-nav">
        <div class="nav-logo">
            <div style="background: #334155; padding: 10px; border-radius: 12px;">
                <iconify-icon icon="solar:shield-check-linear" width="20" style="color: var(--sat-green);"></iconify-icon>
            </div>
            <div>
                <span style="display: block; font-weight: 800; line-height: 1;">SAT</span>
                <span style="font-size: 10px; color: #94a3b8; font-weight: 600;">PLATFORM</span>
            </div>
        </div>
        <a href="{{ path('app_register') }}" class="btn-outline">Créer un compte</a>
    </nav>

    <div class="form-container">
        <div class="auth-card">
            <div class="form-header">
                <div class="icon-box">
                    <iconify-icon icon="solar:user-block-linear" width="32" style="color: var(--sat-green);"></iconify-icon>
                </div>
                <h1>Mots de passe oubliés</h1>
                <p>Entrez votre email pour recevoir un lien de récupération sécurisé.</p>
            </div>

            <form method="post">
                <div class="input-wrapper">
                    <label class="input-label" for="email">Adresse email professionnelle</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        class="form-input" 
                        placeholder="votre@email.com" 
                        required 
                        autofocus
                    >
                </div>

                <button type="submit" class="btn-submit">
                    Envoyer le lien <iconify-icon icon="solar:alt-arrow-right-linear" width="22"></iconify-icon>
                </button>

                <div class="footer-links">
                    <a href="{{ path('app_login') }}" class="link-back">
                        <iconify-icon icon="solar:alt-arrow-left-linear" width="18"></iconify-icon> Retour à la connexion
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}