{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe - SAT Platform{% endblock %}

{% block body %}
<style>
    /* * Définition stricte des couleurs (Thème Clair uniquement).
     * L'utilisation de codes hexadécimaux fixes empêche le navigateur 
     * d'appliquer un mode sombre automatique.
     */
    :root {
        --bg-light-start: #f3f4f6; /* Gris très clair */
        --bg-light-end: #e5e7eb;   /* Gris clair */
        --card-bg: #ffffff;
        --text-dark: #111827;
        --text-muted: #4b5563;
        --primary-blue: #0d6efd; 
        --primary-hover: #0b5ed7;
        --border-light: #d1d5db;
        --error-bg: #fee2e2;
        --error-text: #991b1b;
        --error-border: #f87171;
    }

    .auth-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--bg-light-start) 0%, var(--bg-light-end) 100%);
        padding: 1.5rem;
    }

    .auth-card {
        background-color: var(--card-bg);
        width: 100%;
        max-width: 500px;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05); /* Ombre douce pour le relief en thème clair */
        border: 1px solid var(--border-light);
    }

    .auth-card-body {
        padding: 2.5rem;
    }

    .auth-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .auth-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 0.5rem;
    }

    .auth-subtitle {
        color: var(--text-muted);
    }

    .alert-danger {
        background-color: var(--error-bg);
        color: var(--error-text);
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
        border: 1px solid var(--error-border);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        color: var(--text-dark);
        font-weight: 500;
        margin-bottom: 0.5rem;
        display: block;
    }

    .form-control {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid var(--border-light);
        border-radius: 8px;
        background-color: #fff;
        color: var(--text-dark);
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-control:focus {
        border-color: var(--primary-blue);
        outline: none;
        box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.25);
    }

    .btn-primary {
        width: 100%;
        padding: 0.875rem;
        background-color: var(--primary-blue);
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-primary:hover {
        background-color: var(--primary-hover);
    }
</style>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-card-body">
            
            <div class="auth-header">
                <h2 class="auth-title">Nouveau mot de passe</h2>
                <p class="auth-subtitle">Choisissez un nouveau mot de passe sécurisé</p>
            </div>

            {# Gestion des messages d'erreur #}
            {% for message in app.flashes('error') %}
                <div class="alert-danger">
                    <i class="bi bi-x-circle-fill"></i>
                    <div>{{ message }}</div>
                </div>
            {% endfor %}

            <form method="post">
                
                <div class="form-group">
                    <label class="form-label" for="password">
                        <i class="bi bi-lock"></i> Nouveau mot de passe
                    </label>
                    <input 
                        type="password" 
                        class="form-control" 
                        id="password" 
                        name="password" 
                        required
                        minlength="8"
                        placeholder="Au moins 8 caractères"
                    >
                </div>

                <div class="form-group">
                    <label class="form-label" for="password_confirm">
                        <i class="bi bi-lock-fill"></i> Confirmer le mot de passe
                    </label>
                    <input 
                        type="password" 
                        class="form-control" 
                        id="password_confirm" 
                        name="password_confirm" 
                        required
                        minlength="8"
                        placeholder="Retapez votre mot de passe"
                    >
                </div>

                <button type="submit" class="btn-primary">
                    <i class="bi bi-check-circle"></i>
                    Réinitialiser mon mot de passe
                </button>

            </form>
        </div>
    </div>
</div>
{% endblock %}