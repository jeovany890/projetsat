{% extends 'base.html.twig' %}

{% block title %}Activation de compte - SAT Platform{% endblock %}

{% block body %}
<div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%); padding: var(--space-6);">
    
    <div class="card" style="width: 100%; max-width: 500px;">
        <div class="card-body" style="padding: var(--space-10);">
            
            <div style="text-align: center; margin-bottom: var(--space-8);">
                <div style="display: inline-flex; align-items: center; justify-content: center; width: 80px; height: 80px; background: linear-gradient(135deg, var(--primary-600), var(--secondary-600)); border-radius: var(--radius-full); margin-bottom: var(--space-4);">
                    <i class="bi bi-shield-check" style="font-size: var(--text-4xl); color: white;"></i>
                </div>
                <h2 style="font-size: var(--text-3xl); font-weight: var(--font-bold); color: var(--gray-900); margin-bottom: var(--space-2);">
                    Activez votre compte
                </h2>
                <p style="color: var(--gray-600);">
                    Bienvenue <strong>{{ rssi.prenom }} {{ rssi.nom }}</strong> !<br>
                    Créez votre mot de passe pour accéder à votre espace RSSI.
                </p>
            </div>

            {# Flashes #}
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger" style="margin-bottom: var(--space-6);">
                    <i class="bi bi-x-circle-fill alert-icon"></i>
                    <div class="alert-content">{{ message }}</div>
                </div>
            {% endfor %}

            <form method="post">
                
                <div class="form-group">
                    <label class="form-label" for="password">
                        <i class="bi bi-lock"></i> Nouveau mot de passe
                    </label>
                    <input 
                        type="password" 
                        class="form-control" 
                        id="password" 
                        name="password" 
                        required
                        minlength="8"
                        placeholder="Au moins 8 caractères"
                    >
                    <small style="color: var(--gray-500); font-size: var(--text-xs); margin-top: var(--space-1); display: block;">
                        Utilisez au moins 8 caractères avec des lettres et des chiffres
                    </small>
                </div>

                <div class="form-group">
                    <label class="form-label" for="password_confirm">
                        <i class="bi bi-lock-fill"></i> Confirmer le mot de passe
                    </label>
                    <input 
                        type="password" 
                        class="form-control" 
                        id="password_confirm" 
                        name="password_confirm" 
                        required
                        minlength="8"
                        placeholder="Retapez votre mot de passe"
                    >
                </div>

                <button type="submit" class="btn btn-primary btn-lg btn-block">
                    <i class="bi bi-check-circle"></i>
                    Activer mon compte
                </button>

            </form>

        </div>
    </div>

</div>
{% endblock %}