{% extends 'employe/layout.html.twig' %}
{% block page_title %}Simulation : {{ module.simulationTitre }}{% endblock %}

{% block body %}
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>{{ module.simulationTitre }}</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
*{margin:0;padding:0;box-sizing:border-box;}

/* ══════════════════════════════════════════════
   GMAIL
══════════════════════════════════════════════ */
{% if type == 'GMAIL' %}
html,body{height:100%;overflow:hidden;background:#f6f8fc;font-family:'Google Sans',Roboto,Arial,sans-serif;color:#202124;font-size:14px;}

.gm-top{position:fixed;top:0;left:0;right:0;height:64px;background:#f6f8fc;display:flex;align-items:center;padding:0 8px;gap:4px;z-index:300;border-bottom:1px solid transparent;}
.gm-hamburger{width:48px;height:48px;border-radius:50%;border:none;background:transparent;cursor:pointer;color:#444746;font-size:18px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.gm-hamburger:hover{background:#e8eaed;}
.gm-logo{display:flex;align-items:center;gap:2px;text-decoration:none;padding:0 8px;flex-shrink:0;}
.gm-logo-svg{width:110px;height:40px;}
.gm-search{flex:1;max-width:720px;height:46px;background:#eaf1fb;border-radius:24px;display:flex;align-items:center;padding:0 16px 0 20px;gap:8px;margin:0 8px;}
.gm-search i{color:#444746;font-size:18px;}
.gm-search input{flex:1;border:none;background:transparent;outline:none;font-size:16px;color:#202124;font-family:inherit;}
.gm-search input::placeholder{color:#444746;}
.gm-right{display:flex;align-items:center;gap:4px;margin-left:auto;flex-shrink:0;}
.gm-icon-btn{width:40px;height:40px;border-radius:50%;border:none;background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#444746;font-size:18px;}
.gm-icon-btn:hover{background:#e8eaed;}
.gm-avatar{width:32px;height:32px;border-radius:50%;background:#1a73e8;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:white;cursor:pointer;}

.sim-bar{position:fixed;top:64px;left:0;right:0;z-index:200;background:#fff8e1;border-bottom:2px solid #ffd54f;padding:5px 16px;display:flex;align-items:center;gap:10px;font-size:12px;color:#5d4037;flex-wrap:wrap;}
.sim-bar strong{color:#e65100;}
.sim-prog{width:100px;height:4px;background:#ffe082;border-radius:2px;overflow:hidden;flex-shrink:0;}
.sim-prog-fill{height:100%;background:#f9a825;transition:width .3s;}
#simTxt{font-weight:700;color:#7b5e00;font-size:12px;}

.gm-shell{display:flex;padding-top:101px;height:100vh;overflow:hidden;}
.gm-sb{width:256px;flex-shrink:0;overflow-y:auto;padding:8px 0 8px;transition:width .2s;scrollbar-width:none;}
.gm-sb::-webkit-scrollbar{display:none;}
.gm-sb.mini{width:72px;}

.gm-compose-btn{display:flex;align-items:center;gap:10px;margin:4px 8px 8px 12px;padding:14px 22px;border:none;border-radius:16px;background:white;box-shadow:0 1px 3px rgba(0,0,0,.2);cursor:pointer;font-size:14px;font-weight:500;color:#202124;font-family:inherit;white-space:nowrap;overflow:hidden;width:calc(100% - 20px);}
.gm-compose-btn i{font-size:22px;color:#444746;flex-shrink:0;}
.gm-compose-label{transition:opacity .2s,max-width .2s;max-width:120px;}
.gm-sb.mini .gm-compose-label{max-width:0;opacity:0;}
.gm-sb.mini .gm-compose-btn{margin-left:8px;padding:14px;width:auto;}

.gm-nav{display:flex;align-items:center;gap:16px;padding:0 26px;height:34px;border-radius:0 17px 17px 0;cursor:pointer;font-size:14px;color:#202124;margin-right:16px;transition:background .15s;white-space:nowrap;overflow:hidden;text-decoration:none;}
.gm-nav:hover{background:#e8eaed;}
.gm-nav.active{background:#d3e3fd;font-weight:600;}
.gm-nav i{font-size:18px;width:20px;text-align:center;flex-shrink:0;color:#444746;}
.gm-nav.active i{color:#1a73e8;}
.gm-nav-label{flex:1;transition:opacity .2s,max-width .2s;max-width:140px;}
.gm-nav-count{font-size:12px;font-weight:700;flex-shrink:0;}
.gm-sb.mini .gm-nav-label,.gm-sb.mini .gm-nav-count{max-width:0;opacity:0;}
.gm-sb.mini .gm-nav{padding:0;justify-content:center;margin-right:8px;}

.gm-main{flex:1;display:flex;flex-direction:column;min-width:0;overflow:hidden;}
.gm-tabs{display:flex;background:white;border-bottom:1px solid #e2e8f0;flex-shrink:0;padding:0 8px;height:50px;overflow-x:auto;}
.gm-tab{display:flex;align-items:center;gap:7px;padding:0 16px;cursor:pointer;border-bottom:3px solid transparent;font-size:13px;color:#444746;white-space:nowrap;flex-shrink:0;}
.gm-tab:hover{background:#f1f3f4;}
.gm-tab.active{color:#1a73e8;border-bottom-color:#1a73e8;font-weight:600;}
.gm-tab-badge{font-size:10px;font-weight:700;padding:1px 5px;border-radius:10px;background:#1a73e8;color:white;}

.gm-toolbar{display:flex;align-items:center;padding:0 8px;border-bottom:1px solid #e8eaed;background:white;flex-shrink:0;height:48px;gap:2px;}
.gm-list{flex:1;overflow-y:auto;background:white;}
.gm-row{display:flex;align-items:center;padding:0 16px;height:50px;border-bottom:1px solid #f1f3f4;cursor:pointer;transition:background .1s;position:relative;}
.gm-row:hover{background:#f2f6fc;box-shadow:inset 1px 0 0 #c6d5f5,inset -1px 0 0 #c6d5f5;}
.gm-row.unread{background:#fff;font-weight:600;}
.gm-row.read{background:#f6f8fc;font-weight:400;}
.gm-row.ok-ans{border-left:3px solid #34a853;}
.gm-row.bad-ans{border-left:3px solid #ea4335;}
.gm-row-av{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:white;flex-shrink:0;margin:0 12px 0 4px;}
.gm-row-body{flex:1;min-width:0;display:flex;align-items:baseline;gap:6px;overflow:hidden;}
.gm-sender{font-size:14px;width:180px;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.gm-row-content{flex:1;min-width:0;display:flex;align-items:baseline;gap:4px;overflow:hidden;}
.gm-subj{font-size:14px;white-space:nowrap;flex-shrink:0;max-width:260px;overflow:hidden;text-overflow:ellipsis;}
.gm-sep-dot{color:#9aa0a6;font-size:14px;flex-shrink:0;}
.gm-preview{font-size:14px;color:#9aa0a6;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:400;}
.gm-row-right{display:flex;align-items:center;gap:6px;flex-shrink:0;margin-left:8px;}
.gm-time{font-size:12px;color:#5f6368;white-space:nowrap;}

.gm-panel{display:none;flex-direction:column;flex:1;background:white;overflow:hidden;}
.gm-panel.open{display:flex;}
.gp-topbar{display:flex;align-items:center;gap:4px;padding:6px 8px;border-bottom:1px solid #e8eaed;flex-shrink:0;}
.gp-back-btn{display:flex;align-items:center;gap:6px;padding:8px 12px;border:none;background:transparent;cursor:pointer;font-size:14px;color:#444746;border-radius:4px;font-family:inherit;}
.gp-back-btn:hover{background:#f1f3f4;}
.gp-scroll{flex:1;overflow-y:auto;padding:20px 28px;}
.gp-subject{font-size:22px;font-weight:400;color:#202124;margin-bottom:18px;}
.gp-from-row{display:flex;align-items:flex-start;gap:14px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid #e8eaed;}
.gp-from-av{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;color:white;flex-shrink:0;}
.gp-from-meta{flex:1;}
.gp-from-name{font-size:14px;font-weight:700;color:#202124;}
.gp-from-email{font-size:12px;color:#5f6368;margin-top:2px;}
.gp-from-time{font-size:12px;color:#5f6368;margin-top:2px;}
.gp-body{font-size:14px;color:#202124;line-height:1.7;}
.gp-mail-box{border:1px solid #e8eaed;border-radius:8px;padding:18px 22px;margin-bottom:12px;}

.gp-actions{flex-shrink:0;padding:10px 18px;border-top:1px solid #e8eaed;background:white;display:flex;gap:10px;align-items:center;flex-wrap:wrap;}
.btn-phish,.btn-legit{flex:1;min-width:120px;height:42px;font-size:14px;font-weight:600;cursor:pointer;border-radius:21px;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:6px;}
.btn-phish{background:#d93025;color:white;border:none;}
.btn-legit{background:white;color:#1a73e8;border:2px solid #1a73e8;}
.ans-ok,.ans-bad{flex:1;padding:10px;font-size:13px;border:2px solid;border-radius:21px;display:flex;align-items:center;gap:6px;justify-content:center;}
.ans-ok{background:#e8f5e9;color:#1b5e20;border-color:#a5d6a7;}
.ans-bad{background:#fde8e8;color:#b71c1c;border-color:#ffcdd2;}
.btn-next-gm{flex:0 0 auto;padding:8px 18px;background:white;border:1px solid #dadce0;font-size:14px;color:#444746;border-radius:21px;cursor:pointer;font-family:inherit;}

.gm-results{display:none;flex:1;overflow-y:auto;background:#f6f8fc;padding:24px 16px;}
.gm-results.open{display:flex;flex-direction:column;align-items:center;}

{% elseif type == 'SMS' %}
html,body{height:100%;background:#1c1c1e;font-family:-apple-system,'SF Pro Text',Arial,sans-serif;display:flex;align-items:flex-start;justify-content:center;padding:0;overflow-x:hidden;}
.phone-wrap{width:100%;max-width:430px;min-height:100vh;background:#1c1c1e;display:flex;flex-direction:column;position:relative;overflow:hidden;}
.ios-status{height:50px;padding:14px 24px 0;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;background:#1c1c1e;}
.ios-time{font-size:15px;font-weight:700;color:white;}
.dynamic-island{position:absolute;top:12px;left:50%;transform:translateX(-50%);width:120px;height:34px;background:#000;border-radius:20px;z-index:100;}

.sim-bar-sms{background:rgba(255,159,10,.12);border-bottom:1px solid rgba(255,159,10,.3);padding:6px 16px;display:flex;align-items:center;gap:8px;font-size:11px;color:#ffd60a;flex-shrink:0;}
.sim-prog-sms{flex:1;max-width:80px;height:3px;background:rgba(255,166,0,.2);border-radius:2px;overflow:hidden;}
.sim-prog-sms-fill{height:100%;background:#ff9f0a;transition:width .3s;}
#simTxt{font-size:11px;font-weight:700;color:#ffd60a;}

.sms-app-header{background:#1c1c1e;padding:8px 16px 12px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.sms-title{font-size:28px;font-weight:700;color:white;}
.sms-list{flex:1;overflow-y:auto;scrollbar-width:none;background:#1c1c1e;}
.sms-row{display:flex;align-items:center;gap:12px;padding:10px 16px;border-bottom:1px solid rgba(255,255,255,.07);cursor:pointer;transition:background .1s;}
.sms-row:hover{background:rgba(255,255,255,.04);}
.sms-row.ok-ans{border-left:3px solid #30d158;}
.sms-row.bad-ans{border-left:3px solid #ff3b30;}
.sms-av{width:48px;height:48px;border-radius:50%;background:#3a3a3c;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.sms-av i{font-size:20px;color:rgba(255,255,255,.6);}
.sms-av-txt{font-size:16px;font-weight:700;color:white;}
.sms-row-body{flex:1;min-width:0;}
.sms-row-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:3px;}
.sms-row-name{font-size:15px;font-weight:600;color:white;}
.sms-row-time{font-size:12px;color:rgba(255,255,255,.45);}
.sms-row-prev{font-size:13px;color:rgba(255,255,255,.45);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}

.sms-panel{display:none;flex-direction:column;position:absolute;inset:0;background:#1c1c1e;z-index:50;}
.sms-panel.open{display:flex;}
.sp-nav{display:flex;align-items:center;padding:10px 12px;border-bottom:1px solid rgba(255,255,255,.08);flex-shrink:0;gap:8px;}
.sp-back{background:transparent;border:none;color:#ff9f0a;font-size:15px;cursor:pointer;display:flex;align-items:center;gap:4px;font-family:inherit;padding:8px;}
.sp-contact-info{flex:1;text-align:center;}
.sp-contact-name{font-size:15px;font-weight:700;color:white;}
.sp-contact-num{font-size:12px;color:rgba(255,255,255,.45);}
.sp-scroll{flex:1;overflow-y:auto;padding:12px;scrollbar-width:none;}
.sp-date{text-align:center;font-size:11px;color:rgba(255,255,255,.35);margin:6px 0 14px;}
.sms-bubble-wrap{display:flex;justify-content:flex-start;margin-bottom:8px;}
.sms-bubble{max-width:82%;background:#2c2c2e;border-radius:4px 18px 18px 18px;padding:10px 14px;font-size:14px;line-height:1.55;color:white;}

.sp-action-bar{flex-shrink:0;padding:10px 12px 24px;background:#1c1c1e;border-top:1px solid rgba(255,255,255,.08);display:flex;gap:8px;flex-wrap:wrap;}
.sp-btn-phish,.sp-btn-legit{flex:1;min-width:120px;height:44px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;border-radius:22px;display:flex;align-items:center;justify-content:center;gap:6px;}
.sp-btn-phish{background:#ff3b30;color:white;border:none;}
.sp-btn-legit{background:#2c2c2e;color:#30d158;border:none;}
.sp-ans-ok,.sp-ans-bad{flex:1;padding:10px;border-radius:22px;font-size:13px;font-weight:600;display:flex;align-items:center;gap:6px;justify-content:center;}
.sp-ans-ok{background:rgba(48,209,88,.12);color:#30d158;border:1px solid rgba(48,209,88,.3);}
.sp-ans-bad{background:rgba(255,59,48,.12);color:#ff3b30;border:1px solid rgba(255,59,48,.3);}
.sp-btn-next{padding:10px 16px;background:#2c2c2e;color:rgba(255,255,255,.55);border:none;border-radius:22px;font-size:13px;cursor:pointer;font-family:inherit;}

{% elseif type == 'WHATSAPP' %}
html,body{height:100%;background:#111b21;font-family:-apple-system,'Segoe UI',Arial,sans-serif;overflow:hidden;}
.wa-shell{display:flex;height:100vh;overflow:hidden;}
.wa-strip{width:56px;background:#111b21;display:flex;flex-direction:column;align-items:center;padding-top:20px;gap:6px;border-right:1px solid #222d34;flex-shrink:0;}
.wa-strip-av{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#25d366,#128c7e);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:white;cursor:pointer;margin-bottom:10px;}
.wa-strip-btn{width:40px;height:40px;border-radius:50%;border:none;background:transparent;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:18px;color:#8696a0;}

.wa-sidebar{width:350px;flex-shrink:0;display:flex;flex-direction:column;border-right:1px solid #222d34;background:#111b21;}
.wa-sidebar-top{padding:14px 16px 8px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #222d34;flex-shrink:0;}
.wa-sidebar-title{font-size:20px;font-weight:700;color:#e9edef;}
.wa-sidebar-icons{display:flex;gap:4px;}
.wa-sb-ico{width:36px;height:36px;border-radius:50%;border:none;background:transparent;display:flex;align-items:center;justify-content:center;font-size:17px;color:#8696a0;cursor:pointer;}

.wa-conv-list{flex:1;overflow-y:auto;scrollbar-width:thin;scrollbar-color:#222d34 transparent;}
.wa-conv{display:flex;align-items:center;gap:12px;padding:10px 16px;cursor:pointer;transition:background .1s;}
.wa-conv:hover{background:#1f2c33;}
.wa-conv.ok-ans{border-left:3px solid #25d366;}
.wa-conv.bad-ans{border-left:3px solid #ff3b30;}
.wa-conv-av{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;color:white;flex-shrink:0;}
.wa-conv-body{flex:1;min-width:0;}
.wa-conv-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:3px;}
.wa-conv-name{font-size:15px;font-weight:500;color:#e9edef;}
.wa-conv-time{font-size:12px;color:#8696a0;}
.wa-conv-prev{font-size:13px;color:#8696a0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}

.wa-chat{flex:1;display:flex;flex-direction:column;background:#0b141a;position:relative;min-width:0;}
.wa-sim-bar{background:rgba(255,159,10,.1);border-bottom:1px solid rgba(255,159,10,.2);padding:5px 16px;display:flex;align-items:center;gap:10px;font-size:11px;color:#ffd60a;flex-shrink:0;}
.wa-sim-prog{flex:1;max-width:100px;height:3px;background:rgba(255,166,0,.15);border-radius:2px;overflow:hidden;}
.wa-sim-prog-fill{height:100%;background:#ff9f0a;transition:width .3s;}

.wa-chat-header{display:flex;align-items:center;gap:10px;padding:10px 16px;background:#202c33;border-bottom:1px solid #222d34;flex-shrink:0;}
.wa-chat-av{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;flex-shrink:0;color:white;}
.wa-chat-info{flex:1;}
.wa-chat-name{font-size:15px;font-weight:600;color:#e9edef;}
.wa-chat-status{font-size:12px;color:#8696a0;}

.wa-messages{flex:1;overflow-y:auto;padding:12px 16px;scrollbar-width:thin;scrollbar-color:#222d34 transparent;}
.wa-msg-date{text-align:center;margin:6px 0 12px;}
.wa-msg-date span{background:#182229;color:#8696a0;font-size:12px;padding:4px 12px;border-radius:8px;}
.wa-msg-wrap{display:flex;justify-content:flex-start;margin-bottom:5px;}
.wa-msg-wrap.out{justify-content:flex-end;}
.wa-bubble{max-width:66%;background:#202c33;border-radius:4px 12px 12px 12px;padding:8px 12px;font-size:14px;line-height:1.55;color:#e9edef;}
.wa-msg-wrap.out .wa-bubble{background:#005c4b;border-radius:12px 4px 12px 12px;}

.wa-action-bar{display:flex;gap:8px;padding:8px 12px;background:#202c33;border-top:1px solid #222d34;flex-shrink:0;flex-wrap:wrap;}
.wa-btn-phish,.wa-btn-legit{flex:1;min-width:120px;height:42px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;border-radius:21px;display:flex;align-items:center;justify-content:center;gap:6px;}
.wa-btn-phish{background:#ff3b30;color:white;border:none;}
.wa-btn-legit{background:#2a3942;color:#25d366;border:none;}
.wa-ans-ok,.wa-ans-bad{flex:1;padding:10px;border-radius:21px;font-size:13px;font-weight:600;display:flex;align-items:center;gap:6px;justify-content:center;}
.wa-ans-ok{background:rgba(37,211,102,.1);color:#25d366;border:1px solid rgba(37,211,102,.25);}
.wa-ans-bad{background:rgba(255,59,48,.1);color:#ff3b30;border:1px solid rgba(255,59,48,.25);}
.wa-btn-next{padding:10px 16px;background:#2a3942;color:#8696a0;border:none;border-radius:21px;font-size:13px;cursor:pointer;font-family:inherit;}

.wa-results{display:none;position:absolute;inset:0;background:#0b141a;z-index:100;overflow-y:auto;padding:20px;}
.wa-results.open{display:block;}
{% endif %}

/* ════════════════════════ RÉSULTATS ════════════════════════ */
.res-wrap{max-width:500px;width:100%;margin:0 auto;}
.res-card{background:#202c33;border-radius:16px;padding:22px;}
.res-score-circle{width:84px;height:84px;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0 auto 16px;font-weight:900;}
.rs-good{background:rgba(48,209,88,.12);color:#30d158;border:3px solid #30d158;}
.rs-mid{background:rgba(10,132,255,.12);color:#0a84ff;border:3px solid #0a84ff;}
.rs-bad{background:rgba(255,59,48,.12);color:#ff3b30;border:3px solid #ff3b30;}
.res-title{font-size:17px;font-weight:700;text-align:center;color:#e9edef;margin-bottom:4px;}
.res-sub{font-size:13px;color:#8696a0;text-align:center;margin-bottom:14px;}
.res-item{border-radius:10px;padding:12px;margin-bottom:8px;border:1px solid transparent;}
.ri-ok{background:rgba(48,209,88,.06);border-color:rgba(48,209,88,.2);}
.ri-bad{background:rgba(255,59,48,.06);border-color:rgba(255,59,48,.2);}
.ri-row{display:flex;align-items:flex-start;gap:10px;margin-bottom:6px;}
.ri-name{font-size:14px;font-weight:700;color:#e9edef;}
.ri-addr{font-size:12px;color:#8696a0;}
.ri-badge{font-size:11px;font-weight:700;padding:3px 10px;border-radius:10px;margin-left:auto;flex-shrink:0;}
.ri-badge.ok{background:rgba(48,209,88,.18);color:#30d158;}
.ri-badge.bad{background:rgba(255,59,48,.18);color:#ff3b30;}
.ri-expl{font-size:13px;color:rgba(255,255,255,.6);line-height:1.6;}
.btn-save{width:100%;height:46px;background:#34a853;color:white;border:none;border-radius:12px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;margin-top:12px;}
.btn-retry{width:100%;height:46px;background:#00a884;color:white;border:none;border-radius:12px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;margin-top:10px;}
.btn-home{display:block;width:100%;height:44px;line-height:44px;text-align:center;margin-top:10px;background:rgba(255,255,255,.06);border-radius:12px;font-size:14px;font-weight:600;color:#8696a0;text-decoration:none;}

.toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%);background:rgba(32,44,51,.97);color:white;padding:12px 24px;border-radius:8px;font-size:14px;z-index:9999;opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;}
</style>
</head>
<body>

<script>
const ITEMS   = {{ items|json_encode|raw }};
const SIM_TYPE= "{{ type }}";
const MODULE_ID = {{ module.id }};
const USER_AV = "{{ app.user.prenom|slice(0,1)|upper }}{{ app.user.nom|slice(0,1)|upper }}";
const FORM_URL= "{{ path('employe_simulation_jouer', {id: module.id}) }}";
let answers={}, curIdx=null, startTs=Date.now(), N=ITEMS.length;
</script>

{# ════════════════════════ GMAIL ════════════════════════ #}
{% if type == 'GMAIL' %}
<div class="gm-top">
  <button class="gm-hamburger" onclick="document.getElementById('gmSb').classList.toggle('mini')"><i class="fa-solid fa-bars"></i></button>
  <a class="gm-logo" href="#">
    <svg class="gm-logo-svg" viewBox="0 0 110 40"><rect x="0" y="6" width="28" height="28" rx="2" fill="white" stroke="#dadce0" stroke-width="1"/><path d="M2 8 L14 18 L26 8" stroke="#EA4335" stroke-width="2" fill="none"/><text x="34" y="28" font-family="Product Sans,Google Sans,Arial" font-size="22" fill="#5f6368">Gmail</text></svg>
  </a>
  <div class="gm-search"><i class="fa-solid fa-magnifying-glass"></i><input type="text" placeholder="Rechercher dans les e-mails"></div>
  <div class="gm-right">
    <button class="gm-icon-btn"><i class="fa-regular fa-circle-question"></i></button>
    <button class="gm-icon-btn"><i class="fa-solid fa-gear"></i></button>
    <button class="gm-icon-btn"><i class="fa-solid fa-grip"></i></button>
    <div class="gm-avatar">{{ app.user.prenom|slice(0,1)|upper }}{{ app.user.nom|slice(0,1)|upper }}</div>
  </div>
</div>

<div class="sim-bar"><i class="fa-solid fa-shield-halved"></i><strong>Simulation en cours</strong> — Analysez chaque email<div class="sim-prog"><div class="sim-prog-fill" id="simFill" style="width:0%"></div></div><span id="simTxt">0/{{ items|length }}</span></div>

<div class="gm-shell">
  <div class="gm-sb" id="gmSb">
    <button class="gm-compose-btn"><i class="fa-solid fa-pen-to-square"></i><span class="gm-compose-label">Nouveau message</span></button>
    <a class="gm-nav active" href="#"><i class="fa-solid fa-inbox"></i><span class="gm-nav-label">Boîte de réception</span><span class="gm-nav-count" id="gmUnread">{{ items|length }}</span></a>
    <a class="gm-nav" href="#"><i class="fa-regular fa-star"></i><span class="gm-nav-label">Messages suivis</span></a>
    <a class="gm-nav" href="#"><i class="fa-regular fa-clock"></i><span class="gm-nav-label">En attente</span></a>
    <a class="gm-nav" href="#"><i class="fa-solid fa-paper-plane"></i><span class="gm-nav-label">Messages envoyés</span></a>
  </div>
  <div class="gm-main">
    <div class="gm-tabs"><div class="gm-tab active"><i class="fa-solid fa-inbox"></i> Principal</div><div class="gm-tab"><i class="fa-solid fa-tag"></i> Promotions</div><div class="gm-tab"><i class="fa-solid fa-users"></i> Réseaux sociaux</div></div>
    <div class="gm-toolbar"><input type="checkbox" class="gm-check"><button class="gm-tb-btn"><i class="fa-solid fa-arrows-rotate"></i></button></div>
    <div class="gm-list" id="gmList">
      {% for idx, item in items %}
      <div class="gm-row unread" id="row{{ idx }}" onclick="openItem({{ idx }})">
        <div class="gm-row-av" style="background:{{ item.avatar_color|default('#9e9e9e') }};">{{ item.avatar_text|default(item.sender_name|slice(0,2)|upper) }}</div>
        <div class="gm-row-body">
          <span class="gm-sender">{{ item.sender_name }}</span>
          <div class="gm-row-content"><span class="gm-subj">{{ item.subject }}</span><span class="gm-sep-dot"> – </span><span class="gm-preview">{{ item.body|striptags|slice(0,80) }}</span></div>
        </div>
        <div class="gm-row-right"><span class="gm-time">{{ item.time|default("Aujourd'hui") }}</span></div>
      </div>
      {% endfor %}
    </div>
    <div class="gm-panel" id="gmPanel">
      <div class="gp-topbar"><button class="gp-back-btn" onclick="closeItem()"><i class="fa-solid fa-arrow-left"></i> Retour</button></div>
      <div class="gp-scroll">
        <div class="gp-subject" id="gpSubject"></div>
        <div class="gp-from-row"><div class="gp-from-av" id="gpAv"></div><div class="gp-from-meta"><div class="gp-from-name" id="gpName"></div><div class="gp-from-email" id="gpEmail"></div><div class="gp-from-time" id="gpTime"></div></div></div>
        <div class="gp-body" id="gpBody"></div>
      </div>
      <div class="gp-actions" id="gpActions"></div>
    </div>
    <div class="gm-results" id="gmResults"></div>
  </div>
</div>

{% elseif type == 'SMS' %}
<div class="phone-wrap">
  <div class="dynamic-island"></div>
  <div class="ios-status"><span class="ios-time" id="iosTime">15:05</span><div><i class="fa-solid fa-signal"></i> <i class="fa-solid fa-wifi"></i> <i class="fa-solid fa-battery-three-quarters"></i></div></div>
  <div class="sim-bar-sms"><i class="fa-solid fa-shield-halved"></i><strong>Simulation</strong><div class="sim-prog-sms"><div class="sim-prog-sms-fill" id="simFill" style="width:0%"></div></div><span id="simTxt">0/{{ items|length }}</span></div>
  <div class="sms-app-header"><span class="sms-title">Conversations</span></div>
  <div class="sms-list" id="smsList">
    {% for idx, item in items %}
    <div class="sms-row" id="row{{ idx }}" onclick="openItem({{ idx }})">
      <div class="sms-av">{% if item.num matches '/^[0-9]/' %}<i class="fa-solid fa-building"></i>{% else %}<span class="sms-av-txt">{{ item.name|slice(0,2)|upper }}</span>{% endif %}</div>
      <div class="sms-row-body"><div class="sms-row-top"><span class="sms-row-name">{{ item.name }}</span><span class="sms-row-time">{{ item.date|default("Aujourd'hui") }}</span></div><div class="sms-row-prev">{{ item.message|slice(0,55) }}...</div></div>
    </div>
    {% endfor %}
  </div>
  <div class="sms-panel" id="smsPanel">
    <div class="sp-nav"><button class="sp-back" onclick="closeItem()"><i class="fa-solid fa-chevron-left"></i> Retour</button><div class="sp-contact-info"><div class="sp-contact-name" id="spName"></div><div class="sp-contact-num" id="spNum"></div></div></div>
    <div class="sp-scroll" id="spScroll"></div>
    <div class="sp-action-bar" id="spActions"></div>
  </div>
</div>

{% elseif type == 'WHATSAPP' %}
<div class="wa-shell">
  <div class="wa-strip"><div class="wa-strip-av">{{ app.user.prenom|slice(0,1)|upper }}{{ app.user.nom|slice(0,1)|upper }}</div><button class="wa-strip-btn on"><i class="fa-solid fa-message"></i></button><button class="wa-strip-btn"><i class="fa-solid fa-circle-dot"></i></button><button class="wa-strip-btn"><i class="fa-solid fa-bullhorn"></i></button></div>
  <div class="wa-sidebar">
    <div class="wa-sidebar-top"><span class="wa-sidebar-title">WhatsApp</span><div class="wa-sidebar-icons"><button class="wa-sb-ico"><i class="fa-solid fa-pen-to-square"></i></button><button class="wa-sb-ico"><i class="fa-solid fa-ellipsis-vertical"></i></button></div></div>
    <div class="wa-conv-list" id="waConvList">
      {% for idx, item in items %}
      <div class="wa-conv" id="conv{{ idx }}" onclick="openItem({{ idx }})">
        <div class="wa-conv-av" style="background:{{ item.avatarBg|default('#25d366') }};">{{ item.avatarText|default(item.name|slice(0,2)|upper) }}</div>
        <div class="wa-conv-body"><div class="wa-conv-top"><span class="wa-conv-name">{{ item.name }}</span><span class="wa-conv-time">{{ item.messages|last ? item.messages|last.time : '' }}</span></div><div class="wa-conv-prev">{{ item.messages|last ? item.messages|last.text|slice(0,50) : '' }}</div></div>
      </div>
      {% endfor %}
    </div>
  </div>
  <div class="wa-chat">
    <div class="wa-sim-bar"><i class="fa-solid fa-shield-halved"></i><strong>Simulation</strong><div class="wa-sim-prog"><div class="wa-sim-prog-fill" id="simFill" style="width:0%"></div></div><span id="simTxt">0/{{ items|length }}</span></div>
    <div class="wa-chat-header"><div class="wa-chat-av" id="waChatAv"></div><div class="wa-chat-info"><div class="wa-chat-name" id="waChatName">Sélectionnez une conversation</div><div class="wa-chat-status" id="waChatStatus"></div></div></div>
    <div class="wa-messages" id="waMessages"><div style="display:flex;align-items:center;justify-content:center;height:100%;color:#8696a0;font-size:14px;">Cliquez sur une conversation pour l'analyser</div></div>
    <div class="wa-action-bar" id="waActions"></div>
    <div class="wa-results" id="waResults"></div>
  </div>
</div>
{% endif %}

<div class="toast" id="toast"></div>

<script>
function openItem(idx){
  curIdx=idx;
  if(SIM_TYPE==='GMAIL')      openGmail(idx);
  else if(SIM_TYPE==='SMS')   openSms(idx);
  else                        openWhatsapp(idx);
}

function closeItem(){
  if(SIM_TYPE==='GMAIL'){
    document.getElementById('gmList').style.display='';
    document.getElementById('gmPanel').classList.remove('open');
    document.getElementById('gmResults').classList.remove('open');
  } else if(SIM_TYPE==='SMS'){
    document.getElementById('smsList').style.display='';
    document.getElementById('smsPanel').classList.remove('open');
  }
}

function answer(idx, choice){
  const item=ITEMS[idx];
  const correct=(choice==='phishing')===!!item.is_phishing;
  answers[idx]={choice,correct};
  const pfx=SIM_TYPE==='WHATSAPP'?'conv':'row';
  const row=document.getElementById(pfx+idx);
  if(row){row.classList.remove('ok-ans','bad-ans');row.classList.add(correct?'ok-ans':'bad-ans');}
  const done=Object.keys(answers).length;
  document.getElementById('simFill').style.width=(done/N*100)+'%';
  document.getElementById('simTxt').textContent=done+'/'+N;
  showToast(correct?'Bonne réponse !':'Mauvaise réponse');
  renderActions(idx);
  if(done>=N) setTimeout(showResults,1400);
}

function openGmail(idx){
  const item=ITEMS[idx];
  document.getElementById('gmList').style.display='none';
  document.getElementById('gmPanel').classList.add('open');
  document.getElementById('gmResults').classList.remove('open');
  const row=document.getElementById('row'+idx);
  row.classList.remove('unread');row.classList.add('read');
  document.getElementById('gpSubject').textContent=item.subject||'';
  const av=document.getElementById('gpAv');
  av.style.background=item.avatar_color||'#9e9e9e';
  av.textContent=item.avatar_text||(item.sender_name||'').slice(0,2).toUpperCase();
  document.getElementById('gpName').textContent=item.sender_name||'';
  document.getElementById('gpEmail').innerHTML='<i class="fa-regular fa-envelope"></i> '+esc(item.sender_email||'');
  document.getElementById('gpTime').innerHTML='<i class="fa-regular fa-clock"></i> '+(item.time||"Aujourd'hui");
  document.getElementById('gpBody').innerHTML='<div class="gp-mail-box">'+(item.body||'')+'</div>';
  renderActions(idx);
}

function openSms(idx){
  const item=ITEMS[idx];
  document.getElementById('smsList').style.display='none';
  document.getElementById('smsPanel').classList.add('open');
  document.getElementById('spName').textContent=item.name||'';
  document.getElementById('spNum').textContent=item.num||'';
  document.getElementById('spScroll').innerHTML='<div class="sp-date">'+item.date+'</div><div class="sms-bubble-wrap"><div class="sms-bubble">'+esc(item.message||'')+'<div class="sms-bubble-time">'+item.date+'</div></div></div>';
  renderActions(idx);
}

function openWhatsapp(idx){
  const item=ITEMS[idx];
  document.querySelectorAll('.wa-conv').forEach(e=>e.classList.remove('active'));
  const c=document.getElementById('conv'+idx);if(c)c.classList.add('active');
  const av=document.getElementById('waChatAv');
  av.style.background=item.avatarBg||'#25d366';
  av.textContent=item.avatarText||(item.name||'').slice(0,2).toUpperCase();
  document.getElementById('waChatName').textContent=item.name||'';
  document.getElementById('waChatStatus').textContent=item.status||'';
  let html='<div class="wa-msg-date"><span>Aujourd\'hui</span></div>';
  (item.messages||[]).forEach(m=>{
    html+='<div class="wa-msg-wrap '+(m.out?'out':'')+'"><div class="wa-bubble">'+(m.sender?'<div class="wa-bubble-sender">'+esc(m.sender)+'</div>':'')+esc(m.text||'')+'<div class="wa-bubble-time">'+m.time+'</div></div></div>';
  });
  document.getElementById('waMessages').innerHTML=html;
  setTimeout(()=>{const w=document.getElementById('waMessages');w.scrollTop=w.scrollHeight;},50);
  renderActions(idx);
}

function renderActions(idx){
  const barId=SIM_TYPE==='GMAIL'?'gpActions':SIM_TYPE==='SMS'?'spActions':'waActions';
  const bar=document.getElementById(barId);
  const done=Object.keys(answers).length;
  if(answers[idx]!==undefined){
    const ok=answers[idx].correct;
    bar.innerHTML='<div class="'+(SIM_TYPE==='GMAIL'?(ok?'ans-ok':'ans-bad'):SIM_TYPE==='SMS'?(ok?'sp-ans-ok':'sp-ans-bad'):(ok?'wa-ans-ok':'wa-ans-bad'))+'"><i class="fa-solid '+(ok?'fa-circle-check':'fa-circle-xmark')+'"></i> '+(ok?'Correct !':'Incorrect')+'</div>'+(done<N?('<button class="'+(SIM_TYPE==='GMAIL'?'btn-next-gm':SIM_TYPE==='SMS'?'sp-btn-next':'wa-btn-next')+'" onclick="openItem('+((idx+1)%N)+')">Suivant →</button>'):('<button class="'+(SIM_TYPE==='GMAIL'?'btn-legit':SIM_TYPE==='SMS'?'sp-btn-legit':'wa-btn-legit')+'" onclick="showResults()">Voir les résultats</button>'));
  } else {
    bar.innerHTML=(SIM_TYPE==='GMAIL'?'<button class="btn-phish" onclick="answer('+idx+',\'phishing\')"><i class="fa-solid fa-triangle-exclamation"></i> Signaler phishing</button><button class="btn-legit" onclick="answer('+idx+',\'legit\')"><i class="fa-solid fa-circle-check"></i> Email légitime</button>':SIM_TYPE==='SMS'?'<button class="sp-btn-phish" onclick="answer('+idx+',\'phishing\')"><i class="fa-solid fa-triangle-exclamation"></i> Arnaque</button><button class="sp-btn-legit" onclick="answer('+idx+',\'legit\')"><i class="fa-solid fa-circle-check"></i> Légitime</button>':'<button class="wa-btn-phish" onclick="answer('+idx+',\'phishing\')"><i class="fa-solid fa-triangle-exclamation"></i> Phishing</button><button class="wa-btn-legit" onclick="answer('+idx+',\'legit\')"><i class="fa-solid fa-circle-check"></i> Légitime</button>');
  }
}

function showResults(){
  let score=0;ITEMS.forEach((_,i)=>{if(answers[i]?.correct)score++;});
  const pct=Math.round(score/N*100),cls=pct===100?'rs-good':pct>=60?'rs-mid':'rs-bad';
  const tSecs=Math.round((Date.now()-startTs)/1000);
  const reponsesData=ITEMS.map((item,i)=>({choice:answers[i]?.choice??null,correct:answers[i]?.correct??false}));
  const jsonData=JSON.stringify({score:pct,total:N,correctes:score,reponses:reponsesData,temps_secondes:tSecs});
  
  let html='<div class="res-wrap"><div class="res-card"><div class="res-score-circle '+cls+'"><span style="font-size:28px;">'+score+'/'+N+'</span><span style="font-size:12px;">'+pct+'%</span></div><div class="res-title">'+(pct===100?'Parfait !':pct>=60?'Bien joué !':'Restez vigilant !')+'</div><div class="res-sub">Détail de vos réponses :</div>';
  ITEMS.forEach((item,i)=>{
    const ok=answers[i]?.correct??false;
    const name=item.sender_name||item.name||'';
    html+='<div class="res-item '+(ok?'ri-ok':'ri-bad')+'"><div class="ri-row"><i class="fa-solid '+(ok?'fa-circle-check':'fa-circle-xmark')+'" style="font-size:18px;color:'+(ok?'#34a853':'#ea4335')+';margin-top:2px;"></i><div style="flex:1;"><div class="ri-name">'+esc(name)+'</div><div class="ri-addr">'+esc(item.sender_email||item.num||'')+'</div></div><span class="ri-badge '+(ok?'ok':'bad')+'">'+(ok?'Correct':'Incorrect')+'</span></div><div class="ri-expl">'+(item.explication||'')+'</div></div>';
  });
  html+='<form method="post" action="'+FORM_URL+'"><input type="hidden" name="resultat_json" value=\''+jsonData+'\'><button type="submit" class="btn-save"><i class="fa-solid fa-floppy-disk"></i> Enregistrer et terminer</button></form><button class="btn-retry" onclick="resetSim()"><i class="fa-solid fa-arrows-rotate"></i> Recommencer</button><a class="btn-home" href="{{ path('employe_dashboard') }}"><i class="fa-solid fa-arrow-left"></i> Tableau de bord</a></div></div>';

  if(SIM_TYPE==='GMAIL'){const gr=document.getElementById('gmResults');gr.innerHTML=html;gr.classList.add('open');document.getElementById('gmList').style.display='none';document.getElementById('gmPanel').classList.remove('open');}
  else if(SIM_TYPE==='SMS'){let rs=document.getElementById('smsResults');if(!rs){rs=document.createElement('div');rs.id='smsResults';rs.style.cssText='position:absolute;inset:0;background:#1c1c1e;z-index:60;overflow-y:auto;padding:16px;';document.querySelector('.phone-wrap').appendChild(rs);}rs.innerHTML=html;document.getElementById('smsList').style.display='none';document.getElementById('smsPanel').classList.remove('open');}
  else {const wr=document.getElementById('waResults');wr.innerHTML=html;wr.classList.add('open');}
}

function resetSim(){answers={};curIdx=null;startTs=Date.now();ITEMS.forEach((_,i)=>{const pfx=SIM_TYPE==='WHATSAPP'?'conv':'row';const el=document.getElementById(pfx+i);if(el){el.classList.remove('ok-ans','bad-ans');if(SIM_TYPE==='GMAIL'){el.classList.remove('read');el.classList.add('unread');}}});document.getElementById('simFill').style.width='0%';document.getElementById('simTxt').textContent='0/'+N;if(SIM_TYPE==='GMAIL'){document.getElementById('gmList').style.display='';document.getElementById('gmPanel').classList.remove('open');document.getElementById('gmResults').classList.remove('open');document.getElementById('gmUnread').textContent=N;}else if(SIM_TYPE==='SMS'){const rs=document.getElementById('smsResults');if(rs)rs.remove();document.getElementById('smsList').style.display='';document.getElementById('smsPanel').classList.remove('open');}else{document.getElementById('waResults').classList.remove('open');document.getElementById('waMessages').innerHTML='<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#8696a0;font-size:14px;">Cliquez sur une conversation</div>';document.getElementById('waActions').innerHTML='';}}
function esc(s){return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2200);}
function updateTime(){const n=new Date();const t=document.getElementById('iosTime');if(t)t.textContent=n.getHours()+':'+(n.getMinutes()<10?'0':'')+n.getMinutes();}
updateTime();setInterval(updateTime,30000);
{% if type == 'WHATSAPP' %}if(ITEMS.length>0) openItem(0);{% endif %}
</script>
</body>
</html>
{% endblock %}