{% extends 'base.html.twig' %}
{% block body %}

<div class="sb-overlay" id="sbOverlayE" onclick="sbCloseE()"></div>
<div class="r-shell" id="eShell">

    <aside class="r-sidebar" id="eSidebar">
        <div class="r-brand">
            <div class="r-brand-icon" style="background:linear-gradient(135deg,#10B981,#059669);">  <img src="{{ asset('images/logo.png') }}" alt="SAT Platform" class="r-brand-logo"></div>
            <div class="r-brand-text">
                <div class="r-brand-name">SAT Platform</div>
                <div class="r-brand-role" style="color:#10B981;">Espace Employé</div>
            </div>
            <button class="r-collapse-btn" onclick="sbToggleE()"><i class="bi bi-layout-sidebar-reverse"></i></button>
        </div>

        <nav class="r-nav">
            {# Tableau de bord #}
            <a href="{{ path('employe_dashboard') }}"
               class="r-nav-link {% if app.request.attributes.get('_route') == 'employe_dashboard' %}active{% endif %}">
                <span class="r-nav-icon"><i class="bi bi-grid-1x2-fill"></i></span>
                <span class="r-nav-label">Tableau de bord</span>
            </a>

            <div class="r-nav-sep"><span class="r-nav-sep-text">Formation</span></div>

            <a href="{{ path('employe_formations') }}"
               class="r-nav-link {% if 'employe_formation' in app.request.attributes.get('_route') %}active{% endif %}">
                <span class="r-nav-icon"><i class="bi bi-mortarboard-fill"></i></span>
                <span class="r-nav-label">Mes formations</span>
            </a>

            <div class="r-nav-sep"><span class="r-nav-sep-text">Cybersécurité</span></div>

            {# ══ ANALYSEUR — toujours visible, mis en avant ══ #}
            <a href="{{ path('employe_analyseur') }}"
               class="r-nav-link r-nav-analyseur {% if app.request.attributes.get('_route') == 'employe_analyseur' %}active{% endif %}">
                <span class="r-nav-icon"><i class="bi bi-shield-check"></i></span>
                <span class="r-nav-label">Analyser un lien / fichier</span>
            </a>

            <div class="r-nav-sep"><span class="r-nav-sep-text">Mon compte</span></div>

            <a href="{{ path('employe_profil') }}"
               class="r-nav-link {% if app.request.attributes.get('_route') starts with 'employe_profil' %}active{% endif %}">
                <span class="r-nav-icon"><i class="bi bi-person-circle"></i></span>
                <span class="r-nav-label">Mon profil</span>
            </a>
        </nav>

        <div class="r-user">
            <div class="r-user-avatar" style="background:linear-gradient(135deg,#10B981,#059669);">
                {{ (app.user.prenom|default(''))|slice(0,1)|upper }}{{ (app.user.nom|default(''))|slice(0,1)|upper }}
            </div>
            <div class="r-user-info">
                <div class="r-user-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
                <div class="r-user-email">{{ app.user.email }}</div>
            </div>
            <a href="{{ path('app_logout') }}" class="r-logout" title="Déconnexion"><i class="bi bi-power"></i></a>
        </div>
    </aside>

    <div class="r-main">
        <header class="r-topbar">
            <div class="r-topbar-left">
                <button class="r-menu-btn" id="eMenuBtn"><i class="bi bi-list"></i></button>
                <div class="r-breadcrumb">
                    <span class="r-breadcrumb-root">Employé</span>
                    <i class="bi bi-chevron-right r-breadcrumb-sep"></i>
                    <span class="r-breadcrumb-current">{% block page_title %}Page{% endblock %}</span>
                </div>
            </div>
            <div class="r-topbar-right">
                {% block topbar_actions %}{% endblock %}
                {# Bouton analyseur dans la topbar — toujours visible #}
                <a href="{{ path('employe_analyseur') }}" class="topbar-analyseur-btn" title="Analyser un lien ou fichier suspect">
                    <i class="bi bi-shield-check"></i>
                    <span>Analyser</span>
                </a>
            </div>
        </header>

        <div class="r-flashes">
            {% for msg in app.flashes('success') %}<div class="r-flash r-flash-success flash-message"><i class="bi bi-check-circle-fill"></i><span>{{ msg }}</span><button onclick="this.closest('.r-flash').remove()"><i class="bi bi-x"></i></button></div>{% endfor %}
            {% for msg in app.flashes('error') %}<div class="r-flash r-flash-error flash-message"><i class="bi bi-x-circle-fill"></i><span>{{ msg }}</span><button onclick="this.closest('.r-flash').remove()"><i class="bi bi-x"></i></button></div>{% endfor %}
            {% for msg in app.flashes('danger') %}<div class="r-flash r-flash-error flash-message"><i class="bi bi-x-circle-fill"></i><span>{{ msg }}</span><button onclick="this.closest('.r-flash').remove()"><i class="bi bi-x"></i></button></div>{% endfor %}
            {% for msg in app.flashes('warning') %}<div class="r-flash r-flash-warning flash-message"><i class="bi bi-exclamation-triangle-fill"></i><span>{{ msg }}</span><button onclick="this.closest('.r-flash').remove()"><i class="bi bi-x"></i></button></div>{% endfor %}
        </div>

        <div class="r-content">{% block content %}{% endblock %}</div>
    </div>
</div>

{% block stylesheets %}<link rel="stylesheet" href="{{ asset('css/responsive.css') }}">{% endblock %}

<style>
:root{--r-sb-bg:#0B1120;--r-accent:#10B981;--r-accent-dim:rgba(16,185,129,.12);--r-text:#F1F5F9;--r-muted:rgba(241,245,249,.4);--r-hover:rgba(255,255,255,.05);--r-border:rgba(255,255,255,.07)}
.r-brand{display:flex;align-items:center;gap:12px;padding:20px 16px 18px;border-bottom:1px solid var(--r-border);flex-shrink:0}
.r-brand-icon{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:18px;color:#fff;flex-shrink:0}
.r-brand-name{font-size:14px;font-weight:800;color:var(--r-text);letter-spacing:-.02em;white-space:nowrap}
.r-brand-role{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;white-space:nowrap}
.r-brand-text{flex:1;min-width:0}
.r-collapse-btn{width:28px;height:28px;background:var(--r-hover);border:1px solid var(--r-border);border-radius:7px;color:var(--r-muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;transition:all .15s;flex-shrink:0}
.r-nav{flex:1;padding:12px 10px;overflow-y:auto;background:var(--r-sb-bg)}
.r-nav-sep{padding:14px 8px 5px}
.r-nav-sep-text{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--r-muted)}
.r-nav-link{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:9px;color:var(--r-muted);text-decoration:none;font-size:13.5px;font-weight:500;margin-bottom:2px;transition:all .15s;overflow:hidden}
.r-nav-link:hover{background:var(--r-hover);color:var(--r-text)}
.r-nav-link.active{background:var(--r-accent-dim);color:var(--r-accent);font-weight:600}
.r-nav-icon{width:20px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
.r-nav-label{white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
/* Analyseur mis en avant */
.r-nav-analyseur{color:#FBBF24;border:1px solid rgba(251,191,36,.25);background:rgba(251,191,36,.06);margin-top:4px}
.r-nav-analyseur:hover{background:rgba(251,191,36,.12);color:#FCD34D}
.r-nav-analyseur.active{background:rgba(251,191,36,.15);color:#FBBF24;border-color:rgba(251,191,36,.4)}
.r-nav-analyseur .r-nav-icon{color:#F59E0B}
/* User zone */
.r-user{display:flex;align-items:center;gap:10px;padding:14px;border-top:1px solid var(--r-border);flex-shrink:0}
.r-user-avatar{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0}
.r-user-info{flex:1;min-width:0}
.r-user-name{font-size:13px;font-weight:600;color:var(--r-text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.r-user-email{font-size:11px;color:var(--r-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.r-logout{width:30px;height:30px;display:flex;align-items:center;justify-content:center;color:var(--r-muted);font-size:15px;border-radius:8px;text-decoration:none;transition:all .15s;flex-shrink:0}
.r-logout:hover{background:rgba(248,113,113,.15);color:#F87171}
.r-sidebar{background:var(--r-sb-bg);display:flex;flex-direction:column}
/* Topbar */
.r-topbar{height:60px;background:#fff;border-bottom:1px solid #E2E8F0;display:flex;align-items:center;justify-content:space-between;padding:0 24px;position:sticky;top:0;z-index:50;gap:16px;flex-shrink:0}
.r-topbar-left{display:flex;align-items:center;gap:14px;min-width:0}
.r-topbar-right{display:flex;align-items:center;gap:10px;flex-shrink:0}
.r-menu-btn{width:36px;height:36px;background:#F1F5F9;border:1px solid #E2E8F0;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:18px;color:#475569;cursor:pointer;transition:all .15s;flex-shrink:0}
.r-menu-btn:hover{background:#E2E8F0}
.r-breadcrumb{display:flex;align-items:center;gap:6px;font-size:13px;min-width:0;overflow:hidden}
.r-breadcrumb-root{color:#94A3B8;font-weight:500;flex-shrink:0}
.r-breadcrumb-sep{font-size:10px;color:#CBD5E1;flex-shrink:0}
.r-breadcrumb-current{font-size:14px;font-weight:700;color:#1E293B;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.r-topbar-company{display:flex;align-items:center;gap:6px;padding:6px 12px;border-radius:9px;border:1px solid #BBF7D0;background:#F0FDF4;color:#166534;font-size:12px;font-weight:600}
/* Bouton analyseur dans la topbar */
.topbar-analyseur-btn{display:flex;align-items:center;gap:6px;padding:7px 14px;background:#FFFBEB;border:1.5px solid #FDE68A;border-radius:9px;text-decoration:none;font-size:13px;font-weight:700;color:#92400E;white-space:nowrap;transition:all .15s}
.topbar-analyseur-btn:hover{background:#FEF3C7;border-color:#F59E0B;color:#78350F}
.topbar-analyseur-btn i{font-size:15px;color:#F59E0B}
/* Flashes */
.r-flashes{padding:16px 24px 0;display:flex;flex-direction:column;gap:8px}
.r-flashes:empty{padding:0}
.r-flash{display:flex;align-items:center;gap:10px;padding:11px 16px;border-radius:10px;font-size:13.5px;font-weight:500;animation:flashShake 0.5s ease-in-out}
.r-flash button{margin-left:auto;background:none;border:none;cursor:pointer;color:inherit;opacity:.5;font-size:16px;padding:0 4px}
.r-flash-success{background:#DCFCE7;color:#166534;border:1px solid #BBF7D0}
.r-flash-error{background:#FEE2E2;color:#991B1B;border:1px solid #FECACA}
.r-flash-warning{background:#FFFBEB;color:#92400E;border:1px solid #FDE68A}
@keyframes flashShake{0%,100%{transform:translateX(0)}10%,30%,50%,70%,90%{transform:translateX(-5px)}20%,40%,60%,80%{transform:translateX(5px)}}
.r-content{padding:24px;flex:1}
.r-brand-logo{
    height: 60px;
    width: auto;
    max-width: 150px;
    object-fit: contain;
}
</style>

<script>
(function(){
    var KEY='sat_employe_sb',shell=document.getElementById('eShell'),sidebar=document.getElementById('eSidebar'),overlay=document.getElementById('sbOverlayE');
    var mob=function(){return window.innerWidth<=768;};
    if(!mob()&&localStorage.getItem(KEY)==='mini'){shell.classList.add('sidebar-mini');}
    window.sbToggleE=function(){if(mob()){sbOpenE();return;}shell.classList.toggle('sidebar-mini');localStorage.setItem(KEY,shell.classList.contains('sidebar-mini')?'mini':'open');};
    window.sbOpenE=function(){sidebar.classList.add('mob-open');overlay.classList.add('show');document.body.style.overflow='hidden';};
    window.sbCloseE=function(){sidebar.classList.remove('mob-open');overlay.classList.remove('show');document.body.style.overflow='';};
    document.getElementById('eMenuBtn').addEventListener('click',function(){mob()?sbOpenE():sbToggleE();});
    window.addEventListener('resize',function(){if(!mob()){sbCloseE();}});
})();

document.addEventListener('DOMContentLoaded', function() {
    const flashMessages = document.querySelectorAll('.flash-message');
    flashMessages.forEach(function(message) {
        setTimeout(function() {
            message.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
            message.style.opacity = '0';
            message.style.transform = 'translateX(-100%)';
            setTimeout(function() {
                message.remove();
            }, 500);
        }, 3000);
    });
});
</script>
{% endblock %}
