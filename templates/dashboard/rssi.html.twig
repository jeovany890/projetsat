{% extends 'base.html.twig' %}

{% block title %}Dashboard RSSI - SAT Platform{% endblock %}

{% block body %}
<div style="display: flex; min-height: 100vh;">
    
    {# Sidebar similaire mais avec badge RSSI et menu différent #}
    <aside style="width: 280px; background: var(--primary-900); color: white; padding: var(--space-6);">
        <div style="margin-bottom: var(--space-8);">
            <h1 style="font-size: var(--text-2xl); font-weight: var(--font-black);">SAT Platform</h1>
            <span class="badge" style="background: var(--secondary-600); margin-top: var(--space-2);">RSSI</span>
        </div>
        {# Menu RSSI spécifique #}
    </aside>

    <main style="flex: 1; background: var(--gray-50); padding: var(--space-8);">
        <h2 style="font-size: var(--text-4xl); font-weight: var(--font-bold);">Dashboard RSSI</h2>
        <p>Gérez les formations et campagnes de votre entreprise</p>
        {# Contenu RSSI #}
    </main>

</div>
{% endblock %}