{% extends 'base.html.twig' %}

{% block title %}Mon Espace - SAT Platform{% endblock %}

{% block body %}
<div style="display: flex; min-height: 100vh;">
    
    <aside style="width: 280px; background: var(--success); color: white; padding: var(--space-6);">
        <div style="margin-bottom: var(--space-8);">
            <h1 style="font-size: var(--text-2xl); font-weight: var(--font-black);">SAT Platform</h1>
            <span class="badge" style="background: white; color: var(--success); margin-top: var(--space-2);">EMPLOYÉ</span>
        </div>
        {# Menu Employé #}
    </aside>

    <main style="flex: 1; background: var(--gray-50); padding: var(--space-8);">
        <h2 style="font-size: var(--text-4xl); font-weight: var(--font-bold);">Mon Espace Formation</h2>
        <p>Suivez vos formations et améliorez votre vigilance</p>
        {# Contenu Employé #}
    </main>

</div>
{% endblock %}