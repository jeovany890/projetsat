{% extends 'admin/layout.html.twig' %}

{% block page_title %}Modifier la question {{ index + 1 }} — {{ quiz.titre }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_quiz_questions', {id: quiz.id}) }}" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i> Retour aux questions
    </a>
{% endblock %}

{% block content %}
<div class="form-container">
    <div class="card">
        <div class="card-header">
            <h2>
                <i class="bi bi-pencil-square" style="color: #E53E3E;"></i>
                Modifier la question {{ index + 1 }}
            </h2>
            <p class="card-subtitle">Quiz : <strong>{{ quiz.titre }}</strong></p>
        </div>
        <div class="card-body">
            <form method="post" id="editQuestionForm">
                {% if quiz.estInitial() %}
                    <div class="form-group">
                        <label class="form-label">Catégorie <span style="color:#E53E3E;">*</span></label>
                        <select name="categorie" class="form-control" required>
                            <option value="">-- Choisir --</option>
                            <option value="phishing" {{ question.categorie == 'phishing' ? 'selected' : '' }}>🎣 Phishing (email)</option>
                            <option value="smishing" {{ question.categorie == 'smishing' ? 'selected' : '' }}>📱 Smishing (SMS / WhatsApp)</option>
                            <option value="bonnes_pratiques" {{ question.categorie == 'bonnes_pratiques' ? 'selected' : '' }}>🛡️ Bonnes pratiques en entreprise</option>
                        </select>
                        <p class="form-hint">Le tirage doit proposer phishing, smishing et bonnes pratiques.</p>
                    </div>
                {% endif %}

                <div class="form-group">
                    <label class="form-label">Type de question *</label>
                    <select name="type_question" class="form-control" id="typeQuestion" onchange="updateFormType(this.value)">
                        <option value="QCM_UNIQUE" {{ question.type_question == 'QCM_UNIQUE' ? 'selected' : '' }}>QCM — 1 seule réponse</option>
                        <option value="QCM_MULTIPLE" {{ question.type_question == 'QCM_MULTIPLE' ? 'selected' : '' }}>QCM — Plusieurs réponses</option>
                        <option value="VRAI_FAUX" {{ question.type_question == 'VRAI_FAUX' ? 'selected' : '' }}>Vrai / Faux</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Question *</label>
                    <textarea name="question" class="form-control" rows="3" required>{{ question.question }}</textarea>
                </div>

                <div id="optionsSection" class="form-group">
                    <label class="form-label">Réponses proposées *</label>
                    <div id="optionsList" class="options-list-editor">
                        {% for option in question.options ?? [] %}
                            <div class="option-row">
                                <input type="checkbox" name="reponses_correctes[]" value="{{ option }}" class="option-check" {{ option in (question.reponses_correctes ?? []) ? 'checked' : '' }} title="Cocher si bonne réponse">
                                <input type="text" name="options[]" class="form-control form-control-sm option-text" value="{{ option }}" placeholder="Option {{ loop.index }}" oninput="syncCheckValue(this)">
                                {% if loop.index > 2 %}
                                    <button type="button" class="btn-icon" onclick="this.closest('.option-row').remove()" style="color:#DC2626;flex-shrink:0;">×</button>
                                {% endif %}
                            </div>
                        {% else %}
                            <div class="option-row">
                                <input type="checkbox" name="reponses_correctes[]" value="" class="option-check" title="Cocher si bonne réponse">
                                <input type="text" name="options[]" class="form-control form-control-sm option-text" placeholder="Option A" oninput="syncCheckValue(this)">
                            </div>
                            <div class="option-row">
                                <input type="checkbox" name="reponses_correctes[]" value="" class="option-check" title="Cocher si bonne réponse">
                                <input type="text" name="options[]" class="form-control form-control-sm option-text" placeholder="Option B" oninput="syncCheckValue(this)">
                            </div>
                        {% endfor %}
                    </div>
                    <button type="button" class="btn btn-ghost btn-sm" onclick="addOption()">
                        <i class="bi bi-plus"></i> Ajouter une option
                    </button>
                    <p class="form-hint">☑ Cochez la ou les bonne(s) réponse(s).</p>
                </div>

                <div id="vraiFauxSection" class="form-group" style="display:none;">
                    <label class="form-label">Bonne réponse *</label>
                    <div class="radio-group">
                        <label><input type="radio" name="reponses_correctes[]" value="Vrai" {{ 'Vrai' in (question.reponses_correctes ?? []) ? 'checked' : '' }}> Vrai</label>
                        <label><input type="radio" name="reponses_correctes[]" value="Faux" {{ 'Faux' in (question.reponses_correctes ?? []) ? 'checked' : '' }}> Faux</label>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Points</label>
                        <input type="number" name="points" class="form-control" value="{{ question.points }}" min="1" max="100">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Explication (optionnel)</label>
                        <input type="text" name="explication" class="form-control" value="{{ question.explication }}" placeholder="Pourquoi cette réponse ?">
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Enregistrer la question
                    </button>
                    <a href="{{ path('admin_quiz_questions', {id: quiz.id}) }}" class="btn btn-ghost">
                        <i class="bi bi-x-lg"></i> Annuler
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .form-container {
        max-width: 900px;
        margin: 0 auto;
    }
    .card {
        background: white;
        border-radius: 1rem;
        border: 1px solid #E2E8F0;
        overflow: hidden;
    }
    html.dark .card {
        background: #1E293B;
        border-color: #334155;
    }
    .card-header {
        padding: 1.5rem 1.75rem;
        border-bottom: 1px solid #E2E8F0;
        background: #F8FAFC;
    }
    html.dark .card-header {
        background: #0F172A;
        border-color: #334155;
    }
    .card-header h2 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #0F172A;
        margin: 0 0 0.25rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .card-subtitle {
        font-size: 0.75rem;
        color: #64748B;
        margin: 0;
    }
    html.dark .card-header h2 { color: #F1F5F9; }
    .card-body {
        padding: 1.75rem;
    }
    .form-group { margin-bottom: 1rem; }
    .form-label { display: block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #475569; margin-bottom: 0.4rem; }
    .form-control { width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #CBD5E1; border-radius: 0.5rem; font-size: 0.875rem; background: white; color: #0F172A; transition: all 0.15s; }
    .form-control:focus { outline: none; border-color: #E53E3E; box-shadow: 0 0 0 3px rgba(229,62,62,0.2); }
    html.dark .form-control { background: #0F172A; border-color: #334155; color: #F1F5F9; }
    .form-control-sm { padding: 0.25rem 0.5rem; font-size: 0.75rem; }
    textarea.form-control { resize: vertical; }
    .option-row { display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem; }
    .option-check { width: 18px; height: 18px; accent-color: #E53E3E; }
    .radio-group { display: flex; gap: 1rem; align-items: center; }
    .radio-group label { display: flex; align-items: center; gap: 0.25rem; cursor: pointer; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
    @media (max-width: 640px) { .form-row { grid-template-columns: 1fr; } }
    .btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 1rem; border-radius: 8px; font-size: 0.75rem; font-weight: 600; text-decoration: none; transition: all 0.2s; cursor: pointer; border: none; }
    .btn-primary { background: #E53E3E; color: white; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
    .btn-primary:hover { background: #C53030; transform: translateY(-1px); }
    .btn-ghost { background: transparent; border: 1px solid #E2E8F0; color: #475569; }
    .btn-ghost:hover { background: #F8FAFC; border-color: #CBD5E1; color: #1E293B; }
    .form-actions { display: flex; gap: 0.75rem; justify-content: flex-end; margin-top: 1rem; }
    .form-hint { font-size: 0.7rem; color: #94A3B8; margin-top: 0.25rem; }
</style>
<script>
    function updateFormType(type) {
        const optionsSection = document.getElementById('optionsSection');
        const vfSection      = document.getElementById('vraiFauxSection');
        if (type === 'VRAI_FAUX') {
            optionsSection.style.display = 'none';
            vfSection.style.display      = 'block';
        } else {
            optionsSection.style.display = 'block';
            vfSection.style.display      = 'none';
        }
    }
    function syncCheckValue(input) {
        const row = input.closest('.option-row');
        const cb  = row.querySelector('.option-check');
        if (cb) {
            cb.value = input.value;
        }
    }
    function addOption() {
        const list   = document.getElementById('optionsList');
        const count  = list.querySelectorAll('.option-row').length;
        const labels = ['A','B','C','D','E','F'];
        const letter = labels[count] || (count + 1);
        const row    = document.createElement('div');
        row.className = 'option-row';
        row.innerHTML = `
            <input type="checkbox" name="reponses_correctes[]" value="" class="option-check">
            <input type="text" name="options[]" class="form-control form-control-sm option-text"
                   placeholder="Option ${letter}" oninput="syncCheckValue(this)">
            <button type="button" class="btn-icon" onclick="this.closest('.option-row').remove()"
                    style="color:#DC2626;flex-shrink:0;">×</button>
        `;
        list.appendChild(row);
    }
    document.addEventListener('DOMContentLoaded', function() {
        updateFormType(document.getElementById('typeQuestion').value);
        document.querySelectorAll('.option-text').forEach(syncCheckValue);
    });
</script>
{% endblock %}
