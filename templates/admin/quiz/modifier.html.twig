{% extends 'admin/layout.html.twig' %}

{% block page_title %}Paramètres — {{ quiz.titre }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_quiz_questions', {id: quiz.id}) }}" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i> Retour aux questions
    </a>
{% endblock %}

{% block content %}
<div class="form-container">
    <div class="card">
        <div class="card-header">
            <h2>
                <i class="bi bi-gear" style="color: #E53E3E;"></i>
                Paramètres du quiz
            </h2>
            <p class="card-subtitle">
                {% if quiz.chapitre is not null %}
                    Chapitre : <strong>{{ quiz.chapitre.titre }}</strong>
                    &nbsp;·&nbsp; Module : <strong>{{ quiz.chapitre.module.titre }}</strong>
                {% elseif quiz.module is not null %}
                    Module : <strong>{{ quiz.module.titre }}</strong>
                {% else %}
                    <i class="bi bi-bar-chart-fill" style="color: #7C3AED;"></i>
                    <strong>Quiz d'évaluation initiale</strong>
                {% endif %}
            </p>
        </div>
        <div class="card-body">
            <form method="post">

                {# Informations générales #}
                <div class="form-section">
                    <h3 class="section-title">Informations générales</h3>
                    <div class="form-group">
                        <label class="form-label">Titre du quiz *</label>
                        <input type="text" name="titre" class="form-control" value="{{ quiz.titre }}" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-control" rows="3">{{ quiz.description }}</textarea>
                    </div>
                </div>

                {# Paramètres #}
                <div class="form-section">
                    <h3 class="section-title">Paramètres</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Score minimum (%)</label>
                            <input type="number" name="score_minimum" class="form-control" value="{{ quiz.scoreMinimum }}" min="0" max="100">
                            {% if quiz.module is null and quiz.chapitre is null %}
                                <div class="form-hint info-hint">Mettre 0 pour l'évaluation initiale (pas de seuil).</div>
                            {% endif %}
                        </div>
                        <div class="form-group">
                            <label class="form-label">Tentatives maximum</label>
                            <input type="number" name="tentatives_max" class="form-control" value="{{ quiz.nombreTentativesMax }}" min="1" max="10">
                            {% if quiz.module is null and quiz.chapitre is null %}
                                <div class="form-hint info-hint">Mettre 1 — l'évaluation initiale ne se passe qu'une fois.</div>
                            {% endif %}
                        </div>
                        <div class="form-hint info-hint" style="margin-top:8px;">
                            <i class="bi bi-shuffle"></i> Les questions sont présentées dans un ordre aléatoire automatiquement.
                        </div>
                    </div>
                </div>

                {# Actions #}
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Enregistrer
                    </button>
                    <a href="{{ path('admin_quiz_questions', {id: quiz.id}) }}" class="btn btn-ghost">
                        <i class="bi bi-x-lg"></i> Annuler
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .form-container {
        max-width: 900px;
        margin: 0 auto;
    }
    .card {
        background: white;
        border-radius: 1rem;
        border: 1px solid #E2E8F0;
        overflow: hidden;
    }
    html.dark .card {
        background: #1E293B;
        border-color: #334155;
    }
    .card-header {
        padding: 1.5rem 1.75rem;
        border-bottom: 1px solid #E2E8F0;
        background: #F8FAFC;
    }
    html.dark .card-header {
        background: #0F172A;
        border-color: #334155;
    }
    .card-header h2 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #0F172A;
        margin: 0 0 0.25rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .card-subtitle {
        font-size: 0.75rem;
        color: #64748B;
        margin: 0;
    }
    html.dark .card-header h2 {
        color: #F1F5F9;
    }
    .card-body {
        padding: 1.75rem;
    }
    .form-section {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #E2E8F0;
    }
    html.dark .form-section {
        border-color: #334155;
    }
    .section-title {
        font-size: 1rem;
        font-weight: 700;
        color: #0F172A;
        margin: 0 0 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .section-title:before {
        content: '';
        width: 4px;
        height: 18px;
        background: #E53E3E;
        border-radius: 4px;
        display: inline-block;
    }
    html.dark .section-title {
        color: #F1F5F9;
    }
    .form-group {
        margin-bottom: 1rem;
    }
    .form-row {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }
    @media (max-width: 640px) {
        .form-row {
            grid-template-columns: 1fr;
            gap: 0;
        }
    }
    .form-label {
        display: block;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #475569;
        margin-bottom: 0.4rem;
    }
    .form-control {
        width: 100%;
        padding: 0.5rem 0.75rem;
        border: 1px solid #CBD5E1;
        border-radius: 0.5rem;
        font-size: 0.875rem;
        background: white;
        color: #0F172A;
        transition: all 0.15s;
    }
    .form-control:focus {
        outline: none;
        border-color: #E53E3E;
        box-shadow: 0 0 0 3px rgba(229,62,62,0.2);
    }
    textarea.form-control {
        resize: vertical;
    }
    html.dark .form-control {
        background: #0F172A;
        border-color: #334155;
        color: #F1F5F9;
    }
    .form-hint {
        display: block;
        margin-top: 0.25rem;
        font-size: 0.7rem;
        color: #94A3B8;
    }
    .info-hint {
        color: #7C3AED;
    }
    .form-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
        margin-top: 1rem;
    }
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.375rem 1rem;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
    }
    .btn-primary {
        background: #E53E3E;
        color: white;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
    .btn-primary:hover {
        background: #C53030;
        transform: translateY(-1px);
    }
    .btn-ghost {
        background: transparent;
        border: 1px solid #E2E8F0;
        color: #475569;
    }
    .btn-ghost:hover {
        background: #F8FAFC;
        border-color: #CBD5E1;
        color: #1E293B;
    }
    html.dark .btn-ghost {
        border-color: #334155;
        color: #94A3B8;
    }
    html.dark .btn-ghost:hover {
        background: #1E293B;
        border-color: #475569;
        color: #F1F5F9;
    }
    @media (max-width: 480px) {
        .card-body {
            padding: 1rem;
        }
        .form-actions {
            flex-direction: column;
        }
        .form-actions .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>
{% endblock %}