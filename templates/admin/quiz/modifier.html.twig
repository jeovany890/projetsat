{% extends 'admin/layout.html.twig' %}

{% block page_title %}Paramètres — {{ quiz.titre }}{% endblock %}

{% block content %}

<div style="max-width: 640px;">

    <a href="{{ path('admin_quiz_questions', {id: quiz.id}) }}" class="btn btn-ghost btn-sm" style="margin-bottom: var(--space-6);">
        <i class="bi bi-arrow-left"></i> Retour aux questions
    </a>

    <div class="card">
        <div class="card-body" style="padding: var(--space-8);">

            <h2 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--gray-900); margin-bottom: var(--space-2);">
                <i class="bi bi-gear" style="color: var(--primary);"></i>
                Paramètres du quiz
            </h2>
            <p style="color: var(--gray-500); margin-bottom: var(--space-6);">
                Module : <strong>{{ quiz.module.titre }}</strong>
            </p>

            <form method="post">

                <div class="form-group" style="margin-bottom: var(--space-5);">
                    <label class="form-label">Titre du quiz *</label>
                    <input type="text" name="titre" class="form-control"
                        value="{{ quiz.titre }}" required>
                </div>

                <div class="form-group" style="margin-bottom: var(--space-5);">
                    <label class="form-label">Description</label>
                    <textarea name="description" class="form-control" rows="3">{{ quiz.description }}</textarea>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); margin-bottom: var(--space-5);">

                    <div class="form-group">
                        <label class="form-label">Score minimum (%)</label>
                        <input type="number" name="score_minimum" class="form-control"
                            value="{{ quiz.scoreMinimum }}" min="0" max="100">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Tentatives maximum</label>
                        <input type="number" name="tentatives_max" class="form-control"
                            value="{{ quiz.nombreTentativesMax }}" min="1" max="10">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Temps limite (minutes)</label>
                        <input type="number" name="temps_limite" class="form-control"
                            value="{{ quiz.tempsLimite }}" placeholder="Vide = illimité" min="1">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Ordre des questions</label>
                        <select name="melanger_questions" class="form-control">
                            <option value="1" {{ quiz.isMelangerQuestions ? 'selected' : '' }}>Aléatoire</option>
                            <option value="0" {{ not quiz.isMelangerQuestions ? 'selected' : '' }}>Ordre fixe</option>
                        </select>
                    </div>

                </div>

                <div style="display: flex; gap: var(--space-3); padding-top: var(--space-6); border-top: 1px solid var(--gray-200);">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle"></i> Enregistrer
                    </button>
                    <a href="{{ path('admin_quiz_questions', {id: quiz.id}) }}" class="btn btn-ghost">Annuler</a>
                </div>

            </form>
        </div>
    </div>

</div>

{% endblock %}
