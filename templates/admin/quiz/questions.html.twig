{% extends 'admin/layout.html.twig' %}

{% block page_title %}Questions — {{ quiz.titre }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_quiz_liste') }}" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
    <a href="{{ path('admin_quiz_modifier', {id: quiz.id}) }}" class="btn btn-ghost btn-sm">
        <i class="bi bi-gear"></i> Paramètres
    </a>
{% endblock %}

{% block content %}
<div class="quiz-questions-container">

    {# ── Informations générales du quiz ── #}
    <div class="card info-card">
        <div class="info-content">
            <div class="info-text">
                {% if quiz.estInitial() %}
                    <span><i class="bi bi-bar-chart-fill" style="color:#7C3AED;"></i> <strong>Quiz d'évaluation initiale</strong></span>
                {% elseif quiz.chapitre is not null %}
                    <span><i class="bi bi-journal-text"></i> Chapitre : <strong>{{ quiz.chapitre.titre }}</strong></span>
                    <span><i class="bi bi-book"></i> {{ quiz.chapitre.module.titre }}</span>
                {% elseif quiz.module is not null %}
                    <span><i class="bi bi-book"></i> Module : <strong>{{ quiz.module.titre }}</strong></span>
                {% endif %}
                <span><i class="bi bi-question-circle"></i> {{ quiz.questions|length }} question{{ quiz.questions|length > 1 ? 's' : '' }}</span>
                {% set totalPts = 0 %}
                {% for q in quiz.questions %}{% set totalPts = totalPts + q.points %}{% endfor %}
                <span><i class="bi bi-star"></i> {{ totalPts }} pts total</span>
            </div>

            {# ── Compteur par catégorie (quiz initial uniquement) ── #}
            {% if quiz.estInitial() %}
                {% set nbPh = quiz.questions|filter(q => (q.categorie ?? '') == 'phishing')|length %}
                {% set nbSm = quiz.questions|filter(q => (q.categorie ?? '') == 'smishing')|length %}
                {% set nbBP = quiz.questions|filter(q => (q.categorie ?? '') == 'bonnes_pratiques')|length %}
                <div class="cat-pool">
                    <span class="cat-pill {{ nbPh >= 3 ? 'ok' : 'warn' }}">
                        <i class="bi bi-envelope-exclamation"></i> Phishing : {{ nbPh }}/min.3
                    </span>
                    <span class="cat-pill {{ nbSm >= 3 ? 'ok' : 'warn' }}">
                        <i class="bi bi-phone"></i> Smishing : {{ nbSm }}/min.3
                    </span>
                    <span class="cat-pill {{ nbBP >= 4 ? 'ok' : 'warn' }}">
                        <i class="bi bi-shield-check"></i> Bonnes pratiques : {{ nbBP }}/min.4
                    </span>
                </div>
            {% else %}
                <div class="info-badges">
                    <span class="badge badge-info"><i class="bi bi-patch-check"></i> Score min. {{ quiz.scoreMinimum }}%</span>
                    <span class="badge badge-info"><i class="bi bi-arrow-repeat"></i> {{ quiz.nombreTentativesMax }} tentative{{ quiz.nombreTentativesMax > 1 ? 's' : '' }}</span>
                    <span class="badge badge-info"><i class="bi bi-shuffle"></i> Questions aléatoires</span>
                </div>
            {% endif %}
        </div>
    </div>

    {# ── Grille : liste questions (gauche) + formulaire ajout (droite) ── #}
    <div class="questions-grid">

        {# LISTE DES QUESTIONS #}
        <div class="questions-list">
            {% if quiz.questions is empty %}
                <div class="card empty-state">
                    <i class="bi bi-patch-question"></i>
                    <h3>Aucune question pour l'instant</h3>
                    <p>Utilisez le formulaire à droite pour ajouter votre première question.</p>
                </div>
            {% else %}
                <div class="questions-stack">
                    {% for question in quiz.questions %}
                        <div class="question-card">
                            <div class="question-header">
                                <div class="question-num">{{ loop.index0 }}</div>
                                <div class="question-content">
                                    <div class="question-badge">
                                        {# Badge type #}
                                        {% if question.type_question == 'QCM_UNIQUE' %}
                                            <span class="badge badge-qcm">QCM — 1 réponse</span>
                                        {% elseif question.type_question == 'QCM_MULTIPLE' %}
                                            <span class="badge badge-qcm-multi">QCM — Plusieurs réponses</span>
                                        {% elseif question.type_question == 'VRAI_FAUX' %}
                                            <span class="badge badge-vf">Vrai / Faux</span>
                                        {% endif %}

                                        {# Badge catégorie (quiz initial uniquement) #}
                                        {% if quiz.estInitial() and question.categorie is defined %}
                                            {% if question.categorie == 'phishing' %}
                                                <span class="badge" style="background:#FEE2E2;color:#991B1B;">
                                                    <i class="bi bi-envelope-exclamation"></i> Phishing
                                                </span>
                                            {% elseif question.categorie == 'smishing' %}
                                                <span class="badge" style="background:#FEF9C3;color:#854D0E;">
                                                    <i class="bi bi-phone"></i> Smishing
                                                </span>
                                            {% else %}
                                                <span class="badge" style="background:#DCFCE7;color:#166534;">
                                                    <i class="bi bi-shield-check"></i> Bonnes pratiques
                                                </span>
                                            {% endif %}
                                        {% endif %}
                                    </div>

                                    <p class="question-text">{{ question.question }}</p>

                                    <div class="options-list">
                                        {% for option in question.options %}
                                            {% set isCorrect = option in question.reponses_correctes %}
                                            <span class="option-badge {% if isCorrect %}correct{% else %}incorrect{% endif %}">
                                                {% if isCorrect %}✓ {% endif %}{{ option }}
                                            </span>
                                        {% endfor %}
                                    </div>

                                    {% if question.explication %}
                                        <p class="explanation"><i class="bi bi-lightbulb"></i> {{ question.explication }}</p>
                                    {% endif %}
                                </div>

                                <div class="question-actions">
                                    <span class="points-badge">{{ question.points }} pts</span>
                                    <div class="action-icons">
                                        <a href="{{ path('admin_quiz_question_modifier', {id: quiz.id, index: loop.index0}) }}" class="btn-icon" title="Modifier">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="post"
                                              action="{{ path('admin_quiz_question_supprimer', {quizId: quiz.id, index: loop.index0}) }}"
                                              id="form-supp-quest-{{ loop.index0 }}"
                                              class="inline-form">
                                            <button type="submit" class="btn-icon btn-danger-icon" title="Supprimer"
                                                    data-confirm="Supprimer cette question ?"
                                                    data-form="form-supp-quest-{{ loop.index0 }}">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        {# FORMULAIRE D'AJOUT #}
        <div class="add-question-card">
            <div class="card">
                <div class="card-header">
                    <h2><i class="bi bi-plus-circle" style="color:#E53E3E;"></i> Ajouter une question</h2>
                </div>
                <div class="card-body">
                    <form method="post" action="{{ path('admin_quiz_question_ajouter', {id: quiz.id}) }}" id="formQuestion">

                        {# ── CATÉGORIE — uniquement pour le quiz initial ── #}
                        {% if quiz.estInitial() %}
                        <div class="form-group">
                            <label class="form-label">Catégorie <span style="color:#E53E3E;">*</span></label>
                            <select name="categorie" class="form-control" required>
                                <option value="">-- Choisir --</option>
                                <option value="phishing">🎣 Phishing (email)</option>
                                <option value="smishing">📱 Smishing (SMS / WhatsApp)</option>
                                <option value="bonnes_pratiques">🛡️ Bonnes pratiques en entreprise</option>
                            </select>
                            <p class="form-hint">Le tirage tire 3 phishing · 3 smishing · 4 bonnes pratiques</p>
                        </div>
                        {% endif %}

                        <div class="form-group">
                            <label class="form-label">Type *</label>
                            <select name="type_question" class="form-control" id="typeQuestion" onchange="updateFormType(this.value)">
                                <option value="QCM_UNIQUE">QCM — 1 seule réponse</option>
                                <option value="QCM_MULTIPLE">QCM — Plusieurs réponses</option>
                                <option value="VRAI_FAUX">Vrai / Faux</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Question *</label>
                            <textarea name="question" class="form-control" rows="3"
                                      placeholder="Ex: Que faites-vous si vous recevez un SMS suspect ?" required></textarea>
                        </div>

                        <div id="optionsSection" class="form-group">
                            <label class="form-label">Réponses proposées *</label>
                            <div id="optionsList" class="options-list-editor">
                                <div class="option-row">
                                    <input type="checkbox" name="reponses_correctes[]" value="" class="option-check" title="Cocher si bonne réponse">
                                    <input type="text" name="options[]" class="form-control form-control-sm option-text" placeholder="Option A" oninput="syncCheckValue(this)">
                                </div>
                                <div class="option-row">
                                    <input type="checkbox" name="reponses_correctes[]" value="" class="option-check" title="Cocher si bonne réponse">
                                    <input type="text" name="options[]" class="form-control form-control-sm option-text" placeholder="Option B" oninput="syncCheckValue(this)">
                                </div>
                            </div>
                            <button type="button" class="btn btn-ghost btn-sm" onclick="addOption()">
                                <i class="bi bi-plus"></i> Ajouter une option
                            </button>
                            <p class="form-hint">☑ Cochez la ou les bonne(s) réponse(s)</p>
                        </div>

                        <div id="vraiFauxSection" class="form-group" style="display:none;">
                            <label class="form-label">Bonne réponse *</label>
                            <div class="radio-group">
                                <label><input type="radio" name="reponses_correctes[]" value="Vrai"> Vrai</label>
                                <label><input type="radio" name="reponses_correctes[]" value="Faux"> Faux</label>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Points</label>
                                <input type="number" name="points" class="form-control" value="10" min="1" max="100">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Explication (optionnel)</label>
                                <input type="text" name="explication" class="form-control" placeholder="Pourquoi cette réponse ?">
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-block">
                            <i class="bi bi-plus-circle"></i> Ajouter la question
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .quiz-questions-container { display: flex; flex-direction: column; gap: 1.5rem; }
    .info-card { background: white; border-radius: 1rem; border: 1px solid #E2E8F0; padding: 1rem 1.25rem; }
    .info-content { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
    .info-text { display: flex; flex-wrap: wrap; gap: 1rem; font-size: 0.8125rem; color: #475569; align-items: center; }
    .info-text i { margin-right: 0.25rem; }
    .info-badges { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .badge-info { background: #F1F5F9; color: #475569; padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.7rem; font-weight: 500; display: inline-flex; align-items: center; gap: 0.25rem; }
    /* Compteur pool initial */
    .cat-pool { display: flex; gap: 6px; flex-wrap: wrap; }
    .cat-pill { display: inline-flex; align-items: center; gap: 4px; font-size: 0.68rem; font-weight: 600; padding: 3px 10px; border-radius: 20px; }
    .cat-pill.ok   { background: #DCFCE7; color: #166534; }
    .cat-pill.warn { background: #FEE2E2; color: #991B1B; }
    html.dark .info-card { background: #1E293B; border-color: #334155; }
    html.dark .info-text { color: #94A3B8; }
    .questions-grid { display: grid; grid-template-columns: 1fr 380px; gap: 1.5rem; align-items: start; }
    @media (max-width: 900px) { .questions-grid { grid-template-columns: 1fr; } .add-question-card { position: static; } }
    .questions-stack { display: flex; flex-direction: column; gap: 1rem; }
    .question-card { background: white; border-radius: 1rem; border: 1px solid #E2E8F0; transition: all 0.2s; }
    .question-header { padding: 1rem; display: flex; gap: 1rem; align-items: flex-start; }
    .question-num { width: 32px; height: 32px; background: #EFF6FF; border: 1px solid #BFDBFE; border-radius: 0.75rem; display: flex; align-items: center; justify-content: center; font-weight: 700; color: #E53E3E; flex-shrink: 0; font-size: 13px; }
    .question-content { flex: 1; min-width: 0; }
    .question-badge { margin-bottom: 0.5rem; display: flex; flex-wrap: wrap; gap: 4px; }
    .badge { display: inline-flex; align-items: center; gap: 3px; padding: 2px 8px; border-radius: 20px; font-size: 0.65rem; font-weight: 600; }
    .badge-qcm { background: #DBEAFE; color: #1D4ED8; }
    .badge-qcm-multi { background: #CFFAFE; color: #0E7490; }
    .badge-vf { background: #FEF3C7; color: #B45309; }
    .question-text { font-weight: 600; color: #0F172A; margin: 0 0 0.75rem 0; line-height: 1.4; font-size: 14px; }
    .options-list { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.5rem; }
    .option-badge { padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.7rem; background: #F1F5F9; color: #475569; border: 1px solid #E2E8F0; }
    .option-badge.correct { background: #DCFCE7; color: #166534; border-color: #BBF7D0; }
    .explanation { font-size: 0.7rem; color: #64748B; font-style: italic; margin: 0.5rem 0 0; }
    .question-actions { display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; flex-shrink: 0; }
    .points-badge { background: #FEF9C3; color: #854D0E; padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.7rem; font-weight: 600; }
    .action-icons { display: flex; gap: 0.25rem; }
    .btn-icon { background: transparent; border: 1px solid #E2E8F0; border-radius: 6px; width: 28px; height: 28px; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; color: #64748B; transition: all 0.15s; }
    .btn-icon:hover { background: #F1F5F9; color: #1E293B; }
    .btn-danger-icon:hover { background: #FEE2E2; color: #DC2626; border-color: #FECACA; }
    .inline-form { display: inline; }
    html.dark .question-card { background: #1E293B; border-color: #334155; }
    html.dark .question-text { color: #F1F5F9; }
    html.dark .btn-icon { border-color: #334155; color: #94A3B8; }
    .add-question-card { position: sticky; top: 1.5rem; }
    .add-question-card .card { background: white; border-radius: 1rem; border: 1px solid #E2E8F0; overflow: hidden; }
    html.dark .add-question-card .card { background: #1E293B; border-color: #334155; }
    .add-question-card .card-header { padding: 1rem 1.25rem; border-bottom: 1px solid #E2E8F0; background: #F8FAFC; }
    html.dark .add-question-card .card-header { background: #0F172A; border-color: #334155; }
    .add-question-card .card-header h2 { font-size: 1rem; font-weight: 700; color: #0F172A; margin: 0; display: flex; align-items: center; gap: 0.5rem; }
    html.dark .add-question-card .card-header h2 { color: #F1F5F9; }
    .add-question-card .card-body { padding: 1.25rem; }
    .form-group { margin-bottom: 1rem; }
    .form-label { display: block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #475569; margin-bottom: 0.4rem; }
    .form-control { width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #CBD5E1; border-radius: 0.5rem; font-size: 0.875rem; background: white; color: #0F172A; transition: all 0.15s; }
    .form-control:focus { outline: none; border-color: #E53E3E; box-shadow: 0 0 0 3px rgba(229,62,62,0.2); }
    html.dark .form-control { background: #0F172A; border-color: #334155; color: #F1F5F9; }
    .form-control-sm { padding: 0.25rem 0.5rem; font-size: 0.75rem; }
    .option-row { display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem; }
    .option-check { width: 18px; height: 18px; accent-color: #E53E3E; }
    .option-text { flex: 1; }
    .radio-group { display: flex; gap: 1rem; align-items: center; }
    .radio-group label { display: flex; align-items: center; gap: 0.25rem; cursor: pointer; }
    .form-row { display: grid; grid-template-columns: 1fr 2fr; gap: 0.75rem; }
    @media (max-width: 640px) { .form-row { grid-template-columns: 1fr; } }
    .btn-block { width: 100%; }
    .btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 1rem; border-radius: 8px; font-size: 0.75rem; font-weight: 600; text-decoration: none; transition: all 0.2s; cursor: pointer; border: none; }
    .btn-primary { background: #E53E3E; color: white; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
    .btn-primary:hover { background: #C53030; transform: translateY(-1px); }
    .btn-ghost { background: transparent; border: 1px solid #E2E8F0; color: #475569; }
    .btn-ghost:hover { background: #F8FAFC; border-color: #CBD5E1; color: #1E293B; }
    .btn-sm { padding: 0.25rem 0.75rem; font-size: 0.75rem; }
    .form-hint { font-size: 0.7rem; color: #94A3B8; margin-top: 0.25rem; }
    .empty-state { text-align: center; padding: 2rem 1.5rem; background: white; border-radius: 1rem; border: 1px solid #E2E8F0; }
    .empty-state i { font-size: 3rem; color: #CBD5E1; margin-bottom: 1rem; display: inline-block; }
    .empty-state h3 { font-size: 1rem; color: #0F172A; margin-bottom: 0.5rem; }
    .empty-state p { color: #64748B; font-size: 0.8125rem; }
    html.dark .empty-state { background: #1E293B; border-color: #334155; }
    html.dark .empty-state h3 { color: #F1F5F9; }
</style>
<script>
    function updateFormType(type) {
        const optionsSection = document.getElementById('optionsSection');
        const vfSection      = document.getElementById('vraiFauxSection');
        if (type === 'VRAI_FAUX') {
            optionsSection.style.display = 'none';
            vfSection.style.display      = 'block';
        } else {
            optionsSection.style.display = 'block';
            vfSection.style.display      = 'none';
        }
    }
    function syncCheckValue(input) {
        const row = input.closest('.option-row');
        const cb  = row.querySelector('.option-check');
        cb.value  = input.value;
    }
    function addOption() {
        const list   = document.getElementById('optionsList');
        const count  = list.querySelectorAll('.option-row').length;
        const labels = ['A','B','C','D','E','F'];
        const letter = labels[count] || (count + 1);
        const row    = document.createElement('div');
        row.className = 'option-row';
        row.innerHTML = `
            <input type="checkbox" name="reponses_correctes[]" value="" class="option-check">
            <input type="text" name="options[]" class="form-control form-control-sm option-text"
                   placeholder="Option ${letter}" oninput="syncCheckValue(this)">
            <button type="button" class="btn-icon" onclick="this.closest('.option-row').remove()"
                    style="color:#DC2626;flex-shrink:0;">×</button>
        `;
        list.appendChild(row);
    }
</script>
{% endblock %}
