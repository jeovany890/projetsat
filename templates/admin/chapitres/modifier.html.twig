{% block javascripts %}
{{ parent() }}
<script>
    // Charger les questions existantes
    let questions = {{ chapitre.quizQuestions ? chapitre.quizQuestions|json_encode|raw : '[]' }};
    let editingIndex = null;

    console.log('Questions brutes:', questions);

    // Normaliser les questions pour le formulaire (ancien format -> nouveau format)
    questions = questions.map(q => {
        // Si c'est déjà le nouveau format
        if (q.type && q.options && Array.isArray(q.options) && q.options[0] && typeof q.options[0] === 'object') {
            return q;
        }
        
        // Conversion de l'ancien format
        let type = q.type_question || q.type || 'QCM_UNIQUE';
        let optionsTexte = q.options || [];
        let reponsesCorrectes = q.reponses_correctes || [];
        let points = q.points || 10;
        let explication = q.explication || '';
        let question = q.question || '';
        
        // Construire les options au nouveau format
        let options = optionsTexte.map(texte => ({
            texte: texte,
            correcte: reponsesCorrectes.includes(texte)
        }));
        
        let bonneReponse = q.bonneReponse || (reponsesCorrectes.length > 0 ? reponsesCorrectes[0] : null);
        
        return {
            question: question,
            type: type,
            points: points,
            explication: explication,
            options: options,
            bonneReponse: bonneReponse
        };
    });

    console.log('Questions normalisées:', questions);

    function afficherQuestions() {
        const container = document.getElementById('questionsList');
        
        if (questions.length === 0) {
            container.innerHTML = `<div class="empty-state"><i class="bi bi-inbox"></i><p>Aucune question.</p></div>`;
            return;
        }
        
        container.innerHTML = questions.map((q, index) => {
            let typeLabel = q.type === 'QCM_UNIQUE' ? 'QCM – 1 réponse' : q.type === 'QCM_MULTIPLE' ? 'QCM – Multiple' : 'Vrai / Faux';
            return `
                <div class="question-item">
                    <div class="question-info">
                        <div class="question-texte">${escapeHtml(q.question)}</div>
                        <div class="question-meta"><span>${typeLabel}</span><span>${q.points || 0} pts</span></div>
                    </div>
                    <div class="question-actions">
                        <button type="button" class="btn btn-sm btn-ghost" onclick="modifierQuestion(${index})">Modifier</button>
                        <button type="button" class="btn btn-sm btn-danger" onclick="supprimerQuestion(${index})">Supprimer</button>
                    </div>
                </div>`;
        }).join('');
    }

    function ajouterQuestion() {
        editingIndex = null;
        document.getElementById('modalTitre').textContent = 'Ajouter une question';
        document.getElementById('question').value = '';
        document.getElementById('type_question').value = 'QCM_UNIQUE';
        document.getElementById('points').value = 10;
        document.getElementById('explication').value = '';
        document.querySelectorAll('input[name="vf"]').forEach(r => r.checked = false);
        updateFormType('QCM_UNIQUE');
        document.getElementById('optionsList').innerHTML = '';
        addOption();
        addOption();
        document.getElementById('modalQuestion').style.display = 'flex';
    }

    function modifierQuestion(index) {
        editingIndex = index;
        const q = questions[index];
        console.log('Modification question:', q);
        
        document.getElementById('modalTitre').textContent = 'Modifier la question';
        document.getElementById('question').value = q.question || '';
        document.getElementById('points').value = q.points || 10;
        document.getElementById('explication').value = q.explication || '';
        document.getElementById('type_question').value = q.type || 'QCM_UNIQUE';
        updateFormType(q.type || 'QCM_UNIQUE');
        
        if (q.type === 'VRAI_FAUX') {
            document.querySelectorAll('input[name="vf"]').forEach(r => {
                r.checked = (r.value === q.bonneReponse);
            });
        } else {
            document.getElementById('optionsList').innerHTML = '';
            if (q.options && q.options.length > 0) {
                q.options.forEach(opt => {
                    // opt peut être un objet {texte, correcte} ou une string
                    let texte = typeof opt === 'object' ? (opt.texte || '') : opt;
                    let correcte = typeof opt === 'object' ? (opt.correcte === true) : false;
                    addOption(texte, correcte);
                });
            } else {
                addOption();
                addOption();
            }
        }
        document.getElementById('modalQuestion').style.display = 'flex';
    }

    function supprimerQuestion(index) {
        if (confirm('Supprimer cette question ?')) { questions.splice(index, 1); afficherQuestions(); }
    }

    function updateFormType(type) {
        document.getElementById('optionsSection').style.display = (type === 'VRAI_FAUX') ? 'none' : 'block';
        document.getElementById('vraiFauxSection').style.display = (type === 'VRAI_FAUX') ? 'block' : 'none';
    }

    function addOption(texte = '', correcte = false) {
        const type = document.getElementById('type_question').value;
        const inputType = type === 'QCM_UNIQUE' ? 'radio' : 'checkbox';
        const div = document.createElement('div');
        div.className = 'option-row';
        div.innerHTML = `
            <input type="${inputType}" name="option_correcte" ${correcte ? 'checked' : ''}>
            <input type="text" class="form-control" placeholder="Texte de l'option" value="${escapeHtml(texte)}" required>
            <button type="button" class="btn btn-sm btn-danger" onclick="this.parentElement.remove()">Supprimer</button>`;
        document.getElementById('optionsList').appendChild(div);
    }

    function sauvegarderQuestion() {
        const questionTexte = document.getElementById('question').value.trim();
        const type = document.getElementById('type_question').value;
        const points = parseInt(document.getElementById('points').value) || 0;
        const explication = document.getElementById('explication').value.trim();
        if (!questionTexte) { alert('Saisissez la question.'); return; }
        
        let questionData = { question: questionTexte, type: type, points: points, explication: explication };
        
        if (type === 'VRAI_FAUX') {
            const sel = document.querySelector('input[name="vf"]:checked');
            if (!sel) { alert('Sélectionnez la bonne réponse.'); return; }
            questionData.bonneReponse = sel.value;
        } else {
            const rows = document.querySelectorAll('#optionsList .option-row');
            const options = [];
            let hasCorrect = false;
            rows.forEach(row => {
                const cb = row.querySelector('input[type="radio"], input[type="checkbox"]');
                const ti = row.querySelector('input[type="text"]');
                const t = ti.value.trim();
                if (t) { const c = cb.checked; if (c) hasCorrect = true; options.push({ texte: t, correcte: c }); }
            });
            if (options.length < 2) { alert('Au moins 2 options.'); return; }
            if (!hasCorrect) { alert('Sélectionnez une bonne réponse.'); return; }
            questionData.options = options;
        }
        
        if (editingIndex !== null) questions[editingIndex] = questionData;
        else questions.push(questionData);
        fermerModal();
        afficherQuestions();
    }

    function fermerModal() { document.getElementById('modalQuestion').style.display = 'none'; editingIndex = null; }
    function construireJson() { document.getElementById('quizQuestionsJson').value = JSON.stringify(questions); }
    function escapeHtml(text) { if (!text) return ''; const d = document.createElement('div'); d.textContent = text; return d.innerHTML; }
    window.addEventListener('DOMContentLoaded', () => afficherQuestions());
</script>
{% endblock %}