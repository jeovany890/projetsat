{% extends 'admin/layout.html.twig' %}

{% block page_title %}Modifier chapitre — {{ chapitre.titre }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_chapitres_liste', {moduleId: module.id}) }}" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
{% endblock %}

{% block content %}
<div class="chapitre-form-container">
    <form method="post" id="chapitreForm">
        <input type="hidden" name="quiz_questions_json" id="quizQuestionsJson">

        {# --- Informations générales --- #}
        <div class="card mb-4">
            <div class="card-header">
                <h2><i class="bi bi-journal-plus"></i> Informations du chapitre</h2>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label>Titre *</label>
                    <input type="text" name="titre" class="form-control" required value="{{ chapitre.titre }}">
                </div>
                <div class="form-group">
                    <label>Contenu *</label>
                    <textarea name="contenu" rows="8" class="form-control" required>{{ chapitre.contenu }}</textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>URL vidéo</label>
                        <input type="url" name="url_video" class="form-control" value="{{ chapitre.urlVideo }}">
                    </div>
                    <div class="form-group">
                        <label>Durée vidéo (min)</label>
                        <input type="number" name="duree_video" class="form-control" value="{{ chapitre.dureeVideo }}" min="1">
                    </div>
                </div>
            </div>
        </div>

        {# --- Paramètres du quiz --- #}
        <div class="card mb-4">
            <div class="card-header">
                <h2><i class="bi bi-patch-question"></i> Quiz du chapitre</h2>
            </div>
            <div class="card-body">
                <div class="form-row">
                    <div class="form-group">
                        <label>Nombre de tentatives</label>
                        <input type="number" name="quiz_nombre_tentatives_max" class="form-control" value="{{ chapitre.quizNombreTentativesMax ?? 3 }}" min="1">
                    </div>
                    <div class="form-group">
                        <label>Score minimum (%)</label>
                        <input type="number" name="quiz_score_minimum" class="form-control" value="{{ chapitre.quizScoreMinimum ?? 70 }}" min="0" max="100">
                    </div>
                </div>
            </div>
        </div>

        {# --- Gestionnaire de questions --- #}
        <div class="card mb-4">
            <div class="card-header-flex">
                <h2><i class="bi bi-list-ul"></i> Questions du quiz</h2>
                <button type="button" class="btn btn-primary btn-sm" onclick="ajouterQuestion()">
                    <i class="bi bi-plus-lg"></i> Ajouter une question
                </button>
            </div>
            <div class="card-body">
                <div id="questionsList" class="questions-stack"></div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary" onclick="construireJson()">
                <i class="bi bi-check-lg"></i> Enregistrer les modifications
            </button>
            <a href="{{ path('admin_chapitres_liste', {moduleId: module.id}) }}" class="btn btn-ghost">Annuler</a>
        </div>
    </form>
</div>

{# Modal pour ajouter/modifier une question #}
<div id="modalQuestion" class="modal" style="display:none;">
    <div class="modal-overlay" onclick="fermerModal()"></div>
    <div class="modal-content">
        <div class="modal-header">
            <h3 id="modalTitre">Ajouter une question</h3>
            <button type="button" class="btn-close" onclick="fermerModal()">&times;</button>
        </div>
        <form id="questionForm" onsubmit="event.preventDefault(); sauvegarderQuestion();">
            <div class="modal-body">
                <div class="form-group">
                    <label>Question *</label>
                    <textarea id="question" rows="2" class="form-control" required></textarea>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label>Type *</label>
                        <select id="type_question" class="form-control" onchange="updateFormType(this.value)">
                            <option value="QCM_UNIQUE">QCM – 1 réponse</option>
                            <option value="QCM_MULTIPLE">QCM – Multiple</option>
                            <option value="VRAI_FAUX">Vrai / Faux</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Points</label>
                        <input type="number" id="points" class="form-control" value="10" min="1">
                    </div>
                </div>
                
                {# Section QCM #}
                <div id="optionsSection">
                    <label>Options *</label>
                    <div id="optionsList"></div>
                    <button type="button" class="btn btn-ghost btn-sm mt-2" onclick="addOption()">
                        <i class="bi bi-plus"></i> Ajouter une option
                    </button>
                </div>
                
                {# Section Vrai/Faux #}
                <div id="vraiFauxSection" style="display:none;">
                    <label>Bonne réponse *</label>
                    <div class="radio-group">
                        <label><input type="radio" name="vf" value="Vrai"> Vrai</label>
                        <label><input type="radio" name="vf" value="Faux"> Faux</label>
                    </div>
                </div>
                
                <div class="form-group mt-3">
                    <label>Explication</label>
                    <textarea id="explication" rows="3" class="form-control" placeholder="Pourquoi cette réponse est correcte ?"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="fermerModal()">Annuler</button>
                <button type="submit" class="btn btn-primary">Enregistrer</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

