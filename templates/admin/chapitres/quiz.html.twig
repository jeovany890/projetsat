{% extends 'admin/layout.html.twig' %}

{% block page_title %}Quiz — {{ chapitre.titre }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_chapitres_liste', {moduleId: module.id}) }}" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i> Retour aux chapitres
    </a>
{% endblock %}

{% block content %}
<div class="quiz-chapitre-container">

    {% if quiz is null %}
        {# ── Pas de quiz ── #}
        <div class="card empty-quiz-card">
            <i class="bi bi-patch-question"></i>
            <h2>Ce chapitre n'a pas encore de quiz</h2>
            <p>
                Le quiz permet de vérifier la compréhension de l'employé avant de passer au chapitre suivant.<br>
                <strong>Chaque chapitre doit avoir 4 questions QCM avec 4 propositions de réponse.</strong>
            </p>
            <a href="{{ path('admin_chapitre_quiz', {moduleId: module.id, id: chapitre.id}) }}?creer=1" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Créer le quiz de ce chapitre
            </a>
        </div>
    {% else %}

        {# ── Grille principale : questions (gauche) + formulaire (droite) ── #}
        <div class="quiz-grid">

            {# Colonne gauche : paramètres + liste des questions #}
            <div class="quiz-left">

                {# Paramètres du quiz #}
                <div class="card">
                    <div class="card-header-flex">
                        <h3><i class="bi bi-gear" style="color: #E53E3E;"></i> Paramètres du quiz</h3>
                        <div class="quiz-badges">
                            <span class="badge badge-primary">Seuil : {{ quiz.scoreMinimum }}%</span>
                            <span class="badge badge-secondary">{{ quiz.nombreTentativesMax }} tentative(s)</span>
                            <span class="badge badge-info"><i class="bi bi-shuffle"></i> Questions aléatoires</span>
                        </div>
                    </div>
                    <form method="post" class="quiz-params-form">
                        <input type="hidden" name="action" value="modifier_parametres">
                        <div class="params-grid">
                            <div class="form-group">
                                <label class="form-label">Score minimum (%)</label>
                                <input type="number" class="form-control" name="score_minimum" value="{{ quiz.scoreMinimum }}" min="0" max="100">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Tentatives max</label>
                                <input type="number" class="form-control" name="tentatives_max" value="{{ quiz.nombreTentativesMax }}" min="1" max="10">
                            </div>
                        </div>
                        <button type="submit" class="btn btn-ghost btn-sm">
                            <i class="bi bi-save"></i> Enregistrer
                        </button>
                    </form>
                </div>

                {# Liste des questions #}
                <div class="card">
                    <div class="card-header-flex">
                        <h3><i class="bi bi-list-ol" style="color: #E53E3E;"></i> Questions ({{ quiz.questions|length }})</h3>
                        {% if quiz.questions|length < 4 %}
                            <span class="badge badge-warning">⚠️ Recommandé : 4 questions minimum</span>
                        {% else %}
                            <span class="badge badge-success">✅ {{ quiz.questions|length }} question(s)</span>
                        {% endif %}
                    </div>
                    <div class="questions-list">
                        {% if quiz.questions is empty %}
                            <div class="empty-questions">
                                <i class="bi bi-question-circle"></i>
                                <p>Aucune question. Utilisez le formulaire à droite.</p>
                            </div>
                        {% else %}
                            {% for question in quiz.questions %}
                                <div class="question-card">
                                    <div class="question-header">
                                        <div class="question-title">
                                            <span class="question-num">Q{{ loop.index }}</span>
                                            <span class="question-text">{{ question.question }}</span>
                                        </div>
                                        <form method="post" action="{{ path('admin_chapitre_quiz_question_supprimer', {moduleId: module.id, id: chapitre.id, index: loop.index0}) }}"
                                              onsubmit="return confirm('Supprimer cette question ?')" class="delete-form">
                                            <button type="submit" class="btn-icon btn-danger-icon" title="Supprimer">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                    <div class="options-grid">
                                        {% set letters = ['A', 'B', 'C', 'D'] %}
                                        {% for i, option in question.options %}
                                            {% set isCorrect = option in question.reponses_correctes %}
                                            <div class="option-item {% if isCorrect %}option-correct{% else %}option-incorrect{% endif %}">
                                                <span class="option-letter">{{ letters[i] ?? (i+1) }}</span>
                                                <span class="option-text">{{ option }}</span>
                                                {% if isCorrect %}
                                                    <i class="bi bi-check-circle-fill correct-icon"></i>
                                                {% endif %}
                                            </div>
                                        {% endfor %}
                                    </div>
                                    {% if question.explication %}
                                        <div class="question-explanation">
                                            <i class="bi bi-lightbulb"></i> {{ question.explication }}
                                        </div>
                                    {% endif %}
                                    <div class="question-footer">
                                        <span class="badge badge-light">{{ question.type_question }}</span>
                                        <span class="badge badge-light">{{ question.points }} pts</span>
                                    </div>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
            </div>

            {# Colonne droite : formulaire d'ajout de question #}
            <div class="quiz-right">
                <div class="card sticky-card">
                    <div class="card-header">
                        <h3><i class="bi bi-plus-circle" style="color: #E53E3E;"></i> Ajouter une question</h3>
                    </div>
                    <div class="card-body">
                        <form method="post" id="formQuestion">
                            <input type="hidden" name="action" value="ajouter_question">

                            <div class="form-group">
                                <label class="form-label">Question *</label>
                                <textarea class="form-control" name="question" id="questionText" rows="3" required placeholder="Ex: Quel est le principal signe d'un email phishing ?"></textarea>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Type</label>
                                <select class="form-control" name="type_question" id="typeQuestion" onchange="updateType()">
                                    <option value="QCM_UNIQUE">QCM (1 bonne réponse)</option>
                                    <option value="QCM_MULTIPLE">QCM Multiple</option>
                                    <option value="VRAI_FAUX">Vrai / Faux</option>
                                </select>
                            </div>

                            {# Conteneur des options #}
                            <div class="form-group">
                                <label class="form-label">Les 4 propositions * <span class="form-hint">(cochez la/les bonne(s))</span></label>
                                <div id="optionsContainer" class="options-editor">
                                    {% for lettre, placeholder in {'A': 'Première proposition', 'B': 'Deuxième proposition', 'C': 'Troisième proposition', 'D': 'Quatrième proposition'} %}
                                    <div class="option-row" id="row_{{ lettre }}">
                                        <div class="option-badge" id="badge_{{ lettre }}">{{ lettre }}</div>
                                        <input type="text" class="form-control" name="options[]" id="opt_{{ lettre }}" placeholder="{{ placeholder }}" oninput="syncOption('{{ lettre }}')">
                                        <div class="check-circle" id="checkBtn_{{ lettre }}" onclick="toggleCheck('{{ lettre }}')">
                                            <i class="bi bi-check2"></i>
                                        </div>
                                    </div>
                                    {% endfor %}
                                </div>
                                <div id="hiddenReponses"></div>
                                <p class="form-hint">Cliquez sur le cercle pour marquer la bonne réponse</p>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Explication <span class="form-hint">(optionnel)</span></label>
                                <textarea class="form-control" name="explication" rows="2" placeholder="Explication affichée à l'employé après la correction..."></textarea>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Points</label>
                                <input type="number" class="form-control" name="points" value="10" min="1" max="100">
                            </div>

                            <button type="submit" class="btn btn-primary btn-block" id="btnAjouter" disabled>
                                <i class="bi bi-plus-circle"></i> Ajouter la question
                            </button>
                        </form>

                        <hr class="separator">

                        <div class="suggestions-box">
                            <div class="suggestions-title">💡 Exemples de questions pour ce chapitre</div>
                            <div id="suggestions" class="suggestions-content">
                                Remplissez la question pour voir des suggestions...
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
