        }
        .option-row {
            flex-wrap: wrap;
        }
        .check-circle {
            margin-left: auto;
        }
    }
</style>

<script>
    const lettres = ['A', 'B', 'C', 'D'];
    let selectedChecks = new Set();

    function syncOption(lettre) {
        rebuildHidden();
        validateForm();
    }

    function rebuildHidden() {
        const container = document.getElementById('hiddenReponses');
        if (!container) return;
        container.innerHTML = '';
        selectedChecks.forEach(l => {
            const input = document.getElementById('opt_' + l);
            const val = input ? input.value.trim() : '';
            if (val) {
                const h = document.createElement('input');
                h.type = 'hidden';
                h.name = 'reponses_correctes[]';
                h.value = val;
                container.appendChild(h);
            }
        });
    }

    function toggleCheck(lettre) {
        const input = document.getElementById('opt_' + lettre);
        if (!input || !input.value.trim()) return;

        const type = document.getElementById('typeQuestion').value;
        if (type === 'QCM_UNIQUE' || type === 'VRAI_FAUX') {
            selectedChecks.forEach(l => setCheckVisual(l, false));
            selectedChecks.clear();
        }

        if (selectedChecks.has(lettre)) {
            selectedChecks.delete(lettre);
            setCheckVisual(lettre, false);
        } else {
            selectedChecks.add(lettre);
            setCheckVisual(lettre, true);
        }
        rebuildHidden();
        validateForm();
    }

    function setCheckVisual(lettre, checked) {
        const btn = document.getElementById('checkBtn_' + lettre);
        const badge = document.getElementById('badge_' + lettre);
        if (checked) {
            btn?.classList.add('active');
            if (badge) badge.style.setProperty('background', '#E53E3E');
            if (badge) badge.style.setProperty('color', 'white');
        } else {
            btn?.classList.remove('active');
            if (badge) badge.style.setProperty('background', '#F1F5F9');
            if (badge) badge.style.setProperty('color', '#475569');
        }
    }

    function updateType() {
        const type = document.getElementById('typeQuestion').value;
        selectedChecks.clear();
        rebuildHidden();

        if (type === 'VRAI_FAUX') {
            document.getElementById('optionsContainer').innerHTML = `
                <div class="option-row" id="row_A">
                    <div class="option-badge" id="badge_A">A</div>
                    <input type="text" class="form-control" name="options[]" id="opt_A" value="Vrai" readonly style="flex:1;">
                    <div class="check-circle" id="checkBtn_A" onclick="toggleCheck('A')"><i class="bi bi-check2"></i></div>
                </div>
                <div class="option-row" id="row_B">
                    <div class="option-badge" id="badge_B">B</div>
                    <input type="text" class="form-control" name="options[]" id="opt_B" value="Faux" readonly style="flex:1;">
                    <div class="check-circle" id="checkBtn_B" onclick="toggleCheck('B')"><i class="bi bi-check2"></i></div>
                </div>
            `;
        } else {
            // Restaurer les 4 champs standards
            document.getElementById('optionsContainer').innerHTML = `
                <div class="option-row" id="row_A">
                    <div class="option-badge" id="badge_A">A</div>
                    <input type="text" class="form-control" name="options[]" id="opt_A" placeholder="Première proposition" oninput="syncOption('A')">
                    <div class="check-circle" id="checkBtn_A" onclick="toggleCheck('A')"><i class="bi bi-check2"></i></div>
                </div>
                <div class="option-row" id="row_B">
                    <div class="option-badge" id="badge_B">B</div>
                    <input type="text" class="form-control" name="options[]" id="opt_B" placeholder="Deuxième proposition" oninput="syncOption('B')">
                    <div class="check-circle" id="checkBtn_B" onclick="toggleCheck('B')"><i class="bi bi-check2"></i></div>
                </div>
                <div class="option-row" id="row_C">
                    <div class="option-badge" id="badge_C">C</div>
                    <input type="text" class="form-control" name="options[]" id="opt_C" placeholder="Troisième proposition" oninput="syncOption('C')">
                    <div class="check-circle" id="checkBtn_C" onclick="toggleCheck('C')"><i class="bi bi-check2"></i></div>
                </div>
                <div class="option-row" id="row_D">
                    <div class="option-badge" id="badge_D">D</div>
                    <input type="text" class="form-control" name="options[]" id="opt_D" placeholder="Quatrième proposition" oninput="syncOption('D')">
                    <div class="check-circle" id="checkBtn_D" onclick="toggleCheck('D')"><i class="bi bi-check2"></i></div>
                </div>
            `;
        }
        validateForm();
    }

    function validateForm() {
        const question = document.getElementById('questionText')?.value.trim();
        const hasReponse = selectedChecks.size > 0;
        let hasOpts = false;
        for (let l of ['A','B','C','D']) {
            const el = document.getElementById('opt_' + l);
            if (el && el.value.trim()) { hasOpts = true; break; }
        }
        const btn = document.getElementById('btnAjouter');
        if (btn) btn.disabled = !(question && hasReponse && hasOpts);
    }

    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('questionText')?.addEventListener('input', validateForm);
        validateForm();
    });
</script>
{% endblock %}