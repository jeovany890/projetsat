{% extends 'admin/layout.html.twig' %}

{% block page_title %}Nouveau chapitre{% endblock %}

{% block content %}

<div style="max-width: 900px; margin: 0 auto;">
    
    <div style="margin-bottom: var(--space-6);">
        <a href="{{ path('admin_chapitres_liste', {moduleId: module.id}) }}" style="color: var(--gray-600); display: inline-flex; align-items: center; gap: var(--space-2);">
            <i class="bi bi-arrow-left"></i> Retour aux chapitres
        </a>
    </div>

    <div class="card">
        <div class="card-body" style="padding: var(--space-10);">
            
            <div style="margin-bottom: var(--space-8);">
                <h2 style="font-size: var(--text-3xl); font-weight: var(--font-bold); margin-bottom: var(--space-2);">
                    Nouveau chapitre
                </h2>
                <p style="color: var(--gray-600);">Module : {{ module.titre }}</p>
            </div>

            <form method="post">
                
                <div class="form-group">
                    <label class="form-label" for="titre">Titre du chapitre *</label>
                    <input type="text" class="form-control" id="titre" name="titre" required placeholder="Ex: Qu'est-ce que le phishing ?" autofocus>
                </div>

                <div class="form-group">
                    <label class="form-label" for="contenu">Contenu du chapitre *</label>
                    <textarea class="form-control" id="contenu" name="contenu" rows="15" required placeholder="Le contenu du chapitre (supporte HTML)..."></textarea>
                    <small style="color: var(--gray-500); font-size: var(--text-xs); margin-top: var(--space-1); display: block;">
                        💡 Vous pouvez utiliser du HTML pour formater le texte (gras, listes, etc.)
                    </small>
                </div>

                <div style="display: grid; grid-template-columns: 2fr 1fr; gap: var(--space-6);">
                    <div class="form-group">
                        <label class="form-label" for="url_video">
                            <i class="bi bi-play-circle"></i> URL de la vidéo (optionnelle)
                        </label>
                        <input type="url" class="form-control" id="url_video" name="url_video" placeholder="https://youtube.com/watch?v=...">
                        <small style="color: var(--gray-500); font-size: var(--text-xs); margin-top: var(--space-1); display: block;">
                            YouTube, Vimeo, ou lien direct
                        </small>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="duree_video">Durée (minutes)</label>
                        <input type="number" class="form-control" id="duree_video" name="duree_video" placeholder="10" min="1">
                    </div>
                </div>

                <div style="display: flex; gap: var(--space-4); margin-top: var(--space-8);">
                    <button type="submit" class="btn btn-primary btn-lg" style="flex: 1;">
                        <i class="bi bi-check-circle"></i> Créer le chapitre
                    </button>
                    <a href="{{ path('admin_chapitres_liste', {moduleId: module.id}) }}" class="btn btn-secondary btn-lg">
                        Annuler
                    </a>
                </div>

            </form>

        </div>
    </div>

</div>

{% endblock %}