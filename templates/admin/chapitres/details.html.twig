{% extends 'admin/layout.html.twig' %}

{% block page_title %}{{ module.titre }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_modules_liste') }}" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i> Retour aux modules
    </a>
    <a href="{{ path('admin_module_modifier', {id: module.id}) }}" class="btn btn-ghost btn-sm">
        <i class="bi bi-pencil"></i> Modifier
    </a>
    <a href="{{ path('admin_chapitre_nouveau', {moduleId: module.id}) }}" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg"></i> Ajouter un chapitre
    </a>
{% endblock %}

{% block content %}
<div class="module-detail-container">

    {# Carte d'information du module #}
    <div class="card module-info-card">
        <div class="module-info-content">
            <div>
                <h2>{{ module.titre }}</h2>
                <p class="module-description">{{ module.description }}</p>
                <div class="module-meta">
                    <span><i class="bi bi-folder"></i> {{ module.categorie.titre }}</span>
                    <span><i class="bi bi-signal"></i> {{ module.difficulte|capitalize }}</span>
                    <span><i class="bi bi-clock"></i> {{ module.dureeEstimee }} min</span>
                    <span><i class="bi bi-book"></i> {{ module.chapitres|length }} chapitre(s)</span>
                    <span><i class="bi bi-star"></i> {{ module.pointsReussite }} pts</span>
                </div>
            </div>
            <div class="module-status">
                <span class="badge {{ module.estPublie ? 'badge-success' : 'badge-gray' }}">
                    {{ module.estPublie ? 'Publié' : 'Brouillon' }}
                </span>
                <form method="post" action="{{ path('admin_module_toggle_publication', {id: module.id}) }}" class="inline-form">
                    <button type="submit" class="btn btn-ghost btn-sm">
                        <i class="bi bi-{{ module.estPublie ? 'eye-slash' : 'eye' }}"></i>
                        {{ module.estPublie ? 'Dépublier' : 'Publier' }}
                    </button>
                </form>
            </div>
        </div>
    </div>

    {# Grille principale : chapitres (gauche) + sidebar (droite) #}
    <div class="module-grid">

        {# Colonne gauche : liste des chapitres #}
        <div class="chapitres-section">
            <div class="card">
                <div class="card-header-flex">
                    <h3><i class="bi bi-journal-text" style="color: #E53E3E;"></i> Chapitres ({{ module.chapitres|length }})</h3>
                    <a href="{{ path('admin_chapitre_nouveau', {moduleId: module.id}) }}" class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-lg"></i> Ajouter
                    </a>
                </div>
                <div class="card-body">
                    {% if module.chapitres is empty %}
                        <div class="empty-chapitres">
                            <i class="bi bi-journal-x"></i>
                            <p>Aucun chapitre pour ce module.</p>
                            <a href="{{ path('admin_chapitre_nouveau', {moduleId: module.id}) }}" class="btn btn-primary btn-sm">
                                <i class="bi bi-plus-lg"></i> Créer le premier chapitre
                            </a>
                        </div>
                    {% else %}
                        <div class="chapitres-list">
                            {% for chapitre in module.chapitres %}
                                <div class="chapitre-item" style="border-left-color: 
                                    {% if chapitre.quiz and chapitre.quiz.questions|length >= 4 %}#10B981
                                    {% elseif chapitre.quiz %}#F59E0B
                                    {% else %}#CBD5E1{% endif %}">
                                    <div class="chapitre-header">
                                        <div class="chapitre-num">{{ loop.index }}</div>
                                        <div class="chapitre-info">
                                            <div class="chapitre-titre">{{ chapitre.titre }}</div>
                                            <div class="chapitre-badges">
                                                {% if chapitre.urlVideo %}
                                                    <span class="badge badge-info"><i class="bi bi-play-circle"></i> Vidéo</span>
                                                {% endif %}
                                                {% if chapitre.quiz %}
                                                    {% set nbQ = chapitre.quiz.questions|length %}
                                                    <span class="badge {{ nbQ >= 4 ? 'badge-success' : 'badge-warning' }}">
                                                        <i class="bi bi-patch-question-fill"></i> {{ nbQ }}/4 questions
                                                    </span>
                                                {% else %}
                                                    <span class="badge badge-gray"><i class="bi bi-patch-question"></i> Pas de quiz</span>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                    <div class="chapitre-extrait">
                                        {{ chapitre.contenu|striptags|slice(0, 120) }}{% if chapitre.contenu|length > 120 %}...{% endif %}
                                    </div>
                                    <div class="chapitre-actions">
                                        <a href="{{ path('admin_chapitre_modifier', {moduleId: module.id, id: chapitre.id}) }}" class="btn btn-ghost btn-sm">
                                            <i class="bi bi-pencil"></i> Modifier
                                        </a>
                                        <a href="{{ path('admin_chapitre_quiz', {moduleId: module.id, id: chapitre.id}) }}" class="btn btn-ghost btn-sm">
                                            <i class="bi bi-patch-question{{ chapitre.quiz ? '-fill' : '' }}"></i>
                                            {% if chapitre.quiz %}Quiz ({{ chapitre.quiz.questions|length }}/4){% else %}Ajouter quiz{% endif %}
                                        </a>
                                        <form method="post" action="{{ path('admin_chapitre_supprimer', {moduleId: module.id, id: chapitre.id}) }}" class="delete-form" onsubmit="return confirm('Supprimer « {{ chapitre.titre }} » ?')">
                                            <button type="submit" class="btn btn-ghost btn-sm btn-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>

                        {# Barre de progression des quiz #}
                        {% set chapComplets = module.chapitres|filter(c => c.quiz is not null and c.quiz.questions|length >= 4)|length %}
                        {% set chapTotal = module.chapitres|length %}
                        <div class="progress-quiz">
                            <div class="progress-quiz-header">
                                <span>Chapitres avec quiz complet (4+ questions)</span>
                                <strong class="{{ chapComplets == chapTotal ? 'text-success' : 'text-warning' }}">{{ chapComplets }}/{{ chapTotal }}</strong>
                            </div>
                            <div class="progress-bar-bg">
                                <div class="progress-bar-fill" style="width: {{ chapTotal > 0 ? (chapComplets / chapTotal * 100)|round : 0 }}%; background: {{ chapComplets == chapTotal ? '#10B981' : '#F59E0B' }};"></div>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Colonne droite : résumé, simulation, accès rapide #}
        <div class="sidebar-section">
            {# Résumé statistiques #}
            <div class="card">
                <div class="card-header">
                    <h4><i class="bi bi-graph-up"></i> Résumé</h4>
                </div>
                <div class="card-body">
                    {% set chapAvecQuiz = module.chapitres|filter(c => c.quiz is not null)|length %}
                    {% set totalQuestions = 0 %}
                    {% for chap in module.chapitres %}
                        {% if chap.quiz %}{% set totalQuestions = totalQuestions + chap.quiz.questions|length %}{% endif %}
                    {% endfor %}
                    <div class="stats-summary">
                        <div class="stat-row">
                            <span>Chapitres</span>
                            <strong>{{ module.chapitres|length }}</strong>
                        </div>
                        <div class="stat-row">
                            <span>Avec quiz</span>
                            <strong class="text-success">{{ chapAvecQuiz }}</strong>
                        </div>
                        <div class="stat-row">
                            <span>Sans quiz</span>
                            <strong class="{{ (module.chapitres|length - chapAvecQuiz) > 0 ? 'text-warning' : 'text-muted' }}">{{ module.chapitres|length - chapAvecQuiz }}</strong>
                        </div>
                        <div class="stat-row">
                            <span>Total questions</span>
                            <strong>{{ totalQuestions }}</strong>
                        </div>
                    </div>
                    {% if module.chapitres|length == 0 %}
                        <div class="alert-warning">⚠️ Aucun chapitre</div>
                    {% elseif (module.chapitres|length - chapAvecQuiz) > 0 %}
                        <div class="alert-warning">⚠️ Des chapitres n'ont pas encore de quiz</div>
                    {% else %}
                        <div class="alert-success">✅ Tous les chapitres ont leur quiz</div>
                    {% endif %}
                </div>
            </div>

            {# Simulation finale #}
            <div class="card simulation-card">
                <div class="card-header">
                    <h4><i class="bi bi-joystick" style="color: #8B5CF6;"></i> Simulation finale</h4>
                </div>
                <div class="card-body">
                    <p class="simulation-desc">Jouée par l'employé après avoir terminé tous les chapitres.</p>
                    {% if module.simulation is not null %}
                        <div class="simulation-linked">
                            <div>
                                <strong>{{ module.simulation.titre }}</strong>
                                <div class="simulation-meta">{{ module.simulation.typeSimulation }} · {{ module.simulation.dureeEstimee }} min</div>
                            </div>
                            <span class="badge badge-linked">Liée</span>
                        </div>
                    {% else %}
                        <div class="simulation-empty">
                            <i class="bi bi-joystick"></i>
                            <span>Aucune simulation liée</span>
                        </div>
                    {% endif %}
                    <form method="post" action="{{ path('admin_module_simulation', {id: module.id}) }}" class="simulation-form">
                        <select name="simulation_id" class="form-control">
                            <option value="aucune">— Aucune —</option>
                            {% for sim in simulationsDisponibles %}
                                <option value="{{ sim.id }}" {{ module.simulation and module.simulation.id == sim.id ? 'selected' }}>
                                    {{ sim.titre }}
                                </option>
                            {% endfor %}
                        </select>
                        <button type="submit" class="btn btn-primary btn-sm btn-block">
                            <i class="bi bi-link-45deg"></i> {{ module.simulation is not null ? 'Changer' : 'Lier une simulation' }}
                        </button>
                    </form>
                    {% if simulationsDisponibles is empty %}
                        <div class="text-center mt-3">
                            <a href="{{ path('admin_simulation_nouvelle') }}" class="btn-link">+ Créer une simulation</a>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Accès rapide #}
            <div class="card">
                <div class="card-header">
                    <h4><i class="bi bi-lightning-charge"></i> Accès rapide</h4>
                </div>
                <div class="card-body">
                    <div class="quick-links">
                        <a href="{{ path('admin_chapitre_nouveau', {moduleId: module.id}) }}" class="btn btn-ghost btn-sm">
                            <i class="bi bi-plus-circle"></i> Nouveau chapitre
                        </a>
                        <a href="{{ path('admin_simulation_nouvelle') }}" class="btn btn-ghost btn-sm">
                            <i class="bi bi-joystick"></i> Nouvelle simulation
                        </a>
                        <a href="{{ path('admin_simulations_liste') }}" class="btn btn-ghost btn-sm">
                            <i class="bi bi-collection"></i> Gérer les simulations
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .module-detail-container {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* Carte d'information du module */
    .module-info-card {
        background: white;
        border-radius: 1rem;
        border: 1px solid #E2E8F0;
        padding: 1.25rem;
    }
    .module-info-content {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .module-info-content h2 {
        font-size: 1.25rem;
        font-weight: 800;
        color: #0F172A;
        margin: 0 0 0.5rem 0;
    }
    .module-description {
        color: #475569;
        font-size: 0.8125rem;
        margin: 0 0 0.75rem 0;
        line-height: 1.5;
    }
    .module-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        font-size: 0.7rem;
        color: #64748B;
    }
    .module-meta i {
        margin-right: 0.25rem;
    }
    .module-status {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.5rem;
    }
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        white-space: nowrap;
    }
    .badge-success { background: #DCFCE7; color: #166534; }
    .badge-gray    { background: #F1F5F9; color: #475569; }
    .badge-info    { background: #DBEAFE; color: #1D4ED8; }
    .badge-warning { background: #FEF9C3; color: #854D0E; }
    .badge-linked  { background: #EDE9FE; color: #5B21B6; }
    html.dark .badge-success { background: #14532D; color: #4ADE80; }
    html.dark .badge-gray    { background: #1E293B; color: #94A3B8; }
    html.dark .badge-info    { background: #1E3A8A; color: #60A5FA; }
    html.dark .badge-warning { background: #78350F; color: #FDE047; }
    html.dark .badge-linked  { background: #4C1D95; color: #C4B5FD; }

    /* Grille principale */
    .module-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 1.5rem;
    }
    @media (max-width: 900px) {
        .module-grid {
            grid-template-columns: 1fr;
        }
    }

    /* Cartes génériques */
    .card {
        background: white;
        border-radius: 1rem;
        border: 1px solid #E2E8F0;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }
    html.dark .card {
        background: #1E293B;
        border-color: #334155;
    }
    .card-header-flex {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #E2E8F0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .card-header-flex h3 {
        font-size: 1rem;
        font-weight: 700;
        color: #0F172A;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .card-header {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid #E2E8F0;
    }
    .card-header h4 {
        font-size: 0.8125rem;
        font-weight: 700;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .card-body {
        padding: 1rem;
    }
    html.dark .card-header-flex h3,
    html.dark .card-header h4 {
        color: #F1F5F9;
    }

    /* Liste des chapitres */
    .chapitres-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .chapitre-item {
        border: 1px solid #E2E8F0;
        border-radius: 0.75rem;
        border-left-width: 4px;
        padding: 0.75rem;
        background: white;
    }
    html.dark .chapitre-item {
        background: #0F172A;
        border-color: #334155;
    }
    .chapitre-header {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        margin-bottom: 0.5rem;
    }
    .chapitre-ordre {
        width: 32px;
        height: 32px;
        background: #E53E3E;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: white;
        flex-shrink: 0;
    }
    .chapitre-info {
        flex: 1;
    }
    .chapitre-titre {
        font-weight: 600;
        color: #0F172A;
        font-size: 0.875rem;
    }
    .chapitre-badges {
        display: flex;
        gap: 0.5rem;
        margin-top: 0.25rem;
    }
    .chapitre-order-buttons {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    .btn-icon {
        width: 28px;
        height: 28px;
        background: transparent;
        border: 1px solid #E2E8F0;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #64748B;
        transition: all 0.15s;
    }
    .btn-icon:disabled {
        opacity: 0.3;
        cursor: not-allowed;
    }
    .btn-icon:hover:not(:disabled) {
        background: #F1F5F9;
        border-color: #CBD5E1;
        color: #1E293B;
    }
    .chapitre-extrait {
        font-size: 0.7rem;
        color: #64748B;
        background: #F8FAFC;
        padding: 0.5rem;
        border-radius: 0.5rem;
        margin: 0.5rem 0;
    }
    .chapitre-actions {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .progress-quiz {
        margin-top: 1rem;
        padding: 0.75rem;
        background: #F8FAFC;
        border-radius: 0.75rem;
    }
    .progress-quiz-header {
        display: flex;
        justify-content: space-between;
        font-size: 0.7rem;
        margin-bottom: 0.5rem;
        color: #475569;
    }
    .progress-bar-bg {
        height: 6px;
        background: #E2E8F0;
        border-radius: 99px;
        overflow: hidden;
    }
    .progress-bar-fill {
        height: 100%;
        border-radius: 99px;
        transition: width 0.3s;
    }
    .text-success { color: #166534; }
    .text-warning { color: #D97706; }
    .text-muted { color: #94A3B8; }
    .alert-warning {
        background: #FEF9C3;
        border: 1px solid #FDE68A;
        border-radius: 0.5rem;
        padding: 0.5rem;
        font-size: 0.7rem;
        color: #854D0E;
        margin-top: 0.75rem;
    }
    .alert-success {
        background: #DCFCE7;
        border: 1px solid #BBF7D0;
        border-radius: 0.5rem;
        padding: 0.5rem;
        font-size: 0.7rem;
        color: #166534;
        margin-top: 0.75rem;
    }
    .stats-summary {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .stat-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #E2E8F0;
    }
    .simulation-card {
        border: 2px solid #E2E8F0;
        transition: all 0.15s;
    }
    .simulation-desc {
        font-size: 0.7rem;
        color: #64748B;
        margin-bottom: 0.75rem;
    }
    .simulation-linked {
        background: #F0FDF4;
        border: 1px solid #BBF7D0;
        border-radius: 0.75rem;
        padding: 0.5rem 0.75rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.75rem;
    }
    .simulation-meta {
        font-size: 0.65rem;
        color: #15803D;
    }
    .simulation-empty {
        text-align: center;
        padding: 0.75rem;
        background: #F8FAFC;
        border-radius: 0.75rem;
        margin-bottom: 0.75rem;
        color: #94A3B8;
    }
    .simulation-empty i {
        font-size: 1.25rem;
        display: block;
        margin-bottom: 0.25rem;
    }
    .simulation-form {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .form-control {
        width: 100%;
        padding: 0.4rem 0.75rem;
        border: 1px solid #CBD5E1;
        border-radius: 0.5rem;
        font-size: 0.75rem;
        background: white;
    }
    html.dark .form-control {
        background: #0F172A;
        border-color: #334155;
        color: #F1F5F9;
    }
    .btn-block {
        width: 100%;
    }
    .btn-link {
        font-size: 0.7rem;
        text-decoration: none;
        color: #E53E3E;
    }
    .quick-links {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.375rem 1rem;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
    }
    .btn-sm {
        padding: 0.25rem 0.75rem;
        font-size: 0.75rem;
    }
    .btn-primary {
        background: #E53E3E;
        color: white;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
    .btn-primary:hover {
        background: #C53030;
        transform: translateY(-1px);
    }
    .btn-ghost {
        background: transparent;
        border: 1px solid #E2E8F0;
        color: #475569;
    }
    .btn-ghost:hover {
        background: #F8FAFC;
        border-color: #CBD5E1;
        color: #1E293B;
    }
    .btn-danger {
        color: #DC2626;
        border-color: #FECACA;
    }
    .btn-danger:hover {
        background: #FEE2E2;
        border-color: #FECACA;
        color: #991B1B;
    }
    html.dark .btn-ghost {
        border-color: #334155;
        color: #94A3B8;
    }
    html.dark .btn-ghost:hover {
        background: #1E293B;
        border-color: #475569;
        color: #F1F5F9;
    }
    .inline-form {
        display: inline;
    }
    .delete-form {
        margin-left: auto;
    }
    .empty-chapitres {
        text-align: center;
        padding: 2rem 1rem;
        color: #94A3B8;
    }
    .empty-chapitres i {
        font-size: 2rem;
        display: block;
        margin-bottom: 0.5rem;
    }
    @media (max-width: 640px) {
        .module-info-content {
            flex-direction: column;
        }
        .module-status {
            align-items: flex-start;
        }
        .chapitre-header {
            flex-wrap: wrap;
        }
        .chapitre-order-buttons {
            flex-direction: row;
            margin-left: auto;
        }
        .chapitre-actions {
            flex-direction: column;
            align-items: stretch;
        }
        .delete-form {
            margin-left: 0;
        }
    }
</style>
{% endblock %}