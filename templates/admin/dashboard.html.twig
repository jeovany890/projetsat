{% extends 'admin/layout.html.twig' %}

{% block page_title %}Dashboard Administrateur{% endblock %}

{% block content %}
<div class="dash-container">

    {# 1. Section des KPI (Key Performance Indicators) #}
    <div class="dash-grid-4">
        
        {# Carte: Entreprises actives #}
        <div class="dash-card card-primary-gradient">
            <div class="card-icon-bg"></div>
            <div class="card-content">
                <div class="card-top">
                    <div class="card-info">
                        <span class="card-label text-white-80">Entreprises actives</span>
                        <h3 class="card-value text-white">{{ stats.entreprisesActives }}</h3>
                    </div>
                    <div class="card-icon text-white">
                        <i class="bi bi-building"></i>
                    </div>
                </div>
                <div class="card-bottom text-white-80">
                    <i class="bi bi-graph-up-arrow"></i> Sur {{ stats.totalEntreprises }} au total
                </div>
            </div>
        </div>

        {# Carte: Employés formés #}
        <div class="dash-card border-left-success">
            <div class="card-content">
                <div class="card-top">
                    <div class="card-info">
                        <span class="card-label">RSSI inscrits</span>
                        <h3 class="card-value text-success">{{ stats.totalRSSI }}</h3>
                    </div>
                    <div class="card-icon icon-success">
                        <i class="bi bi-people"></i>
                    </div>
                </div>
                <div class="card-bottom">
                    {{ stats.totalRSSI }} RSSI inscrits
                </div>
            </div>
        </div>

        {# Carte: En attente #}
        <div class="dash-card border-left-warning">
            <div class="card-content">
                <div class="card-top">
                    <div class="card-info">
                        <span class="card-label">En attente</span>
                        <h3 class="card-value text-warning">{{ stats.entreprisesEnAttente }}</h3>
                    </div>
                    <div class="card-icon icon-warning">
                        <i class="bi bi-clock-history"></i>
                    </div>
                </div>
                <div class="card-bottom">
                    Demandes à valider
                </div>
            </div>
        </div>

        {# Carte: Modules #}
        <div class="dash-card border-left-info">
            <div class="card-content">
                <div class="card-top">
                    <div class="card-info">
                        <span class="card-label">Modules actifs</span>
                        <h3 class="card-value text-info">{{ stats.modulesPublies }}</h3>
                    </div>
                    <div class="card-icon icon-info">
                        <i class="bi bi-book"></i>
                    </div>
                </div>
                <div class="card-bottom">
                    Sur {{ stats.totalModules }} créés
                </div>
            </div>
        </div>
    </div>

    {# 2. Section des Graphiques Principaux #}
    <div class="dash-grid-2-1">
        
        {# Évolution #}
        <div class="dash-card">
            <div class="card-header">
                <h3 class="card-title"><i class="bi bi-graph-up text-primary"></i> Évolution des entreprises</h3>
            </div>
            <div class="chart-container">
                <canvas id="chartEvolution"></canvas>
            </div>
        </div>

        {# Secteurs #}
        <div class="dash-card">
            <div class="card-header">
                <h3 class="card-title"><i class="bi bi-pie-chart text-secondary"></i> Secteurs d'activité</h3>
            </div>
            <div class="chart-container">
                <canvas id="chartSecteurs"></canvas>
            </div>
        </div>
    </div>

    {# 3. Section des Graphiques Secondaires #}
    <div class="dash-grid-2">
        
        {# Statut #}
        <div class="dash-card">
            <div class="card-header">
                <h3 class="card-title"><i class="bi bi-bar-chart text-success"></i> Statut des entreprises</h3>
            </div>
            <div class="chart-container">
                <canvas id="chartStatut"></canvas>
            </div>
        </div>

        {# Campagnes #}
        <div class="dash-card flex-center">
            <div class="card-header w-100">
                <h3 class="card-title"><i class="bi bi-envelope-paper text-warning"></i> Campagnes phishing</h3>
            </div>
            <div class="campaign-stats">
                <div class="campaign-number">{{ stats.totalCampagnesPhishing }}</div>
                <div class="campaign-label">Campagnes lancées au total</div>
                <div class="campaign-badge">
                    <span class="badge badge-success pulse-animation">
                        <i class="bi bi-activity"></i> {{ stats.campagnesEnCours }} en cours
                    </span>
                </div>
            </div>
        </div>
    </div>

    {# 4. Section Tableau de données #}
    <div class="dash-card">
        <div class="card-header flex-between">
            <h3 class="card-title"><i class="bi bi-building-add text-info"></i> Dernières inscriptions</h3>
            <a href="{{ path('admin_entreprises_liste') }}" class="btn-link">Voir tout</a>
        </div>
        <div class="table-responsive">
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Entreprise</th>
                        <th>Secteur</th>
                        <th class="text-center">Employés</th>
                        <th>Date d'inscription</th>
                        <th class="text-center">Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entreprise in dernieresEntreprises %}
                    <tr>
                        <td>
                            <div class="fw-bold text-dark">{{ entreprise.nom }}</div>
                            <div class="text-sm text-muted">IFU: {{ entreprise.ifu }}</div>
                        </td>
                        <td>
                            <span class="badge badge-light">{{ entreprise.secteur }}</span>
                        </td>
                        <td class="text-center fw-medium">{{ entreprise.nombreEmployes }}</td>
                        <td class="text-muted text-sm">
                            <i class="bi bi-calendar3"></i> {{ entreprise.dateCreation|date('d/m/Y') }}
                        </td>
                        <td class="text-center">
                            {% if entreprise.statut == 'ACTIF' %}
                                <span class="badge badge-success">Actif</span>
                            {% elseif entreprise.statut == 'EN_ATTENTE' %}
                                <span class="badge badge-warning">En attente</span>
                            {% else %}
                                <span class="badge badge-light">{{ entreprise.statut }}</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Aucune entreprise récente.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>
<style>
/* ==========================================================================
   DASHBOARD UI / UX STYLES (CORRIGÉ ULTRA-RESPONSIVE)
   ========================================================================== */
.dash-container {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding-bottom: 24px;
    width: 100%; /* Empêche le débordement du conteneur parent */
    overflow-x: hidden;
}

/* Grilles CSS avec protection anti-débordement (min(100%, Xpx)) */
.dash-grid-4 {
    display: grid;
    /* La magie opère ici : 240px max, mais 100% si l'écran est plus petit */
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
    gap: 20px;
}
.dash-grid-2-1 {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 20px;
}
.dash-grid-2 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 350px), 1fr));
    gap: 20px;
}

/* Bascule de la grille asymétrique sur les écrans moyens et petits */
@media (max-width: 992px) {
    .dash-grid-2-1 { grid-template-columns: 1fr; }
}

/* Cartes (Cards) */
.dash-card {
    background: #ffffff;
    border-radius: 16px;
    border: 1px solid #E2E8F0;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    padding: 24px;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    width: 100%; /* Sécurité supplémentaire */
    box-sizing: border-box;
}
.dash-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -2px rgba(0, 0, 0, 0.04);
}

/* En-têtes de cartes */
.card-header { margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid #F1F5F9; }
.card-title { font-size: 16px; font-weight: 700; color: #1E293B; margin: 0; display: flex; align-items: center; gap: 8px; }

/* Contenu des KPI */
.card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; position: relative; z-index: 2; }
.card-label { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #64748B; display: block; margin-bottom: 8px; }
.card-value { font-size: 32px; font-weight: 800; margin: 0; line-height: 1; color: #0F172A; }
.card-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0; }
.card-bottom { font-size: 13px; color: #64748B; font-weight: 500; position: relative; z-index: 2; }

/* Couleurs et bordures sémantiques */
.border-left-success { border-left: 4px solid #10B981; }
.border-left-warning { border-left: 4px solid #F59E0B; }
.border-left-info { border-left: 4px solid #3B82F6; }
.icon-success { background: #D1FAE5; color: #10B981; }
.icon-warning { background: #FEF3C7; color: #F59E0B; }
.icon-info { background: #DBEAFE; color: #3B82F6; }
.text-success { color: #10B981 !important; }
.text-warning { color: #F59E0B !important; }
.text-info { color: #3B82F6 !important; }
.text-primary { color: #6366F1 !important; }
.text-secondary { color: #EC4899 !important; }

/* Carte dégradé (Primary) */
.card-primary-gradient { background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%); border: none; }
.card-primary-gradient .card-icon-bg { position: absolute; top: -20px; right: -20px; width: 120px; height: 120px; background: rgba(255,255,255,0.1); border-radius: 50%; z-index: 1; }
.text-white { color: #ffffff !important; }
.text-white-80 { color: rgba(255,255,255,0.8) !important; }

/* Conteneurs Chart.js */
.chart-container { position: relative; width: 100%; height: 300px; }
.chart-container canvas { max-width: 100%; }

/* Zone Campagne */
.campaign-stats { text-align: center; padding: 20px 0; }
.campaign-number { font-size: 56px; font-weight: 900; background: linear-gradient(135deg, #6366F1, #EC4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; line-height: 1; word-break: break-word; }
.campaign-label { color: #64748B; font-weight: 500; margin: 12px 0 20px 0; }

/* Tableaux - Gestion du scroll horizontal forcé sur mobile */
.table-responsive { overflow-x: auto; width: 100%; -webkit-overflow-scrolling: touch; margin-bottom: 0; border-radius: 8px; }
.dash-table { width: 100%; border-collapse: separate; border-spacing: 0; min-width: 600px; }
.dash-table th { padding: 12px 16px; text-align: left; font-size: 12px; font-weight: 700; text-transform: uppercase; color: #64748B; background: #F8FAFC; border-bottom: 2px solid #E2E8F0; white-space: nowrap; }
.dash-table td { padding: 16px; vertical-align: middle; border-bottom: 1px solid #E2E8F0; transition: background 0.2s; }
.dash-table tr:last-child td { border-bottom: none; }
.dash-table tbody tr:hover td { background: #F8FAFC; }

/* Badges & Utilitaires */
.badge { display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; border-radius: 9999px; font-size: 12px; font-weight: 600; white-space: nowrap; }
.badge-success { background: #D1FAE5; color: #065F46; }
.badge-warning { background: #FEF3C7; color: #92400E; }
.badge-light { background: #F1F5F9; color: #475569; }

.flex-between { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
.flex-center { display: flex; flex-direction: column; align-items: center; justify-content: center; }
.w-100 { width: 100%; }
.fw-bold { font-weight: 700; }
.fw-medium { font-weight: 500; }
.text-sm { font-size: 13px; }
.text-muted { color: #94A3B8; }
.py-4 { padding-top: 24px; padding-bottom: 24px; }
.btn-link { color: #6366F1; text-decoration: none; font-size: 13px; font-weight: 600; white-space: nowrap; }
.btn-link:hover { text-decoration: underline; }

/* Animation */
@keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
    70% { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
    100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
}
.pulse-animation { animation: pulse 2s infinite; }

/* ==========================================================================
   CORRECTIF MICRO-ÉCRANS (< 400px) - iPhone SE, etc.
   ========================================================================== */
@media (max-width: 400px) {
    .dash-container { gap: 16px; }
    .dash-grid-4, .dash-grid-2-1, .dash-grid-2 { gap: 16px; }
    
    /* Réduction du padding intérieur pour gagner de l'espace vitale */
    .dash-card { padding: 16px; }
    
    /* Ajustement de la typographie pour éviter le chevauchement */
    .card-value { font-size: 26px; }
    .card-label { font-size: 11px; }
    .card-icon { width: 40px; height: 40px; font-size: 20px; }
    
    .campaign-number { font-size: 42px; }
    .card-title { font-size: 14px; }
    
    /* Les graphiques prennent moins de hauteur sur les petits téléphones */
    .chart-container { height: 250px; }
}
</style>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const colors = { primary: '#6366F1', secondary: '#EC4899', success: '#10B981', warning: '#F59E0B', danger: '#EF4444', info: '#3B82F6', text: '#475569', grid: '#E2E8F0' };

    // Options communes pour rendre les graphiques vraiment responsives
    const commonOptions = {
        responsive: true,
        maintainAspectRatio: false, // Permet au canvas de s'adapter à la hauteur du conteneur
        plugins: {
            legend: { display: false },
            tooltip: { backgroundColor: 'rgba(15, 23, 42, 0.9)', padding: 12, cornerRadius: 8 }
        }
    };

    // 1. Évolution (Ligne)
    new Chart(document.getElementById('chartEvolution').getContext('2d'), {
        type: 'line',
        data: {
            labels: {{ evolutionEntreprises|default([])|map(e => e.mois)|json_encode|raw }},
            datasets: [{
                label: 'Entreprises',
                data: {{ evolutionEntreprises|default([])|map(e => e.total)|json_encode|raw }},
                borderColor: colors.primary,
                backgroundColor: 'rgba(99, 102, 241, 0.1)',
                borderWidth: 3, fill: true, tension: 0.4, pointBackgroundColor: colors.primary, pointRadius: 4
            }]
        },
        options: { ...commonOptions, scales: { 
            y: { beginAtZero: true, grid: { color: colors.grid }, ticks: { precision: 0, color: colors.text } },
            x: { grid: { display: false }, ticks: { color: colors.text } }
        }}
    });

    // 2. Secteurs (Doughnut)
    new Chart(document.getElementById('chartSecteurs').getContext('2d'), {
        type: 'doughnut',
        data: {
            labels: {{ entreprisesParSecteur|default([])|map(e => e.secteur)|json_encode|raw }},
            datasets: [{
                data: {{ entreprisesParSecteur|default([])|map(e => e.total)|json_encode|raw }},
                backgroundColor: [colors.primary, colors.secondary, colors.success, colors.warning, colors.info],
                borderWidth: 0, hoverOffset: 4
            }]
        },
        options: { ...commonOptions, cutout: '70%', plugins: { 
            legend: { display: true, position: 'bottom', labels: { usePointStyle: true, padding: 20, font: { size: 12 } } }
        }}
    });

    // 3. Statut (Bar)
    new Chart(document.getElementById('chartStatut').getContext('2d'), {
        type: 'bar',
        data: {
            labels: ['Actives', 'En attente', 'Suspendues'],
            datasets: [{
                label: 'Entreprises',
                data: [{{ stats.entreprisesActives|default(0) }}, {{ stats.entreprisesEnAttente|default(0) }}, {{ stats.entreprisesSuspendues|default(0) }}],
                backgroundColor: [colors.success, colors.warning, colors.danger],
                borderRadius: 6, barThickness: 40
            }]
        },
        options: { ...commonOptions, scales: {
            y: { beginAtZero: true, grid: { color: colors.grid }, ticks: { precision: 0 } },
            x: { grid: { display: false } }
        }}
    });
});
</script>
{% endblock %}