{% extends 'admin/layout.html.twig' %}

{% block page_title %}Modifier — {{ simulation.titre }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_simulations_liste') }}" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
{% endblock %}

{% block content %}
<div class="simulation-form-container">

    {# Variables pour les placeholders JavaScript #}
    {% set ph_prenom     = '{{PRENOM}}' %}
    {% set ph_nom        = '{{NOM}}' %}
    {% set ph_email      = '{{EMAIL}}' %}
    {% set ph_telephone  = '{{TELEPHONE}}' %}
    {% set ph_entreprise = '{{ENTREPRISE}}' %}

    {# Données existantes #}
    {% set contenu = simulation.contenuSimulation %}
    {% set type_sim = simulation.typeSimulation %}

    <form method="post" id="formSim">
        <input type="hidden" name="contenu_simulation_json" id="contenuJson">

        <div class="sim-grid">
            {# Colonne gauche : formulaire #}
            <div class="sim-left">
                <div class="card">
                    <div class="card-header">
                        <h3>Informations générales</h3>
                        <span class="text-muted">#{{ simulation.id }}</span>
                    </div>
                    <div class="card-body">
                        <div class="form-group">
                            <label class="form-label">Titre *</label>
                            <input type="text" name="titre" required value="{{ simulation.titre }}" class="form-control">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Description</label>
                            <textarea name="description" rows="2" class="form-control">{{ simulation.description }}</textarea>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Type de simulation *</label>
                                <select name="type_simulation" id="typeSelect" class="form-control" onchange="changerType()" required>
                                    <option value="GMAIL"    {{ type_sim == 'GMAIL'    ? 'selected' }}>Gmail — Boite email</option>
                                    <option value="SMS"      {{ type_sim == 'SMS'      ? 'selected' }}>SMS — Messagerie</option>
                                    <option value="WHATSAPP" {{ type_sim == 'WHATSAPP' ? 'selected' }}>WhatsApp</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Difficulté</label>
                                <select name="difficulte" class="form-control">
                                    <option value="facile"    {{ simulation.difficulte == 'facile'    ? 'selected' }}>Facile</option>
                                    <option value="moyen"     {{ simulation.difficulte == 'moyen'     ? 'selected' }}>Moyen</option>
                                    <option value="difficile" {{ simulation.difficulte == 'difficile' ? 'selected' }}>Difficile</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Durée estimée (min)</label>
                                <input type="number" name="duree_estimee" value="{{ simulation.dureeEstimee }}" min="1" max="60" class="form-control">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Points si réussite</label>
                                <input type="number" name="points_reussite" value="{{ simulation.pointsReussite }}" class="form-control">
                            </div>
                        </div>
                        <div class="checkbox-group">
                            <label class="checkbox-label">
                                <input type="checkbox" name="est_publie" {{ simulation.estPublie ? 'checked' }}>
                                <span>Publiée</span>
                            </label>
                        </div>
                    </div>
                </div>

                {# Zone GMAIL #}
                <div id="zoneGmail" class="zone-simulation" style="{{ type_sim == 'GMAIL' ? '' : 'display:none;' }}">
                    <div class="card">
                        <div class="card-header-flex">
                            <div>
                                <h3>Emails de la boite Gmail</h3>
                                <p class="card-subtitle">Ajoutez, modifiez ou supprimez des emails.</p>
                            </div>
                            <button type="button" onclick="ajouterGmail()" class="btn btn-primary btn-sm">
                                <i class="bi bi-plus-lg"></i> Ajouter un email
                            </button>
                        </div>
                        <div class="card-body" id="listeGmail">
                            <div class="empty-message">Chargement...</div>
                        </div>
                    </div>
                </div>

                {# Zone SMS #}
                <div id="zoneSms" class="zone-simulation" style="{{ type_sim == 'SMS' ? '' : 'display:none;' }}">
                    <div class="card">
                        <div class="card-header-flex">
                            <div>
                                <h3>SMS de la messagerie</h3>
                                <p class="card-subtitle">Ajoutez, modifiez ou supprimez des SMS.</p>
                            </div>
                            <button type="button" onclick="ajouterSms()" class="btn btn-primary btn-sm">
                                <i class="bi bi-plus-lg"></i> Ajouter un SMS
                            </button>
                        </div>
                        <div class="card-body" id="listeSms">
                            <div class="empty-message">Chargement...</div>
                        </div>
                    </div>
                </div>

                {# Zone WhatsApp #}
                <div id="zoneWa" class="zone-simulation" style="{{ type_sim == 'WHATSAPP' ? '' : 'display:none;' }}">
                    <div class="card">
                        <div class="card-header-flex">
                            <div>
                                <h3>Conversations WhatsApp</h3>
                                <p class="card-subtitle">Ajoutez, modifiez ou supprimez des conversations.</p>
                            </div>
                            <button type="button" onclick="ajouterWa()" class="btn btn-primary btn-sm">
                                <i class="bi bi-plus-lg"></i> Ajouter une conversation
                            </button>
                        </div>
                        <div class="card-body" id="listeWa">
                            <div class="empty-message">Chargement...</div>
                        </div>
                    </div>
                </div>

                <button type="submit" onclick="return construireJson()" class="btn btn-primary btn-block">
                    <i class="bi bi-check-lg"></i> Enregistrer les modifications
                </button>
            </div>

            {# Colonne droite : aperçu #}
            <div class="sim-right">
                <div class="card">
                    <div class="card-header-flex">
                        <span>Aperçu de l'interface</span>
                        <span id="compteur" class="text-muted">—</span>
                    </div>
                </div>
                <div id="apercuGmail" class="apercu-card" style="{{ type_sim == 'GMAIL' ? '' : 'display:none;' }}">
                    <div class="apercu-header"><i class="bi bi-envelope-fill"></i> Gmail</div>
                    <div class="apercu-subheader">Simulation en cours — Phishing ou légitime ?</div>
                    <div class="apercu-content">
                        <div class="inbox-header">Principal</div>
                        <div id="apercuGmailRows"></div>
                    </div>
                </div>
                <div id="apercuSms" class="apercu-card apercu-dark" style="{{ type_sim == 'SMS' ? '' : 'display:none;' }}">
                    <div class="apercu-header-dark">Messages</div>
                    <div class="apercu-subheader-dark">Simulation SMS en cours</div>
                    <div id="apercuSmsRows"></div>
                </div>
                <div id="apercuWa" class="apercu-card apercu-wa" style="{{ type_sim == 'WHATSAPP' ? '' : 'display:none;' }}">
                    <div class="apercu-header-wa">WhatsApp</div>
                    <div class="apercu-subheader-wa">Simulation WhatsApp en cours</div>
                    <div id="apercuWaRows"></div>
                </div>
                <div id="apercuVide" class="apercu-empty" style="{{ type_sim ? 'display:none;' : '' }}">
                    <i class="bi bi-phone-fill"></i>
                    <p>L'aperçu apparaîtra ici</p>
                </div>
            </div>
        </div>
    </form>
</div>

