<script>
const PH_PRENOM     = "{{ ph_prenom }}";
const PH_NOM        = "{{ ph_nom }}";
const PH_EMAIL      = "{{ ph_email }}";
const PH_TELEPHONE  = "{{ ph_telephone }}";
const PH_ENTREPRISE = "{{ ph_entreprise }}";
const HINT_GMAIL    = "Placeholders : " + PH_PRENOM + " " + PH_NOM + " " + PH_EMAIL + " " + PH_TELEPHONE + " " + PH_ENTREPRISE;
const HINT_SMS      = "Placeholders : " + PH_PRENOM + " " + PH_TELEPHONE;
const HINT_CORPS    = "<p>Bonjour " + PH_PRENOM + ",</p><br><p>...</p>";

const LABELS = {
    GMAIL:    { danger: 'Phishing',           safe: 'Legitime',  badgeDanger: 'Phishing',  badgeSafe: 'Legitime'  },
    SMS:      { danger: 'Smishing',           safe: 'Legitime',  badgeDanger: 'Smishing',  badgeSafe: 'Legitime'  },
    WHATSAPP: { danger: 'Phishing / Arnaque', safe: 'Legitime',  badgeDanger: 'Phishing',  badgeSafe: 'Legitime'  }
};

const TYPE_INITIAL = "{{ type_sim }}";
const CONTENU_BDD  = {{ simulation.contenuSimulation|json_encode|raw }};

let type = TYPE_INITIAL;
let gmails = [];
let smss   = [];
let was    = [];

// Initialisation
(function init() {
    if (!CONTENU_BDD) return;
    if (type === 'GMAIL' && CONTENU_BDD.emails) {
        gmails = CONTENU_BDD.emails.map(e => ({
            is_phishing:  !!e.is_phishing,
            sender_name:  e.sender_name  || '',
            sender_email: e.sender_email || '',
            subject:      e.subject      || '',
            body:         e.body         || '',
            avatar_color: e.avatar_color || '#EA4335',
            avatar_text:  e.avatar_text  || '',
            time:         e.time         || "Aujourd'hui",
            explication:  e.explication  || ''
        }));
        renderGmail();
    } else if (type === 'SMS' && CONTENU_BDD.sms) {
        smss = CONTENU_BDD.sms.map(s => ({
            is_phishing: !!s.is_phishing,
            name:        s.name        || '',
            num:         s.num         || '',
            message:     s.message     || '',
            date:        s.date        || "Aujourd'hui",
            hasLink:     !!s.hasLink,
            explication: s.explication || ''
        }));
        renderSms();
    } else if (type === 'WHATSAPP' && CONTENU_BDD.conversations) {
        was = CONTENU_BDD.conversations.map(conv => ({
            is_phishing: !!conv.is_phishing,
            name:        conv.name       || '',
            status:      conv.status     || 'en ligne',
            avatarBg:    conv.avatarBg   || '#25D366',
            avatarText:  conv.avatarText || '',
            messages:    (conv.messages || []).map(m => ({
                out:    !!m.out,
                sender: m.sender || '',
                text:   m.text   || '',
                time:   m.time   || ''
            })),
            explication: conv.explication || ''
        }));
        renderWa();
    }
    majApercu();
})();

function changerType() {
    type = document.getElementById('typeSelect').value;
    document.getElementById('zoneGmail').style.display   = type === 'GMAIL'    ? '' : 'none';
    document.getElementById('zoneSms').style.display     = type === 'SMS'      ? '' : 'none';
    document.getElementById('zoneWa').style.display      = type === 'WHATSAPP' ? '' : 'none';
    document.getElementById('apercuGmail').style.display = type === 'GMAIL'    ? '' : 'none';
    document.getElementById('apercuSms').style.display   = type === 'SMS'      ? '' : 'none';
    document.getElementById('apercuWa').style.display    = type === 'WHATSAPP' ? '' : 'none';
    majApercu();
}

// GMAIL (identique à la version "nouvelle" mais avec gmails existants)
function ajouterGmail() {
    gmails.push({
        is_phishing: true, sender_name: '', sender_email: '', subject: '', body: '',
        avatar_color: '#EA4335', avatar_text: '', time: "Aujourd'hui", explication: ''
    });
    renderGmail();
}
function supprimerGmail(i) { gmails.splice(i,1); renderGmail(); majApercu(); }
function updateGmail(i, champ, val) {
    gmails[i][champ] = (champ === 'is_phishing') ? (val === 'phishing') : val;
    let card = document.getElementById('gmail-card-'+i);
    if (card) {
        card.className = 'msg-card ' + (gmails[i].is_phishing ? 'phishing' : 'legitime');
        let header = card.querySelector('.msg-card-header');
        if (header) header.className = 'msg-card-header ' + (gmails[i].is_phishing ? 'phishing' : 'legitime');
        let btnP = document.getElementById('gmail-btn-phish-'+i);
        let btnL = document.getElementById('gmail-btn-legit-'+i);
        if (btnP) btnP.className = gmails[i].is_phishing ? 'actif-phish' : '';
        if (btnL) btnL.className = !gmails[i].is_phishing ? 'actif-legit' : '';
    }
    majApercu();
}
function renderGmail() {
    let c = document.getElementById('listeGmail');
    if (!gmails.length) {
        c.innerHTML = '<div class="empty-message">Aucun email. Cliquez "+ Ajouter un email".</div>';
        return;
    }
    c.innerHTML = gmails.map((e,i) => {
        let lbl = LABELS.GMAIL;
        return `<div class="msg-card ${e.is_phishing ? 'phishing' : 'legitime'}" id="gmail-card-${i}">
            <div class="msg-card-header ${e.is_phishing ? 'phishing' : 'legitime'}">
                <div style="width:28px;height:28px;border-radius:50%;background:${e.avatar_color||'#9E9E9E'};display:flex;align-items:center;justify-content:center;font-weight:700;color:white;">${x(e.avatar_text || e.sender_name.slice(0,2).toUpperCase() || '?')}</div>
                <span style="flex:1;font-weight:600;">${e.sender_name ? x(e.sender_name) : '<em>Nom expediteur</em>'}</span>
                <span class="${e.is_phishing ? 'badge-phish' : 'badge-legit'}">${e.is_phishing ? lbl.badgeDanger : lbl.badgeSafe}</span>
                <button type="button" onclick="supprimerGmail(${i})" class="btn-del">✕</button>
            </div>
            <div class="msg-card-body">
                <div class="type-toggle">
                    <button type="button" id="gmail-btn-phish-${i}" class="${e.is_phishing ? 'actif-phish' : ''}" onclick="updateGmail(${i},'is_phishing','phishing')">${lbl.danger}</button>
                    <button type="button" id="gmail-btn-legit-${i}" class="${!e.is_phishing ? 'actif-legit' : ''}" onclick="updateGmail(${i},'is_phishing','legitime')">${lbl.safe}</button>
                </div>
                <div class="champ-row" style="grid-template-columns:1fr 1fr;">
                    <div class="champ"><label>Nom affiché *</label><input type="text" value="${x(e.sender_name)}" placeholder="Ex: BOA Service Client" oninput="gmails[${i}].sender_name=this.value;majApercu()"></div>
                    <div class="champ"><label>Email expéditeur *</label><input type="text" value="${x(e.sender_email)}" placeholder="Ex: support@boa-beniin.com" oninput="gmails[${i}].sender_email=this.value"></div>
                </div>
                <div class="champ"><label>Sujet *</label><input type="text" value="${x(e.subject)}" placeholder="Ex: Votre compte sera suspendu dans 24h" oninput="gmails[${i}].subject=this.value;majApercu()"></div>
                <div class="champ-row" style="grid-template-columns:60px 50px 1fr;">
                    <div class="champ"><label>Couleur avatar</label><input type="color" value="${e.avatar_color||'#EA4335'}" oninput="gmails[${i}].avatar_color=this.value;majApercu()"></div>
                    <div class="champ"><label>Texte</label><input type="text" value="${x(e.avatar_text)}" maxlength="2" placeholder="BO" oninput="gmails[${i}].avatar_text=this.value;majApercu()"></div>
                    <div class="champ"><label>Heure affichée</label><input type="text" value="${x(e.time)}" placeholder="09:14 ou Mar 24" oninput="gmails[${i}].time=this.value"></div>
                </div>
                <div class="champ"><label>Corps de l'email (HTML) *</label><textarea rows="4" placeholder="${x(HINT_CORPS)}" oninput="gmails[${i}].body=this.value">${x(e.body)}</textarea><small>${HINT_GMAIL}</small></div>
                <div class="champ"><label>Explication pédagogique *</label><textarea rows="2" placeholder="Ex: Phishing. Indice 1 : le domaine..." oninput="gmails[${i}].explication=this.value">${x(e.explication)}</textarea></div>
            </div>
        </div>`;
    }).join('');
    majApercu();
}

// SMS (version simplifiée mais fonctionnelle)
function ajouterSms() {
    smss.push({is_phishing:true, name:'', num:'', message:'', date:"Aujourd'hui", hasLink:false, explication:''});
    renderSms();
}
function supprimerSms(i) { smss.splice(i,1); renderSms(); majApercu(); }
function renderSms() {
    let c = document.getElementById('listeSms');
    if (!smss.length) {
        c.innerHTML = '<div class="empty-message">Aucun SMS. Cliquez "+ Ajouter un SMS".</div>';
        return;
    }
    c.innerHTML = smss.map((s,i) => {
        let lbl = LABELS.SMS;
        return `<div class="msg-card ${s.is_phishing ? 'phishing' : 'legitime'}" style="margin-bottom:12px;">
            <div class="msg-card-header ${s.is_phishing ? 'phishing' : 'legitime'}">
                <div style="width:28px;height:28px;border-radius:50%;background:${s.is_phishing ? '#FF9F0A' : '#3A3A3C'};display:flex;align-items:center;justify-content:center;font-weight:700;color:white;">${x((s.name||'?').slice(0,2).toUpperCase())}</div>
                <span style="flex:1;font-weight:600;">${s.name ? x(s.name) : '<em>Expediteur</em>'}</span>
                <span class="${s.is_phishing ? 'badge-phish' : 'badge-legit'}">${s.is_phishing ? lbl.badgeDanger : lbl.badgeSafe}</span>
                <button type="button" onclick="supprimerSms(${i})" class="btn-del">✕</button>
            </div>
            <div class="msg-card-body">
                <div class="type-toggle"><button class="${s.is_phishing ? 'actif-phish' : ''}" onclick="smss[${i}].is_phishing=true;renderSms()">${lbl.danger}</button><button class="${!s.is_phishing ? 'actif-legit' : ''}" onclick="smss[${i}].is_phishing=false;renderSms()">${lbl.safe}</button></div>
                <div class="champ-row" style="grid-template-columns:1fr 1fr;">
                    <div class="champ"><label>Expediteur affiché *</label><input type="text" value="${x(s.name)}" placeholder="Ex: MTNBenin" oninput="smss[${i}].name=this.value;majApercu()"></div>
                    <div class="champ"><label>Numero / info</label><input type="text" value="${x(s.num)}" placeholder="Ex: +229 0145XXXXXX" oninput="smss[${i}].num=this.value"></div>
                </div>
                <div class="champ"><label>Contenu du SMS *</label><textarea rows="3" placeholder="Ex: URGENT! Votre compte MoMo..." oninput="smss[${i}].message=this.value;majApercu()">${x(s.message)}</textarea><small>${HINT_SMS}</small></div>
                <div class="champ-row" style="grid-template-columns:1fr auto;">
                    <div class="champ"><label>Date affichée</label><input type="text" value="${x(s.date)}" placeholder="Mar 20" oninput="smss[${i}].date=this.value"></div>
                    <div class="champ" style="display:flex;align-items:center;gap:8px;"><input type="checkbox" id="sms-lien-${i}" ${s.hasLink ? 'checked' : ''} onchange="smss[${i}].hasLink=this.checked"><label for="sms-lien-${i}">Contient un lien suspect</label></div>
                </div>
                <div class="champ"><label>Explication pédagogique *</label><textarea rows="2" placeholder="Ex: Smishing..." oninput="smss[${i}].explication=this.value">${x(s.explication)}</textarea></div>
            </div>
        </div>`;
    }).join('');
    majApercu();
}

// WhatsApp
function ajouterWa() {
    was.push({is_phishing:true, name:'', status:'en ligne', avatarBg:'#25D366', avatarText:'', messages:[], explication:''});
    renderWa();
}
function supprimerWa(i) { was.splice(i,1); renderWa(); majApercu(); }
function ajouterMsgWa(convIdx) {
    was[convIdx].messages.push({out:false, sender:'', text:'', time:''});
    renderWa();
}
function supprimerMsgWa(convIdx, msgIdx) { was[convIdx].messages.splice(msgIdx,1); renderWa(); }
function updateMsgWa(convIdx, msgIdx, champ, val) {
    was[convIdx].messages[msgIdx][champ] = (champ === 'out') ? (val === 'out') : val;
    if (champ === 'out') renderWa();
}
function renderWa() {
    let c = document.getElementById('listeWa');
    if (!was.length) {
        c.innerHTML = '<div class="empty-message">Aucune conversation. Cliquez "+ Ajouter une conversation".</div>';
        return;
    }
    c.innerHTML = was.map((conv,i) => {
        let lbl = LABELS.WHATSAPP;
        let msgsHtml = '';
        if (conv.messages.length === 0) {
            msgsHtml = '<p class="text-muted" style="padding:0.5rem;">Aucun message. Cliquez "+ Message".</p>';
        } else {
            msgsHtml = conv.messages.map((m,mi) => `
                <div class="wa-msg-ligne">
                    <select class="msg-dir" onchange="updateMsgWa(${i},${mi},'out',this.value)">
                        <option value="in"${!m.out ? ' selected' : ''}>Reçu</option>
                        <option value="out"${m.out ? ' selected' : ''}>Envoyé</option>
                    </select>
                    <input class="msg-texte" type="text" placeholder="Contenu..." value="${x(m.text||'')}" oninput="was[${i}].messages[${mi}].text=this.value;majApercu()">
                    <input class="msg-time" type="text" placeholder="14:30" value="${x(m.time||'')}" oninput="was[${i}].messages[${mi}].time=this.value">
                    ${!m.out ? `<input class="msg-sender" type="text" placeholder="Expéditeur" value="${x(m.sender||'')}" oninput="was[${i}].messages[${mi}].sender=this.value">` : ''}
                    <button type="button" class="btn-del" onclick="supprimerMsgWa(${i},${mi})">✕</button>
                </div>
            `).join('');
        }
        return `<div class="msg-card ${conv.is_phishing ? 'phishing' : 'legitime'}" style="margin-bottom:12px;">
            <div class="msg-card-header ${conv.is_phishing ? 'phishing' : 'legitime'}">
                <div style="width:28px;height:28px;border-radius:50%;background:${conv.avatarBg};display:flex;align-items:center;justify-content:center;font-weight:700;color:white;">${x(conv.avatarText || conv.name.slice(0,2).toUpperCase() || '?')}</div>
                <span style="flex:1;font-weight:600;">${conv.name ? x(conv.name) : '<em>Nom conversation</em>'}</span>
                <span style="font-size:0.65rem;color:#94A3B8;">${conv.messages.length} msg</span>
                <span class="${conv.is_phishing ? 'badge-phish' : 'badge-legit'}">${conv.is_phishing ? lbl.badgeDanger : lbl.badgeSafe}</span>
                <button type="button" onclick="supprimerWa(${i})" class="btn-del">✕</button>
            </div>
            <div class="msg-card-body">
                <div class="type-toggle"><button class="${conv.is_phishing ? 'actif-phish' : ''}" onclick="was[${i}].is_phishing=true;renderWa()">${lbl.danger}</button><button class="${!conv.is_phishing ? 'actif-legit' : ''}" onclick="was[${i}].is_phishing=false;renderWa()">${lbl.safe}</button></div>
                <div class="champ-row" style="grid-template-columns:1fr 1fr;">
                    <div class="champ"><label>Nom conversation *</label><input type="text" value="${x(conv.name)}" placeholder="Ex: Recruteur CFAO Benin" oninput="was[${i}].name=this.value;majApercu()"></div>
                    <div class="champ"><label>Statut / info</label><input type="text" value="${x(conv.status)}" placeholder="en ligne ou Groupe · 8 membres" oninput="was[${i}].status=this.value"></div>
                </div>
                <div class="champ-row" style="grid-template-columns:60px 1fr;">
                    <div class="champ"><label>Couleur avatar</label><input type="color" value="${conv.avatarBg||'#25D366'}" oninput="was[${i}].avatarBg=this.value;majApercu()"></div>
                    <div class="champ"><label>Texte avatar</label><input type="text" value="${x(conv.avatarText)}" maxlength="3" placeholder="CF ou emoji" oninput="was[${i}].avatarText=this.value;majApercu()"></div>
                </div>
                <div style="margin-bottom:10px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                        <label>Messages de la conversation *</label>
                        <button type="button" onclick="ajouterMsgWa(${i})" class="btn btn-ghost btn-sm">+ Message</button>
                    </div>
                    <div>${msgsHtml}</div>
                </div>
                <div class="champ"><label>Explication pédagogique *</label><textarea rows="2" placeholder="Ex: Phishing..." oninput="was[${i}].explication=this.value">${x(conv.explication)}</textarea></div>
            </div>
        </div>`;
    }).join('');
    majApercu();
}

function majApercu() {
    document.getElementById('apercuGmail').style.display = type === 'GMAIL'    ? '' : 'none';
    document.getElementById('apercuSms').style.display   = type === 'SMS'      ? '' : 'none';
    document.getElementById('apercuWa').style.display    = type === 'WHATSAPP' ? '' : 'none';

    let lbl = LABELS[type] || LABELS.GMAIL;

    if (type === 'GMAIL') {
        document.getElementById('compteur').innerHTML = `${gmails.length} email(s) — ${gmails.filter(e=>e.is_phishing).length} phishing`;
        document.getElementById('apercuGmailRows').innerHTML = gmails.length ? gmails.map(e => `
            <div class="gmail-row">
                <div class="gmail-av" style="background:${e.avatar_color||'#9E9E9E'};">${x(e.avatar_text || e.sender_name.slice(0,2).toUpperCase()||'?')}</div>
                <div class="gmail-body"><div class="gmail-sender">${e.sender_name?x(e.sender_name):'...'}</div><div class="gmail-subj">${e.subject?x(e.subject):'...'}</div></div>
                <div><div class="gmail-time">${x(e.time||'')}</div><span class="${e.is_phishing?'badge-phish':'badge-legit'}" style="font-size:9px;">${e.is_phishing?lbl.badgeDanger:lbl.badgeSafe}</span></div>
            </div>
        `).join('') : '<div class="text-muted p-3">Ajoutez des emails...</div>';
    } else if (type === 'SMS') {
        document.getElementById('compteur').innerHTML = `${smss.length} SMS — ${smss.filter(s=>s.is_phishing).length} smishing`;
        document.getElementById('apercuSmsRows').innerHTML = smss.length ? smss.map(s => `
            <div class="sms-row">
                <div class="sms-av">${x((s.name||'?').slice(0,2).toUpperCase())}</div>
                <div><div class="sms-name">${s.name?x(s.name):'...'}</div><div class="sms-preview">${s.message?x(s.message.slice(0,50))+'...':'...'}</div></div>
                <span class="${s.is_phishing?'badge-phish':'badge-legit'}" style="font-size:9px;">${s.is_phishing?lbl.badgeDanger:lbl.badgeSafe}</span>
            </div>
        `).join('') : '<div class="text-muted p-3">Ajoutez des SMS...</div>';
    } else if (type === 'WHATSAPP') {
        document.getElementById('compteur').innerHTML = `${was.length} conversation(s) — ${was.filter(w=>w.is_phishing).length} phishing`;
        document.getElementById('apercuWaRows').innerHTML = was.length ? was.map(conv => `
            <div class="wa-row">
                <div class="wa-av" style="background:${conv.avatarBg};">${x(conv.avatarText||conv.name.slice(0,2).toUpperCase()||'?')}</div>
                <div><div class="wa-name">${conv.name?x(conv.name):'...'}</div><div class="wa-last">${conv.messages.length?x(conv.messages[conv.messages.length-1].text.slice(0,40)||''):'Aucun message'}</div></div>
                <span class="${conv.is_phishing?'badge-phish':'badge-legit'}" style="font-size:9px;">${conv.is_phishing?lbl.badgeDanger:lbl.badgeSafe}</span>
            </div>
        `).join('') : '<div class="text-muted p-3">Ajoutez des conversations...</div>';
    }
}

function construireJson() {
    if (!type) { alert('Type de simulation manquant.'); return false; }
    let items = type === 'GMAIL' ? gmails : type === 'SMS' ? smss : was;
    if (items.length < 2) { alert('Ajoutez au moins 2 éléments.'); return false; }
    let nbPhish = items.filter(i=>i.is_phishing).length;
    let nbLegit = items.filter(i=>!i.is_phishing).length;
    if (nbPhish < 1) { alert('Ajoutez au moins 1 élément Phishing.'); return false; }
    if (nbLegit < 1) { alert('Ajoutez au moins 1 élément Légitime.'); return false; }
    let erreur = '';
    if (type === 'GMAIL') {
        gmails.forEach((e,i)=>{
            if(!e.sender_name) erreur += `Email ${i+1} : nom manquant\n`;
            if(!e.sender_email) erreur += `Email ${i+1} : email expéditeur manquant\n`;
            if(!e.subject) erreur += `Email ${i+1} : sujet manquant\n`;
            if(!e.body) erreur += `Email ${i+1} : corps manquant\n`;
            if(!e.explication) erreur += `Email ${i+1} : explication manquante\n`;
        });
    } else if (type === 'SMS') {
        smss.forEach((s,i)=>{
            if(!s.name) erreur += `SMS ${i+1} : expéditeur manquant\n`;
            if(!s.message) erreur += `SMS ${i+1} : contenu manquant\n`;
            if(!s.explication) erreur += `SMS ${i+1} : explication manquante\n`;
        });
    } else if (type === 'WHATSAPP') {
        was.forEach((conv,i)=>{
            if(!conv.name) erreur += `Conversation ${i+1} : nom manquant\n`;
            if(!conv.messages.length) erreur += `Conversation ${i+1} : aucun message\n`;
            if(!conv.explication) erreur += `Conversation ${i+1} : explication manquante\n`;
        });
    }
    if (erreur) { alert('Champs manquants :\n\n'+erreur); return false; }
    let nb = Math.min(items.length, 6);
    let contenu = {};
    if (type === 'GMAIL') contenu = {type:'gmail_banque', nb_a_tirer:nb, emails:gmails};
    if (type === 'SMS') contenu = {type:'sms_banque', nb_a_tirer:nb, sms:smss};
    if (type === 'WHATSAPP') contenu = {type:'whatsapp_banque', nb_a_tirer:nb, conversations:was};
    document.getElementById('contenuJson').value = JSON.stringify(contenu);
    return true;
}

function x(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
</script>
