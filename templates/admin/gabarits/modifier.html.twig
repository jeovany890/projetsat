{% extends 'admin/layout.html.twig' %}

{% block page_title %}Modifier — {{ gabarit.titre }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_gabarits_liste') }}" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
{% endblock %}

{% block content %}
<div class="form-container">
    <div class="card">
        <div class="card-header">
            <h2>
                <i class="bi bi-pencil-square" style="color: #E53E3E;"></i>
                Modifier le gabarit
            </h2>
            
        </div>
        <div class="card-body">
            <form method="post">

                {# Informations générales #}
                <div class="form-section">
                    <h3 class="section-title">Informations générales</h3>
                    <div class="form-group">
                        <label class="form-label">Titre *</label>
                        <input type="text" class="form-control" name="titre" required value="{{ gabarit.titre }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" name="description" rows="2">{{ gabarit.description }}</textarea>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Catégorie *</label>
                            <select class="form-control" name="categorie" required>
                                <option value="">Sélectionnez une catégorie...</option>
                                {% for cat in categoriesModules %}
                                    <option value="{{ cat.valeur }}" {{ gabarit.categorie == cat.valeur ? 'selected' }}>
                                        {{ cat.label }}
                                    </option>
                                {% else %}
                                    <option value="" disabled>Aucun module publié</option>
                                {% endfor %}
                                {# Si la catégorie actuelle n'est plus dans les modules, l'afficher quand même #}
                                {% set categoriesValeurs = categoriesModules|map(c => c.valeur) %}
                                {% if gabarit.categorie and gabarit.categorie not in categoriesValeurs %}
                                    <option value="{{ gabarit.categorie }}" selected>
                                        {{ gabarit.categorie }} (module non publié)
                                    </option>
                                {% endif %}
                            </select>
                            <p class="form-hint" style="margin-top:4px;font-size:11px;color:#64748B;">
                                <i class="bi bi-info-circle"></i>
                                Catégories issues des modules de formation publiés. En cas d'échec phishing,
                                le module de la même catégorie sera proposé automatiquement à l'employé.
                            </p>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Difficulté</label>
                            <select class="form-control" name="difficulte">
                                <option value="facile"    {{ gabarit.difficulte == 'facile' ? 'selected' }}>Facile</option>
                                <option value="moyen"     {{ gabarit.difficulte == 'moyen' ? 'selected' }}>Moyen</option>
                                <option value="difficile" {{ gabarit.difficulte == 'difficile' ? 'selected' }}>Difficile</option>
                            </select>
                        </div>
                    </div>
                </div>

                {# Contenu email #}
                <div class="form-section">
                    <h3 class="section-title">Contenu de l'email</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Nom expéditeur</label>
                            <input type="text" class="form-control" name="nom_expediteur" value="{{ gabarit.nomExpediteur }}">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email affiché</label>
                            <input type="text" class="form-control" name="email_expediteur" value="{{ gabarit.emailExpediteur }}">
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Sujet</label>
                        <input type="text" class="form-control" name="sujet_email" value="{{ gabarit.sujetEmail }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Compte d'envoi Gmail</label>
                        <select class="form-control" name="compte_email_dsn">
                          <option value="MAILER_PHISHING_PHISHING" {{ gabarit.compteEmailDsn == 'MAILER_PHISHING_PHISHING' ? 'selected' }}>Phishing</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Contenu HTML</label>
                        <textarea class="form-control" name="contenu_html" rows="12" style="font-family: monospace;">{{ gabarit.contenuHtml }}</textarea>
                        <small class="form-hint">
                            Variables : <code>{{ '{{' }}LIEN_PIEGE{{ '}}' }}</code> <code>{{ '{{' }}PRENOM_EMPLOYE{{ '}}' }}</code> <code>{{ '{{' }}NOM_EMPLOYE{{ '}}' }}</code> <code>{{ '{{' }}EMAIL_EMPLOYE{{ '}}' }}</code>
                        </small>
                    </div>
                </div>

                {# Indices #}
                <div class="form-section">
                    <h3 class="section-title">Indices de phishing</h3>
                    <div class="form-group">
                        <label class="form-label">Indices (un par ligne)</label>
                        <textarea class="form-control" name="indices_pieges" rows="5">{{ gabarit.indicesPieges ? gabarit.indicesPieges|join('\n') : '' }}</textarea>
                        <small class="form-hint">Ces indices seront affichés aux employés après le test pour les former.</small>
                    </div>
                </div>

                {# Activation #}
                <div class="form-section">
                    <label class="checkbox-label">
                        <input type="checkbox" name="est_actif" {{ gabarit.estActif ? 'checked' }}>
                        <span>
                            <strong>Gabarit actif</strong><br>
                            <small>Disponible pour créer des campagnes</small>
                        </span>
                    </label>
                </div>

                {# Actions #}
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Enregistrer
                    </button>
                    <a href="{{ path('admin_gabarits_liste') }}" class="btn btn-ghost">
                        <i class="bi bi-x-lg"></i> Annuler
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .form-container {
        max-width: 900px;
        margin: 0 auto;
    }
    .card {
        background: white;
        border-radius: 1rem;
        border: 1px solid #E2E8F0;
        overflow: hidden;
    }
    html.dark .card {
        background: #1E293B;
        border-color: #334155;
    }
    .card-header {
        padding: 1.5rem 1.75rem;
        border-bottom: 1px solid #E2E8F0;
        background: #F8FAFC;
    }
    html.dark .card-header {
        background: #0F172A;
        border-color: #334155;
    }
    .card-header h2 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #0F172A;
        margin: 0 0 0.25rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .card-subtitle {
        font-size: 0.75rem;
        color: #64748B;
        margin: 0;
    }
    html.dark .card-header h2 {
        color: #F1F5F9;
    }
    .card-body {
        padding: 1.75rem;
    }
    .form-section {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #E2E8F0;
    }
    html.dark .form-section {
        border-color: #334155;
    }
    .section-title {
        font-size: 1rem;
        font-weight: 700;
        color: #0F172A;
        margin: 0 0 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .section-title:before {
        content: '';
        width: 4px;
        height: 18px;
        background: #E53E3E;
        border-radius: 4px;
        display: inline-block;
    }
    html.dark .section-title {
        color: #F1F5F9;
    }
    .form-group {
        margin-bottom: 1rem;
    }
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }
    @media (max-width: 640px) {
        .form-row {
            grid-template-columns: 1fr;
            gap: 0;
        }
    }
    .form-label {
        display: block;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #475569;
        margin-bottom: 0.4rem;
    }
    .form-control {
        width: 100%;
        padding: 0.5rem 0.75rem;
        border: 1px solid #CBD5E1;
        border-radius: 0.5rem;
        font-size: 0.875rem;
        background: white;
        color: #0F172A;
        transition: all 0.15s;
    }
    .form-control:focus {
        outline: none;
        border-color: #E53E3E;
        box-shadow: 0 0 0 3px rgba(229,62,62,0.2);
    }
    textarea.form-control {
        font-family: monospace;
        resize: vertical;
    }
    html.dark .form-control {
        background: #0F172A;
        border-color: #334155;
        color: #F1F5F9;
    }
    .form-hint {
        display: block;
        margin-top: 0.25rem;
        font-size: 0.7rem;
        color: #94A3B8;
    }
    .checkbox-label {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        cursor: pointer;
        padding: 0.75rem;
        background: #F8FAFC;
        border-radius: 0.75rem;
        border: 1px solid #E2E8F0;
    }
    .checkbox-label input {
        width: 18px;
        height: 18px;
        margin-top: 2px;
        accent-color: #E53E3E;
    }
    .checkbox-label strong {
        font-size: 0.875rem;
        color: #0F172A;
    }
    .checkbox-label small {
        font-size: 0.7rem;
        color: #64748B;
    }
    html.dark .checkbox-label {
        background: #0F172A;
        border-color: #334155;
    }
    html.dark .checkbox-label strong {
        color: #F1F5F9;
    }
    .form-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
        margin-top: 1rem;
    }
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.375rem 1rem;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
    }
    .btn-primary {
        background: #E53E3E;
        color: white;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
    .btn-primary:hover {
        background: #C53030;
        transform: translateY(-1px);
    }
    .btn-ghost {
        background: transparent;
        border: 1px solid #E2E8F0;
        color: #475569;
    }
    .btn-ghost:hover {
        background: #F8FAFC;
        border-color: #CBD5E1;
        color: #1E293B;
    }
    html.dark .btn-ghost {
        border-color: #334155;
        color: #94A3B8;
    }
    html.dark .btn-ghost:hover {
        background: #1E293B;
        border-color: #475569;
        color: #F1F5F9;
    }
    @media (max-width: 480px) {
        .card-body {
            padding: 1rem;
        }
        .form-actions {
            flex-direction: column;
        }
        .form-actions .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>
{% endblock %}