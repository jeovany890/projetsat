{% extends 'admin/layout.html.twig' %}

{% block page_title %}Modifier — {{ gabarit.titre }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_gabarits_liste') }}" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
{% endblock %}

{% block content %}
<div class="form-container">
    <div class="card">
        <div class="card-header">
            <h2>
                <i class="bi bi-pencil-square" style="color:#E53E3E;"></i>
                Modifier le gabarit
            </h2>
        </div>
        <div class="card-body">

            {# enctype="multipart/form-data" obligatoire pour l'upload du logo #}
            <form method="post" enctype="multipart/form-data">

                {# ── INFORMATIONS GÉNÉRALES ── #}
                <div class="form-section">
                    <h3 class="section-title">Informations générales</h3>
                    <div class="form-group">
                        <label class="form-label">Titre *</label>
                        <input type="text" class="form-control" name="titre" required value="{{ gabarit.titre }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" name="description" rows="2">{{ gabarit.description }}</textarea>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Catégorie *</label>
                            <select class="form-control" name="categorie" required>
                                <option value="">Sélectionnez...</option>
                                {% for cat in categoriesModules %}
                                    <option value="{{ cat.valeur }}" {{ gabarit.categorie == cat.valeur ? 'selected' }}>
                                        {{ cat.label }}
                                    </option>
                                {% else %}
                                    <option value="" disabled>Aucun module publié</option>
                                {% endfor %}
                                {% set categoriesValeurs = categoriesModules|map(c => c.valeur) %}
                                {% if gabarit.categorie and gabarit.categorie not in categoriesValeurs %}
                                    <option value="{{ gabarit.categorie }}" selected>
                                        {{ gabarit.categorie }} (module non publié)
                                    </option>
                                {% endif %}
                            </select>
                            <small class="form-hint">
                                <i class="bi bi-info-circle"></i>
                                En cas d'échec phishing, le module de la même catégorie est proposé automatiquement.
                            </small>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Difficulté</label>
                            <select class="form-control" name="difficulte">
                                <option value="facile"    {{ gabarit.difficulte == 'facile'    ? 'selected' }}>Facile</option>
                                <option value="moyen"     {{ gabarit.difficulte == 'moyen'     ? 'selected' }}>Moyen</option>
                                <option value="difficile" {{ gabarit.difficulte == 'difficile' ? 'selected' }}>Difficile</option>
                            </select>
                        </div>
                    </div>
                </div>

                {# ── LOGO DU GABARIT ── #}
                <div class="form-section">
                    <h3 class="section-title">Logo du gabarit</h3>

                    {% if gabarit.logoPath %}
                    {# Logo existant #}
                    <div class="logo-current" id="logoCurrent">
                        <div class="logo-current-preview">
                            <img src="{{ asset(gabarit.logoPath) }}"
                                 alt="Logo actuel"
                                 style="max-height:64px;max-width:200px;object-fit:contain;border-radius:6px;">
                        </div>
                        <div class="logo-current-actions">
                            <span style="font-size:12px;color:#64748B;">
                                <i class="bi bi-check-circle-fill" style="color:#22C55E;"></i>
                                Logo actuel : <strong>{{ gabarit.logoPath|split('/')|last }}</strong>
                            </span>
                            <div style="display:flex;gap:8px;margin-top:8px;flex-wrap:wrap;">
                                <label class="btn btn-outline-upload btn-sm" for="logoInput">
                                    <i class="bi bi-arrow-repeat"></i> Remplacer
                                </label>
                                <label class="btn btn-outline-danger btn-sm" style="cursor:pointer;">
                                    <input type="checkbox" name="supprimer_logo" value="1"
                                           style="margin-right:4px;accent-color:#EF4444;">
                                    Supprimer le logo
                                </label>
                            </div>
                        </div>
                    </div>
                    {# Aperçu du nouveau logo si remplacement #}
                    <div class="logo-upload-zone" id="logoUploadZone" style="margin-top:12px;display:none;">
                        <div class="logo-preview-wrap" id="logoPreviewWrap">
                            <img id="logoPreview" src="" alt="Aperçu logo"
                                 style="max-height:64px;max-width:200px;border-radius:6px;object-fit:contain;">
                            <button type="button" class="logo-remove-btn" onclick="annulerRemplacement()">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    </div>

                    {% else %}
                    {# Aucun logo — zone d'upload #}
                    <div class="logo-upload-zone" id="logoUploadZone">
                        <div class="logo-preview-wrap" id="logoPreviewWrap" style="display:none;">
                            <img id="logoPreview" src="" alt="Aperçu logo"
                                 style="max-height:64px;max-width:200px;border-radius:6px;object-fit:contain;">
                            <button type="button" class="logo-remove-btn" onclick="supprimerLogoSelection()">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                        <div id="logoPlaceholder">
                            <i class="bi bi-image" style="font-size:2rem;color:#CBD5E1;display:block;margin-bottom:8px;"></i>
                            <p style="margin:0 0 10px;font-size:13px;color:#64748B;">
                                Logo affiché dans l'email phishing<br>
                                <span style="font-size:11px;color:#94A3B8;">JPEG, PNG, WebP — max 2Mo</span>
                            </p>
                            <label class="btn btn-outline-upload" for="logoInput">
                                <i class="bi bi-upload"></i> Choisir un logo
                            </label>
                        </div>
                    </div>
                    {% endif %}

                    <input type="file" id="logoInput" name="logo"
                           accept="image/jpeg,image/png,image/gif,image/webp,image/svg+xml"
                           style="display:none;" onchange="previewLogo(this)">

                    <small class="form-hint" style="margin-top:8px;display:block;">
                        Utilisez <code>{% verbatim %}{{LOGO_ENTREPRISE}}{% endverbatim %}</code> dans le contenu HTML
                        pour insérer ce logo dans l'email.
                        Si aucun logo n'est uploadé, le logo par défaut est utilisé.
                    </small>
                </div>

                {# ── CONTENU EMAIL ── #}
                <div class="form-section">
                    <h3 class="section-title">Contenu de l'email</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Nom expéditeur</label>
                            <input type="text" class="form-control" name="nom_expediteur"
                                   value="{{ gabarit.nomExpediteur }}">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email affiché</label>
                            <input type="text" class="form-control" name="email_expediteur"
                                   value="{{ gabarit.emailExpediteur }}">
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Sujet</label>
                        <input type="text" class="form-control" name="sujet_email"
                               value="{{ gabarit.sujetEmail }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Compte d'envoi Gmail</label>
                        <select class="form-control" name="compte_email_dsn">
                            <option value="MAILER_PHISHING_PHISHING"
                                {{ gabarit.compteEmailDsn == 'MAILER_PHISHING_PHISHING' ? 'selected' }}>
                                Phishing
                            </option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Contenu HTML</label>
                        <div class="variables-hint">
                            <span class="var-badge">{% verbatim %}{{LOGO_ENTREPRISE}}{% endverbatim %}</span>
                            <span class="var-badge">{% verbatim %}{{LIEN_PIEGE}}{% endverbatim %}</span>
                            <span class="var-badge">{% verbatim %}{{LIEN_SIGNALEMENT}}{% endverbatim %}</span>
                            <span class="var-badge">{% verbatim %}{{PRENOM_EMPLOYE}}{% endverbatim %}</span>
                            <span class="var-badge">{% verbatim %}{{NOM_EMPLOYE}}{% endverbatim %}</span>
                            <span class="var-badge">{% verbatim %}{{EMAIL_EMPLOYE}}{% endverbatim %}</span>
                            <span class="var-badge">{% verbatim %}{{DATE_ACTUELLE}}{% endverbatim %}</span>
                            <span class="var-badge">{% verbatim %}{{HEURE_ACTUELLE}}{% endverbatim %}</span>
                            <span class="var-badge">{% verbatim %}{{DATE_LIMITE}}{% endverbatim %}</span>
                        </div>
                        <textarea class="form-control code-area" name="contenu_html"
                                  rows="14">{{ gabarit.contenuHtml }}</textarea>
                    </div>
                </div>

                {# ── INDICES PIÈGES ── #}
                <div class="form-section">
                    <h3 class="section-title">Indices de phishing</h3>
                    <div class="form-group">
                        <label class="form-label">Indices (un par ligne)</label>
                        <textarea class="form-control" name="indices_pieges" rows="5">{{ gabarit.indicesPieges ? gabarit.indicesPieges|join('\n') : '' }}</textarea>
                        <small class="form-hint">Affichés aux employés après le test pour les former</small>
                    </div>
                </div>

                {# ── ACTIVATION ── #}
                <div class="form-section">
                    <label class="checkbox-label">
                        <input type="checkbox" name="est_actif" {{ gabarit.estActif ? 'checked' }}>
                        <span>
                            <strong>Gabarit actif</strong><br>
                            <small>Disponible pour créer des campagnes</small>
                        </span>
                    </label>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Enregistrer
                    </button>
                    <a href="{{ path('admin_gabarits_liste') }}" class="btn btn-ghost">
                        <i class="bi bi-x-lg"></i> Annuler
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.form-container { max-width: 900px; margin: 0 auto; }
.card { background: white; border-radius: 1rem; border: 1px solid #E2E8F0; overflow: hidden; }
html.dark .card { background: #1E293B; border-color: #334155; }
.card-header { padding: 1.5rem 1.75rem; border-bottom: 1px solid #E2E8F0; background: #F8FAFC; }
html.dark .card-header { background: #0F172A; border-color: #334155; }
.card-header h2 { font-size: 1.25rem; font-weight: 700; color: #0F172A; margin: 0; display: flex; align-items: center; gap: 0.5rem; }
html.dark .card-header h2 { color: #F1F5F9; }
.card-body { padding: 1.75rem; }
.form-section { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid #E2E8F0; }
html.dark .form-section { border-color: #334155; }
.section-title { font-size: 1rem; font-weight: 700; color: #0F172A; margin: 0 0 1rem; display: flex; align-items: center; gap: 0.5rem; }
.section-title:before { content: ''; width: 4px; height: 18px; background: #E53E3E; border-radius: 4px; display: inline-block; }
html.dark .section-title { color: #F1F5F9; }
.form-group { margin-bottom: 1rem; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
@media (max-width: 640px) { .form-row { grid-template-columns: 1fr; gap: 0; } }
.form-label { display: block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #475569; margin-bottom: 0.4rem; }
.form-control { width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #CBD5E1; border-radius: 0.5rem; font-size: 0.875rem; background: white; color: #0F172A; transition: all 0.15s; box-sizing: border-box; }
.form-control:focus { outline: none; border-color: #E53E3E; box-shadow: 0 0 0 3px rgba(229,62,62,0.2); }
html.dark .form-control { background: #0F172A; border-color: #334155; color: #F1F5F9; }
.code-area { font-family: monospace; resize: vertical; }
.form-hint { display: block; margin-top: 0.25rem; font-size: 0.7rem; color: #94A3B8; }

/* Logo existant */
.logo-current { display: flex; align-items: center; gap: 16px; padding: 12px 16px; background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 10px; flex-wrap: wrap; }
html.dark .logo-current { background: #0F172A; border-color: #334155; }
.logo-current-preview { background: white; border: 1px solid #E2E8F0; border-radius: 8px; padding: 8px; display: flex; align-items: center; justify-content: center; min-width: 80px; }
html.dark .logo-current-preview { background: #1E293B; border-color: #334155; }

/* Zone upload */
.logo-upload-zone { border: 2px dashed #E2E8F0; border-radius: 0.75rem; padding: 1.5rem; text-align: center; background: #F8FAFC; transition: border-color 0.2s; }
.logo-upload-zone:hover { border-color: #E53E3E; }
html.dark .logo-upload-zone { background: #0F172A; border-color: #334155; }
.logo-preview-wrap { position: relative; display: inline-block; padding: 8px; background: white; border-radius: 8px; border: 1px solid #E2E8F0; }
html.dark .logo-preview-wrap { background: #1E293B; border-color: #334155; }
.logo-remove-btn { position: absolute; top: -8px; right: -8px; width: 22px; height: 22px; border-radius: 50%; background: #EF4444; color: white; border: none; cursor: pointer; font-size: 10px; display: flex; align-items: center; justify-content: center; }

.btn-outline-upload { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border: 1px solid #E53E3E; border-radius: 8px; color: #E53E3E; font-size: 12px; font-weight: 600; cursor: pointer; background: white; transition: all 0.15s; }
.btn-outline-upload:hover { background: #FEF2F2; }
html.dark .btn-outline-upload { background: #1E293B; }
.btn-outline-danger { display: inline-flex; align-items: center; gap: 4px; padding: 6px 14px; border: 1px solid #FCA5A5; border-radius: 8px; color: #EF4444; font-size: 12px; font-weight: 600; background: #FEF2F2; }
.btn-sm { font-size: 12px; padding: 5px 12px; }

.variables-hint { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 8px; }
.var-badge { display: inline-block; padding: 2px 8px; background: #FEF2F2; color: #E53E3E; border: 1px solid #FECACA; border-radius: 4px; font-size: 11px; font-family: monospace; cursor: pointer; transition: background 0.15s; }
.var-badge:hover { background: #FEE2E2; }

.checkbox-label { display: flex; align-items: flex-start; gap: 0.75rem; cursor: pointer; padding: 0.75rem; background: #F8FAFC; border-radius: 0.75rem; border: 1px solid #E2E8F0; }
.checkbox-label input[type="checkbox"]:not([name="supprimer_logo"]) { width: 18px; height: 18px; margin-top: 2px; accent-color: #E53E3E; }
.checkbox-label strong { font-size: 0.875rem; color: #0F172A; }
.checkbox-label small { font-size: 0.7rem; color: #64748B; }
html.dark .checkbox-label { background: #0F172A; border-color: #334155; }
html.dark .checkbox-label strong { color: #F1F5F9; }

.form-actions { display: flex; gap: 0.75rem; justify-content: flex-end; margin-top: 1rem; }
.btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 1rem; border-radius: 8px; font-size: 0.75rem; font-weight: 600; text-decoration: none; transition: all 0.2s; cursor: pointer; border: none; }
.btn-primary { background: #E53E3E; color: white; }
.btn-primary:hover { background: #C53030; transform: translateY(-1px); }
.btn-ghost { background: transparent; border: 1px solid #E2E8F0; color: #475569; }
.btn-ghost:hover { background: #F8FAFC; border-color: #CBD5E1; color: #1E293B; }
html.dark .btn-ghost { border-color: #334155; color: #94A3B8; }
</style>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function previewLogo(input) {
    if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) {
            var zone = document.getElementById('logoUploadZone');
            var wrap = document.getElementById('logoPreviewWrap');
            var ph   = document.getElementById('logoPlaceholder');
            document.getElementById('logoPreview').src = e.target.result;
            if (zone) zone.style.display = 'block';
            if (wrap) wrap.style.display  = 'inline-block';
            if (ph)   ph.style.display    = 'none';
        };
        reader.readAsDataURL(input.files[0]);
    }
}

function supprimerLogoSelection() {
    document.getElementById('logoInput').value = '';
    document.getElementById('logoPreviewWrap').style.display = 'none';
    document.getElementById('logoPlaceholder').style.display = 'block';
}

function annulerRemplacement() {
    document.getElementById('logoInput').value = '';
    document.getElementById('logoUploadZone').style.display = 'none';
}

// Clic sur badge → insère dans le textarea
document.querySelectorAll('.var-badge').forEach(function(badge) {
    badge.addEventListener('click', function() {
        var textarea = document.querySelector('textarea[name="contenu_html"]');
        var pos = textarea.selectionStart;
        var txt = badge.textContent;
        textarea.value = textarea.value.substring(0, pos) + txt + textarea.value.substring(textarea.selectionEnd);
        textarea.selectionStart = textarea.selectionEnd = pos + txt.length;
        textarea.focus();
    });
});
</script>
{% endblock %}
