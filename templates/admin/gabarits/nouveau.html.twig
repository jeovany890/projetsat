{% extends 'admin/layout.html.twig' %}

{% block page_title %}Créer un gabarit{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_gabarits_liste') }}" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
{% endblock %}

{% block content %}
<div class="form-container">
    <div class="card">
        <div class="card-header">
            <h2>
                <i class="bi bi-envelope-paper" style="color: #E53E3E;"></i>
                Nouveau gabarit
            </h2>
           
        </div>
        <div class="card-body">
            <form method="post" id="formGabarit">

                {# ── INFOS GÉNÉRALES ── #}
                <div class="form-section">
                    <h3 class="section-title">Informations générales</h3>
                    <div class="form-group">
                        <label class="form-label">Titre du gabarit *</label>
                        <input type="text" class="form-control" name="titre" required placeholder="Ex: Smishing BOA - Compte bloqué">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" name="description" rows="2" placeholder="Description interne..."></textarea>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Catégorie *</label>
                            <select class="form-control" name="categorie" required>
                                <option value="">Sélectionnez une catégorie...</option>
                                {% for cat in categoriesModules %}
                                    <option value="{{ cat.valeur }}">{{ cat.label }}</option>
                                {% else %}
                                    <option value="" disabled>Aucun module publié — créez d'abord un module</option>
                                {% endfor %}
                            </select>
                            <p class="form-hint" style="margin-top:4px;font-size:11px;color:#64748B;">
                                <i class="bi bi-info-circle"></i>
                                Catégories issues des modules de formation publiés. En cas d'échec phishing,
                                le module de la même catégorie sera proposé automatiquement à l'employé.
                            </p>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Difficulté</label>
                            <select class="form-control" name="difficulte">
                                <option value="facile">Facile</option>
                                <option value="moyen" selected>Moyen</option>
                                <option value="difficile">Difficile</option>
                            </select>
                        </div>
                    </div>
                </div>

                {# ── SECTION EMAIL ── #}
                <div class="form-section">
                    <h3 class="section-title">Contenu Email</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Nom de l'expéditeur affiché *</label>
                            <input type="text" class="form-control" name="nom_expediteur" placeholder="Ex: BOA Service Client">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email affiché *</label>
                            <input type="text" class="form-control" name="email_expediteur" placeholder="Ex: support@boa-beniin.com">
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Sujet de l'email *</label>
                        <input type="text" class="form-control" name="sujet_email" placeholder="Ex:Votre compte sera suspendu dans 24h">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Compte d'envoi Gmail</label>
                        <select class="form-control" name="compte_email_dsn">
                            <option value="MAILER_PHISHING_PHISHING">Phishing</option>
                        </select>
                        <small class="form-hint">Compte Gmail utilisé pour l'envoi — doit correspondre au gabarit</small>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Contenu HTML *</label>
                        <textarea class="form-control" name="contenu_html" rows="12" style="font-family: monospace;" placeholder="<div>...</div>"></textarea>
                        <small class="form-hint">
                            Variables : <code>{{ '{{' }}LIEN_PIEGE{{ '}}' }}</code> <code>{{ '{{' }}PRENOM_EMPLOYE{{ '}}' }}</code> <code>{{ '{{' }}NOM_EMPLOYE{{ '}}' }}</code> <code>{{ '{{' }}EMAIL_EMPLOYE{{ '}}' }}</code>
                        </small>
                    </div>
                </div>

                {# ── INDICES PIÈGES ── #}
                <div class="form-section">
                    <h3 class="section-title">Indices de phishing (pour la correction)</h3>
                    <div class="form-group">
                        <label class="form-label">Liste des pièges / indices</label>
                        <textarea class="form-control" name="indices_pieges" rows="5" placeholder="Un indice par ligne :&#10;Faute dans le nom de domaine&#10;Urgence artificielle&#10;Lien raccourci suspect&#10;Numéro expéditeur inconnu"></textarea>
                        <small class="form-hint">Affichés aux employés après le test pour les former</small>
                    </div>
                </div>

                {# ── ACTIVATION ── #}
                <div class="form-section">
                    <label class="checkbox-label">
                        <input type="checkbox" name="est_actif" checked>
                        <span>
                            <strong>Gabarit actif</strong><br>
                            <small>Disponible pour créer des campagnes</small>
                        </span>
                    </label>
                </div>

                {# Actions #}
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Créer le gabarit
                    </button>
                    <a href="{{ path('admin_gabarits_liste') }}" class="btn btn-ghost">
                        <i class="bi bi-x-lg"></i> Annuler
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .form-container {
        max-width: 900px;
        margin: 0 auto;
    }
    .card {
        background: white;
        border-radius: 1rem;
        border: 1px solid #E2E8F0;
        overflow: hidden;
    }
    html.dark .card {
        background: #1E293B;
        border-color: #334155;
    }
    .card-header {
        padding: 1.5rem 1.75rem;
        border-bottom: 1px solid #E2E8F0;
        background: #F8FAFC;
    }
    html.dark .card-header {
        background: #0F172A;
        border-color: #334155;
    }
    .card-header h2 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #0F172A;
        margin: 0 0 0.25rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .card-subtitle {
        font-size: 0.75rem;
        color: #64748B;
        margin: 0;
    }
    html.dark .card-header h2 {
        color: #F1F5F9;
    }
    .card-body {
        padding: 1.75rem;
    }
    .form-section {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #E2E8F0;
    }
    html.dark .form-section {
        border-color: #334155;
    }
    .section-title {
        font-size: 1rem;
        font-weight: 700;
        color: #0F172A;
        margin: 0 0 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .section-title:before {
        content: '';
        width: 4px;
        height: 18px;
        background: #E53E3E;
        border-radius: 4px;
        display: inline-block;
    }
    html.dark .section-title {
        color: #F1F5F9;
    }
    .form-group {
        margin-bottom: 1rem;
    }
    .form-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
    }
    .form-row.two-cols {
        grid-template-columns: 1fr 1fr;
    }
    @media (max-width: 768px) {
        .form-row {
            grid-template-columns: 1fr;
            gap: 0;
        }
    }
    .form-label {
        display: block;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #475569;
        margin-bottom: 0.4rem;
    }
    .form-control {
        width: 100%;
        padding: 0.5rem 0.75rem;
        border: 1px solid #CBD5E1;
        border-radius: 0.5rem;
        font-size: 0.875rem;
        background: white;
        color: #0F172A;
        transition: all 0.15s;
    }
    .form-control:focus {
        outline: none;
        border-color: #E53E3E;
        box-shadow: 0 0 0 3px rgba(229,62,62,0.2);
    }
    textarea.form-control {
        font-family: monospace;
        resize: vertical;
    }
    html.dark .form-control {
        background: #0F172A;
        border-color: #334155;
        color: #F1F5F9;
    }
    .form-hint {
        display: block;
        margin-top: 0.25rem;
        font-size: 0.7rem;
        color: #94A3B8;
    }
    .checkbox-label {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        cursor: pointer;
        padding: 0.75rem;
        background: #F8FAFC;
        border-radius: 0.75rem;
        border: 1px solid #E2E8F0;
    }
    .checkbox-label input {
        width: 18px;
        height: 18px;
        margin-top: 2px;
        accent-color: #E53E3E;
    }
    .checkbox-label strong {
        font-size: 0.875rem;
        color: #0F172A;
    }
    .checkbox-label small {
        font-size: 0.7rem;
        color: #64748B;
    }
    html.dark .checkbox-label {
        background: #0F172A;
        border-color: #334155;
    }
    html.dark .checkbox-label strong {
        color: #F1F5F9;
    }
    .form-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
        margin-top: 1rem;
    }
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.375rem 1rem;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
    }
    .btn-primary {
        background: #E53E3E;
        color: white;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
    .btn-primary:hover {
        background: #C53030;
        transform: translateY(-1px);
    }
    .btn-ghost {
        background: transparent;
        border: 1px solid #E2E8F0;
        color: #475569;
    }
    .btn-ghost:hover {
        background: #F8FAFC;
        border-color: #CBD5E1;
        color: #1E293B;
    }
    html.dark .btn-ghost {
        border-color: #334155;
        color: #94A3B8;
    }
    html.dark .btn-ghost:hover {
        background: #1E293B;
        border-color: #475569;
        color: #F1F5F9;
    }
    @media (max-width: 480px) {
        .card-body {
            padding: 1rem;
        }
        .form-actions {
            flex-direction: column;
        }
        .form-actions .btn {
            width: 100%;
            justify-content: center;
        }
    }
    .alert-warning {
        background: #FEF3C7;
        border: 1px solid #FDE68A;
        border-radius: 0.75rem;
        padding: 0.75rem 1rem;
        margin-bottom: 1rem;
        font-size: 0.8125rem;
        color: #92400E;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
</style>
{% endblock %}