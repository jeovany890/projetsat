{% extends 'admin/layout.html.twig' %}

{% block page_title %}{{ entreprise.nom }}{% endblock %}

{% block header %}
<div style="display: flex; justify-content: space-between; align-items: center;">
    <div>
        <div style="display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-2);">
            <a href="{{ path('admin_entreprises_liste') }}" style="color: var(--gray-500); text-decoration: none; font-size: var(--text-sm);">
                <i class="bi bi-arrow-left"></i> Entreprises
            </a>
            <span style="color: var(--gray-300);">/</span>
            <span style="color: var(--gray-700); font-size: var(--text-sm);">{{ entreprise.nom }}</span>
        </div>
        <h2 style="font-size: var(--text-3xl); font-weight: var(--font-bold); color: var(--gray-900); margin: 0;">
            <i class="bi bi-building"></i> {{ entreprise.nom }}
        </h2>
    </div>

    {# Actions selon le statut #}
    <div style="display: flex; gap: var(--space-3);">
        {% if entreprise.statut == 'ACTIF' %}
            <span class="badge badge-success" style="font-size: var(--text-base); padding: var(--space-2) var(--space-4);">
                <i class="bi bi-check-circle"></i> Active
            </span>
            <form method="post" action="{{ path('admin_entreprise_suspendre', {id: entreprise.id}) }}" onsubmit="return confirm('Suspendre cette entreprise ?')">
                <button type="submit" class="btn btn-outline" style="border-color: var(--warning); color: var(--warning);">
                    <i class="bi bi-pause-circle"></i> Suspendre
                </button>
            </form>
        {% elseif entreprise.statut == 'SUSPENDU' %}
            <span class="badge badge-danger" style="font-size: var(--text-base); padding: var(--space-2) var(--space-4);">
                <i class="bi bi-pause-circle"></i> Suspendue
            </span>
            <form method="post" action="{{ path('admin_entreprise_reactiver', {id: entreprise.id}) }}">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-play-circle"></i> Réactiver
                </button>
            </form>
        {% elseif entreprise.statut == 'EN_ATTENTE' %}
            <span class="badge badge-warning" style="font-size: var(--text-base); padding: var(--space-2) var(--space-4);">
                <i class="bi bi-clock-history"></i> En attente
            </span>
        {% elseif entreprise.statut == 'REJETE' %}
            <span class="badge badge-danger" style="font-size: var(--text-base); padding: var(--space-2) var(--space-4);">
                <i class="bi bi-x-circle"></i> Rejetée
            </span>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block content %}

{# ── STATS RAPIDES ── #}
<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-5); margin-bottom: var(--space-8);">

    <div class="card" style="border-left: 4px solid var(--primary-500);">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <div style="font-size: var(--text-sm); color: var(--gray-500); margin-bottom: var(--space-1);">Employés</div>
                <div style="font-size: var(--text-3xl); font-weight: var(--font-bold); color: var(--primary-600);">{{ totalEmployes }}</div>
            </div>
            <i class="bi bi-people" style="font-size: var(--text-3xl); color: var(--primary-200);"></i>
        </div>
        <div style="font-size: var(--text-xs); color: var(--gray-500); margin-top: var(--space-2);">
            {{ employesActifs }} actifs
        </div>
    </div>

    <div class="card" style="border-left: 4px solid var(--success);">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <div style="font-size: var(--text-sm); color: var(--gray-500); margin-bottom: var(--space-1);">Score vigilance</div>
                <div style="font-size: var(--text-3xl); font-weight: var(--font-bold); color: var(--success);">{{ scoreMoyen }}%</div>
            </div>
            <i class="bi bi-shield-check" style="font-size: var(--text-3xl); color: var(--success); opacity: 0.3;"></i>
        </div>
        <div style="font-size: var(--text-xs); color: var(--gray-500); margin-top: var(--space-2);">Moyenne équipe</div>
    </div>

    <div class="card" style="border-left: 4px solid var(--info);">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <div style="font-size: var(--text-sm); color: var(--gray-500); margin-bottom: var(--space-1);">Secteur</div>
                <div style="font-size: var(--text-lg); font-weight: var(--font-bold); color: var(--info);">{{ entreprise.secteur }}</div>
            </div>
            <i class="bi bi-briefcase" style="font-size: var(--text-3xl); color: var(--info); opacity: 0.3;"></i>
        </div>
        <div style="font-size: var(--text-xs); color: var(--gray-500); margin-top: var(--space-2);">Domaine d'activité</div>
    </div>

    <div class="card" style="border-left: 4px solid var(--secondary-500);">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <div style="font-size: var(--text-sm); color: var(--gray-500); margin-bottom: var(--space-1);">Inscrite le</div>
                <div style="font-size: var(--text-lg); font-weight: var(--font-bold); color: var(--secondary-600);">{{ entreprise.dateCreation|date('d/m/Y') }}</div>
            </div>
            <i class="bi bi-calendar-check" style="font-size: var(--text-3xl); color: var(--secondary-200);"></i>
        </div>
        {% if entreprise.dateValidation %}
            <div style="font-size: var(--text-xs); color: var(--gray-500); margin-top: var(--space-2);">
                Validée le {{ entreprise.dateValidation|date('d/m/Y') }}
            </div>
        {% endif %}
    </div>

</div>

{# ── INFOS ENTREPRISE + RSSI ── #}
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-6); margin-bottom: var(--space-8);">

    {# Informations entreprise #}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title"><i class="bi bi-building"></i> Informations légales</h3>
        </div>
        <div class="card-body" style="padding: var(--space-6);">
            <table style="width: 100%; border-collapse: collapse;">
                <tr style="border-bottom: 1px solid var(--gray-100);">
                    <td style="padding: var(--space-3) 0; color: var(--gray-500); font-size: var(--text-sm); width: 40%;">Nom</td>
                    <td style="padding: var(--space-3) 0; font-weight: var(--font-semibold); color: var(--gray-900);">{{ entreprise.nom }}</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--gray-100);">
                    <td style="padding: var(--space-3) 0; color: var(--gray-500); font-size: var(--text-sm);">IFU</td>
                    <td style="padding: var(--space-3) 0; font-family: var(--font-mono); color: var(--gray-900);">{{ entreprise.ifu }}</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--gray-100);">
                    <td style="padding: var(--space-3) 0; color: var(--gray-500); font-size: var(--text-sm);">RCCM</td>
                    <td style="padding: var(--space-3) 0; color: var(--gray-900);">{{ entreprise.rccm }}</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--gray-100);">
                    <td style="padding: var(--space-3) 0; color: var(--gray-500); font-size: var(--text-sm);">Email</td>
                    <td style="padding: var(--space-3) 0; color: var(--gray-900);">{{ entreprise.email }}</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--gray-100);">
                    <td style="padding: var(--space-3) 0; color: var(--gray-500); font-size: var(--text-sm);">Téléphone</td>
                    <td style="padding: var(--space-3) 0; color: var(--gray-900);">{{ entreprise.telephone }}</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--gray-100);">
                    <td style="padding: var(--space-3) 0; color: var(--gray-500); font-size: var(--text-sm);">Taille</td>
                    <td style="padding: var(--space-3) 0; color: var(--gray-900);">{{ entreprise.nombreEmployes }} employés déclarés</td>
                </tr>
                {% if entreprise.adresse %}
                <tr>
                    <td style="padding: var(--space-3) 0; color: var(--gray-500); font-size: var(--text-sm);">Adresse</td>
                    <td style="padding: var(--space-3) 0; color: var(--gray-900);">{{ entreprise.adresse }}</td>
                </tr>
                {% endif %}
            </table>
        </div>
    </div>

    {# RSSI associé #}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title"><i class="bi bi-person-badge"></i> RSSI Responsable</h3>
        </div>
        <div class="card-body" style="padding: var(--space-6);">
            {% if rssi %}
                {# Avatar + nom #}
                <div style="display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4); background: var(--gray-50); border-radius: var(--radius-lg); margin-bottom: var(--space-6);">
                    <div style="width: 56px; height: 56px; background: linear-gradient(135deg, var(--primary-600), var(--secondary-600)); border-radius: var(--radius-full); display: flex; align-items: center; justify-content: center; color: white; font-size: var(--text-xl); font-weight: var(--font-bold);">
                        {{ rssi.prenom|slice(0,1) }}{{ rssi.nom|slice(0,1) }}
                    </div>
                    <div>
                        <div style="font-weight: var(--font-bold); font-size: var(--text-lg); color: var(--gray-900);">
                            {{ rssi.prenom }} {{ rssi.nom }}
                        </div>
                        <div style="font-size: var(--text-sm); color: var(--gray-500);">RSSI</div>
                    </div>
                    {% if rssi.estActif %}
                        <span class="badge badge-success" style="margin-left: auto;">Actif</span>
                    {% else %}
                        <span class="badge badge-warning" style="margin-left: auto;">Inactif</span>
                    {% endif %}
                </div>

                <table style="width: 100%; border-collapse: collapse;">
                    <tr style="border-bottom: 1px solid var(--gray-100);">
                        <td style="padding: var(--space-3) 0; color: var(--gray-500); font-size: var(--text-sm); width: 40%;">Email</td>
                        <td style="padding: var(--space-3) 0; color: var(--gray-900);">{{ rssi.email }}</td>
                    </tr>
                    {% if rssi.telephone %}
                    <tr style="border-bottom: 1px solid var(--gray-100);">
                        <td style="padding: var(--space-3) 0; color: var(--gray-500); font-size: var(--text-sm);">Téléphone</td>
                        <td style="padding: var(--space-3) 0; color: var(--gray-900);">{{ rssi.telephone }}</td>
                    </tr>
                    {% endif %}
                    <tr style="border-bottom: 1px solid var(--gray-100);">
                        <td style="padding: var(--space-3) 0; color: var(--gray-500); font-size: var(--text-sm);">Compte créé</td>
                        <td style="padding: var(--space-3) 0; color: var(--gray-900);">{{ rssi.dateCreation|date('d/m/Y') }}</td>
                    </tr>
                    <tr>
                        <td style="padding: var(--space-3) 0; color: var(--gray-500); font-size: var(--text-sm);">Dernière connexion</td>
                        <td style="padding: var(--space-3) 0; color: var(--gray-900);">
                            {% if rssi.dateDerniereConnexion %}
                                {{ rssi.dateDerniereConnexion|date('d/m/Y à H:i') }}
                            {% else %}
                                <span style="color: var(--gray-400); font-style: italic;">Jamais connecté</span>
                            {% endif %}
                        </td>
                    </tr>
                </table>

                {# Renvoi email activation si RSSI jamais connecté #}
                {% if not rssi.estActif %}
                <div style="margin-top: var(--space-4); padding: var(--space-4); background: var(--warning-50, #FFFBEB); border: 1px solid var(--warning); border-radius: var(--radius-lg);">
                    <p style="margin: 0 0 var(--space-3); font-size: var(--text-sm); color: var(--gray-700);">
                        <i class="bi bi-exclamation-triangle"></i> Ce RSSI n'a pas encore activé son compte.
                    </p>
                    <form method="post" action="{{ path('admin_entreprise_valider', {id: entreprise.id}) }}">
                        <button type="submit" class="btn btn-outline" style="font-size: var(--text-sm);">
                            <i class="bi bi-envelope-arrow-up"></i> Renvoyer l'email d'activation
                        </button>
                    </form>
                </div>
                {% endif %}

            {% else %}
                <div style="text-align: center; padding: var(--space-10); color: var(--gray-400);">
                    <i class="bi bi-person-x" style="font-size: 48px; margin-bottom: var(--space-4); display: block;"></i>
                    <p>Aucun RSSI associé à cette entreprise.</p>
                </div>
            {% endif %}
        </div>
    </div>

</div>

{# ── LISTE DES EMPLOYÉS ── #}
<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3 class="card-title"><i class="bi bi-people"></i> Employés ({{ totalEmployes }})</h3>
        <div style="display: flex; gap: var(--space-2);">
            <span class="badge" style="background: var(--success-100, #D1FAE5); color: var(--success);">{{ employesActifs }} actifs</span>
            <span class="badge" style="background: var(--gray-100); color: var(--gray-600);">{{ totalEmployes - employesActifs }} inactifs</span>
        </div>
    </div>

    {% if employes|length == 0 %}
        <div style="text-align: center; padding: var(--space-16); color: var(--gray-400);">
            <i class="bi bi-people" style="font-size: 48px; margin-bottom: var(--space-4); display: block;"></i>
            <p>Aucun employé enregistré pour cette entreprise.</p>
            <p style="font-size: var(--text-sm);">Le RSSI peut ajouter des employés depuis son tableau de bord.</p>
        </div>
    {% else %}
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead style="background: var(--gray-50); border-bottom: 2px solid var(--gray-200);">
                    <tr>
                        <th style="padding: var(--space-3) var(--space-4); text-align: left; font-size: var(--text-sm); color: var(--gray-600); font-weight: var(--font-semibold);">Employé</th>
                        <th style="padding: var(--space-3) var(--space-4); text-align: left; font-size: var(--text-sm); color: var(--gray-600); font-weight: var(--font-semibold);">Poste</th>
                        <th style="padding: var(--space-3) var(--space-4); text-align: left; font-size: var(--text-sm); color: var(--gray-600); font-weight: var(--font-semibold);">Département</th>
                        <th style="padding: var(--space-3) var(--space-4); text-align: center; font-size: var(--text-sm); color: var(--gray-600); font-weight: var(--font-semibold);">Score vigilance</th>
                        <th style="padding: var(--space-3) var(--space-4); text-align: center; font-size: var(--text-sm); color: var(--gray-600); font-weight: var(--font-semibold);">Points</th>
                        <th style="padding: var(--space-3) var(--space-4); text-align: center; font-size: var(--text-sm); color: var(--gray-600); font-weight: var(--font-semibold);">Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for employe in employes %}
                    <tr style="border-bottom: 1px solid var(--gray-100);" onmouseover="this.style.background='var(--gray-50)'" onmouseout="this.style.background='white'">
                        <td style="padding: var(--space-3) var(--space-4);">
                            <div style="display: flex; align-items: center; gap: var(--space-3);">
                                <div style="width: 36px; height: 36px; background: linear-gradient(135deg, var(--primary-400), var(--secondary-400)); border-radius: var(--radius-full); display: flex; align-items: center; justify-content: center; color: white; font-size: var(--text-sm); font-weight: var(--font-bold); flex-shrink: 0;">
                                    {{ employe.prenom|slice(0,1) }}{{ employe.nom|slice(0,1) }}
                                </div>
                                <div>
                                    <div style="font-weight: var(--font-semibold); color: var(--gray-900);">{{ employe.prenom }} {{ employe.nom }}</div>
                                    <div style="font-size: var(--text-xs); color: var(--gray-500);">{{ employe.email }}</div>
                                </div>
                            </div>
                        </td>
                        <td style="padding: var(--space-3) var(--space-4); color: var(--gray-600); font-size: var(--text-sm);">
                            {{ employe.poste ?? '—' }}
                        </td>
                        <td style="padding: var(--space-3) var(--space-4); color: var(--gray-600); font-size: var(--text-sm);">
                            {{ employe.departement ? employe.departement.nom : '—' }}
                        </td>
                        <td style="padding: var(--space-3) var(--space-4); text-align: center;">
                            {% set score = employe.scoreVigilance %}
                            {% set couleur = score >= 80 ? 'var(--success)' : (score >= 60 ? 'var(--info)' : (score >= 40 ? 'var(--warning)' : 'var(--danger)')) %}
                            <div style="display: flex; flex-direction: column; align-items: center; gap: var(--space-1);">
                                <span style="font-weight: var(--font-bold); color: {{ couleur }};">{{ score }}%</span>
                                <div style="width: 60px; height: 4px; background: var(--gray-200); border-radius: 2px;">
                                    <div style="width: {{ score }}%; height: 100%; background: {{ couleur }}; border-radius: 2px;"></div>
                                </div>
                                <span style="font-size: var(--text-xs); color: var(--gray-500);">{{ employe.niveauVigilance }}</span>
                            </div>
                        </td>
                        <td style="padding: var(--space-3) var(--space-4); text-align: center;">
                            <span style="display: inline-flex; align-items: center; gap: var(--space-1); font-weight: var(--font-semibold); color: var(--primary-600);">
                                ⭐ {{ employe.totalEtoiles }}
                                <span style="color: var(--gray-400); font-size: var(--text-xs); font-weight: normal;">({{ employe.totalPoints }} pts)</span>
                            </span>
                        </td>
                        <td style="padding: var(--space-3) var(--space-4); text-align: center;">
                            {% if employe.estActif %}
                                <span class="badge badge-success">Actif</span>
                            {% else %}
                                <span class="badge badge-warning">Inactif</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>

{% endblock %}
