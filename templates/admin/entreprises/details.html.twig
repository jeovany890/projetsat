{% extends 'admin/layout.html.twig' %}

{% block page_title %}{{ entreprise.nom }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_entreprises_liste') }}" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
{% endblock %}

{% block content %}
<div class="entreprise-detail-container">

    {# En-tête #}
    <div class="entreprise-header">
        <div>
            <h1><i class="bi bi-building"></i> {{ entreprise.nom }}</h1>
            <div class="entreprise-breadcrumb">
                <a href="{{ path('admin_entreprises_liste') }}">Entreprises</a> / <span>{{ entreprise.nom }}</span>
            </div>
        </div>
        <div class="entreprise-actions-top">
            {% if entreprise.statut == 'ACTIF' %}
                <span class="badge badge-success">Active</span>
                <form method="post" action="{{ path('admin_entreprise_suspendre', {id: entreprise.id}) }}" id="form-susp-entrep-{{ entreprise.id }}" class="inline-form">
                    <button type="submit" class="btn btn-ghost btn-sm btn-warning"
                            data-confirm="Suspendre cette entreprise ?"
                            data-form="form-susp-entrep-{{ entreprise.id }}">
                        <i class="bi bi-pause-circle"></i> Suspendre
                    </button>
                </form>
            {% elseif entreprise.statut == 'SUSPENDU' %}
                <span class="badge badge-danger">Suspendue</span>
                <form method="post" action="{{ path('admin_entreprise_reactiver', {id: entreprise.id}) }}" class="inline-form">
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-play-circle"></i> Réactiver
                    </button>
                </form>
            {% elseif entreprise.statut == 'EN_ATTENTE' %}
                <span class="badge badge-warning">En attente</span>
            {% elseif entreprise.statut == 'REJETE' %}
                <span class="badge badge-danger">Rejetée</span>
            {% endif %}
        </div>
    </div>

    {# Statistiques #}
    <div class="stats-grid stats-grid-4">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
            <div class="stat-info">
                <div class="stat-value">{{ totalEmployes }}</div>
                <div class="stat-label">Employés</div>
                <div class="stat-sub">{{ employesActifs }} actifs</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon success"><i class="bi bi-shield-check"></i></div>
            <div class="stat-info">
                <div class="stat-value">{{ scoreMoyen }}%</div>
                <div class="stat-label">Score vigilance</div>
                <div class="stat-sub">Moyenne équipe</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon info"><i class="bi bi-briefcase-fill"></i></div>
            <div class="stat-info">
                <div class="stat-value">{{ entreprise.secteur }}</div>
                <div class="stat-label">Secteur</div>
                <div class="stat-sub">Domaine d'activité</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon secondary"><i class="bi bi-calendar-check-fill"></i></div>
            <div class="stat-info">
                <div class="stat-value">{{ entreprise.dateCreation|date('d/m/Y') }}</div>
                <div class="stat-label">Inscrite le</div>
                {% if entreprise.dateValidation %}
                    <div class="stat-sub">Validée le {{ entreprise.dateValidation|date('d/m/Y') }}</div>
                {% endif %}
            </div>
        </div>
    </div>

    {# Informations entreprise + RSSI #}
    <div class="details-grid">
        <div class="card">
            <div class="card-header">
                <h3><i class="bi bi-building"></i> Informations légales</h3>
            </div>
            <div class="card-body">
                <div class="info-table">
                    <div class="info-row">
                        <span class="info-label">Nom</span>
                        <span class="info-value">{{ entreprise.nom }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">IFU</span>
                        <span class="info-value">{{ entreprise.ifu }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">RCCM</span>
                        <span class="info-value">{{ entreprise.rccm }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Email</span>
                        <span class="info-value">{{ entreprise.email }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Téléphone</span>
                        <span class="info-value">{{ entreprise.telephone }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Taille</span>
                        <span class="info-value">{{ entreprise.nombreEmployes }} employés déclarés</span>
                    </div>
                    {% if entreprise.adresse %}
                        <div class="info-row">
                            <span class="info-label">Adresse</span>
                            <span class="info-value">{{ entreprise.adresse }}</span>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3><i class="bi bi-person-badge"></i> RSSI Responsable</h3>
            </div>
            <div class="card-body">
                {% if rssi %}
                    <div class="rssi-profile">
                        <div class="rssi-avatar">{{ rssi.prenom|slice(0,1) }}{{ rssi.nom|slice(0,1) }}</div>
                        <div>
                            <div class="rssi-name">{{ rssi.prenom }} {{ rssi.nom }}</div>
                            <div class="rssi-role">RSSI</div>
                        </div>
                        {% if rssi.estActif %}
                            <span class="badge badge-success">Actif</span>
                        {% else %}
                            <span class="badge badge-warning">Inactif</span>
                        {% endif %}
                    </div>
                    <div class="info-table">
                        <div class="info-row">
                            <span class="info-label">Email</span>
                            <span class="info-value">{{ rssi.email }}</span>
                        </div>
                        {% if rssi.telephone %}
                            <div class="info-row">
                                <span class="info-label">Téléphone</span>
                                <span class="info-value">{{ rssi.telephone }}</span>
                            </div>
                        {% endif %}
                        <div class="info-row">
                            <span class="info-label">Compte créé</span>
                            <span class="info-value">{{ rssi.dateCreation|date('d/m/Y') }}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Dernière connexion</span>
                            <span class="info-value">
                                {% if rssi.dateDerniereConnexion %}
                                    {{ rssi.dateDerniereConnexion|date('d/m/Y à H:i') }}
                                {% else %}
                                    <em>Jamais connecté</em>
                                {% endif %}
                            </span>
                        </div>
                    </div>
                    {% if not rssi.estActif %}
                        <div class="activation-warning">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            Ce RSSI n'a pas encore activé son compte.
                            <form method="post" action="{{ path('admin_entreprise_valider', {id: entreprise.id}) }}" class="inline-form">
                                <button type="submit" class="btn btn-ghost btn-sm">
                                    <i class="bi bi-envelope-arrow-up"></i> Renvoyer l'email d'activation
                                </button>
                            </form>
                        </div>
                    {% endif %}
                {% else %}
                    <div class="empty-rssi">
                        <i class="bi bi-person-x"></i>
                        <p>Aucun RSSI associé à cette entreprise.</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {# Liste des employés #}
    <div class="card">
        <div class="card-header-flex">
            <h3><i class="bi bi-people-fill"></i> Employés ({{ totalEmployes }})</h3>
            <div class="employes-stats">
                <span class="badge badge-success">{{ employesActifs }} actifs</span>
                <span class="badge badge-gray">{{ totalEmployes - employesActifs }} inactifs</span>
            </div>
        </div>
        <div class="card-body">
            {% if employes|length == 0 %}
                <div class="empty-employes">
                    <i class="bi bi-people"></i>
                    <p>Aucun employé enregistré pour cette entreprise.</p>
                    <small>Le RSSI peut ajouter des employés depuis son tableau de bord.</small>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="employes-table">
                        <thead>
                            <tr>
                                <th>Employé</th>
                                <th>Poste</th>
                                <th>Département</th>
                                <th class="text-center">Score vigilance</th>
                                <th class="text-center">Points</th>
                                <th class="text-center">Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for employe in employes %}
                                <tr>
                                    <td>
                                        <div class="employe-avatar">{{ employe.prenom|slice(0,1) }}{{ employe.nom|slice(0,1) }}</div>
                                        <div>
                                            <div class="employe-name">{{ employe.prenom }} {{ employe.nom }}</div>
                                            <div class="employe-email">{{ employe.email }}</div>
                                        </div>
                                    </td>
                                    <td>{{ employe.poste ?? '—' }}</td>
                                    <td>{{ employe.departement ? employe.departement.nom : '—' }}</td>
                                    <td class="text-center">
                                        {% set score = employe.scoreVigilance %}
                                        <div class="score-cell">
                                            <span class="score-value" data-score="{{ score }}">{{ score }}%</span>
                                            <div class="progress-bar-bg small">
                                                <div class="progress-bar-fill" data-score="{{ score }}"></div>
                                            </div>
                                            <span class="score-level">{{ employe.niveauVigilance }}</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="stars">{{ employe.nombreEtoiles }}/5 ★</span>
                                        <span class="points">({{ employe.totalPoints }} pts)</span>
                                    </td>
                                    <td class="text-center">
                                        {% if employe.estActif %}
                                            <span class="badge badge-success">Actif</span>
                                        {% else %}
                                            <span class="badge badge-warning">Inactif</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .entreprise-detail-container {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* En-tête */
    .entreprise-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .entreprise-header h1 {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0F172A;
        margin: 0 0 0.25rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .entreprise-breadcrumb {
        font-size: 0.75rem;
        color: #64748B;
    }
    .entreprise-breadcrumb a {
        color: #64748B;
        text-decoration: none;
    }
    .entreprise-breadcrumb a:hover {
        color: #E53E3E;
    }
    .entreprise-actions-top {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        flex-wrap: wrap;
    }
    .inline-form {
        display: inline;
    }
    .btn-warning {
        color: #D97706;
        border-color: #FDE68A;
    }
    .btn-warning:hover {
        background: #FEF9C3;
        border-color: #FDE68A;
        color: #B45309;
    }
    html.dark .entreprise-header h1 {
        color: #F1F5F9;
    }

    /* Statistiques */
    .stats-grid {
        display: grid;
        gap: 1rem;
    }
    .stats-grid-4 {
        grid-template-columns: repeat(4, 1fr);
    }
    @media (max-width: 900px) {
        .stats-grid-4 {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (max-width: 550px) {
        .stats-grid-4 {
            grid-template-columns: 1fr;
        }
    }
    .stat-card {
        background: white;
        border-radius: 0.75rem;
        border: 1px solid #E2E8F0;
        padding: 0.875rem;
        display: flex;
        align-items: center;
        gap: 0.875rem;
    }
    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: #F1F5F9;
        color: #475569;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }
    .stat-icon.success { background: #DCFCE7; color: #166534; }
    .stat-icon.info    { background: #DBEAFE; color: #1D4ED8; }
    .stat-icon.secondary { background: #FEF9C3; color: #D97706; }
    .stat-value {
        font-size: 1.75rem;
        font-weight: 800;
        color: #0F172A;
        line-height: 1.2;
    }
    .stat-label {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        color: #64748B;
        margin-top: 0.2rem;
    }
    .stat-sub {
        font-size: 0.65rem;
        color: #94A3B8;
        margin-top: 0.1rem;
    }
    html.dark .stat-card {
        background: #1E293B;
        border-color: #334155;
    }
    html.dark .stat-value { color: #F1F5F9; }

    /* Grille détails */
    .details-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }
    @media (max-width: 900px) {
        .details-grid {
            grid-template-columns: 1fr;
        }
    }
    .card {
        background: white;
        border-radius: 1rem;
        border: 1px solid #E2E8F0;
        overflow: hidden;
    }
    html.dark .card {
        background: #1E293B;
        border-color: #334155;
    }
    .card-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #E2E8F0;
        background: #F8FAFC;
    }
    .card-header h3 {
        font-size: 1rem;
        font-weight: 700;
        color: #0F172A;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    html.dark .card-header {
        background: #0F172A;
        border-color: #334155;
    }
    html.dark .card-header h3 {
        color: #F1F5F9;
    }
    .card-body {
        padding: 1.25rem;
    }
    .info-table {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .info-row {
        display: flex;
        flex-wrap: wrap;
        padding: 0.5rem 0;
        border-bottom: 1px solid #E2E8F0;
        font-size: 0.8125rem;
    }
    .info-label {
        width: 35%;
        font-weight: 600;
        color: #475569;
    }
    .info-value {
        width: 65%;
        color: #0F172A;
    }
    html.dark .info-row {
        border-color: #334155;
    }
    html.dark .info-label {
        color: #94A3B8;
    }
    html.dark .info-value {
        color: #F1F5F9;
    }

    /* RSSI */
    .rssi-profile {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: #F8FAFC;
        padding: 1rem;
        border-radius: 0.75rem;
        margin-bottom: 1rem;
    }
    .rssi-avatar {
        width: 56px;
        height: 56px;
        background: linear-gradient(135deg, #E53E3E, #C53030);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        font-weight: 700;
        color: white;
    }
    .rssi-name {
        font-weight: 700;
        font-size: 1rem;
        color: #0F172A;
    }
    .rssi-role {
        font-size: 0.75rem;
        color: #64748B;
    }
    .activation-warning {
        margin-top: 1rem;
        padding: 0.75rem;
        background: #FFFBEB;
        border: 1px solid #FDE68A;
        border-radius: 0.75rem;
        font-size: 0.75rem;
        color: #854D0E;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.75rem;
    }
    .empty-rssi {
        text-align: center;
        padding: 2rem;
        color: #94A3B8;
    }
    .empty-rssi i {
        font-size: 2.5rem;
        display: block;
        margin-bottom: 0.5rem;
    }
    html.dark .rssi-profile {
        background: #0F172A;
    }
    html.dark .rssi-name {
        color: #F1F5F9;
    }

    /* Tableau employés */
    .card-header-flex {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #E2E8F0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .card-header-flex h3 {
        font-size: 1rem;
        font-weight: 700;
        color: #0F172A;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .employes-stats {
        display: flex;
        gap: 0.5rem;
    }
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        white-space: nowrap;
    }
    .badge-success { background: #DCFCE7; color: #166534; }
    .badge-warning { background: #FEF9C3; color: #854D0E; }
    .badge-danger  { background: #FEE2E2; color: #991B1B; }
    .badge-gray    { background: #F1F5F9; color: #475569; }
    html.dark .badge-success { background: #14532D; color: #4ADE80; }
    html.dark .badge-warning { background: #78350F; color: #FDE047; }
    html.dark .badge-danger  { background: #7F1D1D; color: #FCA5A5; }
    html.dark .badge-gray    { background: #1E293B; color: #94A3B8; }

    .table-responsive {
        overflow-x: auto;
    }
    .employes-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.8125rem;
    }
    .employes-table th {
        text-align: left;
        padding: 0.75rem 1rem;
        background: #F8FAFC;
        color: #475569;
        font-weight: 600;
        border-bottom: 1px solid #E2E8F0;
    }
    .employes-table td {
