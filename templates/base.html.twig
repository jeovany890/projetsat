<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SAT Platform{% endblock %}</title>

    {# Favicon #}
    <link rel="icon" type="image/jpeg" href="{{ asset('images/logo.jpeg') }}">

    {# Google Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">

    {# Iconify #}
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>

    {# Bootstrap Icons CSS #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    {# Design System #}
    <link rel="stylesheet" href="{{ asset('css/design-system.css') }}">
    <link rel="stylesheet" href="{{ asset('css/responsive.css') }}">

    {# Bootstrap CSS #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    {% block stylesheets %}{% endblock %}
</head>
<body>
    {% block body %}{% endblock %}

    {# Alpine.js #}
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    {# Bootstrap JS #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
    function initTableScroll() {
        document.querySelectorAll('.a-content table, .r-content table, .card table').forEach(function(table) {
            if (table.closest('.table-scroll-wrap')) return;
            var wrap = document.createElement('div');
            wrap.className = 'table-scroll-wrap';
            table.parentNode.insertBefore(wrap, table);
            wrap.appendChild(table);
        });
    }
    document.addEventListener('DOMContentLoaded', initTableScroll);
    document.addEventListener('turbo:load', initTableScroll);
    </script>

    {# MODAL DE CONFIRMATION - VERSION QUI FONCTIONNE #}
    
    <div id="satConfirmModal" aria-modal="true" role="dialog" aria-labelledby="satConfirmTitle"
         style="display:none;position:fixed;inset:0;z-index:9999;align-items:center;justify-content:center;">
        <div id="satConfirmBackdrop"
             style="position:absolute;inset:0;background:rgba(15,23,42,0.55);backdrop-filter:blur(3px);"></div>
        <div style="position:relative;background:#fff;border-radius:16px;padding:28px 28px 24px;
                    max-width:420px;width:calc(100% - 32px);box-shadow:0 20px 60px rgba(0,0,0,0.18);
                    animation:satModalIn .18s ease;">
            <div style="display:flex;align-items:flex-start;gap:14px;margin-bottom:16px;">
                <div id="satConfirmIcon"
                     style="width:42px;height:42px;border-radius:12px;background:#FEE2E2;
                            display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <iconify-icon id="satConfirmIconify" icon="mdi:alert-decagram" style="font-size: 24px; color: #DC2626;"></iconify-icon>
                </div>
                <div>
                    <h3 id="satConfirmTitle"
                        style="margin:0 0 6px;font-size:16px;font-weight:700;color:#0f172a;">
                        Confirmer l'action
                    </h3>
                    <p id="satConfirmMessage"
                       style="margin:0;font-size:14px;color:#475569;line-height:1.5;">
                        Êtes-vous sûr de vouloir effectuer cette action ?
                    </p>
                </div>
            </div>
            <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:20px;">
                <button id="satConfirmCancel"
                        style="padding:9px 18px;border-radius:8px;border:1px solid #e2e8f0;
                               background:#f8fafc;color:#475569;font-weight:600;font-size:13px;cursor:pointer;">
                    Annuler
                </button>
                <button id="satConfirmOk"
                        style="padding:9px 18px;border-radius:8px;border:none;
                               background:#DC2626;color:#fff;font-weight:600;font-size:13px;cursor:pointer;">
                    Confirmer
                </button>
            </div>
        </div>
    </div>
    
    <style>
    @keyframes satModalIn {
        from { opacity:0; transform:scale(.95) translateY(6px); }
        to   { opacity:1; transform:scale(1)  translateY(0);    }
    }
    html.dark #satConfirmModal > div:last-child {
        background: #1e293b;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    }
    html.dark #satConfirmTitle  { color: #f1f5f9; }
    html.dark #satConfirmMessage{ color: #94a3b8; }
    html.dark #satConfirmCancel {
        background:#334155; border-color:#475569; color:#e2e8f0;
    }
    </style>

    {% block javascripts %}{% endblock %}

    <script>
    /**
     * MODAL DE CONFIRMATION - VERSION SIMPLIFIÉE QUI FONCTIONNE À 100%
     */
    (function () {
        // Récupérer les éléments
        var modal = document.getElementById('satConfirmModal');
        var backdrop = document.getElementById('satConfirmBackdrop');
        var msgEl = document.getElementById('satConfirmMessage');
        var titleEl = document.getElementById('satConfirmTitle');
        var okBtn = document.getElementById('satConfirmOk');
        var cancelBtn = document.getElementById('satConfirmCancel');
        
        // Variables pour stocker l'action à executer
        var actionEnAttente = null;
        var formulaireEnAttente = null;
        var elementEnAttente = null;
        
        // Fonction pour fermer le modal
        function fermerModal() {
            if (modal) modal.style.display = 'none';
            document.body.style.overflow = '';
        }
        
        // Fonction pour ouvrir le modal
        function ouvrirModal(message, type, element, formulaire) {
            // Définir le message
            if (msgEl) msgEl.textContent = message;
            
            // Stocker l'action
            elementEnAttente = element;
            formulaireEnAttente = formulaire;
            
            // Configurer le style selon le type
            var estDangereux = (type === 'danger' || !type);
            if (titleEl) {
                titleEl.textContent = estDangereux ? 'Confirmer l\'action' : 'Confirmation';
            }
            if (okBtn) {
                okBtn.style.background = estDangereux ? '#DC2626' : '#D97706';
            }
            
            // Afficher
            if (modal) {
                modal.style.display = 'flex';
                document.body.style.overflow = 'hidden';
            }
        }
        
        // Action quand on clique sur Confirmer
        if (okBtn) {
            okBtn.addEventListener('click', function() {
                console.log('Confirmation - Déclenchement de l\'action');
                fermerModal();
                
                // PRIORITÉ 1: Si on a un formulaire, le soumettre
                if (formulaireEnAttente) {
                    console.log('Soumission du formulaire:', formulaireEnAttente);
                    formulaireEnAttente.submit();
                    return;
                }
                
                // PRIORITÉ 2: Si c'est un lien avec data-href
                if (elementEnAttente && elementEnAttente.getAttribute('data-href')) {
                    var href = elementEnAttente.getAttribute('data-href');
                    console.log('Navigation vers:', href);
                    window.location.href = href;
                    return;
                }
                
                // PRIORITÉ 3: Si c'est un lien normal
                if (elementEnAttente && elementEnAttente.tagName === 'A' && elementEnAttente.getAttribute('href')) {
                    var href = elementEnAttente.getAttribute('href');
                    if (href && href !== '#') {
                        console.log('Navigation vers le lien:', href);
                        window.location.href = href;
                    }
                    return;
                }
                
                // PRIORITÉ 4: Si c'est un bouton dans un formulaire
                if (elementEnAttente) {
                    var formParent = elementEnAttente.closest('form');
                    if (formParent) {
                        console.log('Soumission du formulaire parent:', formParent);
                        formParent.submit();
                        return;
                    }
                }
                
                console.log('Aucune action trouvée à exécuter');
            });
        }
        
        // Action quand on clique sur Annuler
        if (cancelBtn) {
            cancelBtn.addEventListener('click', function() {
                console.log('Action annulée');
                fermerModal();
                elementEnAttente = null;
                formulaireEnAttente = null;
            });
        }
        
        // Fermer en cliquant sur le fond
        if (backdrop) {
            backdrop.addEventListener('click', function() {
                fermerModal();
                elementEnAttente = null;
                formulaireEnAttente = null;
            });
        }
        
        // Fermer avec Echap
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && modal && modal.style.display === 'flex') {
                fermerModal();
                elementEnAttente = null;
                formulaireEnAttente = null;
            }
        });
        
        // Intercepter tous les clics sur les éléments avec data-confirm
        function initialiserConfirmations() {
            var elements = document.querySelectorAll('[data-confirm]');
            console.log('Éléments avec data-confirm trouvés:', elements.length);
            
            elements.forEach(function(el) {
                // Éviter les doublons
                if (el.hasAttribute('data-sat-bound')) return;
                el.setAttribute('data-sat-bound', 'true');
                
                el.addEventListener('click', function(e) {
                    var message = el.getAttribute('data-confirm');
                    var type = el.getAttribute('data-confirm-type') || 'danger';
                    var idFormulaire = el.getAttribute('data-form');
                    var formulaire = null;
                    
                    console.log('Clic sur élément avec confirmation:', el);
                    console.log('Message:', message);
                    
                    // Trouver le formulaire à soumettre
                    if (idFormulaire) {
                        formulaire = document.getElementById(idFormulaire);
                        console.log('Formulaire par ID:', idFormulaire, formulaire);
                    } else {
                        formulaire = el.closest('form');
                        console.log('Formulaire parent:', formulaire);
                    }
                    
                    // Empêcher l'action par défaut
                    e.preventDefault();
                    e.stopPropagation();
                    
                    // Ouvrir le modal
                    ouvrirModal(message, type, el, formulaire);
                });
            });
        }
        
        // Intercepter aussi les formulaires avec onsubmit
        function initialiserFormulairesLegacy() {
            var formulaires = document.querySelectorAll('form[onsubmit]');
            console.log('Formulaires legacy trouvés:', formulaires.length);
            
            formulaires.forEach(function(form) {
                if (form.hasAttribute('data-sat-form-bound')) return;
                form.setAttribute('data-sat-form-bound', 'true');
                
                var onsubmitOriginal = form.onsubmit;
                
                form.addEventListener('submit', function(e) {
                    if (form.hasAttribute('data-sat-processing')) return;
                    
                    var codeSource = onsubmitOriginal.toString();
                    var match = codeSource.match(/confirm\(['"]([^'"]+)['"]\)/);
                    
                    if (match) {
                        e.preventDefault();
                        e.stopPropagation();
                        form.setAttribute('data-sat-processing', 'true');
                        
                        ouvrirModal(match[1], 'danger', null, form);
                        
                        form.removeAttribute('data-sat-processing');
                    }
                });
            });
        }
        
        // Initialisation au chargement
        function init() {
            console.log('Initialisation du modal de confirmation');
            initialiserConfirmations();
            initialiserFormulairesLegacy();
        }
        
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
        
        // Support Turbo Drive
        document.addEventListener('turbo:load', function() {
            console.log('Re-initialisation après Turbo');
            document.querySelectorAll('[data-sat-bound]').forEach(function(el) {
                el.removeAttribute('data-sat-bound');
            });
            document.querySelectorAll('[data-sat-form-bound]').forEach(function(el) {
                el.removeAttribute('data-sat-form-bound');
            });
            init();
        });
    })();
    </script>
</body>
</html>