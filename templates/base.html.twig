<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SAT Platform{% endblock %}</title>
    
    {# Favicon #}
    <link rel="icon" type="image/jpeg" href="{{ asset('images/logo.jpeg') }}">
    
    {# Google Fonts - Inter Variable #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
    
    {# Iconify - Remplace Bootstrap Icons ET Font Awesome (une seule librairie pour tout) #}
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    
    {# Design System Premium #}
    <link rel="stylesheet" href="{{ asset('css/design-system.css') }}">
    
    <link rel="stylesheet" href="{{ asset('css/responsive.css') }}">
    
    {# Bootstrap CSS pour les modals Symfony uniquement #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {% block body %}{% endblock %}
    
    {# Alpine.js pour interactions #}
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    {# Bootstrap JS pour les modals Symfony #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
    // Rend tous les tableaux scrollables sur mobile sans casser leur structure
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.a-content table, .r-content table, .card table').forEach(function(table) {
            if (table.closest('.table-scroll-wrap')) return;
            var wrap = document.createElement('div');
            wrap.className = 'table-scroll-wrap';
            table.parentNode.insertBefore(wrap, table);
            wrap.appendChild(table);
        });
    });
    </script>

    {% block javascripts %}{% endblock %}
</body>
</html>