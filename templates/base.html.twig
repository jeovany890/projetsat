<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SAT Platform{% endblock %}</title>
    
    {# Favicon #}
    {# Au lieu de favicon.ico (inexistant), utilisez votre image #}
    <link rel="icon" type="image/jpeg" href="{{ asset('images/logo.jpeg') }}">
    
    {# Google Fonts - Inter Variable #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
    {# Bootstrap Icons #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    
    {# Design System Premium #}
    <link rel="stylesheet" href="{{ asset('css/design-system.css') }}">
    
    <link rel="stylesheet" href="{{ asset('css/responsive.css') }}">
    
    {# Bootstrap CSS pour les modals Symfony #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {% block body %}{% endblock %}
    
    {# Alpine.js pour interactions #}
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    {# Bootstrap JS pour les modals Symfony #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
    // Rend tous les tableaux scrollables sur mobile sans casser leur structure
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.a-content table, .r-content table, .card table').forEach(function(table) {
            if (table.closest('.table-scroll-wrap')) return;
            var wrap = document.createElement('div');
            wrap.className = 'table-scroll-wrap';
            table.parentNode.insertBefore(wrap, table);
            wrap.appendChild(table);
        });
    });
    </script>

    <!-- Modal Symfony standard -->
    <div class="modal fade" id="confirmationModal" tabindex="-1" aria-labelledby="confirmationModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmationModalLabel">Confirmation</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="confirmationModalMessage">
                    Êtes-vous sûr de vouloir effectuer cette action ?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="button" class="btn btn-danger" id="confirmationModalConfirm">Confirmer</button>
                </div>
            </div>
        </div>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const modal = new bootstrap.Modal(document.getElementById('confirmationModal'));
        const confirmBtn = document.getElementById('confirmationModalConfirm');
        const messageEl = document.getElementById('confirmationModalMessage');

        document.addEventListener('click', function(e) {
            const el = e.target.closest('[data-confirm]');
            if (!el) return;
            e.preventDefault();
            
            messageEl.textContent = el.dataset.confirm || 'Êtes-vous sûr de vouloir effectuer cette action ?';
            
            confirmBtn.onclick = function() {
                if (el.dataset.form) {
                    document.getElementById(el.dataset.form).submit();
                } else if (el.href) {
                    window.location.href = el.href;
                }
                modal.hide();
            };
            
            modal.show();
        });
    });
    </script>

    {% block javascripts %}{% endblock %}
</body>
</html>