<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Simulation détectée — SAT Platform</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<style>
:root{
    --bg:#F8FAFC;
    --card:#FFFFFF;
    --text:#0F172A;
    --muted:#64748B;
    --border:#E2E8F0;

    --danger:#DC2626;
    --danger-soft:#FEF2F2;

    --warning:#D97706;
    --warning-soft:#FFF7ED;

    --success:#16A34A;
    --success-soft:#F0FDF4;

    --primary:#0F172A;
    --primary-light:#1E293B;
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Inter',sans-serif;
    background:linear-gradient(180deg,#F8FAFC 0%, #F1F5F9 100%);
    color:var(--text);
    min-height:100vh;
    padding:40px 18px;
}

.container{
    max-width:760px;
    margin:auto;
}

.card{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:28px;
    overflow:hidden;
    box-shadow:0 20px 50px rgba(15,23,42,.08);
}

/* HEADER */
.hero{
    padding:36px 36px 28px;
    border-bottom:1px solid var(--border);
    background:linear-gradient(135deg,#ffffff 0%, #F8FAFC 100%);
}

.badge{
    display:inline-flex;
    align-items:center;
    gap:8px;
    background:var(--danger-soft);
    color:var(--danger);
    border:1px solid #FECACA;
    padding:8px 14px;
    border-radius:999px;
    font-size:13px;
    font-weight:700;
    margin-bottom:18px;
}

.hero-top{
    display:flex;
    align-items:flex-start;
    gap:18px;
}

.hero-icon{
    width:58px;
    height:58px;
    border-radius:18px;
    background:var(--danger-soft);
    color:var(--danger);
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:26px;
    flex-shrink:0;
}

.hero h1{
    font-size:28px;
    font-weight:800;
    margin-bottom:8px;
    letter-spacing:-0.03em;
}

.hero p{
    color:var(--muted);
    font-size:15px;
    line-height:1.7;
    max-width:520px;
}

/* BODY */
.content{
    padding:32px 36px 36px;
    display:flex;
    flex-direction:column;
    gap:24px;
}

/* SECTION */
.section{
    border:1px solid var(--border);
    border-radius:18px;
    padding:22px;
}

.section-title{
    display:flex;
    align-items:center;
    gap:10px;
    font-size:15px;
    font-weight:700;
    margin-bottom:18px;
}

.section-title i{
    font-size:18px;
}

/* SCORE */
.score-card{
    background:var(--danger-soft);
    border-color:#FECACA;
}

.score-flex{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:20px;
    flex-wrap:wrap;
}

.score-main h2{
    font-size:32px;
    font-weight:800;
    color:var(--danger);
    margin-bottom:4px;
}

.score-main p{
    font-size:14px;
    color:#991B1B;
}

.user-level{
    text-align:right;
}

.user-level span{
    display:block;
    font-size:13px;
    color:var(--muted);
    margin-bottom:8px;
}

.stars{
    color:#F59E0B;
    font-size:18px;
    letter-spacing:2px;
    margin-bottom:6px;
}

.level-badge{
    display:inline-block;
    background:white;
    border:1px solid #FECACA;
    color:#991B1B;
    padding:6px 12px;
    border-radius:999px;
    font-size:12px;
    font-weight:700;
}

/* EMAIL */
.email-grid{
    display:grid;
    gap:12px;
}

.email-row{
    display:flex;
    gap:10px;
    font-size:14px;
    line-height:1.6;
}

.email-label{
    min-width:110px;
    font-weight:700;
    color:var(--text);
}

.email-value{
    color:var(--muted);
    word-break:break-word;
}

.email-danger{
    color:var(--danger);
    font-weight:600;
}

/* INDICES */
.hints{
    display:flex;
    flex-direction:column;
    gap:12px;
}

.hint{
    display:flex;
    gap:14px;
    align-items:flex-start;
    background:var(--warning-soft);
    border:1px solid #FED7AA;
    border-radius:14px;
    padding:14px;
}

.hint-number{
    width:28px;
    height:28px;
    border-radius:50%;
    background:var(--warning);
    color:white;
    font-size:12px;
    font-weight:800;
    display:flex;
    align-items:center;
    justify-content:center;
    flex-shrink:0;
}

.hint p{
    font-size:14px;
    line-height:1.6;
    color:#92400E;
}

/* TIPS */
.tips{
    display:flex;
    flex-direction:column;
    gap:12px;
}

.tip{
    display:flex;
    gap:12px;
    align-items:flex-start;
    background:var(--success-soft);
    border:1px solid #BBF7D0;
    border-radius:14px;
    padding:14px;
}

.tip i{
    color:var(--success);
    font-size:18px;
    margin-top:2px;
}

.tip span{
    font-size:14px;
    color:#166534;
    line-height:1.6;
}

/* BUTTONS */
.actions{
    display:flex;
    flex-direction:column;
    gap:12px;
}

.btn{
    text-decoration:none;
    border:none;
    cursor:pointer;
    padding:15px 18px;
    border-radius:14px;
    font-size:15px;
    font-weight:700;
    font-family:inherit;
    display:flex;
    align-items:center;
    justify-content:center;
    gap:10px;
    transition:.25s ease;
}

.btn-primary{
    background:linear-gradient(135deg,var(--primary),var(--primary-light));
    color:white;
}

.btn-primary:hover{
    transform:translateY(-2px);
    box-shadow:0 12px 24px rgba(15,23,42,.12);
}

.btn-secondary{
    background:white;
    color:var(--text);
    border:1px solid var(--border);
}

.btn-secondary:hover{
    background:#F8FAFC;
}

/* FOOTER */
.footer{
    text-align:center;
    color:var(--muted);
    font-size:12px;
    line-height:1.8;
    padding-top:8px;
}

.footer strong{
    color:var(--text);
}

/* MOBILE */
@media(max-width:640px){
    .hero,
    .content{
        padding:24px;
    }

    .hero h1{
        font-size:23px;
    }

    .hero-top{
        flex-direction:column;
    }

    .score-flex{
        flex-direction:column;
        align-items:flex-start;
    }

    .user-level{
        text-align:left;
    }

    .email-row{
        flex-direction:column;
        gap:4px;
    }
}
</style>
</head>
<body>

<div class="container">
    <div class="card">

        <!-- HERO -->
        <div class="hero">
            <div class="badge">
                <i class="bi bi-shield-exclamation"></i>
                Simulation éducative
            </div>

            <div class="hero-top">
                <div class="hero-icon">
                    <i class="bi bi-bug-fill"></i>
                </div>

                <div>
                    <h1>Simulation détectée</h1>
                    <p>
                        Vous venez d’interagir avec une campagne de phishing simulée
                        organisée par votre entreprise dans le cadre de votre programme
                        de sensibilisation à la cybersécurité.
                        <strong>Aucune donnée sensible n’a été collectée.</strong>
                    </p>
                </div>
            </div>
        </div>

        <!-- CONTENT -->
        <div class="content">

            <!-- SCORE -->
            <div class="section score-card">
                <div class="section-title">
                    <i class="bi bi-graph-down-arrow" style="color:#DC2626;"></i>
                    Impact sur votre score de vigilance
                </div>

                <div class="score-flex">
                    <div class="score-main">
                        <h2>{{ employe.scoreVigilance|round }}/100</h2>
                        <p>Votre score de vigilance a été mis à jour.</p>
                    </div>

                    <div class="user-level">
                        <span>Profil actuel</span>
                        <div class="stars">
                            {% for i in 1..5 %}{{ i <= employe.nombreEtoiles ? '★' : '☆' }}{% endfor %}
                        </div>
                        <div class="level-badge">{{ employe.niveauVigilance }}</div>
                    </div>
                </div>
            </div>

            {% if modulePropose is defined and modulePropose %}
            <!-- FORMATION RECOMMANDÉE -->
            <div class="section" style="background:#FFF7ED;border-color:#FED7AA;">
                <div class="section-title">
                    <i class="bi bi-mortarboard-fill" style="color:#D97706;"></i>
                    Formation recommandée
                </div>
                <p style="font-size:14px;color:#92400E;margin-bottom:14px;line-height:1.6;">
                    Pour éviter ce type d'attaque à l'avenir, voici une formation adaptée à votre situation :
                </p>
                <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;
                            background:white;border:1px solid #FED7AA;border-radius:12px;padding:14px 16px;">
                    <div style="flex:1;min-width:0;">
                        <div style="font-size:14px;font-weight:700;color:#92400E;margin-bottom:4px;">
                            {{ modulePropose.titre }}
                        </div>
                        {% if modulePropose.description %}
                        <div style="font-size:12px;color:#B45309;">
                            {{ modulePropose.description|slice(0,90) }}{% if modulePropose.description|length > 90 %}…{% endif %}
                        </div>
                        {% endif %}
                    </div>
                    <form method="post" action="{{ path('employe_formation_commencer', {id: modulePropose.id}) }}">
                        <button type="submit"
                                style="display:inline-flex;align-items:center;gap:7px;
                                       background:linear-gradient(135deg,#D97706,#B45309);
                                       color:white;border:none;border-radius:10px;
                                       padding:10px 16px;font-size:13px;font-weight:700;cursor:pointer;">
                            <i class="bi bi-play-circle-fill"></i> Commencer
                        </button>
                    </form>
                </div>
            </div>
            {% endif %}

            <!-- EMAIL -->
            <div class="section">
                <div class="section-title">
                    <i class="bi bi-envelope-paper-fill" style="color:#2563EB;"></i>
                    Analyse de l’email reçu
                </div>

                <div class="email-grid">
                    <div class="email-row">
                        <div class="email-label">Expéditeur</div>
                        <div class="email-value email-danger">
                            {{ gabarit.nomExpediteur }} &lt;{{ gabarit.emailExpediteur }}&gt;
                        </div>
                    </div>

                    <div class="email-row">
                        <div class="email-label">Sujet</div>
                        <div class="email-value">{{ gabarit.sujetEmail }}</div>
                    </div>

                    <div class="email-row">
                        <div class="email-label">Catégorie</div>
                        <div class="email-value">{{ gabarit.categorie }}</div>
                    </div>
                </div>
            </div>

            <!-- INDICES -->
            <div class="section">
                <div class="section-title">
                    <i class="bi bi-lightbulb-fill" style="color:#D97706;"></i>
                    Indices que vous auriez dû remarquer
                </div>

                <div class="hints">
                    {% for i, indice in indices %}
                    <div class="hint">
                        <div class="hint-number">{{ i + 1 }}</div>
                        <p>{{ indice }}</p>
                    </div>
                    {% endfor %}
                </div>
            </div>

            <!-- TIPS -->
            <div class="section">
                <div class="section-title">
                    <i class="bi bi-shield-check" style="color:#16A34A;"></i>
                    Bonnes pratiques à retenir
                </div>

                <div class="tips">
                    <div class="tip">
                        <i class="bi bi-check2-circle"></i>
                        <span>Vérifiez toujours l’adresse complète de l’expéditeur avant toute action.</span>
                    </div>

                    <div class="tip">
                        <i class="bi bi-check2-circle"></i>
                        <span>Ne cliquez jamais sur un lien avant d’en vérifier la destination.</span>
                    </div>

                    <div class="tip">
                        <i class="bi bi-check2-circle"></i>
                        <span>Signalez les emails suspects depuis votre tableau de bord sécurité.</span>
                    </div>

                    <div class="tip">
                        <i class="bi bi-check2-circle"></i>
                        <span>Continuez vos modules de formation pour améliorer votre score de vigilance.</span>
                    </div>
                </div>
            </div>

            <!-- ACTIONS -->
            <div class="actions">
                {% if modulePropose is defined and modulePropose %}
                <form method="post" action="{{ path('employe_formation_commencer', {id: modulePropose.id}) }}">
                    <button type="submit" class="btn btn-primary" style="width:100%;">
                        <i class="bi bi-mortarboard-fill"></i>
                        Commencer la formation recommandée
                    </button>
                </form>
                {% endif %}
                <a href="{{ path('app_login') }}" class="btn {% if modulePropose is not defined or not modulePropose %}btn-primary{% else %}btn-secondary{% endif %}">
                    <i class="bi bi-grid"></i>
                   Connecter-vous pour suivre la formation qui vous a été recommandée 
                </a>
            </div>

            <!-- FOOTER -->
            <div class="footer">
                Cette simulation a été organisée par votre responsable sécurité
                dans le cadre du programme de sensibilisation de votre entreprise.<br>
                <strong>Aucune donnée personnelle ni identifiant n’a été stocké.</strong>
            </div>

        </div>
    </div>
</div>

</body>
</html>