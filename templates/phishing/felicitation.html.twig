<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Félicitations – SAT Platform</title>
    <!-- Bootstrap Icons & Inter font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
        :root {
            --bg: #F8FAFC;
            --surface: #FFFFFF;
            --surface-alt: #F1F5F9;
            --text-primary: #0A0C10;
            --text-secondary: #475569;
            --text-tertiary: #64748B;
            --border-light: #E2E8F0;
            --border-medium: #CBD5E1;
            --success: #15803D;
            --success-bg: #F0FDF4;
            --success-border: #BBF7D0;
            --warning: #B45309;
            --warning-bg: #FFFBEB;
            --warning-border: #FDE68A;
            --accent: #1E293B;
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: var(--bg);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 24px;
            color: var(--text-primary);
        }
        .card {
            max-width: 520px;
            background: var(--surface);
            border: 1px solid var(--border-light);
            border-radius: 24px;
            padding: 40px 32px;
            text-align: center;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.02), 0 2px 4px rgba(0, 0, 0, 0.02);
        }
        /* Icône succès */
        .icon-success {
            width: 72px;
            height: 72px;
            margin: 0 auto 20px;
            background: var(--success-bg);
            border-radius: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--success);
            border: 1px solid var(--success-border);
        }
        .icon-success i {
            font-size: 36px;
        }
        .icon-warning {
            width: 72px;
            height: 72px;
            margin: 0 auto 20px;
            background: var(--warning-bg);
            border-radius: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--warning);
            border: 1px solid var(--warning-border);
        }
        .icon-warning i {
            font-size: 36px;
        }
        h1 {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: -0.02em;
            margin-bottom: 12px;
            color: var(--text-primary);
        }
        .subtitle {
            font-size: 15px;
            color: var(--text-secondary);
            line-height: 1.5;
            margin-bottom: 24px;
        }
        .points-card {
            background: var(--surface-alt);
            border: 1px solid var(--border-light);
            border-radius: 20px;
            padding: 20px;
            margin: 20px 0;
        }
        .points-row {
            display: flex;
            justify-content: center;
            gap: 32px;
            flex-wrap: wrap;
        }
        .point-item {
            text-align: center;
        }
        .point-value {
            font-size: 32px;
            font-weight: 800;
            color: var(--text-primary);
            line-height: 1.2;
            margin-bottom: 4px;
        }
        .point-label {
            font-size: 13px;
            font-weight: 500;
            color: var(--text-tertiary);
        }
        .stars {
            font-size: 22px;
            letter-spacing: 3px;
            color: #F59E0B;
            margin: 12px 0 8px;
        }
        .score-line {
            font-size: 14px;
            color: var(--text-secondary);
            margin-top: 8px;
        }
        .score-line strong {
            color: var(--text-primary);
            font-weight: 700;
        }
        .message {
            margin-top: 20px;
            font-size: 14px;
            color: var(--text-secondary);
            border-top: 1px solid var(--border-light);
            padding-top: 20px;
        }
        .btn {
            display: inline-block;
            margin-top: 28px;
            padding: 12px 28px;
            background: var(--accent);
            color: white;
            text-decoration: none;
            border-radius: 40px;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.2s ease;
            border: 1px solid var(--accent);
        }
        .btn:hover {
            background: #334155;
            transform: translateY(-1px);
        }
        hr {
            margin: 24px 0 16px;
            border: none;
            border-top: 1px solid var(--border-light);
        }
        .small-note {
            font-size: 12px;
            color: var(--text-tertiary);
            margin-top: 16px;
        }
        @media (max-width: 480px) {
            .card { padding: 28px 20px; }
            h1 { font-size: 24px; }
            .point-value { font-size: 26px; }
            .points-row { gap: 20px; }
        }
    </style>
</head>
<body>
    <div class="card">
        {% if not already %}
            <!-- Cas succès : l'employé a signalé correctement -->
            <div class="icon-success">
                <i class="bi bi-check-lg"></i>
            </div>
            <h1>Félicitations, {{ employe.prenom }} !</h1>
            <div class="subtitle">
                Vous avez parfaitement identifié ce message suspect.<br>
                Votre vigilance fait la différence.
            </div>

            <div class="points-card">
                <div class="points-row">
                    <div class="point-item">
                        <div class="point-value">+{{ deltaPoints }}</div>
                        <div class="point-label">points</div>
                    </div>
                    <div class="point-item">
                        <div class="point-value">+{{ deltaVigilance }}</div>
                        <div class="point-label">vigilance</div>
                    </div>
                </div>
            </div>

            <div class="stars">
                {% for i in 1..5 %}{{ i <= employe.nombreEtoiles ? '★' : '☆' }}{% endfor %}
            </div>
            <div class="score-line">
                Score actuel : <strong>{{ employe.scoreVigilance|round }}/100 — {{ employe.niveauVigilance }}</strong>
            </div>
            <div class="message">
                Continuez à rester vigilant et signalez tout email suspect.
            </div>
            <hr>
            <a href="{{ path('employe_dashboard') }}" class="btn">Retour au tableau de bord</a>
            <div class="small-note">
                <i class="bi bi-shield-check"></i> SAT Platform – cybersécurité proactive
            </div>
        {% else %}
            <!-- Cas déjà traité (clic ou déjà signalé) -->
            <div class="icon-warning">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <h1>Déjà traité</h1>
            <div class="subtitle">
                Vous avez déjà signalé ce message ou vous aviez déjà cliqué sur le lien piège.
            </div>
            <div class="points-card">
                <div class="point-item">
                    <div class="point-value">0</div>
                    <div class="point-label">point ajouté</div>
                </div>
            </div>
            <hr>
            <a href="{{ path('employe_dashboard') }}" class="btn">Retour au tableau de bord</a>
            <div class="small-note">
                <i class="bi bi-info-circle"></i> Un seul signalement par campagne est comptabilisé.
            </div>
        {% endif %}
    </div>
</body>
</html>