<!DOCTYPE html>
<html lang="fr" class="scroll-smooth dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SAT Platform · Security Awareness Training</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=Syne:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* ============ RESET & BASE ============ */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'DM Sans', sans-serif;
            background-color: #F8FAFC;
            color: #1e293b;
            transition: background-color 0.3s ease, color 0.3s ease;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        .dark body { background-color: #060810; color: #e2e8f0; }

        h1,h2,h3,h4,h5,h6, .font-display { font-family: 'Syne', sans-serif; }

        ::selection { background-color: rgba(0,229,160,0.2); color: #00E5A0; }
        .dark ::selection { background-color: rgba(0,229,160,0.2); color: #00E5A0; }

        /* scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #F8FAFC; }
        .dark ::-webkit-scrollbar-track { background: #060810; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        .dark ::-webkit-scrollbar-thumb { background: #1e293b; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        .dark ::-webkit-scrollbar-thumb:hover { background: #334155; }

        /* ============ TYPOGRAPHY ============ */
        .tracking-tighter { letter-spacing: -0.05em; }
        .tracking-widest { letter-spacing: 0.1em; }
        .uppercase { text-transform: uppercase; }
        .font-medium { font-weight: 500; }
        .font-semibold { font-weight: 600; }
        .text-xs { font-size: 0.75rem; }
        .text-sm { font-size: 0.875rem; }
        .text-base { font-size: 1rem; }
        .text-lg { font-size: 1.125rem; }
        .text-xl { font-size: 1.25rem; }
        .text-2xl { font-size: 1.5rem; }
        .text-3xl { font-size: 1.875rem; }
        .text-4xl { font-size: 2.25rem; }
        .text-5xl { font-size: 3rem; }
        .text-7xl { font-size: 4.5rem; }
        .text-8xl { font-size: 6rem; }
        .leading-tight { line-height: 1.25; }
        .leading-relaxed { line-height: 1.625; }
        .leading-\[1\.05\] { line-height: 1.05; }

        /* ============ LAYOUT ============ */
        .max-w-7xl { max-width: 80rem; margin-left: auto; margin-right: auto; }
        .max-w-5xl { max-width: 64rem; }
        .max-w-4xl { max-width: 56rem; }
        .max-w-3xl { max-width: 48rem; }
        .max-w-md { max-width: 28rem; }
        .mx-auto { margin-left: auto; margin-right: auto; }
        .px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
        .py-24 { padding-top: 6rem; padding-bottom: 6rem; }
        .pt-40 { padding-top: 10rem; }
        .pb-24 { padding-bottom: 6rem; }
        .py-32 { padding-top: 8rem; padding-bottom: 8rem; }
        .py-8 { padding-top: 2rem; padding-bottom: 2rem; }
        .gap-16 { gap: 4rem; }
        .gap-8 { gap: 2rem; }
        .gap-6 { gap: 1.5rem; }
        .gap-4 { gap: 1rem; }
        .gap-2 { gap: 0.5rem; }

        .flex { display: flex; }
        .inline-flex { display: inline-flex; }
        .flex-col { flex-direction: column; }
        .items-center { align-items: center; }
        .items-start { align-items: flex-start; }
        .justify-between { justify-content: space-between; }
        .justify-center { justify-content: center; }
        .text-center { text-align: center; }
        .text-left { text-align: left; }
        .grid { display: grid; }
        .grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .relative { position: relative; }
        .absolute { position: absolute; }
        .fixed { position: fixed; }
        .top-0 { top: 0; }
        .left-0 { left: 0; }
        .right-0 { right: 0; }
        .bottom-0 { bottom: 0; }
        .z-10 { z-index: 10; }
        .z-50 { z-index: 50; }
        .overflow-hidden { overflow: hidden; }
        .overflow-x-auto { overflow-x: auto; }
        .w-full { width: 100%; }
        .h-20 { height: 5rem; }
        .h-\[600px\] { height: 600px; }
        .w-\[800px\] { width: 800px; }
        .w-\[600px\] { width: 600px; }
        .w-\[500px\] { width: 500px; }
        .h-\[300px\] { height: 300px; }
        .-translate-x-1\/2 { transform: translateX(-50%); }
        .-translate-y-1\/2 { transform: translateY(-50%); }
        .translate-y-1 { transform: translateY(0.25rem); }

        /* ============ COLORS & BACKGROUNDS ============ */
        .bg-white\/80 { background-color: rgba(255,255,255,0.8); }
        .dark .bg-white\/80 { background-color: rgba(12,15,29,0.8); }
        .bg-\[\#00E5A0\] { background-color: #00E5A0; }
        .bg-\[\#FF3B5C\] { background-color: #FF3B5C; }
        .bg-\[\#F59E0B\] { background-color: #F59E0B; }
        .bg-\[\#3B82F6\] { background-color: #3B82F6; }
        .bg-\[\#0C0F1D\] { background-color: #0C0F1D; }
        .bg-\[\#060810\] { background-color: #060810; }
        .bg-\[\#030408\] { background-color: #030408; }
        .bg-\[\#0a0d16\] { background-color: #0a0d16; }

        .text-\[\#00E5A0\] { color: #00E5A0; }
        .text-\[\#FF3B5C\] { color: #FF3B5C; }
        .text-\[\#F59E0B\] { color: #F59E0B; }
        .text-\[\#3B82F6\] { color: #3B82F6; }
        .text-\[\#060810\] { color: #060810; }
        .text-slate-900 { color: #0f172a; }
        .text-slate-600 { color: #475569; }
        .text-slate-500 { color: #64748b; }
        .text-slate-400 { color: #94a3b8; }
        .text-slate-300 { color: #cbd5e1; }
        .text-white { color: #fff; }

        .bg-slate-100 { background-color: #f1f5f9; }
        .bg-slate-50 { background-color: #f8fafc; }
        .bg-white { background-color: #fff; }
        .bg-transparent { background-color: transparent; }

        .dark .dark\:bg-\[\#0C0F1D\]\/80 { background-color: rgba(12,15,29,0.8); }
        .dark .dark\:bg-\[\#0C0F1D\]\/60 { background-color: rgba(12,15,29,0.6); }
        .dark .dark\:bg-\[\#0C0F1D\]\/50 { background-color: rgba(12,15,29,0.5); }
        .dark .dark\:bg-\[\#0C0F1D\]\/30 { background-color: rgba(12,15,29,0.3); }
        .dark .dark\:bg-\[\#0C0F1D\] { background-color: #0C0F1D; }
        .dark .dark\:bg-\[\#060810\] { background-color: #060810; }
        .dark .dark\:text-white { color: #fff; }
        .dark .dark\:text-slate-400 { color: #94a3b8; }
        .dark .dark\:text-slate-300 { color: #cbd5e1; }

        /* borders – on garde seulement les bordures structurelles, pas autour des icônes */
        .border { border: 1px solid; }
        .border-t { border-top: 1px solid; }
        .border-b { border-bottom: 1px solid; }
        .border-y { border-top: 1px solid; border-bottom: 1px solid; }
        .border-black\/5 { border-color: rgba(0,0,0,0.05); }
        .dark .dark\:border-white\/5 { border-color: rgba(255,255,255,0.05); }
        .border-white\/10 { border-color: rgba(255,255,255,0.1); }
        .dark .dark\:border-white\/10 { border-color: rgba(255,255,255,0.1); }
        .border-black\/10 { border-color: rgba(0,0,0,0.1); }
        .dark .dark\:border-white\/15 { border-color: rgba(255,255,255,0.15); }

        /* rounded */
        .rounded-full { border-radius: 9999px; }
        .rounded-3xl { border-radius: 1.5rem; }
        .rounded-2xl { border-radius: 1rem; }
        .rounded-xl { border-radius: 0.75rem; }
        .rounded-lg { border-radius: 0.5rem; }
        .rounded { border-radius: 0.25rem; }

        /* shadows */
        .shadow-xl { box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1); }
        .shadow-2xl { box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); }
        .shadow-sm { box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); }
        .shadow-black\/\[0\.02\] { box-shadow: 0 1px 2px rgba(0,0,0,0.02); }
        .dark .dark\:shadow-none { box-shadow: none; }
        .dark .dark\:shadow-\[0_20px_60px_-15px_rgba\(0\,0\,0\,\.8\)\] { box-shadow: 0 20px 60px -15px rgba(0,0,0,0.8); }
        .shadow-\[0_0_24px_rgba\(0\,229\,160\,\.3\)\] { box-shadow: 0 0 24px rgba(0,229,160,0.3); }
        .shadow-\[0_0_30px_rgba\(0\,229\,160\,\.2\)\] { box-shadow: 0 0 30px rgba(0,229,160,0.2); }

        /* backdrop */
        .backdrop-blur-md { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
        .backdrop-blur-sm { backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); }
        .backdrop-blur-lg { backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); }

        /* ============ TRANSITIONS & HOVER ============ */
        .transition-colors { transition: background-color 0.3s, color 0.3s, border-color 0.3s; }
        .transition-all { transition: all 0.3s ease; }
        .transition-transform { transition: transform 0.3s ease; }
        .hover\:scale-105:hover { transform: scale(1.05); }
        .hover\:scale-110:hover { transform: scale(1.1); }
        .hover\:bg-white:hover { background-color: #fff; }
        .dark .dark\:hover\:bg-white:hover { background-color: #fff; }
        .hover\:bg-slate-50:hover { background-color: #f8fafc; }
        .dark .dark\:hover\:bg-\[\#0C0F1D\]:hover { background-color: #0C0F1D; }
        .hover\:bg-\[\#00E5A0\]\/5:hover { background-color: rgba(0,229,160,0.05); }
        .hover\:border-\[\#FF3B5C\]\/30:hover { border-color: rgba(255,59,92,0.3); }
        .hover\:border-\[\#F59E0B\]\/30:hover { border-color: rgba(245,158,11,0.3); }
        .hover\:border-\[\#00E5A0\]\/30:hover { border-color: rgba(0,229,160,0.3); }
        .hover\:border-\[\#3B82F6\]\/20:hover { border-color: rgba(59,130,246,0.2); }
        .hover\:border-\[\#00E5A0\]\/20:hover { border-color: rgba(0,229,160,0.2); }
        .hover\:border-\[\#FF3B5C\]\/20:hover { border-color: rgba(255,59,92,0.2); }
        .hover\:border-\[\#F59E0B\]\/20:hover { border-color: rgba(245,158,11,0.2); }
        .hover\:text-slate-900:hover { color: #0f172a; }
        .dark .dark\:hover\:text-white:hover { color: #fff; }
        .hover\:text-\[\#00E5A0\]:hover { color: #00E5A0; }

        .group:hover .group-hover\:scale-110 { transform: scale(1.1); }
        .group:hover .group-hover\:border-\[\#00E5A0\]\/50 { border-color: rgba(0,229,160,0.5); }

        /* ============ GRID BG ============ */
        .bg-grid {
            background-size: 40px 40px;
            background-image:
                linear-gradient(to right, rgba(0,0,0,0.04) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(0,0,0,0.04) 1px, transparent 1px);
        }
        .dark .bg-grid {
            background-image:
                linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px);
        }

        /* glows */
        .glow-emerald { background: radial-gradient(circle at center, rgba(0,229,160,0.15) 0%, transparent 70%); }
        .glow-red { background: radial-gradient(circle at center, rgba(255,59,92,0.1) 0%, transparent 70%); }

        /* ============ ANIMATIONS ============ */
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
        .animate-blink { animation: blink 1s step-end infinite; }

        @keyframes fadeDown { from{opacity:0;transform:translateY(-24px)} to{opacity:1;transform:translateY(0)} }
        @keyframes fadeUp   { from{opacity:0;transform:translateY(24px)}  to{opacity:1;transform:translateY(0)} }
        @keyframes navSlide { from{opacity:0;transform:translateY(-100%)} to{opacity:1;transform:translateY(0)} }
        @keyframes pulseGlow { 0%,100%{box-shadow:0 0 8px rgba(0,229,160,0.6)} 50%{box-shadow:0 0 22px rgba(0,229,160,1)} }
        @keyframes floatY { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }
        @keyframes terminalType { from{opacity:0;transform:translateX(-8px)} to{opacity:1;transform:translateX(0)} }
        @keyframes counterUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }

        .anim-nav        { animation: navSlide 0.5s ease both; }
        .anim-fade-down  { animation: fadeDown 0.7s cubic-bezier(0.22,0.68,0,1.2) both; }
        .anim-fade-up    { animation: fadeUp   0.7s cubic-bezier(0.22,0.68,0,1.2) both; }

        .delay-0  { animation-delay: 0s; }
        .delay-1  { animation-delay: 0.1s; }
        .delay-2  { animation-delay: 0.2s; }
        .delay-3  { animation-delay: 0.3s; }
        .delay-4  { animation-delay: 0.4s; }

        .dot-pulse  { animation: pulseGlow 2s ease-in-out infinite; }
        .float-anim { animation: floatY 5s ease-in-out infinite; }

        .tl { animation: terminalType 0.5s ease both; opacity:0; }
        .tl:nth-child(1){ animation-delay: 0.3s; }
        .tl:nth-child(2){ animation-delay: 0.8s; }
        .tl:nth-child(3){ animation-delay: 1.3s; }
        .tl:nth-child(4){ animation-delay: 1.8s; }
        .tl:nth-child(5){ animation-delay: 2.3s; }
        .tl:nth-child(6){ animation-delay: 2.8s; }
        .tl:nth-child(7){ animation-delay: 3.3s; }

        .stat-item { animation: counterUp 0.7s cubic-bezier(0.22,0.68,0,1.2) both; }
        .stat-item:nth-child(1){ animation-delay: 0.6s; }
        .stat-item:nth-child(2){ animation-delay: 0.75s; }
        .stat-item:nth-child(3){ animation-delay: 0.9s; }
        .stat-item:nth-child(4){ animation-delay: 1.05s; }

        .reveal, .reveal-left {
            opacity: 0;
            transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22,0.68,0,1.2);
        }
        .reveal      { transform: translateY(28px); }
        .reveal-left { transform: translateX(-28px); }
        .reveal.visible, .reveal-left.visible { opacity: 1; transform: translate(0); }

        .card-lift { transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease; }
        .card-lift:hover { transform: translateY(-6px); }

        /* ============ ADDITIONAL ============ */
        .shrink-0 { flex-shrink: 0; }
        .opacity-60 { opacity: 0.6; }
        .opacity-50 { opacity: 0.5; }
        .opacity-40 { opacity: 0.4; }
        .opacity-30 { opacity: 0.3; }
        .opacity-80 { opacity: 0.8; }
        .pointer-events-none { pointer-events: none; }
        .antialiased { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
        .mr-2 { margin-right: 0.5rem; }
        .ml-auto { margin-left: auto; }
        .ml-1 { margin-left: 0.25rem; }
        .mb-1 { margin-bottom: 0.25rem; }
        .mb-2 { margin-bottom: 0.5rem; }
        .mb-3 { margin-bottom: 0.75rem; }
        .mb-4 { margin-bottom: 1rem; }
        .mb-6 { margin-bottom: 1.5rem; }
        .mb-8 { margin-bottom: 2rem; }
        .mb-10 { margin-bottom: 2.5rem; }
        .mb-12 { margin-bottom: 3rem; }
        .mb-16 { margin-bottom: 4rem; }
        .mb-20 { margin-bottom: 5rem; }
        .mb-24 { margin-bottom: 6rem; }
        .hidden { display: none; }
        .block { display: block; }
        .inline-block { display: inline-block; }
        .w-2 { width: 0.5rem; }
        .w-3 { width: 0.75rem; }
        .w-4 { width: 1rem; }
        .w-8 { width: 2rem; }
        .w-10 { width: 2.5rem; }
        .w-12 { width: 3rem; }
        .w-16 { width: 4rem; }
        .h-2 { height: 0.5rem; }
        .h-3 { height: 0.75rem; }
        .h-4 { height: 1rem; }
        .h-8 { height: 2rem; }
        .h-10 { height: 2.5rem; }
        .h-12 { height: 3rem; }
        .px-4 { padding-left: 1rem; padding-right: 1rem; }
        .px-5 { padding-left: 1.25rem; padding-right: 1.25rem; }
        .px-8 { padding-left: 2rem; padding-right: 2rem; }
        .py-2 { padding-top: 0.5rem; padding-bottom: 0.5rem; }
        .py-2\.5 { padding-top: 0.625rem; padding-bottom: 0.625rem; }
        .py-4 { padding-top: 1rem; padding-bottom: 1rem; }
        .py-3 { padding-top: 0.75rem; padding-bottom: 0.75rem; }
        .p-8 { padding: 2rem; }
        .p-6 { padding: 1.5rem; }
        .space-y-3 > * + * { margin-top: 0.75rem; }
        .text-\[10px\] { font-size: 10px; }

        /* Icônes SVG : on les centre */
        .icon-svg { display: inline-flex; align-items: center; justify-content: center; }
        .icon-svg svg { width: 100%; height: 100%; fill: currentColor; }

        /* ============ RESPONSIVE ============ */
        @media (min-width: 640px) {
            .sm\:flex-row { flex-direction: row; }
        }

        @media (min-width: 768px) {
            .md\:block { display: block; }
            .md\:flex-row { flex-direction: row; }
            .md\:items-start { align-items: flex-start; }
            .md\:items-end { align-items: flex-end; }
            .md\:text-left { text-align: left; }
            .md\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .md\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
            .md\:grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
            .md\:pt-52 { padding-top: 13rem; }
            .md\:pb-32 { padding-bottom: 8rem; }
            .md\:text-7xl { font-size: 4.5rem; }
            .md\:text-5xl { font-size: 3rem; }
            .md\:text-4xl { font-size: 2.25rem; }
            .md\:text-xl { font-size: 1.25rem; }
            .md\:text-lg { font-size: 1.125rem; }
            .md\:text-sm { font-size: 0.875rem; }
            .md\:p-8 { padding: 2rem; }
            .md\:gap-4 { gap: 1rem; }
            .md\:flex { display: flex; }
        }

        @media (min-width: 1024px) {
            .lg\:text-8xl { font-size: 6rem; }
        }
    </style>
</head>
