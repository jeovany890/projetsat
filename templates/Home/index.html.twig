    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <style>
        :root { --font-display:'Syne',sans-serif; --font-body:'DM Sans',sans-serif; }
        body { font-family:var(--font-body); background-color:#060810; color:#e2e8f0; }
        h1,h2,h3,h4,h5,h6,.font-display { font-family:var(--font-display); }
        .bg-grid { background-size:40px 40px; background-image:linear-gradient(to right,rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,.03) 1px,transparent 1px); }
        .glow-emerald { background:radial-gradient(circle at center,rgba(0,229,160,.15) 0%,transparent 70%); }
        .glow-red { background:radial-gradient(circle at center,rgba(255,59,92,.1) 0%,transparent 70%); }

        /* ── ANIMATIONS ── */
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
        .animate-blink { animation:blink 1s step-end infinite; }

        @keyframes fadeDown { from{opacity:0;transform:translateY(-24px)} to{opacity:1;transform:translateY(0)} }
        @keyframes fadeUp   { from{opacity:0;transform:translateY(24px)}  to{opacity:1;transform:translateY(0)} }
        @keyframes slideRight { from{opacity:0;transform:translateX(-32px)} to{opacity:1;transform:translateX(0)} }
        @keyframes navSlide { from{opacity:0;transform:translateY(-100%)} to{opacity:1;transform:translateY(0)} }
        @keyframes pulseGlow { 0%,100%{box-shadow:0 0 8px rgba(0,229,160,.6)} 50%{box-shadow:0 0 22px rgba(0,229,160,1)} }
        @keyframes floatY { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }
        @keyframes terminalType { from{opacity:0;transform:translateX(-8px)} to{opacity:1;transform:translateX(0)} }
        @keyframes counterUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }

        .anim-nav        { animation:navSlide .5s ease both; }
        .anim-fade-down  { animation:fadeDown .7s cubic-bezier(.22,.68,0,1.2) both; }
        .anim-fade-up    { animation:fadeUp   .7s cubic-bezier(.22,.68,0,1.2) both; }

        .delay-0  { animation-delay:.0s }  .delay-1  { animation-delay:.1s }
        .delay-2  { animation-delay:.2s }  .delay-3  { animation-delay:.3s }
        .delay-4  { animation-delay:.4s }  .delay-5  { animation-delay:.5s }

        .dot-pulse  { animation:pulseGlow 2s ease-in-out infinite; }
        .float-anim { animation:floatY 5s ease-in-out infinite; }

        /* Terminal lignes */
        .tl { animation:terminalType .5s ease both; opacity:0; }
        .tl:nth-child(1){animation-delay:.3s}  .tl:nth-child(2){animation-delay:.8s}
        .tl:nth-child(3){animation-delay:1.3s} .tl:nth-child(4){animation-delay:1.8s}
        .tl:nth-child(5){animation-delay:2.3s} .tl:nth-child(6){animation-delay:2.8s}
        .tl:nth-child(7){animation-delay:3.3s}

        /* Stats */
        .stat-item { animation:counterUp .7s cubic-bezier(.22,.68,0,1.2) both; }
        .stat-item:nth-child(1){animation-delay:.6s} .stat-item:nth-child(2){animation-delay:.75s}
        .stat-item:nth-child(3){animation-delay:.9s} .stat-item:nth-child(4){animation-delay:1.05s}

        /* Scroll reveal */
        .reveal,.reveal-left { opacity:0; transition:opacity .7s ease,transform .7s cubic-bezier(.22,.68,0,1.2); }
        .reveal      { transform:translateY(28px); }
        .reveal-left { transform:translateX(-28px); }
        .reveal.visible,.reveal-left.visible { opacity:1; transform:translate(0); }

        /* Card hover */
        .card-lift { transition:transform .3s ease,border-color .3s ease,background .3s ease; }
        .card-lift:hover { transform:translateY(-6px); }

        ::-webkit-scrollbar{width:8px} ::-webkit-scrollbar-track{background:#060810}
        ::-webkit-scrollbar-thumb{background:#1e293b;border-radius:4px}
        ::-webkit-scrollbar-thumb:hover{background:#334155}
    </style>
</head>
